[{"data":1,"prerenderedAt":465},["ShallowReactive",2],{"collection-events-981254823":3,"_apollo:default":464},{"data":4,"meta":460},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"eventStart":10,"location":11,"info":12,"createdAt":13,"updatedAt":14,"publishedAt":15,"eventTimes":16,"darkMode":16,"documentId":17,"imageUrl":18,"seo":16,"blocks":60,"expertises":78},11,"Hybride Deepdive 'n Drinks","Hybride werken, we horen deze term vaak en het is waarschijnlijk ook niet meer weg te denken. Maar hoe doe je dat, hybride werken? We laten je een aantal praktische scenario’s zien met behulp van Microsoft 365. Zoals effectief vergaderen en werken met documenten. Ben jij erbij?","hybride-deepdive-n-drinks","2021-12-10T14:00:00.000Z","Online via Teams of live op ons kantoor","Thema: hybride werken","2023-08-31T17:11:51.004Z","2023-08-31T17:11:52.917Z","2023-08-31T17:11:52.890Z",null,"x7xq8xtn6gmo02bbcyxt6o2s",{"id":19,"name":20,"alternativeText":16,"caption":16,"width":21,"height":22,"formats":23,"hash":53,"ext":25,"mime":28,"size":54,"url":55,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":57,"updatedAt":57,"documentId":58,"publishedAt":59,"focalPoint":16},180,"ShareValue_NEXT_imagehero.jpg",1280,500,{"large":24,"small":33,"medium":39,"thumbnail":46},{"ext":25,"url":26,"hash":27,"mime":28,"name":29,"path":16,"size":30,"width":31,"height":32},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Share_Value_NEXT_imagehero_affd49466d.jpg","large_Share_Value_NEXT_imagehero_affd49466d","image/jpeg","large_ShareValue_NEXT_imagehero.jpg",36.76,1000,391,{"ext":25,"url":34,"hash":35,"mime":28,"name":36,"path":16,"size":37,"width":22,"height":38},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Share_Value_NEXT_imagehero_affd49466d.jpg","small_Share_Value_NEXT_imagehero_affd49466d","small_ShareValue_NEXT_imagehero.jpg",12.25,195,{"ext":25,"url":40,"hash":41,"mime":28,"name":42,"path":16,"size":43,"width":44,"height":45},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Share_Value_NEXT_imagehero_affd49466d.jpg","medium_Share_Value_NEXT_imagehero_affd49466d","medium_ShareValue_NEXT_imagehero.jpg",23.2,750,293,{"ext":25,"url":47,"hash":48,"mime":28,"name":49,"path":16,"size":50,"width":51,"height":52},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Share_Value_NEXT_imagehero_affd49466d.jpg","thumbnail_Share_Value_NEXT_imagehero_affd49466d","thumbnail_ShareValue_NEXT_imagehero.jpg",3.94,245,96,"Share_Value_NEXT_imagehero_affd49466d",50.76,"https://incredible-beef-2a6059b946.media.strapiapp.com/Share_Value_NEXT_imagehero_affd49466d.jpg","strapi-provider-upload-strapi-cloud","2023-08-31T14:22:00.585Z","jna8xynlhepmniri92flat9q","2026-01-05T12:38:34.018Z",[61,67,71,75],{"id":62,"title":16,"asideText":63,"underline":64,"centered":64,"blankAside":64,"aside":16,"content":65,"introductionText":16,"__component":66},129,"De ‘Deepdive’",false,"eel organisaties zitten in deze periode midden in de meest veranderlijke periode van hun bestaan. Na de noodzaak om thuis te werken, waarin iedereen in een soort crisis-modus aan de slag ging, willen we nu naar een periode van bestendiging. Een periode waarin we nieuwe vormen zoeken en uitproberen om met elkaar samen te werken. Op een veilige en duurzame manier.\n\nTijdens de Hybride Deepdive ’n Drinks op 10 december 2021, laten wij aan de hand van een aantal praktische scenario’s zien hoe Microsoft 365 je in staat stelt om locatieonafhankelijk samen te werken.\n\nWe tonen en bespreken bijvoorbeeld de scenario’s:\n\n- Effectief vergaderen in een hybride wereld\n- Werken met documenten in een hybride wereld\n- Microsoft Teams als ingang naar nieuws, informatie, communicatie en samenwerken. Vanaf elke locatie, op je laptop en mobiel. Inclusief het ShareValue IK-WIJ-ONS intranet.\n \nWe staan ook even stil bij een aantal nieuwe ontwikkelingen op het gebied van Microsoft 365 en Teams die zijn aangekondigd tijdens Microsoft Ignite 2021.\n\nGeheel in thema vindt de Deepdive deze keer plaats in hybride vorm. Je kunt dus kiezen tussen online deelname via Microsoft Teams of live deelname op ons kantoor in Gouda (met toepassing van de 1,5 meter regel). Mocht de overheid met nieuwe maatregelen komen waardoor samenkomen tijdelijk niet mogelijk is, dan zal de Deepdive geheel online plaatsvinden.","global.pagesection",{"id":68,"title":16,"asideText":69,"underline":64,"centered":64,"blankAside":64,"aside":16,"content":70,"introductionText":16,"__component":66},130,"De ‘Drinks’","De deelnemers die aanwezig zijn op ons kantoor kunnen gezellig napraten en ervaringen uitwisselen onder het genot van een hapje en drankje (op 1,5 meter afstand).\n\nEventdetails op een rij:\n\n- Vrijdag 10 december 2021\n- Start 15:00 uur, einde ca. 17:00 uur\n- De borrel op kantoor start na de Deepdive, ca. 17:00 uur\n- Aanmelden kan via de aanmeldlink t/m 6 december",{"id":72,"title":16,"asideText":73,"underline":64,"centered":64,"blankAside":64,"aside":16,"content":74,"introductionText":16,"__component":66},131,"Vragen?","\nHeb je vragen? Neem contact op met ShareValue.\n\nE-mail: [events@sharevalue.nl](mailto:events@sharevalue.nl)\n\nTelefoon: 0182-516 468\n\n \n\nHeb je een ander vraagstuk waarmee wij je kunnen helpen? Wij organiseren op verzoek ook sessies over andere onderwerpen. Welk onderwerp het ook is, [laat ons weten!](mailto:events@sharevalue.nl)",{"id":6,"title":76,"showBlankAside":16,"__component":77},"Deel deze pagina","global.social-sharing",[79],{"id":80,"title":81,"subTitle":82,"description":83,"shortDescription":84,"slug":85,"createdAt":86,"updatedAt":87,"publishedAt":88,"isCoreExpertise":89,"documentId":90,"image":91,"seo":109,"blocks":127,"midPageBlocks":167},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":92,"name":93,"alternativeText":16,"caption":16,"width":94,"height":68,"formats":95,"hash":104,"ext":97,"mime":100,"size":105,"url":106,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":107,"updatedAt":107,"documentId":108,"publishedAt":59,"focalPoint":16},16,"microsoft-365.png",282,{"thumbnail":96},{"ext":97,"url":98,"hash":99,"mime":100,"name":101,"path":16,"size":102,"width":51,"height":103},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":110,"metaTitle":111,"metaDescription":112,"structuredData":113,"metaImage":16,"metaSocial":126},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":114,"@type":115,"@context":116,"provider":117,"areaServed":121,"description":124,"serviceType":125},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":118,"name":119,"@type":120},"https://www.sharevalue.nl","ShareValue","Organization",{"name":122,"@type":123},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[128,136],{"id":129,"title":130,"aside":16,"postType":131,"limit":132,"expertise":133,"__component":135},166,"Lees meer over Microsoft 365","alle",3,[134],{"id":80,"title":81,"subTitle":82,"description":83,"shortDescription":84,"slug":85,"createdAt":86,"updatedAt":87,"publishedAt":88,"isCoreExpertise":89,"documentId":90},"strapi.related-kennisbank-list",{"id":137,"titleLeft":138,"callToActionTextLeft":139,"callToActionLinkUrlLeft":140,"titleRight":141,"callToActionTextRight":142,"callToActionLinkUrlRight":143,"iconUrlLeft":144,"iconUrlRight":157,"__component":166},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":145,"name":146,"alternativeText":16,"caption":16,"width":147,"height":148,"formats":16,"hash":149,"ext":150,"mime":151,"size":152,"url":153,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":154,"updatedAt":155,"documentId":156,"publishedAt":59,"focalPoint":16},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":158,"name":159,"alternativeText":16,"caption":16,"width":148,"height":148,"formats":16,"hash":160,"ext":150,"mime":151,"size":161,"url":162,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":163,"updatedAt":164,"documentId":165,"publishedAt":59,"focalPoint":16},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[168,210,246,280,314,349,383,419,453],{"id":169,"title":170,"subTitle":171,"content":172,"callToActionText":16,"callToActionLink":16,"colorStyle":173,"showAsides":64,"imageUrl":174,"__component":209},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"id":175,"name":176,"alternativeText":16,"caption":16,"width":21,"height":177,"formats":178,"hash":204,"ext":25,"mime":28,"size":205,"url":206,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":207,"updatedAt":207,"documentId":208,"publishedAt"