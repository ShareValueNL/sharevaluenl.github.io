":254,"hash":275,"ext":25,"mime":28,"size":276,"url":277,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":278,"updatedAt":278,"documentId":279,"publishedAt":59,"focalPoint":16},784,"trends.jpg",{"large":255,"small":260,"medium":265,"thumbnail":270},{"ext":25,"url":256,"hash":257,"mime":28,"name":258,"path":16,"size":259,"width":31,"height":184},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_trends_e84a321990.jpg","large_trends_e84a321990","large_trends.jpg",198.92,{"ext":25,"url":261,"hash":262,"mime":28,"name":263,"path":16,"size":264,"width":22,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_trends_e84a321990.jpg","small_trends_e84a321990","small_trends.jpg",59.76,{"ext":25,"url":266,"hash":267,"mime":28,"name":268,"path":16,"size":269,"width":44,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":25,"url":271,"hash":272,"mime":28,"name":273,"path":16,"size":274,"width":202,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"id":281,"title":282,"subTitle":283,"content":284,"callToActionText":16,"callToActionLink":16,"colorStyle":216,"showAsides":64,"imageUrl":285,"__component":209},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":286,"name":287,"alternativeText":16,"caption":16,"width":21,"height":177,"formats":288,"hash":309,"ext":25,"mime":28,"size":310,"url":311,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":312,"updatedAt":312,"documentId":313,"publishedAt":59,"focalPoint":16},785,"microsoft development.jpg",{"large":289,"small":294,"medium":299,"thumbnail":304},{"ext":25,"url":290,"hash":291,"mime":28,"name":292,"path":16,"size":293,"width":31,"height":184},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":25,"url":295,"hash":296,"mime":28,"name":297,"path":16,"size":298,"width":22,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":25,"url":300,"hash":301,"mime":28,"name":302,"path":16,"size":303,"width":44,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":25,"url":305,"hash":306,"mime":28,"name":307,"path":16,"size":308,"width":202,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":315,"title":316,"subTitle":317,"content":318,"callToActionText":319,"callToActionLink":140,"colorStyle":173,"showAsides":64,"imageUrl":320,"__component":209},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":321,"name":322,"alternativeText":16,"caption":16,"width":21,"height":177,"formats":323,"hash":344,"ext":25,"mime":28,"size":345,"url":346,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":347,"updatedAt":347,"documentId":348,"publishedAt":59,"focalPoint":16},786,"migratie.jpg",{"large":324,"small":329,"medium":334,"thumbnail":339},{"ext":25,"url":325,"hash":326,"mime":28,"name":327,"path":16,"size":328,"width":31,"height":184},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":25,"url":330,"hash":331,"mime":28,"name":332,"path":16,"size":333,"width":22,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":25,"url":335,"hash":336,"mime":28,"name":337,"path":16,"size":338,"width":44,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":25,"url":340,"hash":341,"mime":28,"name":342,"path":16,"size":343,"width":202,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":350,"title":351,"subTitle":352,"content":353,"callToActionText":16,"callToActionLink":16,"colorStyle":216,"showAsides":64,"imageUrl":354,"__component":209},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":355,"name":356,"alternativeText":16,"caption":16,"width":21,"height":177,"formats":357,"hash":378,"ext":25,"mime":28,"size":379,"url":380,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":381,"updatedAt":381,"documentId":382,"publishedAt":59,"focalPoint":16},787,"microsoft security.jpg",{"large":358,"small":363,"medium":368,"thumbnail":373},{"ext":25,"url":359,"hash":360,"mime":28,"name":361,"path":16,"size":362,"width":31,"height":184},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":25,"url":364,"hash":365,"mime":28,"name":366,"path":16,"size":367,"width":22,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":25,"url":369,"hash":370,"mime":28,"name":371,"path":16,"size":372,"width":44,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":25,"url":374,"hash":375,"mime":28,"name":376,"path":16,"size":377,"width":202,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":384,"title":385,"subTitle":386,"content":387,"callToActionText":388,"callToActionLink":389,"colorStyle":173,"showAsides":64,"imageUrl":390,"__component":209},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":391,"name":392,"alternativeText":16,"caption":16,"width":21,"height":177,"formats":393,"hash":414,"ext":25,"mime":28,"size":415,"url":416,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":417,"updatedAt":417,"documentId":418,"publishedAt":59,"focalPoint":16},788,"vergaderruimte.jpg",{"large":394,"small":399,"medium":404,"thumbnail":409},{"ext":25,"url":395,"hash":396,"mime":28,"name":397,"path":16,"size":398,"width":31,"height":184},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":25,"url":400,"hash":401,"mime":28,"name":402,"path":16,"size":403,"width":22,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":25,"url":40