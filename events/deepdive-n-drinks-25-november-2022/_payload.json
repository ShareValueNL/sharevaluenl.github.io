h":44,"height":45},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Share_Value_NEXT_imagehero_affd49466d.jpg","medium_Share_Value_NEXT_imagehero_affd49466d","medium_ShareValue_NEXT_imagehero.jpg",23.2,750,293,{"ext":25,"url":47,"hash":48,"mime":28,"name":49,"path":16,"size":50,"width":51,"height":52},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Share_Value_NEXT_imagehero_affd49466d.jpg","thumbnail_Share_Value_NEXT_imagehero_affd49466d","thumbnail_ShareValue_NEXT_imagehero.jpg",3.94,245,96,"Share_Value_NEXT_imagehero_affd49466d",50.76,"https://incredible-beef-2a6059b946.media.strapiapp.com/Share_Value_NEXT_imagehero_affd49466d.jpg","strapi-provider-upload-strapi-cloud","2023-08-31T14:22:00.585Z","jna8xynlhepmniri92flat9q","2026-01-05T12:38:34.018Z",[61],{"id":62,"title":63,"subTitle":64,"description":65,"shortDescription":66,"slug":67,"createdAt":68,"updatedAt":69,"publishedAt":70,"isCoreExpertise":71,"documentId":72,"image":73,"blocks":92,"midPageBlocks":209,"seo":458},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":74,"name":75,"alternativeText":16,"caption":16,"width":76,"height":77,"formats":78,"hash":87,"ext":80,"mime":83,"size":88,"url":89,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":90,"updatedAt":90,"documentId":91,"publishedAt":59},16,"microsoft-365.png",282,130,{"thumbnail":79},{"ext":80,"url":81,"hash":82,"mime":83,"name":84,"path":16,"size":85,"width":51,"height":86},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",[93,187],{"__component":94,"id":95,"title":96,"aside":16,"postType":97,"limit":98,"expertise":99},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",3,[100],{"id":62,"title":63,"subTitle":64,"description":65,"shortDescription":66,"slug":67,"createdAt":68,"updatedAt":69,"publishedAt":70,"isCoreExpertise":71,"documentId":72,"image":101,"blocks":104,"midPageBlocks":115,"seo":170},{"id":74,"name":75,"alternativeText":16,"caption":16,"width":76,"height":77,"formats":102,"hash":87,"ext":80,"mime":83,"size":88,"url":89,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":90,"updatedAt":90,"documentId":91,"publishedAt":59},{"thumbnail":103},{"ext":80,"url":81,"hash":82,"mime":83,"name":84,"path":16,"size":85,"width":51,"height":86},[105,106],{"__component":94,"id":95,"title":96,"aside":16,"postType":97,"limit":98},{"__component":107,"id":108,"titleLeft":109,"callToActionTextLeft":110,"callToActionLinkUrlLeft":111,"titleRight":112,"callToActionTextRight":113,"callToActionLinkUrlRight":114},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[116,124,131,136,141,147,152,159,164],{"__component":117,"id":118,"title":119,"subTitle":120,"content":121,"callToActionText":16,"callToActionLink":16,"colorStyle":122,"showAsides":123},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"__component":117,"id":125,"title":126,"subTitle":127,"content":128,"callToActionText":129,"callToActionLink":111,"colorStyle":130,"showAsides":123},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":117,"id":132,"title":133,"subTitle":134,"content":135,"callToActionText":16,"callToActionLink":16,"colorStyle":122,"showAsides":123},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":117,"id":137,"title":138,"subTitle":139,"content":140,"callToActionText":16,"callToActionLink":16,"colorStyle":130,"showAsides":123},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":117,"id":142,"title":143,"subTitle":144,"content":145,"callToActionText":146,"callToActionLink":111,"colorStyle":122,"showAsides":123},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":117,"id":148,"title":149,"subTitle":150,"content":151,"callToActionText":16,"callToActionLink":16,"colorStyle":130,"showAsides":123},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":117,"id":153,"title":154,"subTitle":155,"content":156,"callToActionText":157,"callToActionLink":158,"colorStyle":122,"showAsides":123},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":117,"id":160,"title":161,"subTitle":162,"content":163,"callToActionText":16,"callToActionLink":16,"colorStyle":130,"showAsides":123},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":165,"id":166,"title":167,"callToActionText":168,"callToActionLinkUrl":169,"body":16},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":171,"metaTitle":172,"metaDescription":173,"structuredData":174},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":175,"@type":176,"@context":177,"provider":178,"areaServed":182,"description":185,"serviceType":186},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":179,"name":180,"@type":181},"https://www.sharevalue.nl","ShareValue","Organization",{"name":183,"@type":184},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":107,"id":108,"titleLeft":109,"callToActionTextLeft":110,"callToActionLinkUrlLeft":111,"titleRight":112,"callToActionTextRight":113,"callToActionLinkUrlRight":114,"iconUrlLeft":188,"iconUrlRight":200},{"id":6,"name":189,"alternativeText":16,"caption":16,"width":190,"height":191,"formats":16,"hash":192,"ext":193,"mime":194,"size":195,"url":196,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":197,"updatedAt":198,"documentId":199,"publishedAt":59},"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_d