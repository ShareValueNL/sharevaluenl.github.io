l":320},{"ext":26,"url":306,"hash":307,"mime":29,"name":308,"path":16,"size":309,"width":32,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":26,"url":311,"hash":312,"mime":29,"name":313,"path":16,"size":314,"width":40,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":26,"url":316,"hash":317,"mime":29,"name":318,"path":16,"size":319,"width":48,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":26,"url":321,"hash":322,"mime":29,"name":323,"path":16,"size":324,"width":49,"height":41},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":331,"title":332,"subTitle":333,"content":334,"callToActionText":335,"callToActionLink":157,"colorStyle":190,"showAsides":17,"imageUrl":336,"__component":225},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":337,"name":338,"alternativeText":16,"caption":16,"width":194,"height":195,"formats":339,