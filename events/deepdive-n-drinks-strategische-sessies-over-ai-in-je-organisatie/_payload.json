:373,"hash":394,"ext":26,"mime":29,"size":395,"url":396,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":397,"updatedAt":397,"documentId":398,"publishedAt":65,"focalPoint":16},787,"microsoft security.jpg",{"large":374,"small":379,"medium":384,"thumbnail":389},{"ext":26,"url":375,"hash":376,"mime":29,"name":377,"path":16,"size":378,"width":32,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":26,"url":380,"hash":381,"mime":29,"name":382,"path":16,"size":383,"width":40,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":26,"url":385,"hash":386,"mime":29,"name":387,"path":16,"size":388,"width":48,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":26,"url":390,"hash":391,"mime":29,"name":392,"path":16,"size":393,"width":49,"height":41},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":400,"title":401,"subTitle":402,"content":403,"callToActionText":404,"callToActionLink":405,"colorStyle":190,"showAsides":17,"imageUrl":406,"__component":225},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":407,"name":408,"alternativeText":16,"caption":16,"width":194,"height":195,"formats":409,"hash":430,"ext":26,"mime":29,"size":431,"url":432,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":433,"updatedAt":433,"documentId":434,"publishedAt":65,"focalPoint":16},788,"vergaderruimte.jpg",{"large":410,"small":415,"medium":420,"thumbnail":425},{"ext":26,"url":411,"hash":412,"mime":29,"name":413,"path":16,"size":414,"width":32,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":26,"url":416,"hash":417,"mime":29,"name":418,"path":16,"size":419,"width":40,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":26,"url":421,"hash":422,"mime":29,"name":423,"path":16,"size":424,"width":48,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",