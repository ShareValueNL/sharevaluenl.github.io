[{"data":1,"prerenderedAt":631},["ShallowReactive",2],{"collection-events--509150425":3,"_apollo:default":630},{"data":4,"meta":627},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"eventStart":10,"location":11,"info":12,"createdAt":13,"updatedAt":14,"publishedAt":15,"eventTimes":16,"darkMode":17,"documentId":18,"imageUrl":19,"seo":16,"blocks":66,"expertises":94},23,"Deepdive 'n Drinks, strategische sessies over AI in je organisatie","Voor organisaties is het een uitdaging om AI en veiligheid hand in hand te laten gaan. Op ons event Deepdive ’n Drinks brengen we deze keer twee cruciale thema’s samen: hoe AI zowel bondgenoot als risico kan zijn binnen een Zero Trust-aanpak, en wat er nodig is om M365 Copilot veilig en effectief te implementeren. Een middag met strategische inzichten, actuele voorbeelden en ruimte voor gesprek met vakgenoten.","deepdive-n-drinks-strategische-sessies-over-ai-in-je-organisatie","2025-11-28T13:00:00.000Z","ShareValue in Gouda","Aanmelden via het aanmeldformulier","2025-10-13T13:40:27.686Z","2025-11-17T11:19:12.185Z","2025-10-16T12:16:33.423Z",null,false,"cdsc56m0x44ecvzasda83cs9",{"id":20,"name":21,"alternativeText":16,"caption":16,"width":22,"height":23,"formats":24,"hash":59,"ext":26,"mime":29,"size":60,"url":61,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":63,"updatedAt":63,"documentId":64,"publishedAt":65,"focalPoint":16},1264,"Afb Deepdive n Drinks header website JPG.jpg",3000,938,{"large":25,"small":35,"medium":43,"thumbnail":51},{"ext":26,"url":27,"hash":28,"mime":29,"name":30,"path":16,"size":31,"width":32,"height":33,"sizeInBytes":34},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1.jpg","large_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1","image/jpeg","large_Afb Deepdive n Drinks header website JPG.jpg",22.99,1000,313,22994,{"ext":26,"url":36,"hash":37,"mime":29,"name":38,"path":16,"size":39,"width":40,"height":41,"sizeInBytes":42},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1.jpg","small_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1","small_Afb Deepdive n Drinks header website JPG.jpg",7.87,500,156,7868,{"ext":26,"url":44,"hash":45,"mime":29,"name":46,"path":16,"size":47,"width":48,"height":49,"sizeInBytes":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1.jpg","medium_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1","medium_Afb Deepdive n Drinks header website JPG.jpg",14.77,750,235,14770,{"ext":26,"url":52,"hash":53,"mime":29,"name":54,"path":16,"size":55,"width":56,"height":57,"sizeInBytes":58},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1.jpg","thumbnail_Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1","thumbnail_Afb Deepdive n Drinks header website JPG.jpg",2.76,245,76,2762,"Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1",122.96,"https://incredible-beef-2a6059b946.media.strapiapp.com/Afb_Deepdive_n_Drinks_header_website_JPG_4243d88fb1.jpg","strapi-provider-upload-strapi-cloud","2025-10-13T13:56:55.841Z","dfcdhvns3rsjh8lssrs1gv93","2026-01-05T12:38:34.018Z",[67,71,75,79,83,87,91],{"id":68,"title":16,"asideText":16,"underline":17,"centered":17,"blankAside":17,"aside":16,"content":69,"introductionText":16,"__component":70},2197,"## Deepdive 'n Drinks, strategische sessies over AI in je organisatie\n\nVoor organisaties is het een uitdaging om AI en veiligheid hand in hand te laten gaan. Op ons event Deepdive ’n Drinks brengen we deze keer twee cruciale thema’s samen: hoe AI zowel bondgenoot als risico kan zijn binnen een Zero Trust-aanpak, en wat er nodig is om M365 Copilot veilig en effectief te implementeren. Een middag met strategische inzichten, actuele voorbeelden en ruimte voor gesprek met vakgenoten.\n\nNaast inspirerende sessies is er ook ruimte voor ontspanning. Tijdens de borrel kunnen we napraten en ervaringen uitwisselen onder het genot van een hapje en drankje in de bar van ShareValue.\n\nEr is beperkt plek, dus meld je op tijd aan.\n\n**Het programma:**\n- 14:00 - 14:30 uur Inloop\n- 14:30 - 15:00 uur AI en Zero Trust: van visie naar actie - door Gert Labuschagne\n- 15:00 - 15:15 uur Koffiepauze\n- 15:15 - 16:00 uur Governance & praktijk: de route naar M365 Copilot-succes - door Dennis Postmus\n- 16:00 - 17:30 uur Borrel met hapjes","global.pagesection",{"id":72,"title":16,"asideText":16,"underline":17,"centered":17,"blankAside":17,"aside":73,"content":74,"introductionText":16,"__component":70},2190,"Sessie 1: Zero Trust & AI","### AI en Zero Trust: van visie naar actie\n_Spreker: Gert Labuschagne (ShareValue, Azure Engineer & Architect en Zero Trust expert)_\n\nAI verandert razendsnel hoe organisaties werken, én hoe we moeten nadenken over beveiliging. Tijdens deze sessie laat onze Azure Architect zien hoe je met een Zero Trust-aanpak grip houdt op data, identiteit en risico’s, zonder innovatie af te remmen. Je krijgt praktische inzichten om vandaag al te beginnen met een veilige en toekomstbestendige AI-strategie binnen jouw organisatie.",{"id":76,"title":16,"asideText":16,"underline":17,"centered":17,"blankAside":17,"aside":77,"content":78,"introductionText":16,"__component":70},2191,"Sessie 2: M365 Copilot & AI","### Governance & praktijk: de route naar M365 Copilot-succes\n_Spreker: Dennis Postmus (ShareValue, Microsoft 365 Consultant en M365 Copilot expert)_\n\nM365 Copilot is meer dan een knop in Teams. Het vraagt om een solide fundament: Zero Trust, datahygiëne en slimme instellingen. In deze sessie nemen we de werking van Copilot door, bespreken de laatste vernieuwingen, en geven inzicht in governance-opties en cruciale instellingen. Je krijgt concrete voorbereidingstips én inspirerende praktijkcases met meetbare resultaten, zodat jouw organisatie klaar is voor een succesvolle Copilot-implementatie.",{"id":80,"title":16,"asideText":16,"underline":17,"centered":17,"blankAside":17,"aside":81,"content":82,"introductionText":16,"__component":70},2192,"Borrel met hapjes","### De Drinks\nNa de Deepdive is het tijd voor de Drinks. Onderling even napraten en ervaringen uitwisselen onder het genot van een hapje en drankje in de bar van ShareValue.",{"id":84,"title":16,"asideText":16,"underline":17,"centered":17,"blankAside":17,"aside":85,"content":86,"introductionText":16,"__component":70},2195,"Aanmelden","### Ben jij erbij?\nDeze middag is bedoeld voor IT-managers en vergelijkbare functies en biedt een unieke kans om in een kleine setting relevante kennis op te doen. Meld je aan via het aanmeldformulier.\n\n\u003Ca class=\"btn-primary\" href=\"https://forms.office.com/e/D185zZWgp2\" target=\"_blank\" rel=\"noopener noreferrer\">Ga naar het aanmeldformulier\u003C/a>",{"id":88,"title":16,"asideText":16,"underline":17,"centered":17,"blankAside":17,"aside":89,"content":90,"introductionText":16,"__component":70},2196,"Vragen?","Heb je vragen over deze Deepdive 'n Drinks? Neem contact met ons op via [events@sharevalue.nl](mailto:events@sharevalue.nl)",{"id":92,"title":16,"showBlankAside":17,"__component":93},239,"global.social-sharing",[95,476],{"id":96,"title":97,"subTitle":98,"description":99,"shortDescription":100,"slug":101,"createdAt":102,"updatedAt":103,"publishedAt":104,"isCoreExpertise":105,"documentId":106,"image":107,"seo":126,"blocks":144,"midPageBlocks":184},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":108,"name":109,"alternativeText":16,"caption":16,"width":110,"height":111,"formats":112,"hash":121,"ext":114,"mime":117,"size":122,"url":123,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":124,"updatedAt":124,"documentId":125,"publishedAt":65,"focalPoint":16},16,"microsoft-365.png",282,130,{"thumbnail":113},{"ext":114,"url":115,"hash":116,"mime":117,"name":118,"path":16,"size":119,"width":56,"height":120},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":127,"metaTitle":128,"metaDescription":129,"structuredData":130,"metaImage":16,"metaSocial":143},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":131,"@type":132,"@context":133,"provider":134,"areaServed":138,"description":141,"serviceType":142},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":135,"name":136,"@type":137},"https://www.sharevalue.nl","ShareValue","Organization",{"name":139,"@type":140},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[145,153],{"id":146,"title":147,"aside":16,"postType":148,"limit":149,"expertise":150,"__component":152},166,"Lees meer over Microsoft 365","alle",3,[151],{"id":96,"title":97,"subTitle":98,"description":99,"shortDescription":100,"slug":101,"createdAt":102,"updatedAt":103,"publishedAt":104,"isCoreExpertise":105,"documentId":106},"strapi.related-kennisbank-list",{"id":154,"titleLeft":155,"callToActionTextLeft":156,"callToActionLinkUrlLeft":157,"titleRight":158,"callToActionTextRight":159,"callToActionLinkUrlRight":160,"iconUrlLeft":161,"iconUrlRight":174,"__component":183},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":162,"name":163,"alternativeText":16,"caption":16,"width":164,"height":165,"formats":16,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":65,"focalPoint":16},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":175,"name":176,"alternativeText":16,"caption":16,"width":165,"height":165,"formats":16,"hash":177,"ext":167,"mime":168,"size":178,"url":179,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":180,"updatedAt":181,"documentId":182,"publishedAt":65,"focalPoint":16},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[185,226,262,296,330,365,399,435,469],{"id":186,"title":187,"subTitle":188,"content":189,"callToActionText":16,"callToActionLink":16,"colorStyle":190,"showAsides":17,"imageUrl":191,"__component":225},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"id":192,"name":193,"alternativeText":16,"caption":16,"width":194,"height":195,"formats":196,"hash":220,"ext":26,"mime":29,"size":221,"url":222,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":223,"updatedAt":223,"documentId":224,"publishedAt":65,"focalPoint":16},782,"Teams.jpg",1280,850,{"large":197,"small":203,"medium":209,"thumbnail":215},{"ext":26,"url":198,"hash":199,"mime":29,"name":200,"path":16,"size":201,"width":32,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Teams_43eca91eed.jpg","large_Teams_43eca91eed","large_Teams.jpg",75.76,664,{"ext":26,"url":204,"hash":205,"mime":29,"name":206,"path":16,"size":207,"width":40,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Teams_43eca91eed.jpg","small_Teams_43eca91eed","small_Teams.jpg",24.28,332,{"ext":26,"url":210,"hash":211,"mime":29,"name":212,"path":16,"size":213,"width":48,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Teams_43eca91eed.jpg","medium_Teams_43eca91eed","medium_Teams.jpg",45.38,498,{"ext":26,"url":216,"hash":217,"mime":29,"name":218,"path":16,"size":219,"width":49,"height":41},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Teams_43eca91eed.jpg","thumbnail_Teams_43eca91eed","thumbnail_Teams.jpg",8.28,"Teams_43eca91eed",119.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Teams_43eca91eed.jpg","2024-08-08T09:42:56.910Z","ht6rctym4qbbspr1vnahyrg1","global.alternating-page-section",{"id":227,"title":228,"subTitle":229,"content":230,"callToActionText":231,"callToActionLink":157,"colorStyle":232,"showAsides":17,"imageUrl":233,"__component":225},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"id":234,"name":235,"alternativeText":16,"caption":16,"width":194,"height":195,"formats":236,"hash":257,"ext":26,"mime":29,"size":258,"url":259,"previewUrl":16,"provider":62,"provider_metadata":16,"createdAt":260,"updatedAt":260,"documentId":261,"publishedAt":65,"focalPoint":16},783,"adoptie.jpg",