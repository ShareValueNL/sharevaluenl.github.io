:217,"ext":25,"mime":28,"size":218,"url":219,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":220,"updatedAt":220,"documentId":221,"publishedAt":59},791,"service bus.jpg",{"large":197,"small":202,"medium":207,"thumbnail":212},{"ext":25,"url":198,"hash":199,"mime":28,"name":200,"path":16,"size":201,"width":31,"height":167},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_service_bus_2b48e3a7cc.jpg","large_service_bus_2b48e3a7cc","large_service bus.jpg",82.82,{"ext":25,"url":203,"hash":204,"mime":28,"name":205,"path":16,"size":206,"width":22,"height":173},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_service_bus_2b48e3a7cc.jpg","small_service_bus_2b48e3a7cc","small_service bus.jpg",29.35,{"ext":25,"url":208,"hash":209,"mime":28,"name":210,"path":16,"size":211,"width":44,"height":179},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_service_bus_2b48e3a7cc.jpg","medium_service_bus_2b48e3a7cc","medium_service bus.jpg",54.72,{"ext":25,"url":213,"hash":214,"mime":28,"name":215,"path":16,"size":216,"width":185,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_service_bus_2b48e3a7cc.jpg","thumbnail_service_bus_2b48e3a7cc","thumbnail_service bus.jpg",8.71,"service_bus_2b48e3a7cc",117.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/service_bus_2b48e3a7cc.jpg","2024-08-09T08:35:35.231Z","rbpawsulv6vrsistrk2yupwg",{"__component":114,"id":124,"title":125,"subTitle":16,"content":126,"callToActionText":16,"callToActionLink":16,"colorStyle":16,"showAsides":16,"imageUrl":223},{"id":224,"name":225,"alternativeText":16,"caption":16,"width":21,"height":160,"formats":226,"hash":247,"ext":25,"mime":28,"size":248,"url":249,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":250,"updatedAt":250,"documentId":251,"publishedAt":59},792,"security dotnet.jpg",{"large":227,"small":232,"medium":237,"thumbnail":242},{"ext":25,"url":228,"hash":229,"mime":28,"name":230,"path":16,"size":231,"width":31,"height":167},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_dotnet_a65d687baf.jpg","large_security_dotnet_a65d687baf","large_security dotnet.jpg",38.7,{"ext":25,"url":233,"hash":234,"mime":28,"name":235,"path":16,"size":236,"width":22,"height":173},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_dotnet_a65d687baf.jpg","small_security_dotnet_a65d687baf","small_security dotnet.jpg",13.37,{"ext":25,"url":238,"hash":239,"mime":28,"name":240,"path":16,"size":241,"width":44,"height":179},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_dotnet_a65d687baf.jpg","medium_security_dotnet_a65d687baf","medium_security dotnet.jpg",24.75,{"ext":25,"url":243,"hash":244,"mime":28,"name":245,"path":16,"size":246,"width":185,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_dotnet_a65d687baf.jpg","thumbnail_security_dotnet_a65d687baf","thumbnail_security dotnet.jpg",4.63,"security_dotnet_a65d687baf",57.25,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_dotnet_a65d687baf.jpg","2024-08-09T08:36:56.895Z","srupv8bm7kvcgseu2efeadhk",{"__component":128,"id":129,"title":130,"callToActionText":131,"callToActionLinkUrl":132,"body":16,"imageUrl":253},{"id":135,"name":136,"alternativeText":16,"caption":16,"width":137,"height":138,"formats":16,"hash":139,"ext":140,"mime":141,"size":142,"url":143,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":144,"updatedAt":145,"documentId":146,"publishedAt":59},[255,259,263,301,304],{"__component":256,"id":257,"title":16,"asideText":16,"underline":71,"centered":71,"blankAside":71,"aside":16,"content":258,"introductionText":16},"global.pagesection",102,"\n## Voor wie is dit evenement?\n\n- De bioscooppremière van Black Panther: Wakanda Forever is voor alle consultants, developers en engineers in ons netwerk, en iedereen die een team aanstuurt die hieruit bestaat.\n\n- Het expertpanel is bedoeld voor iedereen met interesse in .NET 7 en wat dat voor jouw organisatie kan betekenen.\n- \nVoordat je je aanmeldt, vragen we je wel om onze [promotievoorwaarden](https://incredible-beef-2a6059b946.media.strapiapp.com/promotievoorwaarden_Bits_Bites_Bios_28a0fffeca.jpg) te controleren.",{"__component":256,"id":260,"title":16,"asideText":16,"underline":71,"centered":71,"blankAside":71,"aside":261,"content":262,"introductionText":16},98,"![microsoft-365.png](https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png)","## Het programma:\n\n- 17:00 uur: inloop voor genodigden, inclusief pizzaslices\n- 17:30 uur: start van expertpanel .NET 7 met Astrid Hackenberg (Technical Trainer Lead bij Microsoft)\n- 19:00 uur: einde van het panel. Tijd voor netwerken en meer pizzaslices\n- 20:00 uur: bioscooppremière van Black Panther: Wakanda Forever\n- 22:30 uur: netwerkborrel in de foyer\n- 00:00 uur: einde avond\n \n\nUiteraard is het ook mogelijk om alleen de panelbespreking of juist alleen de film bij te wonen. Wanneer je je aanmeldt kies je welke onderdelen je bijwoont!\n\n## Waarom moet jíj aan de slag met .NET 7?\n\nIn november wordt .NET 7 gelanceerd tijdens de .NET Conf, welke wordt georganiseerd door de .NET Community en Microsoft.\n\nOp 9 november blikken wij hierop terug in Cinema Gouda. We gaan kijken naar een deel van de keynote en naar highlights van de eerste sessies. Met ons panel bestaande uit ShareValue .NET experts Michiel, Alex en Marco gaan we kijken wat .NET 7 voor organisaties betekent en uiteraard beantwoorden we ook vragen uit de zaal.\n\nHoewel .NET 7 slechts een korte periode ondersteuning krijgt van Microsoft (tot mei 2024), biedt deze versie wel weer veel verbeteringen. Deze versie is weer een stuk sneller dan .NET 6, bijvoorbeeld bij Regular Expressions. Ook de nieuwe Entity Framework (Core) sluit nu aan bij de nieuwe .NET. En hoe wordt .NET MAUI, gelanceerd dit voorjaar tijdens Microsoft Build, door .NET 7 ondersteund?\n\n \n\nOnze gastspreker Astrid Hackenberg is Technical Trainer Lead en werkt al 10 jaar bij Microsoft. Ze gaat ons meenemen in de trainingen en certificeringen die Microsoft aanbiedt.\n\n## Bioscooppremière Black Panther: Wakanda Forever\nBlack Panther was natuurlijk een geweldige film. In Wakanda Forever leren we meer over de cultuur van Wakanda en zijn inwoners, terwijl overleden hoofdrolspeler Chadwick Boseman wordt geëerd. Natuurlijk gaat dit gepaard met de nodige actie wanneer er gevaar dreigt voor het volk.",{"__component":264,"id":124,"title":16,"videoUrl":265,"stillImage":266},"global.video","https://youtube.com/embed/RlOB3UALvrQ",{"id":267,"name":268,"alternativeText":16,"caption":16,"width":269,"height":270,"formats":271,"hash":296,"ext":25,"mime":28,"size":137,"url":297,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":298,"updatedAt":299,"documentId":300,"publishedAt":59},183,"scale.jpg",1200,675,{"large":272,"small":278,"medium":284,"thumbnail":290},{"ext":25,"url":273,"hash":274,"mime":28,"name":275,"path":16,"size":276,"width":31,"height":277},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_scale_b0aa106334.jpg","large_scale_b0aa106334","large_scale.jpg",52.52,563,{"ext":25,"url":279,"hash":280,"mime":28,"name":281,"path":16,"size":282,"width":22,"height":283},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_scale_b0aa106334.jpg","small_scale_b0aa106334","small_scale.jpg",18.02,281,{"ext":25,"url":285,"hash":286,"mime":28,"name":287,"path":16,"size":288,"width":44,"height":289},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_scale_b0aa106334.jpg","medium_scale_b0aa106334","medium_scale.jpg",33.39,422,{"ext":25,"url":291,"hash":292,"mime":28,"name":293,"path":16,"size":294,"width":51,"height":295},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_scale_b0aa106334.jpg","thumbnail_scale_b0aa106334","thumbnail_scale.jpg",5.86,138,"scale_b0aa106334","https://incredible-beef-2a6059b946.media.strapiapp.com/scale_b0aa106334.jpg","2023-08-31T15:51:21.141Z","2024-01-15T13:22:21.505Z","z427o5p9nr9e5b0l8h8rh2vt",{"__component":256,"id":302,"title":16,"asideText":16,"underline":71,"centered":71,"blankAside":71,"aside":16,"content":303,"introductionText":16},100,"## Aanmelden\nDe sessie is bedoeld voor IT-managers en mensen in een vergelijkbare functie die hier graag meer over willen weten. Wil je erbij zijn? Meld je dan nu aan!\n\n**Dit event is al geweest, aanmelden is niet meer mogelijk.**",{"__component":305,"id":6,"title":306,"showBlankAside":71},"global.social-sharing","Deel deze pagina",{"pagination":308},{"page":309,"pageSize":302},1,{},1781518588784]