[{"data":1,"prerenderedAt":304},["ShallowReactive",2],{"collection-events-309092154":3,"_apollo:default":303},{"data":4,"meta":299},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"eventStart":10,"location":11,"info":12,"createdAt":13,"updatedAt":14,"publishedAt":15,"eventTimes":16,"darkMode":16,"documentId":17,"imageUrl":18,"seo":16,"blocks":60,"expertises":118},17,"Bits, Bites & Bios","\nWil jij je laten onderdompelen in de wereld van .NET 8 en de grenzeloze mogelijkheden van AI ontdekken? En wil je naar The Hunger Games: The Ballad of Songbirds and Snakes? Dit is jouw kans! Doe mee aan ons event, Bits, Bites & Bios, op 29 november, in de betoverende setting van Cinema Gouda. Een avond die in het teken staat van innovatie, connecties en entertainment.","bits-bites-bios-2023","2023-11-29T16:00:00.000Z","Cinema Gouda","Inhoudelijk én fun!","2024-01-15T13:48:35.580Z","2024-08-19T09:07:40.426Z","2024-01-15T14:28:55.471Z",null,"tvj586xm2q4hhfvg39g6wbmf",{"id":19,"name":20,"alternativeText":16,"caption":16,"width":21,"height":22,"formats":23,"hash":53,"ext":25,"mime":28,"size":54,"url":55,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":57,"updatedAt":57,"documentId":58,"publishedAt":59,"focalPoint":16},438,"BBB_2023_headerfoto_psd.webp",1280,500,{"large":24,"small":33,"medium":39,"thumbnail":46},{"ext":25,"url":26,"hash":27,"mime":28,"name":29,"path":16,"size":30,"width":31,"height":32},".webp","https://incredible-beef-2a6059b946.media.strapiapp.com/large_BBB_2023_headerfoto_psd_67c02b881d.webp","large_BBB_2023_headerfoto_psd_67c02b881d","image/webp","large_BBB_2023_headerfoto_psd.webp",37.45,1000,391,{"ext":25,"url":34,"hash":35,"mime":28,"name":36,"path":16,"size":37,"width":22,"height":38},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_BBB_2023_headerfoto_psd_67c02b881d.webp","small_BBB_2023_headerfoto_psd_67c02b881d","small_BBB_2023_headerfoto_psd.webp",15.05,195,{"ext":25,"url":40,"hash":41,"mime":28,"name":42,"path":16,"size":43,"width":44,"height":45},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_BBB_2023_headerfoto_psd_67c02b881d.webp","medium_BBB_2023_headerfoto_psd_67c02b881d","medium_BBB_2023_headerfoto_psd.webp",26.45,750,293,{"ext":25,"url":47,"hash":48,"mime":28,"name":49,"path":16,"size":50,"width":51,"height":52},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_BBB_2023_headerfoto_psd_67c02b881d.webp","thumbnail_BBB_2023_headerfoto_psd_67c02b881d","thumbnail_BBB_2023_headerfoto_psd.webp",5.13,245,96,"BBB_2023_headerfoto_psd_67c02b881d",60.29,"https://incredible-beef-2a6059b946.media.strapiapp.com/BBB_2023_headerfoto_psd_67c02b881d.webp","strapi-provider-upload-strapi-cloud","2024-01-15T14:27:31.681Z","b3m3hjb8u9ojc5rv2qi4vx6s","2026-01-05T12:38:34.018Z",[61,66,70,74,114],{"id":62,"title":16,"asideText":16,"underline":63,"centered":63,"blankAside":63,"aside":16,"content":64,"introductionText":16,"__component":65},1776,false,"## Voor wie is dit evenement?\n\nShareValue organiseert deze tweeledige avond voor alle .NET Developers en .NET geïnteresseerden in ons netwerk. Voordat je je aanmeldt, vragen we je wel om onze [promotievoorwaarden](https://incredible-beef-2a6059b946.media.strapiapp.com/promotievoorwaarden_bits_bites_bios_2023_da21c3501b.jpg) te controleren.","global.pagesection",{"id":67,"title":16,"asideText":68,"underline":63,"centered":63,"blankAside":63,"aside":16,"content":69,"introductionText":16,"__component":65},1778,"Het programma","## Het programma\n\n- 17:00 uur: je bent welkom in Cinema Gouda\n- 17:30 uur: unieke technisch inhoudelijke sessies:\n     - .NET 8 - Belangrijke nieuwe features van Entity Framework\n     - The Best Bits of Blazor in .NET 8\n     - Boost je development workflow met AI\n- 19:00 uur: afsluiting van het inhoudelijke gedeelte. Tijd om te netwerken en te genieten van heerlijke pizzapunten.\n- 20:00 uur: bioscoopfilm The Hunger Games: The Ballad of Songbirds and Snakes\n- 22:30 uur: samenkomen tijdens de netwerkborrel in de foyer",{"id":71,"title":16,"asideText":72,"underline":63,"centered":63,"blankAside":63,"aside":16,"content":73,"introductionText":16,"__component":65},1780,"Daarna gaan we naar de film","## Onze inhoudelijke sessies\n\n## Michiel: .NET 8 – Belangrijke nieuwe features van Entity Framework \n##\n\nEntity Framework Core heeft een inhaalslag gemaakt vanuit het oude Entity Framework. Michiel laat nieuwe features zien die meerwaarde bieden aan de developer. Raw SQL, JSON columns en meer. \n\nEn dat in real live demo's met Blazor!\n\n## Gastspreker MVP Fanie Reynders: The Best Bits of Blazor in .NET 8 (Engelstalige sessie)\n##\nDuik diep in de vernieuwingen van Blazor in .NET 8, met focus op de .NET WebAssembly runtime configuratie voor een geoptimaliseerde start. Ontdek de verfijnde configuratie van verbindings-timeouts via HubConnectionBuilder. Deze update zal elke .NET-enthousiasteling of Blazor-nieuwkomer zeker boeien!\n\n## Raymon en Marco: Boost je development workflow met AI ##\n\nTijdens deze sessie vertellen Marco en Raymon je hoe AI de .NET-ontwikkelingswereld verandert. Ontdek hoe je met AI documentatie kunt genereren en code kunt refactoren met Github Copilot. Ook leggen de heren uit hoe je lastige recruiters afhandelt en nog veel meer dingen die jouw werk makkelijker maken! ",{"id":75,"title":16,"videoUrl":76,"stillImage":77,"__component":113},38,"https://youtube.com/embed/NxW_X4kzeus",{"id":78,"name":79,"alternativeText":16,"caption":16,"width":21,"height":80,"formats":81,"hash":108,"ext":83,"mime":86,"size":109,"url":110,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":111,"updatedAt":111,"documentId":112,"publishedAt":59,"focalPoint":16},436,"trailer_still.jpg",720,{"large":82,"small":90,"medium":96,"thumbnail":102},{"ext":83,"url":84,"hash":85,"mime":86,"name":87,"path":16,"size":88,"width":31,"height":89},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_trailer_still_75909179c8.jpg","large_trailer_still_75909179c8","image/jpeg","large_trailer_still.jpg",72.34,563,{"ext":83,"url":91,"hash":92,"mime":86,"name":93,"path":16,"size":94,"width":22,"height":95},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_trailer_still_75909179c8.jpg","small_trailer_still_75909179c8","small_trailer_still.jpg",25.6,281,{"ext":83,"url":97,"hash":98,"mime":86,"name":99,"path":16,"size":100,"width":44,"height":101},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trailer_still_75909179c8.jpg","medium_trailer_still_75909179c8","medium_trailer_still.jpg",47.01,422,{"ext":83,"url":103,"hash":104,"mime":86,"name":105,"path":16,"size":106,"width":51,"height":107},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trailer_still_75909179c8.jpg","thumbnail_trailer_still_75909179c8","thumbnail_trailer_still.jpg",8.7,138,"trailer_still_75909179c8",93.43,"https://incredible-beef-2a6059b946.media.strapiapp.com/trailer_still_75909179c8.jpg","2024-01-15T14:25:32.692Z","xlwjrf60uk6uqa6eieg6sryc","global.video",{"id":115,"title":116,"showBlankAside":63,"__component":117},182,"Deel deze pagina:","global.social-sharing",[119],{"id":120,"title":121,"subTitle":122,"description":123,"shortDescription":124,"slug":125,"createdAt":126,"updatedAt":127,"publishedAt":128,"isCoreExpertise":63,"documentId":129,"image":130,"seo":16,"blocks":148,"midPageBlocks":184},3,"Microsoft .NET","Maatwerkoplossingen voor ieder vraagstuk","Ons team van .NET-experts staat niet alleen klaar om onze klanten te ondersteunen bij diverse implementatie uitdagingen, maar we zijn ook gespecialiseerd in het testen van applicaties op verschillende niveaus, zoals unit tests, integratietests en acceptatietests. We streven naar uitmuntende testdekking om de stabiliteit en betrouwbaarheid van de applicaties te waarborgen.\n\nDaarnaast zijn we bedreven in het gebruik van verschillende Azure-services om schaalbare en veilige oplossingen te bieden aan onze klanten. Zo bieden we met Azure DevOps krachtige tools voor het beheren van de ontwikkeling, het automatiseren van tests en het geautomatiseerd uitrollen naar acceptatie- of productieomgevingen met CI/CD-pipelines.\n\nHet samenwerken met onze klanten staat centraal in ons werk, en we denken proactief mee om samen de meest optimale oplossingen te realiseren.","In de praktijk komen de .NET developers van ShareValue terecht in allerlei verschillende branches met uiteenlopende technische uitdagingen.","dotnet","2023-08-17T11:19:57.991Z","2024-12-13T12:16:04.480Z","2023-08-17T11:22:08.050Z","v9pl553hsjk98esvs5gzoso3",{"id":6,"name":131,"alternativeText":16,"caption":16,"width":132,"height":133,"formats":134,"hash":143,"ext":136,"mime":139,"size":144,"url":145,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":146,"updatedAt":146,"documentId":147,"publishedAt":59,"focalPoint":16},"dotnet_logo.png",282,130,{"thumbnail":135},{"ext":136,"url":137,"hash":138,"mime":139,"name":140,"path":16,"size":141,"width":51,"height":142},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_dotnet_logo_d38dbc3865.png","thumbnail_dotnet_logo_d38dbc3865","image/png","thumbnail_dotnet_logo.png",7.14,113,"dotnet_logo_d38dbc3865",2.93,"https://incredible-beef-2a6059b946.media.strapiapp.com/dotnet_logo_d38dbc3865.png","2023-08-17T09:47:56.313Z","nnimzsossci29qmi8z0texlp",[149,156],{"id":150,"title":151,"aside":16,"postType":152,"limit":120,"expertise":153,"__component":155},167," Lees meer over .NET Development","alle",[154],{"id":120,"title":121,"subTitle":122,"description":123,"shortDescription":124,"slug":125,"createdAt":126,"updatedAt":127,"publishedAt":128,"isCoreExpertise":63,"documentId":129},"strapi.related-kennisbank-list",{"id":157,"titleLeft":158,"callToActionTextLeft":159,"callToActionLinkUrlLeft":160,"titleRight":161,"callToActionTextRight":159,"callToActionLinkUrlRight":160,"iconUrlLeft":162,"iconUrlRight":175,"__component":183},212,"Heb je een .NET expert nodig?","Neem contact met ons op","/contact","Weten welke expert op dit moment beschikbaar is?",{"id":163,"name":164,"alternativeText":16,"caption":16,"width":165,"height":166,"formats":16,"hash":167,"ext":168,"mime":169,"size":170,"url":171,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":172,"updatedAt":173,"documentId":174,"publishedAt":59,"focalPoint":16},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":176,"name":177,"alternativeText":16,"caption":16,"width":166,"height":166,"formats":16,"hash":178,"ext":168,"mime":169,"size":179,"url":180,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":181,"updatedAt":181,"documentId":182,"publishedAt":59,"focalPoint":16},250,"looking-glass.svg","looking_glass_cfa3801802",0.6,"https://incredible-beef-2a6059b946.media.strapiapp.com/looking_glass_cfa3801802.svg","2023-10-11T09:43:10.911Z","suv3p7h0kw7jdnuddk1l2rdu","call-to-action.double",[185,226,259,292],{"id":186,"title":187,"subTitle":16,"content":188,"callToActionText":189,"callToActionLink":160,"colorStyle":16,"showAsides":16,"imageUrl":190,"__component":225},36,"Bouwen en testen","Onze .NET-experts kunnen uiteraard goede en betrouwbare applicaties ontwikkelen met de laatste .NET-versies. Ook zijn onze collega’s ervaren in het onderhouden van oudere software. We kunnen je helpen met het upgraden en uitbreiden van je applicatie zodat deze aan de laatste wensen en eisen voldoet. Het uitvoeren van uitgebreide unit- en integratietests om de stabiliteit van applicaties te waarborgen, wordt meegenomen als standaard onderdeel van het werk. Met een focus op grondige testdekking streven we ernaar om eventuele bugs vroegtijdig op te sporen en op te lossen, waardoor de algehele kwaliteit van jouw product wordt verbeterd.  \n\nVan Blazor Front-End of REST API’s tot database communicatie, onze .NET-experts hebben er ruime ervaring mee.","Weten wat onze experts voor jou kunnen doen?",{"id":191,"name":192,"alternativeText":16,"caption":16,"width":21,"height":193,"formats":194,"hash":220,"ext":83,"mime":86,"size":221,"url":222,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":223,"updatedAt":223,"documentId":224,"publishedAt":59,"focalPoint":16},790,"code matrix.jpg",850,{"large":195,"small":201,"medium":207,"thumbnail":213},{"ext":83,"url":196,"hash":197,"mime":86,"name":198,"path":16,"size":199,"width":31,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_code_matrix_939256fff4.jpg","large_code_matrix_939256fff4","large_code matrix.jpg",164.22,664,{"ext":83,"url":202,"hash":203,"mime":86,"name":204,"path":16,"size":205,"width":22,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_code_matrix_939256fff4.jpg","small_code_matrix_939256fff4","small_code matrix.jpg",42.02,332,{"ext":83,"url":208,"hash":209,"mime":86,"name":210,"path":16,"size":211,"width":44,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_code_matrix_939256fff4.jpg","medium_code_matrix_939256fff4","medium_code matrix.jpg",97.04,498,{"ext":83,"url":214,"hash":215,"mime":86,"name":216,"path":16,"size":217,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_code_matrix_939256fff4.jpg","thumbnail_code_matrix_939256fff4","thumbnail_code matrix.jpg",8.35,235,156,"code_matrix_939256fff4",258.04,"https://incredible-beef-2a6059b946.media.strapiapp.com/code_matrix_939256fff4.jpg","2024-08-09T08:30:59.615Z","s5v68ezvz0ho9m6ot0mbk8z2","global.alternating-page-section",{"id":227,"title":228,"subTitle":16,"content":229,"callToActionText":16,"callToActionLink":16,"colorStyle":16,"showAsides":16,"imageUrl":230,"__component":225},37,"Combineren met Azure","Wil je profiteren van Azure-services voor jouw project? Ons team van experts kan je helpen met het selecteren en opzetten van de juiste services. Of je gebruik wil maken van App services, Function Apps, storage of database oplossingen of bijvoorbeeld een Service Bus, onze experts kunnen je helpen bij het kiezen en het realiseren van stabiele, schaalbare en veilige oplossingen die voldoen aan jouw specifieke behoeften.",{"id":231,"name":232,"alternativeText":16,"caption":16,"width":21,"height":193,"formats":233,"hash":254,"ext":83,"mime":86,"size":255,"url":256,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":257,"updatedAt":257,"documentId":258,"publishedAt":59,"focalPoint":16},791,"service bus.jpg",{"large":234,"small":239,"medium":244,"thumbnail":249},{"ext":83,"url":235,"hash":236,"mime":86,"name":237,"path":16,"size":238,"width":31,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_service_bus_2b48e3a7cc.jpg","large_service_bus_2b48e3a7cc","large_service bus.jpg",82.82,{"ext":83,"url":240,"hash":241,"mime":86,"name":242,"path":16,"size":243,"width":22,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_service_bus_2b48e3a7cc.jpg","small_service_bus_2b48e3a7cc","small_service bus.jpg",29.35,{"ext":83,"url":245,"hash":246,"mime":86,"name":247,"path":16,"size":248,"width":44,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_service_bus_2b48e3a7cc.jpg","medium_service_bus_2b48e3a7cc","medium_service bus.jpg",54.72,{"ext":83,"url":250,"hash":251,"mime":86,"name":252,"path":16,"size":253,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_service_bus_2b48e3a7cc.jpg","thumbnail_service_bus_2b48e3a7cc","thumbnail_service bus.jpg",8.71,"service_bus_2b48e3a7cc",117.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/service_bus_2b48e3a7cc.jpg","2024-08-09T08:35:35.231Z","rbpawsulv6vrsistrk2yupwg",{"id":260,"title":261,"subTitle":16,"content":262,"callToActionText":16,"callToActionLink":16,"colorStyle":16,"showAsides":16,"imageUrl":263,"__component":225},35,"Houd het veilig!","Om de toegang tot je producten veilig te houden, kan ons team van .NET-experts je helpen bij het opzetten en onderhouden van authenticatie en autorisatie. Onze experts zijn ervaren in het opzetten de juiste entra diensten zodat de toegang tot zowel Front-End als Back-End of deamon-processen op een juiste manier afgehandeld wordt. Ook kunnen we je helpen met het opzetten van verschillende groepen, rechten en rollen, en deze op de juiste manier toepassen binnen de applicatie zodat onterechte toegang op functieniveau geregeld kan worden. Bij het opzetten en implementeren wordt er rekening gehouden met het reduceren van de administratieve overhead zonder concessies te doen aan de beveiliging.",{"id":264,"name":265,"alternativeText":16,"caption":16,"width":21,"height":193,"formats":266,"hash":287,"ext":83,"mime":86,"size":288,"url":289,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":290,"updatedAt":290,"documentId":291,"publishedAt":59,"focalPoint":16},792,"security dotnet.jpg",{"large":267,"small":272,"medium":277,"thumbnail":282},{"ext":83,"url":268,"hash":269,"mime":86,"name":270,"path":16,"size":271,"width":31,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_dotnet_a65d687baf.jpg","large_security_dotnet_a65d687baf","large_security dotnet.jpg",38.7,{"ext":83,"url":273,"hash":274,"mime":86,"name":275,"path":16,"size":276,"width":22,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_dotnet_a65d687baf.jpg","small_security_dotnet_a65d687baf","small_security dotnet.jpg",13.37,{"ext":83,"url":278,"hash":279,"mime":86,"name":280,"path":16,"size":281,"width":44,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_dotnet_a65d687baf.jpg","medium_security_dotnet_a65d687baf","medium_security dotnet.jpg",24.75,{"ext":83,"url":283,"hash":284,"mime":86,"name":285,"path":16,"size":286,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_dotnet_a65d687baf.jpg","thumbnail_security_dotnet_a65d687baf","thumbnail_security dotnet.jpg",4.63,"security_dotnet_a65d687baf",57.25,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_dotnet_a65d687baf.jpg","2024-08-09T08:36:56.895Z","srupv8bm7kvcgseu2efeadhk",{"id":293,"title":294,"callToActionText":295,"callToActionLinkUrl":296,"body":16,"imageUrl":297,"__component":298},46,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij KPN","/klantcases/de-continue-bereikbaarheid-van-een-alarmcentrale",{"id":163,"name":164,"alternativeText":16,"caption":16,"width":165,"height":166,"formats":16,"hash":167,"ext":168,"mime":169,"size":170,"url":171,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":172,"updatedAt":173,"documentId":174,"publishedAt":59,"focalPoint":16},"call-to-action.single",{"pagination":300},{"page":301,"pageSize":302},1,100,{},1784280395167]