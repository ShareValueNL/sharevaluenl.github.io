":47,"hash":48,"mime":28,"name":49,"path":16,"size":50,"width":51,"height":52},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_tafelvoetbal_a0b91d5c15.jpg","thumbnail_tafelvoetbal_a0b91d5c15","thumbnail_tafelvoetbal.jpg",6.14,245,96,"tafelvoetbal_a0b91d5c15",131.04,"https://incredible-beef-2a6059b946.media.strapiapp.com/tafelvoetbal_a0b91d5c15.jpg","strapi-provider-upload-strapi-cloud","2023-08-31T17:20:44.416Z","qlxm0rmq1ylkm26ekr4ml191","2026-01-05T12:38:34.018Z",[61,66],{"id":62,"title":16,"asideText":16,"underline":63,"centered":63,"blankAside":63,"aside":16,"content":64,"introductionText":16,"__component":65},134,false,"## Programma:\n17:30 uur: Inloop op ons kantoor\n\n18:00 uur: Gezellig pizza eten\n\nNa het eten: Voldoende tijd om het kantoor te ontdekken (lees: poolen, flipperen, Xboxen en tafelvoetballen)\n\n19:00 uur: Start presentatie\n\nNa presentatie: Ruimte voor het stellen van vragen, kennismaken en inschrijven\n\n \n\n21:00 uur: Einde van de Info-Avond\n\nBen jij erbij? Meld je dan aan middels het formulier bovenaan deze pagina! Je kunt natuurlijk ook alvast meer informatie lezen in onze vacature, of contact opnemen met Dana via mail of WhatsApp om je vragen te stellen.","global.pagesection",{"id":6,"title":67,"showBlankAside":16,"__component":68},"Deel deze pagina","global.social-sharing",[70],{"id":71,"title":72,"subTitle":73,"description":74,"shortDescription":75,"slug":76,"createdAt":77,"updatedAt":78,"publishedAt":79,"isCoreExpertise":80,"documentId":81,"image":82,"seo":101,"blocks":119,"midPageBlocks":159},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":83,"name":84,"alternativeText":16,"caption":16,"width":85,"height":86,"formats":87,"hash":96,"ext":89,"mime":92,"size":97,"url":98,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":99,"updatedAt":99,"documentId":100,"publishedAt":59,"focalPoint":16},16,"microsoft-365.png",282,130,{"thumbnail":88},{"ext":89,"url":90,"hash":91,"mime":92,"name":93,"path":16,"size":94,"width":51,"height":95},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":102,"metaTitle":103,"metaDescription":104,"structuredData":105,"metaImage":16,"metaSocial":118},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":106,"@type":107,"@context":108,"provider":109,"areaServed":113,"description":116,"serviceType":117},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":110,"name":111,"@type":112},"https://www.sharevalue.nl","ShareValue","Organization",{"name":114,"@type":115},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[120,128],{"id":121,"title":122,"aside":16,"postType":123,"limit":124,"expertise":125,"__component":127},166,"Lees meer over Microsoft 365","alle",3,[126],{"id":71,"title":72,"subTitle":73,"description":74,"shortDescription":75,"slug":76,"createdAt":77,"updatedAt":78,"publishedAt":79,"isCoreExpertise":80,"documentId":81},"strapi.related-kennisbank-list",{"id":129,"titleLeft":130,"callToActionTextLeft":131,"callToActionLinkUrlLeft":132,"titleRight":133,"callToActionTextRight":134,"callToActionLinkUrlRight":135,"iconUrlLeft":136,"iconUrlRight":149,"__component":158},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":137,"name":138,"alternativeText":16,"caption":16,"width":139,"height":140,"formats":16,"hash":141,"ext":142,"mime":143,"size":144,"url":145,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":146,"updatedAt":147,"documentId":148,"publishedAt":59,"focalPoint":16},6,"bulb.svg",71,70,"b