[{"data":1,"prerenderedAt":467},["ShallowReactive",2],{"collection-events--1394279905":3,"_apollo:default":466},{"data":4,"meta":462},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"eventStart":10,"location":11,"info":12,"createdAt":13,"updatedAt":14,"publishedAt":15,"eventTimes":16,"darkMode":17,"documentId":18,"imageUrl":19,"seo":17,"blocks":61,"expertises":80},10,"Online Deepdive 'n Drinks","Viva Connections en het IK-WIJ-ONS intranet","online-deepdive-n-drinks","2021-10-01T13:00:00.000Z","Online via Microsoft Teams","Deelname via het e-mailadres wat je opgeeft, check deze goed","2023-08-31T17:08:24.157Z","2024-01-17T15:24:04.186Z","2023-08-31T17:08:26.393Z","Start 15:00 uur",null,"uj54axzlj1yy6lj3mhdrwa5n",{"id":20,"name":21,"alternativeText":17,"caption":17,"width":22,"height":23,"formats":24,"hash":54,"ext":26,"mime":29,"size":55,"url":56,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":58,"updatedAt":58,"documentId":59,"publishedAt":60,"focalPoint":17},180,"ShareValue_NEXT_imagehero.jpg",1280,500,{"large":25,"small":34,"medium":40,"thumbnail":47},{"ext":26,"url":27,"hash":28,"mime":29,"name":30,"path":17,"size":31,"width":32,"height":33},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Share_Value_NEXT_imagehero_affd49466d.jpg","large_Share_Value_NEXT_imagehero_affd49466d","image/jpeg","large_ShareValue_NEXT_imagehero.jpg",36.76,1000,391,{"ext":26,"url":35,"hash":36,"mime":29,"name":37,"path":17,"size":38,"width":23,"height":39},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Share_Value_NEXT_imagehero_affd49466d.jpg","small_Share_Value_NEXT_imagehero_affd49466d","small_ShareValue_NEXT_imagehero.jpg",12.25,195,{"ext":26,"url":41,"hash":42,"mime":29,"name":43,"path":17,"size":44,"width":45,"height":46},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Share_Value_NEXT_imagehero_affd49466d.jpg","medium_Share_Value_NEXT_imagehero_affd49466d","medium_ShareValue_NEXT_imagehero.jpg",23.2,750,293,{"ext":26,"url":48,"hash":49,"mime":29,"name":50,"path":17,"size":51,"width":52,"height":53},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Share_Value_NEXT_imagehero_affd49466d.jpg","thumbnail_Share_Value_NEXT_imagehero_affd49466d","thumbnail_ShareValue_NEXT_imagehero.jpg",3.94,245,96,"Share_Value_NEXT_imagehero_affd49466d",50.76,"https://incredible-beef-2a6059b946.media.strapiapp.com/Share_Value_NEXT_imagehero_affd49466d.jpg","strapi-provider-upload-strapi-cloud","2023-08-31T14:22:00.585Z","jna8xynlhepmniri92flat9q","2026-01-05T12:38:34.018Z",[62,68,72,76],{"id":63,"title":17,"asideText":64,"underline":65,"centered":65,"blankAside":65,"aside":17,"content":66,"introductionText":17,"__component":67},126,"Inhoud sessie",false,"Eerst gaat Gerard in op Microsoft Viva, het nieuwe platform voor werknemerservaring dat kennis, onderwijs, resources en inzichten samenbrengt op een centrale plek.\n\n \n\nVervolgens laat Gerard zien hoe je met behulp van Viva Connections jouw SharePoint intranet kunt ontsluiten in Teams. Met deze koppeling maak je de bedrijfsinformatie voor je medewerkers nog makkelijker vindbaar. Hij demonstreert dit met het ‘IK – WIJ – ONS intranet’ van ShareValue.\n\nTen slotte sluiten we af met een gezellige online borrel, waarbij we elkaars ervaringen uitwisselen.\n\nDe sessie is bedoeld voor IT-managers en mensen in een vergelijkbare functie die hier graag meer over willen weten.","global.pagesection",{"id":69,"title":17,"asideText":70,"underline":65,"centered":65,"blankAside":65,"aside":17,"content":71,"introductionText":17,"__component":67},127,"Borrel","De borrel is altijd een hoog gewaardeerd onderdeel van onze Deepdive ‘n Drinks sessies. In een ongedwongen setting wisselen we dan met elkaar ervaringen uit onder het genot van een hapje en een drankje in onze bar. Omdat de sessie geheel online plaatsvindt, bieden wij alle deelnemers een leuk borrelpakket aan zodat we toch gezellig online kunnen napraten!\n\n \n\nIs het onderwerp van deze Deepdive interessant voor jou? En wil je ervaringen uitwisselen met anderen in een vergelijkbare functie? Meld je dan nu aan via het formulier bovenaan deze pagina!\n\n**Dit event is al geweest, aanmelden is niet meer mogelijk.**",{"id":73,"title":17,"asideText":74,"underline":65,"centered":65,"blankAside":65,"aside":17,"content":75,"introductionText":17,"__component":67},128,"Vragen?","\nHeb je vragen? Neem contact op met ShareValue.\n\nE-mail: [events@sharevalue.nl](mailto:events@sharevalue.nl)\n\nTelefoon: 0182-516 468\n\n \n\nHeb je een ander vraagstuk waarmee wij je kunnen helpen? Wij organiseren op verzoek ook sessies over andere onderwerpen. Welk onderwerp het ook is, [laat ons weten!](mailto:events@sharevalue.nl)",{"id":6,"title":77,"showBlankAside":78,"__component":79},"Deel deze pagina",true,"global.social-sharing",[81],{"id":82,"title":83,"subTitle":84,"description":85,"shortDescription":86,"slug":87,"createdAt":88,"updatedAt":89,"publishedAt":90,"isCoreExpertise":78,"documentId":91,"image":92,"seo":111,"blocks":129,"midPageBlocks":169},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z","ci9jcjkdq0gjpkaebdvdf08c",{"id":93,"name":94,"alternativeText":17,"caption":17,"width":95,"height":96,"formats":97,"hash":106,"ext":99,"mime":102,"size":107,"url":108,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":109,"updatedAt":109,"documentId":110,"publishedAt":60,"focalPoint":17},16,"microsoft-365.png",282,130,{"thumbnail":98},{"ext":99,"url":100,"hash":101,"mime":102,"name":103,"path":17,"size":104,"width":52,"height":105},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":112,"metaTitle":113,"metaDescription":114,"structuredData":115,"metaImage":17,"metaSocial":128},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":116,"@type":117,"@context":118,"provider":119,"areaServed":123,"description":126,"serviceType":127},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":120,"name":121,"@type":122},"https://www.sharevalue.nl","ShareValue","Organization",{"name":124,"@type":125},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[130,138],{"id":131,"title":132,"aside":17,"postType":133,"limit":134,"expertise":135,"__component":137},166,"Lees meer over Microsoft 365","alle",3,[136],{"id":82,"title":83,"subTitle":84,"description":85,"shortDescription":86,"slug":87,"createdAt":88,"updatedAt":89,"publishedAt":90,"isCoreExpertise":78,"documentId":91},"strapi.related-kennisbank-list",{"id":139,"titleLeft":140,"callToActionTextLeft":141,"callToActionLinkUrlLeft":142,"titleRight":143,"callToActionTextRight":144,"callToActionLinkUrlRight":145,"iconUrlLeft":146,"iconUrlRight":159,"__component":168},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":147,"name":148,"alternativeText":17,"caption":17,"width":149,"height":150,"formats":17,"hash":151,"ext":152,"mime":153,"size":154,"url":155,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":156,"updatedAt":157,"documentId":158,"publishedAt":60,"focalPoint":17},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":160,"name":161,"alternativeText":17,"caption":17,"width":150,"height":150,"formats":17,"hash":162,"ext":152,"mime":153,"size":163,"url":164,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":60,"focalPoint":17},8,"briefcase.svg","brie