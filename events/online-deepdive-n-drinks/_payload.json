e84a321990.jpg","small_trends_e84a321990","small_trends.jpg",59.76,{"ext":26,"url":268,"hash":269,"mime":29,"name":270,"path":17,"size":271,"width":45,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":26,"url":273,"hash":274,"mime":29,"name":275,"path":17,"size":276,"width":204,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"id":283,"title":284,"subTitle":285,"content":286,"callToActionText":17,"callToActionLink":17,"colorStyle":218,"showAsides":65,"imageUrl":287,"__component":211},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":288,"name":289,"alternativeText":17,"caption":17,"width":22,"height":179,"formats":290,"hash":311,"ext":26,"mime":29,"size":312,"url":313,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":314,"updatedAt":314,"documentId":315,"publishedAt":60,"focalPoint":17},785,"microsoft development.jpg",{"large":291,"small":296,"medium":301,"thumbnail":306},{"ext":26,"url":292,"hash":293,"mime":29,"name":294,"path":17,"size":295,"width":32,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":26,"url":297,"hash":298,"mime":29,"name":299,"path":17,"size":300,"width":23,"height":192},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":26,"url":302,"hash":303,"mime":29,"name":304,"path":17,"size":305,"width":45,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":26,"url":307,"hash":308,"mime":29,"name":309,"path":17,"size":310,"width":204,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":317,"title":318,"subTitle":319,"content":320,"callToActionText":321,"callToActionLink":142,"colorStyle":175,"showAsides":65,"imageUrl":322,"__component":211},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":323,"name":324,"alternativeText":17,"caption":17,"width":22,"height":179,"formats":325,"hash":346,"ext":26,"mime":29,"size":347,"url":348,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":349,"updatedAt":349,"documentId":350,"publishedAt":60,"focalPoint":17},786,"migratie.jpg",{"large":326,"small":331,"medium":336,"thumbnail":341},{"ext":26,"url":327,"hash":328,"mime":29,"name":329,"path":17,"size":330,"width":32,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":26,"url":332,"hash":333,"mime":29,"name":334,"path":17,"size":335,"width":23,"height":192},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":26,"url":337,"hash":338,"mime":29,"name":339,"path":17,"size":340,"width":45,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":26,"url":342,"hash":343,"mime":29,"name":344,"path":17,"size":345,"width":204,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":352,"title":353,"subTitle":354,"content":355,"callToActionText":17,"callToActionLink":17,"colorStyle":218,"showAsides":65,"imageUrl":356,"__component":211},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":357,"name":358,"alternativeText":17,"caption":17,"width":22,"height":179,"formats":359,"hash":380,"ext":26,"mime":29,"size":381,"url":382,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":383,"updatedAt":383,"documentId":384,"publishedAt":60,"focalPoint":17},787,"microsoft security.jpg",{"large":360,"small":365,"medium":370,"thumbnail":375},{"ext":26,"url":361,"hash":362,"mime":29,"name":363,"path":17,"size":364,"width":32,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":26,"url":366,"hash":367,"mime":29,"name":368,"path":17,"size":369,"width":23,"height":192},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":26,"url":371,"hash":372,"mime":29,"name":373,"path":17,"size":374,"width":45,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":26,"url":376,"hash":377,"mime":29,"name":378,"path":17,"size":379,"width":204,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":386,"title":387,"subTitle":388,"content":389,"callToActionText":390,"callToActionLink":391,"colorStyle":175,"showAsides":65,"imageUrl":392,"__component":211},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":393,"name":394,"alternativeText":17,"caption":17,"width":22,"height":179,"formats":395,"hash":416,"ext":26,"mime":29,"size":417,"url":418,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":419,"updatedAt":419,"documentId":420,"publishedAt":60,"focalPoint":17},788,"vergaderruimte.jpg",{"large":396,"small":401,"medium":406,"thumbnail":411},{"ext":26,"url":397,"hash":398,"mime":29,"name":399,"path":17,"size":400,"width":32,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":26,"url":402,"hash":403,"mime":29,"name":404,"path":17,"size":405,"width":23,"height":192},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":26,"url":407,"hash":408,"mime":29,"name":409,"path":17,"size":410,"width":45,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":26,"url":412,"hash":413,"mime":29,"name":414,"path":17,"size":415,"width":204,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":422,"title":423,"subTitle":424,"content":425,"callToActionText":17,"callToActionLink":17,"colorStyle":218,"showAsides":65,"imageUrl":426,"__component":211},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":427,"name":428,"alternativeText":17,"caption":17,"width":22,"height":179,"formats":429,"hash":450,"ext":26,"mime":29,"size":451,"url":452,"previewUrl":17,"provider":57,"provider_metadata":17,"createdAt":453,"updatedAt":453,"documentId":454,"publishedAt":60,"focalPoint":17},789,"teamwork.jpg",{"large":430,"small":435,"medium":440,"thumbnail":445},{"ext":26,"url":431,"hash":432,"mime":29,"name":433,"path":17,"size":434,"width":32,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":26,"url":436,"hash":437,"mime":29,"name":438,"path":17,"size":439,"width":23,"height":192},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":26,"url":441,"hash":442,"mime":29,"name":443,"path":17,"size":444,"width":45,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":26,"url":446,"hash":447,"mime":29,"name":448,"path":17,"size":449,"width":204,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredi