25,"alternativeText":16,"caption":16,"width":21,"height":160,"formats":226,"hash":247,"ext":25,"mime":28,"size":248,"url":249,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":250,"updatedAt":250,"documentId":251,"publishedAt":59},792,"security dotnet.jpg",{"large":227,"small":232,"medium":237,"thumbnail":242},{"ext":25,"url":228,"hash":229,"mime":28,"name":230,"path":16,"size":231,"width":31,"height":167},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_dotnet_a65d687baf.jpg","large_security_dotnet_a65d687baf","large_security dotnet.jpg",38.7,{"ext":25,"url":233,"hash":234,"mime":28,"name":235,"path":16,"size":236,"width":22,"height":173},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_dotnet_a65d687baf.jpg","small_security_dotnet_a65d687baf","small_security dotnet.jpg",13.37,{"ext":25,"url":238,"hash":239,"mime":28,"name":240,"path":16,"size":241,"width":44,"height":179},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_dotnet_a65d687baf.jpg","medium_security_dotnet_a65d687baf","medium_security dotnet.jpg",24.75,{"ext":25,"url":243,"hash":244,"mime":28,"name":245,"path":16,"size":246,"width":185,"height":186},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_dotnet_a65d687baf.jpg","thumbnail_security_dotnet_a65d687baf","thumbnail_security dotnet.jpg",4.63,"security_dotnet_a65d687baf",57.25,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_dotnet_a65d687baf.jpg","2024-08-09T08:36:56.895Z","srupv8bm7kvcgseu2efeadhk",{"__component":128,"id":129,"title":130,"callToActionText":131,"callToActionLinkUrl":132,"body":16,"imageUrl":253},{"id":135,"name":136,"alternativeText":16,"caption":16,"width":137,"height":138,"formats":16,"hash":139,"ext":140,"mime":141,"size":142,"url":143,"previewUrl":16,"provider":56,"provider_metadata":16,"createdAt":144,"updatedAt":145,"documentId":146,"publishedAt":59},[255,260,264,268,272],{"__component":256,"id":257,"title":16,"asideText":258,"underline":71,"centered":71,"blankAside":71,"aside":16,"content":259,"introductionText":16},"global.pagesection",109,"Het programma in het kort","## Programma:\n- 17:30-18:00 uur inloop\n- 18:00-19:00 uur eten\n- 19:00-21:00 uur twee .NET sessies:\n  - .NET MAUI (Multi-platform App UI) - One size fits all?\n  - Mocking Around with .NET Unit Tests\n- 21:00 uur borrel in de bar van ShareValue",{"__component":256,"id":261,"title":16,"asideText":262,"underline":71,"centered":71,"blankAside":71,"aside":16,"content":263,"introductionText":16},108,"De sessies","## Sessie 1: .NET MAUI (Multi-platform App UI) - One size fits all?\n### door Alex Hensen (Competence Lead .NET)\n \n\nSinds de release van .NET 7, afgelopen november, is .NET MAUI (Multi-platform App UI) beschikbaar voor het grote publiek. \nMaar wat is .NET MAUI nou precies, en misschien belangrijker, wat kan je er mee? Voor wie is het geschikt? \nIn deze sessie gaan we in op deze vraagstukken en duiken we in de wereld van cross-platform app development met .NET MAUI.\n\n## Sessie 2: Mocking Around with .NET Unit Tests\n### door Marco Kreeft (Competence Lead .NET)\n \n\nDeze geavanceerde sessie gaat dieper in op de wereld van unit test mocking in .NET. \nWe bestuderen geavanceerde technieken en methoden voor het maken van realistische mock objecten en het optimaliseren van onze tests. \nHet is bedoeld voor ontwikkelaars die al ervaring hebben met unit testing en op zoek naar slimmere manieren om hun code te mocken.",{"__component":256,"id":265,"title":16,"asideText":266,"underline":71,"centered":71,"blankAside":71,"aside":16,"content":267,"introductionText":16},110,"De details","- Wanneer: donderdag 23 maart 2023\n- Hoe laat: inloop 17:30 uur, start 18:00 uur\n- Inclusief vers gemaakte broodjes hamburger door onze chefkok Louis\n- Waar: kantoor van ShareValue, Kampenringweg 45A in Gouda",{"__component":256,"id":269,"title":16,"asideText":270,"underline":71,"centered":71,"blankAside":71,"aside":16,"content":271,"introductionText":16},111,"Aanmelden","## Aanmelden\nWil je erbij zijn? Meld je dan nu aan en geef in het aanmeldformulier aan of je mee wilt eten.\n\n**Dit event is al geweest, aanmelden is niet meer mogelijk.**\n\nHeb je vragen? Stel ze gerust via [events@sharevalue.nl](mailto:events@sharevalue.nl)",{"__component":273,"id":6,"title":274,"showBlankAside":275},"global.social-sharing","Deel deze pagina:",true,{"pagination":277},{"page":278,"pageSize":279},1,100,{},1782465836314]