[{"data":1,"prerenderedAt":379},["ShallowReactive",2],{"collection-aanpakken--1898649845":3,"_apollo:default":378},{"data":4,"meta":374},[5],{"id":6,"title":7,"subTitle":8,"description":9,"slug":10,"createdAt":11,"updatedAt":12,"publishedAt":13,"priority":9,"menuTitle":14,"documentId":15,"image":9,"seo":16,"blocks":34},2,"De ShareValue Migratiestraat","Grip op datamigraties in vier fases",null,"migratiestraat","2024-12-13T12:20:06.812Z","2025-04-25T07:57:50.422Z","2024-12-13T12:20:08.072Z","Migratiestraat","i8op2t0bwnoc0m62412a8fqv",{"id":17,"metaTitle":18,"metaDescription":19,"structuredData":20,"metaImage":9,"metaSocial":33},21,"Migratiestraat – Slim overstappen naar Microsoft 365","Een soepele migratie naar Microsoft 365, zonder gedoe. Wij begeleiden elke stap – van strategie tot oplevering.",{"url":21,"@type":22,"@context":23,"provider":24,"areaServed":28,"description":31,"serviceType":32},"https://www.sharevalue.nl/onze-aanpak/migratiestraat","Service","https://schema.org",{"url":25,"name":26,"@type":27},"https://www.sharevalue.nl","ShareValue","Organization",{"name":29,"@type":30},"Nederland","Country","De migratiestraat van ShareValue biedt een gestructureerde aanpak voor de overstap naar Microsoft 365. Wij begeleiden organisaties van intake tot implementatie, met aandacht voor techniek én gebruikers.","Microsoft 365 migratiebegeleiding",[],[35,81,87,130,171,205,240,243,296,342],{"id":36,"title":7,"subTitle":8,"callToActionText":9,"darkMode":37,"callToActionLink":9,"imageUrl":38,"__component":80},81,false,{"id":39,"name":40,"alternativeText":9,"caption":9,"width":41,"height":42,"formats":43,"hash":73,"ext":45,"mime":48,"size":74,"url":75,"previewUrl":9,"provider":76,"provider_metadata":9,"createdAt":77,"updatedAt":77,"documentId":78,"publishedAt":79,"focalPoint":9},901,"Migratiestraat header websitepagina.jpg",2560,1000,{"large":44,"small":52,"medium":59,"thumbnail":66},{"ext":45,"url":46,"hash":47,"mime":48,"name":49,"path":9,"size":50,"width":42,"height":51},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Migratiestraat_header_websitepagina_041264c676.jpg","large_Migratiestraat_header_websitepagina_041264c676","image/jpeg","large_Migratiestraat header websitepagina.jpg",107.5,391,{"ext":45,"url":53,"hash":54,"mime":48,"name":55,"path":9,"size":56,"width":57,"height":58},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Migratiestraat_header_websitepagina_041264c676.jpg","small_Migratiestraat_header_websitepagina_041264c676","small_Migratiestraat header websitepagina.jpg",26.63,500,195,{"ext":45,"url":60,"hash":61,"mime":48,"name":62,"path":9,"size":63,"width":64,"height":65},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Migratiestraat_header_websitepagina_041264c676.jpg","medium_Migratiestraat_header_websitepagina_041264c676","medium_Migratiestraat header websitepagina.jpg",59.8,750,293,{"ext":45,"url":67,"hash":68,"mime":48,"name":69,"path":9,"size":70,"width":71,"height":72},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Migratiestraat_header_websitepagina_041264c676.jpg","thumbnail_Migratiestraat_header_websitepagina_041264c676","thumbnail_Migratiestraat header websitepagina.jpg",6.96,245,96,"Migratiestraat_header_websitepagina_041264c676",575.83,"https://incredible-beef-2a6059b946.media.strapiapp.com/Migratiestraat_header_websitepagina_041264c676.jpg","strapi-provider-upload-strapi-cloud","2024-12-13T12:26:38.272Z","z4qq4zoo8w4hhzt8s42q70bz","2026-01-05T12:38:34.018Z","hero.primary",{"id":82,"title":83,"asideText":9,"underline":84,"centered":37,"blankAside":37,"aside":9,"content":85,"introductionText":9,"__component":86},1967,"Jouw gids voor succesvolle datamigraties",true,"Data migreren kan een complexe uitdaging zijn, maar wij maken het behapbaar. Of het nu gaat om het verplaatsen van netwerkschijven naar Microsoft 365, het overzetten van On-Premises SharePoint-sites naar SharePoint Online, of een tenant-to-tenant migratie. \nDe ShareValue Migratiestraat is geen standaard aanpak, maar een slimme, gestructureerde methode die is geboren uit jaren ervaring. Onze Migratiestraat is je navigatiesysteem door de complexe wereld van datamigratie in vier heldere fases.\nOnze consultants begeleiden je door het hele migratietraject. En geven je vooraf inzicht in de benodigde werkzaamheden en de duur van het traject, zodat je goed voorbereid bent.","global.pagesection",{"id":88,"title":89,"subTitle":90,"content":91,"callToActionText":9,"callToActionLink":9,"colorStyle":92,"showAsides":37,"imageUrl":93,"__component":129},51,"Fase 1: Fundering","Stevige basis, soepele start","De eerste stap is het leggen van een stevige fundering voor het migratieproject. Onze consultants analyseren de te migreren data, stellen een projectteam samen, en zorgen voor de benodigde bevoegdheden. We organiseren workshops en gesprekken met stakeholders en stellen een communicatieplan op. Zo zorgen we ervoor dat iedereen goed geïnformeerd is en dat het project soepel kan starten.","Sugar Glaze",{"id":94,"name":95,"alternativeText":9,"caption":9,"width":96,"height":97,"formats":98,"hash":123,"ext":45,"mime":48,"size":124,"url":125,"previewUrl":9,"provider":76,"provider_metadata":9,"createdAt":126,"updatedAt":127,"documentId":128,"publishedAt":79,"focalPoint":9},902,"Migratiestraat fase 1 1280x850.jpg",7730,5156,{"large":99,"small":105,"medium":111,"thumbnail":116},{"ext":45,"url":100,"hash":101,"mime":48,"name":102,"path":9,"size":103,"width":42,"height":104},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Migratiestraat_fase_1_1280x850_58c8f1174a.jpg","large_Migratiestraat_fase_1_1280x850_58c8f1174a","large_Migratiestraat fase 1 1280x850.jpg",43.33,667,{"ext":45,"url":106,"hash":107,"mime":48,"name":108,"path":9,"size":109,"width":57,"height":110},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Migratiestraat_fase_1_1280x850_58c8f1174a.jpg","small_Migratiestraat_fase_1_1280x850_58c8f1174a","small_Migratiestraat fase 1 1280x850.jpg",15.31,333,{"ext":45,"url":112,"hash":113,"mime":48,"name":114,"path":9,"size":115,"width":64,"height":57},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Migratiestraat_fase_1_1280x850_58c8f1174a.jpg","medium_Migratiestraat_fase_1_1280x850_58c8f1174a","medium_Migratiestraat fase 1 1280x850.jpg",27.78,{"ext":45,"url":117,"hash":118,"mime":48,"name":119,"path":9,"size":120,"width":121,"height":122},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Migratiestraat_fase_1_1280x850_58c8f1174a.jpg","thumbnail_Migratiestraat_fase_1_1280x850_58c8f1174a","thumbnail_Migratiestraat fase 1 1280x850.jpg",5.15,234,156,"Migratiestraat_fase_1_1280x850_58c8f1174a",3386.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/Migratiestraat_fase_1_1280x850_58c8f1174a.jpg","2024-12-13T12:26:45.746Z","2024-12-13T13:22:19.328Z","jnfilrt12024fra08m5xe8kx","global.alternating-page-section",{"id":131,"title":132,"subTitle":133,"content":134,"callToActionText":9,"callToActionLink":9,"colorStyle":135,"showAsides":37,"imageUrl":136,"__component":129},52,"Fase 2: Inventarisatie","Maatwerk is onze standaard","In deze fase bepalen we samen met jou de beste migratiemethode en de juiste tools. We kijken naar specifieke wensen, zoals het behoud van metadata en compliance met wet- en regelgeving. We bereiden de omgeving voor op de migratie, zorgen ervoor dat toegangsrechten op de juiste manier worden ingericht, en zetten automatiseringen en scripts op. Zo creëren we een solide basis voor een succesvolle migratie.","White",{"id":137,"name":138,"alternativeText":9,"caption":9,"width":139,"height":140,"formats":141,"hash":166,"ext":45,"mime":48,"size":167,"url":168,"previewUrl":9,"provider":76,"provider_metadata":9,"createdAt":169,"updatedAt":169,"documentId":170,"publishedAt":79,"focalPoint":9},898,"Migratiestraat fase 2 1280x850.jpg",1280,850,{"large":142,"small":148,"medium":154,"thumbnail":160},{"ext":45,"url":143,"hash":144,"mime":48,"name":145,"path":9,"size":146,"width":42,"height":147},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Migratiestraat_fase_2_1280x850_70fd6e8f9c.jpg","large_Migratiestraat_fase_2_1280x850_70fd6e8f9c","large_Migratiestraat fase 2 1280x850.jpg",56.34,664,{"ext":45,"url":149,"hash":150,"mime":48,"name":151,"path":9,"size":152,"width":57,"height":153},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Migratiestraat_fase_2_1280x850_70fd6e8f9c.jpg","small_Migratiestraat_fase_2_1280x850_70fd6e8f9c","small_Migratiestraat fase 2 1280x850.jpg",20.45,332,{"ext":45,"url":155,"hash":156,"mime":48,"name":157,"path":9,"size":158,"width":64,"height":159},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Migratiestraat_fase_2_1280x850_70fd6e8f9c.jpg","medium_Migratiestraat_fase_2_1280x850_70fd6e8f9c","medium_Migratiestraat fase 2 1280x850.jpg",36.84,498,{"ext":45,"url":161,"hash":162,"mime":48,"name":163,"path":9,"size":164,"width":165,"height":122},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Migratiestraat_fase_2_1280x850_70fd6e8f9c.jpg","thumbnail_Migratiestraat_fase_2_1280x850_70fd6e8f9c","thumbnail_Migratiestraat fase 2 1280x850.jpg",7.3,235,"Migratiestraat_fase_2_1280x850_70fd6e8f9c",81.02,"https://incredible-beef-2a6059b946.media.strapiapp.com/Migratiestraat_fase_2_1280x850_70fd6e8f9c.jpg","2024-12-13T12:26:35.072Z","ciim00qq9ujuvsn3cvikynoq",{"id":172,"title":173,"subTitle":174,"content":175,"callToActionText":9,"callToActionLink":9,"colorStyle":92,"showAsides":37,"imageUrl":176,"__component":129},53,"Fase 3: Migratie","EFFICIËNT, MET MINIMALE VERSTORING","Tijdens de migratie zelf zorgen onze consultants ervoor dat de data op de juiste manier tussen verschillende locaties wordt verplaatst. We stellen runbooks en blueprints op, houden rekening met de indeling van de data en zorgen dat alles op de juiste plek terechtkomt. Communicatie is hierin key: we zorgen ervoor dat alle medewerkers weten waar zij hun data kunnen vinden en wat zij van de veranderingen kunnen verwachten. We minimaliseren downtime waar mogelijk en bieden extra ondersteuning om een soepele overgang te waarborgen.",{"id":177,"name":178,"alternativeText":9,"caption":9,"width":139,"height":140,"formats":179,"hash":200,"ext":45,"mime":48,"size":201,"url":202,"previewUrl":9,"provider":76,"provider_metadata":9,"createdAt":203,"updatedAt":203,"documentId":204,"publishedAt":79,"focalPoint":9},900,"Migratiestraat fase 3 1280x850.jpg",{"large":180,"small":185,"medium":190,"thumbnail":195},{"ext":45,"url":181,"hash":182,"mime":48,"name":183,"path":9,"size":184,"width":42,"height":147},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","large_Migratiestraat_fase_3_1280x850_c05f5823ab","large_Migratiestraat fase 3 1280x850.jpg",176.78,{"ext":45,"url":186,"hash":187,"mime":48,"name":188,"path":9,"size":189,"width":57,"height":153},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","small_Migratiestraat_fase_3_1280x850_c05f5823ab","small_Migratiestraat fase 3 1280x850.jpg",45.63,{"ext":45,"url":191,"hash":192,"mime":48,"name":193,"path":9,"size":194,"width":64,"height":159},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","medium_Migratiestraat_fase_3_1280x850_c05f5823ab","medium_Migratiestraat fase 3 1280x850.jpg",102.18,{"ext":45,"url":196,"hash":197,"mime":48,"name":198,"path":9,"size":199,"width":165,"height":122},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","thumbnail_Migratiestraat_fase_3_1280x850_c05f5823ab","thumbnail_Migratiestraat fase 3 1280x850.jpg",10.34,"Migratiestraat_fase_3_1280x850_c05f5823ab",277.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","2024-12-13T12:26:36.878Z","izdsf62qfvfgs6yv82096gp8",{"id":206,"title":207,"subTitle":208,"content":209,"callToActionText":9,"callToActionLink":9,"colorStyle":210,"showAsides":37,"imageUrl":211,"__component":129},54,"Fase 4: Evaluatie & Projectafronding","EVALUEREN EN KENNISOVERDRACHT","Na de migratie sluiten we het project af met een grondige evaluatie. We zorgen voor gedetailleerde documentatie en evalueren het proces, zodat we eventuele verbeterpunten kunnen identificeren. Ook zorgen we voor kennisoverdracht naar jouw IT-afdeling, zodat zij optimaal met de nieuwe omgeving kunnen werken. Tot slot bieden we doorlopende support voor de nieuwe werkwijze.","Ivory",{"id":212,"name":213,"alternativeText":9,"caption":9,"width":139,"height":140,"formats":214,"hash":235,"ext":45,"mime":48,"size":236,"url":237,"previewUrl":9,"provider":76,"provider_metadata":9,"createdAt":238,"updatedAt":238,"documentId":239,"publishedAt":79,"focalPoint":9},899,"Migratiestraat fase 4 verkleind.jpg",{"large":215,"small":220,"medium":225,"thumbnail":230},{"ext":45,"url":216,"hash":217,"mime":48,"name":218,"path":9,"size":219,"width":42,"height":147},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Migratiestraat_fase_4_verkleind_b55f558400.jpg","large_Migratiestraat_fase_4_verkleind_b55f558400","large_Migratiestraat fase 4 verkleind.jpg",111,{"ext":45,"url":221,"hash":222,"mime":48,"name":223,"path":9,"size":224,"width":57,"height":153},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Migratiestraat_fase_4_verkleind_b55f558400.jpg","small_Migratiestraat_fase_4_verkleind_b55f558400","small_Migratiestraat fase 4 verkleind.jpg",34.47,{"ext":45,"url":226,"hash":227,"mime":48,"name":228,"path":9,"size":229,"width":64,"height":159},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Migratiestraat_fase_4_verkleind_b55f558400.jpg","medium_Migratiestraat_fase_4_verkleind_b55f558400","medium_Migratiestraat fase 4 verkleind.jpg",67.11,{"ext":45,"url":231,"hash":232,"mime":48,"name":233,"path":9,"size":234,"width":165,"height":122},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Migratiestraat_fase_4_verkleind_b55f558400.jpg","thumbnail_Migratiestraat_fase_4_verkleind_b55f558400","thumbnail_Migratiestraat fase 4 verkleind.jpg",10.7,"Migratiestraat_fase_4_verkleind_b55f558400",175.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/Migratiestraat_fase_4_verkleind_b55f558400.jpg","2024-12-13T12:26:35.621Z","wduqm9mjxis7d6nxbgopc6rr",{"id":241,"title":9,"asideText":9,"underline":37,"centered":37,"blankAside":37,"aside":9,"content":242,"introductionText":9,"__component":86},1968,"## Waarom kiezen voor de ShareValue Migratiestraat?\n\nOnze gestructureerde aanpak zorgt voor een soepele en transparante migratie, waarbij je altijd weet wat je kunt verwachten. Dankzij onze uitgebreide ervaring kunnen we migraties uitvoeren die voldoen aan jouw specifieke eisen, en zorgen we voor minimale verstoring van je bedrijfsvoering. We hebben al veel bedrijven geholpen met hun migratie, en we staan klaar om ook jou te ondersteunen.\nBen jij klaar voor een migratie en wil je weten wat wij voor jouw organisatie kunnen betekenen? Neem dan vrijblijvend contact ons op en bespreek de mogelijkheden.",{"id":6,"Title":244,"Description":245,"ConfirmationText":246,"ConfirmationSubtext":247,"DownloadImage":248,"DownloadableContent":285,"__component":295},"Lees de whitepaper 'Datamigratie in vier fases met voorbeelden uit de praktijk'","Benieuwd naar onze aanpak? Vraag onze whitepaper ‘Datamigratie in vier fases met voorbeelden uit de praktijk’ aan en krijg nog meer inzicht in hoe wij complexe migraties efficiënt aanpakken!","Bedankt voor je aanvraag!","Wij sturen zo spoedig mogelijk de whitepaper naar je e-mailadres.",{"id":249,"name":250,"alternativeText":9,"caption":9,"width":251,"height":252,"formats":253,"hash":280,"ext":255,"mime":258,"size":281,"url":282,"previewUrl":9,"provider":76,"provider_metadata":9,"createdAt":283,"updatedAt":283,"documentId":284,"publishedAt":79,"focalPoint":9},915,"CTA afb Whitepaper 