[{"data":1,"prerenderedAt":321},["ShallowReactive",2],{"onzeAanpakPage":3,"_apollo:default":320},{"data":4,"meta":319},{"id":5,"createdAt":6,"updatedAt":7,"publishedAt":8,"documentId":9,"seo":10,"blocks":29},1,"2024-12-13T12:18:12.729Z","2025-05-12T12:30:00.902Z","2024-12-13T12:18:36.450Z","ry20zx3ccnhf2ia3cnjnwfcn",{"id":11,"metaTitle":12,"metaDescription":13,"structuredData":14,"metaImage":27,"metaSocial":28},4,"Onze aanpak – Microsoft experts die écht passen","Wij vinden de juiste Microsoft consultant voor jouw vraag. Persoonlijk, doelgericht en duurzaam. Ontdek hoe wij dat aanpakken.",{"url":15,"@type":16,"@context":17,"provider":18,"areaServed":22,"description":25,"serviceType":26},"https://www.sharevalue.nl/onze-aanpak","Service","https://schema.org",{"url":19,"name":20,"@type":21},"https://www.sharevalue.nl","ShareValue","Organization",{"name":23,"@type":24},"Nederland","Country","Onze aanpak is persoonlijk, transparant en gericht op duurzame samenwerkingen tussen Microsoft specialisten en opdrachtgevers. Wij leveren consultants met expertise in Microsoft 365, Azure, Power Platform en Development.","Microsoft consultancy",null,[],[30,79,84,128,164,199,234,252,298],{"id":31,"title":32,"subTitle":33,"callToActionText":27,"darkMode":34,"callToActionLink":27,"imageUrl":35,"__component":78},79,"Onze aanpak","Slimme methodes, bewezen succes",false,{"id":36,"name":37,"alternativeText":27,"caption":27,"width":38,"height":39,"formats":40,"hash":71,"ext":42,"mime":45,"size":72,"url":73,"previewUrl":27,"provider":74,"provider_metadata":27,"createdAt":75,"updatedAt":75,"documentId":76,"publishedAt":77,"focalPoint":27},911,"Hoofdafb Onze aanpak.jpg",9428,5303,{"large":41,"small":50,"medium":57,"thumbnail":64},{"ext":42,"url":43,"hash":44,"mime":45,"name":46,"path":27,"size":47,"width":48,"height":49},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Hoofdafb_Onze_aanpak_9400c748ee.jpg","large_Hoofdafb_Onze_aanpak_9400c748ee","image/jpeg","large_Hoofdafb Onze aanpak.jpg",118.82,1000,562,{"ext":42,"url":51,"hash":52,"mime":45,"name":53,"path":27,"size":54,"width":55,"height":56},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Hoofdafb_Onze_aanpak_9400c748ee.jpg","small_Hoofdafb_Onze_aanpak_9400c748ee","small_Hoofdafb Onze aanpak.jpg",23.03,500,281,{"ext":42,"url":58,"hash":59,"mime":45,"name":60,"path":27,"size":61,"width":62,"height":63},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Hoofdafb_Onze_aanpak_9400c748ee.jpg","medium_Hoofdafb_Onze_aanpak_9400c748ee","medium_Hoofdafb Onze aanpak.jpg",58.39,750,421,{"ext":42,"url":65,"hash":66,"mime":45,"name":67,"path":27,"size":68,"width":69,"height":70},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Hoofdafb_Onze_aanpak_9400c748ee.jpg","thumbnail_Hoofdafb_Onze_aanpak_9400c748ee","thumbnail_Hoofdafb Onze aanpak.jpg",7.02,245,138,"Hoofdafb_Onze_aanpak_9400c748ee",7781.06,"https://incredible-beef-2a6059b946.media.strapiapp.com/Hoofdafb_Onze_aanpak_9400c748ee.jpg","strapi-provider-upload-strapi-cloud","2024-12-13T14:12:40.673Z","gyku2cvzq03fikquykdcg8s2","2026-01-05T12:38:34.018Z","hero.primary",{"id":80,"title":32,"asideText":27,"underline":34,"centered":34,"blankAside":34,"aside":81,"content":82,"introductionText":27,"__component":83},1971,"![Schaakstuk los.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Schaakstuk_los_41d043d733.png)","Bij ShareValue combineren we uitgebreide praktijkervaring met de beste methodes om IT-uitdagingen effectief en efficiënt aan te pakken. Door opdrachten uit te voeren bij honderden klanten in uiteenlopende sectoren, hebben onze experts waardevolle inzichten en werkwijzen ontwikkeld die zich keer op keer bewijzen in de praktijk.\nHoewel maatwerk altijd centraal staat in onze werkwijze, zijn er specifieke aanpakken die bijzonder succesvol en breed inzetbaar zijn gebleken. Deze bewezen werkwijzen hebben we verder geoptimaliseerd en gestructureerd, zodat ze helder, transparant en voorspelbaar zijn voor onze klanten.\nOntdek hieronder onze aanpakken, zoals de ShareValue Adoptiestraat, de ShareValue Migratiestraat en de NIS2-Modules. We blijven continu vernieuwen en uitbreiden, dus houd deze pagina in de gaten voor meer oplossingen van onze IT-experts.","global.pagesection",{"id":85,"title":86,"subTitle":27,"content":87,"callToActionText":88,"callToActionLink":89,"colorStyle":90,"showAsides":34,"imageUrl":91,"__component":127},75,"De Microsoft 365 Copilot-straat","Bij ShareValue begrijpen we dat de implementatie van nieuwe technologieën zoals Microsoft 365 Copilot een uitdaging kan zijn. Daarom hebben we de ShareValue M365 Copilot-straat ontwikkeld, een gestructureerde aanpak die je stap voor stap begeleidt bij de implementatie en adoptie van Copilot binnen jouw organisatie. Met deze methode zorgen we ervoor dat je Copilot op een passende en veilige manier implementeert, zodat je het maximale uit deze krachtige oplossing haalt.","Naar de Microsoft 365 Copilot-straat","/onze-aanpak/microsoft-365-copilot-straat","Sugar Glaze",{"id":92,"name":93,"alternativeText":27,"caption":27,"width":94,"height":95,"formats":96,"hash":122,"ext":42,"mime":45,"size":123,"url":124,"previewUrl":27,"provider":74,"provider_metadata":27,"createdAt":125,"updatedAt":125,"documentId":126,"publishedAt":77,"focalPoint":27},1082,"Afb Onze aanpakpagina M365 Copilot-straat.jpg",1280,850,{"large":97,"small":103,"medium":109,"thumbnail":115},{"ext":42,"url":98,"hash":99,"mime":45,"name":100,"path":27,"size":101,"width":48,"height":102},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489.jpg","large_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489","large_Afb Onze aanpakpagina M365 Copilot-straat.jpg",61.88,664,{"ext":42,"url":104,"hash":105,"mime":45,"name":106,"path":27,"size":107,"width":55,"height":108},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489.jpg","small_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489","small_Afb Onze aanpakpagina M365 Copilot-straat.jpg",21.89,332,{"ext":42,"url":110,"hash":111,"mime":45,"name":112,"path":27,"size":113,"width":62,"height":114},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489.jpg","medium_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489","medium_Afb Onze aanpakpagina M365 Copilot-straat.jpg",40.57,498,{"ext":42,"url":116,"hash":117,"mime":45,"name":118,"path":27,"size":119,"width":120,"height":121},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489.jpg","thumbnail_Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489","thumbnail_Afb Onze aanpakpagina M365 Copilot-straat.jpg",6.79,235,156,"Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489",86.35,"https://incredible-beef-2a6059b946.media.strapiapp.com/Afb_Onze_aanpakpagina_M365_Copilot_straat_f1231ee489.jpg","2025-05-12T12:29:21.071Z","elv5eblkthixtzardu4suoui","global.alternating-page-section",{"id":129,"title":130,"subTitle":27,"content":131,"callToActionText":132,"callToActionLink":133,"colorStyle":134,"showAsides":34,"imageUrl":135,"__component":127},61,"NIS2-Modules","Wil je weten in hoeverre jouw organisatie voldoet aan de NIS2-richtlijn of hulp bij het compliant maken ervan? Wij bieden een flexibele en modulaire aanpak. Kies de bouwstenen die passen bij jouw situatie, van een enkele module tot een uitgebreide combinatie.\nLees meer over onze modules: Analysepakket, Inzicht & Advies, Security Uitrol Pakket, en Training & Awareness. Elke module is los af te nemen of te combineren tot een compleet pakket op maat. Samen zorgen we voor een toegankelijke aanpak die jouw organisatie voorbereid op de toekomst. ","Lees meer over de NIS2-Modules","/onze-aanpak/nis2-modules","White",{"id":136,"name":137,"alternativeText":27,"caption":27,"width":94,"height":95,"formats":138,"hash":159,"ext":42,"mime":45,"size":160,"url":161,"previewUrl":27,"provider":74,"provider_metadata":27,"createdAt":162,"updatedAt":162,"documentId":163,"publishedAt":77,"focalPoint":27},913,"Afb NIS2.jpg",{"large":139,"small":144,"medium":149,"thumbnail":154},{"ext":42,"url":140,"hash":141,"mime":45,"name":142,"path":27,"size":143,"width":48,"height":102},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Afb_NIS_2_1b42b81b1b.jpg","large_Afb_NIS_2_1b42b81b1b","large_Afb NIS2.jpg",52.83,{"ext":42,"url":145,"hash":146,"mime":45,"name":147,"path":27,"size":148,"width":55,"height":108},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Afb_NIS_2_1b42b81b1b.jpg","small_Afb_NIS_2_1b42b81b1b","small_Afb NIS2.jpg",20.32,{"ext":42,"url":150,"hash":151,"mime":45,"name":152,"path":27,"size":153,"width":62,"height":114},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Afb_NIS_2_1b42b81b1b.jpg","medium_Afb_NIS_2_1b42b81b1b","medium_Afb NIS2.jpg",35.53,{"ext":42,"url":155,"hash":156,"mime":45,"name":157,"path":27,"size":158,"width":120,"height":121},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Afb_NIS_2_1b42b81b1b.jpg","thumbnail_Afb_NIS_2_1b42b81b1b","thumbnail_Afb NIS2.jpg",7.48,"Afb_NIS_2_1b42b81b1b",73.58,"https://incredible-beef-2a6059b946.media.strapiapp.com/Afb_NIS_2_1b42b81b1b.jpg","2024-12-13T14:27:47.036Z","j6n6cx9pnwj6h6o55blbk0t2",{"id":165,"title":166,"subTitle":27,"content":167,"callToActionText":168,"callToActionLink":169,"colorStyle":90,"showAsides":34,"imageUrl":170,"__component":127},60,"De ShareValue Migratiestraat","Het migreren van data is vaak een uitdagend proces, maar wij zorgen ervoor dat het overzichtelijk en haalbaar blijft. Of je nu netwerkschijven wilt verplaatsen naar Microsoft 365, On-Premises SharePoint-sites wilt overzetten naar SharePoint Online, of een tenant-to-tenant migratie wilt uitvoeren.\n\nMet de ShareValue Migratiestraat bieden we geen standaard oplossing, maar een doordachte en gestructureerde aanpak die gebaseerd is op jarenlange ervaring. Deze methode begeleidt je in vier duidelijke stappen door het complexe landschap van datamigratie. Lees meer over de fases Fundering, Inventarisatie, Migratie en Evaluatie & Projectafronding.","Naar de ShareValue Migratiestraat","/onze-aanpak/migratiestraat",{"id":171,"name":172,"alternativeText":27,"caption":27,"width":94,"height":95,"formats":173,"hash":194,"ext":42,"mime":45,"size":195,"url":196,"previewUrl":27,"provider":74,"provider_metadata":27,"createdAt":197,"updatedAt":197,"documentId":198,"publishedAt":77,"focalPoint":27},900,"Migratiestraat fase 3 1280x850.jpg",{"large":174,"small":179,"medium":184,"thumbnail":189},{"ext":42,"url":175,"hash":176,"mime":45,"name":177,"path":27,"size":178,"width":48,"height":102},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","large_Migratiestraat_fase_3_1280x850_c05f5823ab","large_Migratiestraat fase 3 1280x850.jpg",176.78,{"ext":42,"url":180,"hash":181,"mime":45,"name":182,"path":27,"size":183,"width":55,"height":108},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","small_Migratiestraat_fase_3_1280x850_c05f5823ab","small_Migratiestraat fase 3 1280x850.jpg",45.63,{"ext":42,"url":185,"hash":186,"mime":45,"name":187,"path":27,"size":188,"width":62,"height":114},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","medium_Migratiestraat_fase_3_1280x850_c05f5823ab","medium_Migratiestraat fase 3 1280x850.jpg",102.18,{"ext":42,"url":190,"hash":191,"mime":45,"name":192,"path":27,"size":193,"width":120,"height":121},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Migratiestraat_fase_3_1280x850_c05f5823ab.jpg","thumbnail_Migratiestraat_fase_3_1280x850_c05f5823ab","thumbnail_Migratiestraat fase 3 1280x850.jpg",10.34,"Migratiestraat_fase_3_1280x850_c05f5823ab",277.1,"https://incredi