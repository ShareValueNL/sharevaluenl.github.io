bd8d2",91.91,"https://incredible-beef-2a6059b946.media.strapiapp.com/Over_ons_hoofdfoto_4dbdebd8d2.jpg","strapi-provider-upload-strapi-cloud","2023-11-01T11:42:24.618Z","2026-06-01T13:08:55.384Z","t9twq5okngt773gko3mrx8sw","2026-01-05T12:38:34.018Z",{"__component":61,"id":62,"title":63,"asideText":64,"underline":65,"centered":16,"blankAside":16,"aside":66,"content":67,"introductionText":68},"global.pagesection",32," ShareValue, de standaard voorbij","over ons",true,"","Onze consultants, developers, engineers en architecten zijn ondernemend, communicatief en altijd goed op de hoogte. Wij investeren namelijk in onze experts met opleidingen, trainingen en certificeringen. Zo wonen zij zowel nationaal als internationaal conferenties bij en komen we regelmatig bij elkaar voor interne kennisdeling tijdens onze LevelUp-sessies. Zo blijven wij up-to-date met de laatste technieken en zijn wij in staat de beste oplossingen voor de klant te bieden. En niet alleen op technisch vlak, maar ook qua bedrijfscultuur. We kennen onze medewerkers goed en zetten altijd in op de perfecte match tussen expert en opdracht.\n\nWij gaan in de samenwerking de standaard voorbij.\n","Wij weten liever van een aantal expertises alles, dan van alles een beetje. Daarom kiezen we bij ShareValue voor een focus op een aantal specifieke expertises, namelijk: Azure, Microsoft 365, Power Platform, .NET en Front-End.",{"__component":70,"id":71,"title":72,"howWeWorkItems":73},"global.how-we-work",3,"Zo werkt ShareValue",[74,91,105,118,131,142],{"id":75,"title":76,"content":77,"imageUrl":78},7,"Experts","Onze experts weten alles van Azure, Microsoft 365, Power Platform, .NET en Front-End.",{"id":79,"name":80,"alternativeText":15,"caption":15,"width":81,"height":82,"formats":15,"hash":83,"ext":84,"mime":85,"size":86,"url":87,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":88,"updatedAt":89,"documentId":90,"publishedAt":59},811,"icoon experts.svg",77,78,"icoon_experts_be70a74c59",".svg","image/svg+xml",20.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/icoon_experts_be70a74c59.svg","2024-09-13T13:12:59.420Z","2024-09-16T10:00:55.418Z","rx5hd6f88yj11rtt6j5o5czf",{"id":92,"title":93,"content":94,"imageUrl":95},8,"Eigen mensen","Wij kennen onze mensen goed. Hierdoor zorgen we voor een goede match tussen medewerker en opdracht.",{"id":75,"name":96,"alternativeText":15,"caption":15,"width":97,"height":98,"formats":15,"hash":99,"ext":84,"mime":85,"size":100,"url":101,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":102,"updatedAt":103,"documentId":104,"publishedAt":59},"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":106,"title":107,"content":108,"imageUrl":109},9,"Hoog kennisniveau","Wij investeren in de kennis van onze experts met opleidingen, certificeringen en conferenties.",{"id":110,"name":111,"alternativeText":15,"caption":15,"width":112,"height":98,"formats":15,"hash":113,"ext":84,"mime":85,"size":114,"url":115,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":116,"updatedAt":116,"documentId":117,"publishedAt":59},11,"knowledge.svg",48,"knowledge_b6478948aa",2.46,"https://incredible-beef-2a6059b946.media.strapiapp.com/knowledge_b6478948aa.svg","2023-08-17T08:31:37.042Z","iq8irfmrh98mir861cy1nnw2",{"id":119,"title":120,"content":121,"imageUrl":122},10,"Flexibel","Wat de vraag of aanpassing ook is, wij schakelen snel en efficient.",{"id":13,"name":123,"alternativeText":15,"caption":15,"width":124,"height":125,"formats":15,"hash":126,"ext":84,"mime":85,"size":127,"url":128,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":129,"updatedAt":129,"documentId":130,"publishedAt":59},"flexible.svg",106,56,"flexible_90360361fe",4.42,"https://incredible-beef-2a6059b946.media.strapiapp.com/flexible_90360361fe.svg","2023-08-17T08:31:36.982Z","emvgdlady21979rwdt04z8ip",{"id":110,"title":132,"content":133,"imageUrl":134},"Ondernemend","Achterover leunen en afwachten is niet onze stijl. Onze experts denken graag proactief mee met de opdrachtgever.",{"id":106,"name":135,"alternativeText":15,"caption":15,"width":136,"height":125,"formats":15,"hash":137,"ext":84,"mime":85,"size":138,"url":139,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":140,"updatedAt":140,"documentId":141,"publishedAt":59},"venturous.svg",79,"venturous_00d728d2b6",3.91,"https://incredible-beef-2a6059b946.media.strapiapp.com/venturous_00d728d2b6.svg","2023-08-17T08:31:37.041Z","x5csycvtvfb5qretr2oftwg6",{"id":143,"title":144,"content":145,"imageUrl":146},12,"Communicatief","Persoonlijk contact is ons kenmerk. Contact met de opdrachtgever en met de medewerkers staat centraal.",{"id":119,"name":147,"alternativeText":15,"caption":15,"width":148,"height":125,"formats":15,"hash":149,"ext":84,"mime":85,"size":150,"url":151,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":116,"updatedAt":116,"documentId":152,"publishedAt":59},"communication.svg",62,"communication_9ec4002407",3.81,"https://incredible-beef-2a6059b946.media.strapiapp.com/communication_9ec4002407.svg","gax61s1qfs7yapfyw8z6x4g6",{"__component":154,"id":155,"title":156,"text":157,"darkMode":65,"customerItems":158},"global.customers",4,"Onze opdrachtgevers","Onze consultants, developers, engineers en architecten werken verspreid door het hele land bij opdrachtgevers in alle denkbare branches. Op zowel kortdurende als langdurende opdrachten. Wij werken niet alleen voor grote organisaties of A-merken, ook voor het MKB kunnen wij waardevolle experts inzetten om de bedrijfsprocessen te optimaliseren.",[159,228,295,362,406,473,527,584,653],{"id":119,"title":160,"linkUrl":15,"imageUrl":161,"imageUrlDark":199},"DBF",{"id":162,"name":163,"alternativeText":15,"caption":15,"width":164,"height":165,"formats":166,"hash":194,"ext":168,"mime":171,"size":195,"url":196,"previewUrl