_Silvia.jpg",4.25,"Silvia_4ea4c01654",1145.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Silvia_4ea4c01654.jpg","2024-04-22T13:06:32.514Z","y8jqe7re37t3wknnwdqatzmb",{"id":407,"title":844,"shortContent":845,"emailLink":846,"personName":847,"personTitle":848,"personBio":849,"subtitle":15,"phone":15,"emailButtonLabel":15,"phoneButtonLabel":15,"personImageUrl":850},"Meer weten? Evan weet er alles van.","Heb je een vraag? Stuur dan een e-mail aan Evan en hij neemt zo snel mogelijk contact met je op.","e.zomerdijk@sharevalue.nl","Evan","Business Developer","Evan loopt de hele dag met de telefoon aan zijn oor. Als pro-actieve New Business Developer helpt hij op een dag veel mensen.",{"id":851,"name":852,"alternativeText":15,"caption":15,"width":853,"height":854,"formats":855,"hash":875,"ext":24,"mime":27,"size":876,"url":877,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":878,"updatedAt":878,"documentId":879,"publishedAt":59},699,"Evan.jpg",3305,4407,{"large":856,"small":861,"medium":865,"thumbnail":870},{"ext":24,"url":857,"hash":858,"mime":27,"name":859,"path":15,"size":860,"width":43,"height":30},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Evan_9b2c6943ad.jpg","large_Evan_9b2c6943ad","large_Evan.jpg",50.1,{"ext":24,"url":862,"hash":863,"mime":27,"name":864,"path":15,"size":516,"width":788,"height":21},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Evan_9b2c6943ad.jpg","small_Evan_9b2c6943ad","small_Evan.jpg",{"ext":24,"url":866,"hash":867,"mime":27,"name":868,"path":15,"size":869,"width":598,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Evan_9b2c6943ad.jpg","medium_Evan_9b2c6943ad","medium_Evan.jpg",27.56,{"ext":24,"url":871,"hash":872,"mime":27,"name":873,"path":15,"size":874,"width":260,"height":193},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Evan_9b2c6943ad.jpg","thumbnail_Evan_9b2c6943ad","thumbnail_Evan.jpg",2.39,"Evan_9b2c6943ad",778.25,"https://incredible-beef-2a6059b946.media.strapiapp.com/Evan_9b2c6943ad.jpg","2024-04-22T13:06:45.516Z","cz29n5ywa4e278ci6ir255b6",{"__component":881,"id":71,"quotes":882},"global.quotes",[883,889,895,901],{"id":884,"title":885,"content":886,"customerTitle":887,"customerName":888,"customerCompany":475},38,"De developers van ShareValue hebben een goede werkhouding en zijn echte specialisten op hun vakgebied","De developers van ShareValue hebben een goede werkhouding en zijn echte specialisten op hun vakgebied. Ze hebben niet alleen de juiste papieren, maar houden ook hun vaardigheden bij. De één heeft meer ervaring dan de ander, maar ze begrijpen allemaal onze vraagstukken en leveren snel.","Directeur","Ernst-Jan Heuseveldt",{"id":890,"title":891,"content":892,"customerTitle":887,"customerName":893,"customerCompany":894},40,"ShareValue vindt altijd de juiste man die matcht met de behoefte","Dbf en ShareValue kennen elkaar al vele jaren. ShareValue is in al die jaren altijd in staat geweest de juiste man te vinden die matcht met de behoefte van dbf op dat moment. Als het niet uit de eigen organisatie lukte, dan werd er verder gezocht in het brede netwerk wat ze inmiddels hebben.","Jasper Kruter","dbf",{"id":585,"title":896,"content":897,"customerTitle":898,"customerName":899,"customerCompany":900},"Bij ShareValue haal je altijd de juiste mensen in huis","Bij Carante Groep zoeken we altijd samenwerkingspartners, geen leveranciers. In ShareValue hebben we zo’n partner gevonden. Op het gebied van SharePoint, Nintex en projectleiding zetten we de deskundigen van ShareValue graag in. Je kunt erop vertrouwen dat je de juiste mensen in huis haalt om de afgesproken werkzaamheden uit te voeren. ","Hoofd ICT","Jerry van Rekom","Carante Groep",{"id":902,"title":903,"content":904,"customerTitle":15,"customerName":15,"customerCompany":905},20,"Zeer fijne partner om mee samen te werken","Zeer fijne partner om mee samen te werken. Open en transparant naar ons toe en altijd bereid om te helpen en mee te denken!","Een grote pensioenorganisatie",{"__component":907,"id":155,"title":908,"content":909,"images":910},"global.partner","Een betrouwbare partner","ShareValue is Microsoft Solution Partner en SNA-gecertificeerd. Het SNA-keurmerk wordt al jaren aan ShareValue toegekend. Dit keurmerk is ontwikkeld om de risico’s te beperken omtrent keten- en inlenersaansprakelijkheid. Tweemaal per jaar worden wij door een geaccrediteerde inspectie-instelling gecontroleerd, met toekenning van het certificaat als gevolg.\nShareValue is EPOS Platinum Partner. EPOS is producent van hoogwaardige audio- en video-oplossingen voor vergaderingen en samenwerkingen.",[911,927,936],{"id":155,"name":912,"alternativeText":15,"caption":15,"width":913,"height":914,"formats":915,"hash":922,"ext":168,"mime":171,"size":923,"url":924,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":925,"updatedAt":925,"documentId":926,"publishedAt":59},"Logo_MS_Solution_Partner_PNG.png",493,224,{"thumbnail":916},{"ext":168,"url":917,"hash":918,"mime":171,"name":919,"path":15,"size":920,"width":50,"height":921},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_MS_Solution_Partner_PNG_21fa5d8224.png","thumbnail_Logo_MS_Solution_Partner_PNG_21fa5d8224","thumbnail_Logo_MS_Solution_Partner_PNG.png",10.62,111,"Logo_MS_Solution_Partner_PNG_21fa5d8224",4.94,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_MS_Solution_Partner_PNG_21fa5d8224.png","2023-08-17T08:27:03.163Z","hy0vwbytlmn2ronrstha7uy1",{"id":71,"name":928,"alternativeText":15,"caption":15,"width":929,"height":930,"formats":15,"hash":931,"ext":84,"mime":85,"size":932,"url":933,"previewUrl":15,"provider":55,"provider_metadata":15,"createdAt":934,"updatedAt":934,"documentId":935,"publishedAt":59},"stichtingNormeringArbeid.svg",100,90,"stichting_Normering_Arbeid_69674de7a9",59.14,"https://incredible-beef-2a6059b946.media.strapiapp.com/stichting_Normering_Arbeid_69674de7a9.svg","2023-08-17T08:27:03.044Z","r0v5u