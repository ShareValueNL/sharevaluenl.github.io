[{"data":1,"prerenderedAt":431},["ShallowReactive",2],{"azureEngineerBootcamp":3,"_apollo:default":430},{"data":4,"meta":429},{"id":5,"createdAt":6,"updatedAt":7,"publishedAt":8,"documentId":9,"blocks":10,"seo":22},1,"2024-02-23T13:17:27.882Z","2024-08-23T07:23:46.471Z","2024-08-23T07:23:46.385Z","b547xez1s51yy1ukcib8sdgf",[11,63,67,86,89,111,115,228,330,354,400],{"__component":12,"id":13,"title":14,"subTitle":15,"callToActionText":16,"darkMode":17,"callToActionLink":18,"imageUrl":19},"hero.primary",61,"Volg onze Azure Engineer BootCamp","en word de expert die je wil zijn","Neem voor meer informatie contact op met Dana",false,"mailto:d.vandertouw@sharevalue.nl",{"id":20,"name":21,"alternativeText":22,"caption":22,"width":23,"height":24,"formats":25,"hash":56,"ext":27,"mime":30,"size":57,"url":58,"previewUrl":22,"provider":59,"provider_metadata":22,"createdAt":60,"updatedAt":60,"documentId":61,"publishedAt":62},623,"Huiskamer bank header 3.jpg",null,3840,1500,{"large":26,"small":35,"medium":42,"thumbnail":49},{"ext":27,"url":28,"hash":29,"mime":30,"name":31,"path":22,"size":32,"width":33,"height":34},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Huiskamer_bank_header_3_f2a34362b9.jpg","large_Huiskamer_bank_header_3_f2a34362b9","image/jpeg","large_Huiskamer bank header 3.jpg",76.15,1000,391,{"ext":27,"url":36,"hash":37,"mime":30,"name":38,"path":22,"size":39,"width":40,"height":41},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Huiskamer_bank_header_3_f2a34362b9.jpg","small_Huiskamer_bank_header_3_f2a34362b9","small_Huiskamer bank header 3.jpg",24.45,500,195,{"ext":27,"url":43,"hash":44,"mime":30,"name":45,"path":22,"size":46,"width":47,"height":48},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Huiskamer_bank_header_3_f2a34362b9.jpg","medium_Huiskamer_bank_header_3_f2a34362b9","medium_Huiskamer bank header 3.jpg",46.64,750,293,{"ext":27,"url":50,"hash":51,"mime":30,"name":52,"path":22,"size":53,"width":54,"height":55},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Huiskamer_bank_header_3_f2a34362b9.jpg","thumbnail_Huiskamer_bank_header_3_f2a34362b9","thumbnail_Huiskamer bank header 3.jpg",7.43,245,95,"Huiskamer_bank_header_3_f2a34362b9",627.84,"https://incredible-beef-2a6059b946.media.strapiapp.com/Huiskamer_bank_header_3_f2a34362b9.jpg","strapi-provider-upload-strapi-cloud","2024-04-04T11:58:52.845Z","ewm7ikitaz718qsczuofgxlj","2026-01-05T12:38:34.018Z",{"__component":64,"id":65,"title":22,"asideText":22,"underline":17,"centered":17,"blankAside":17,"aside":22,"content":66,"introductionText":22},"global.pagesection",1819,"Ben jij klaar voor een uitdagende start van je carrière als Azure Engineer? Grijp dan nu je kans om deel te nemen aan onze intensieve en leerzame Azure Engineer BootCamp. Na een zorgvuldige voorselectie bieden wij slechts twee toppers de unieke kans om deel te nemen aan dit programma, dus wees er snel bij!\n\n \n\n### Wat houdt de Azure Engineer BootCamp in?\n\n- Duur: 6 weken \n- Locatie: Kantoor in Gouda en bij inspirerende opdrachtgevers \n- Startdatum: 01 september 2024 \n\n \n\n### Programma\n\nDe eerste 6 weken behaal je onder begeleiding van Microsoft Certified Trainers wekelijks een certificaat. Je vergroot je Azure-kennis én krijgt daar ook bewijs van! Hierna ga je 40 uur per week aan de slag bij een van onze opdrachtgevers, om de theoretische kennis in de praktijk te brengen.\n\n![timeline bootcamp.png](https://incredible-beef-2a6059b946.media.strapiapp.com/timeline_bootcamp_ed239110a3.png)\n\nNa deze basis behaal je de AZ-104. Vervolgcertificeringen zijn afhankelijk van jouw interesse en ambitie. Of je nu kiest voor Security, Network, Hybrid of DevOps, jij bepaalt je eigen stip aan de horizon en wij helpen je graag op weg. \n\nBen je al in het bezit van 1 of meer certificeringen bij de start van de BootCamp? Dan wordt er samen met jou gekeken naar een aangepast en op maat gemaakt programma. ",{"__component":68,"id":69,"title":70,"callToActionText":71,"callToActionLinkUrl":72,"body":22,"imageUrl":73},"call-to-action.single",96,"Leer van onze experts","Lees onze Azure-blogs","https://www.sharevalue.nl/kennisbank/blogs/azure/",{"id":74,"name":75,"alternativeText":22,"caption":22,"width":76,"height":77,"formats":22,"hash":78,"ext":79,"mime":80,"size":81,"url":82,"previewUrl":22,"provider":59,"provider_metadata":22,"createdAt":83,"updatedAt":84,"documentId":85,"publishedAt":62},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"__component":64,"id":87,"title":22,"asideText":22,"underline":17,"centered":17,"blankAside":17,"aside":22,"content":88,"introductionText":22},1820,"Uiteraard word je tijdens de BootCamp begeleid. Naast de trainingen door onder andere Certified Trainers, krijg je persoonlijke begeleiding van onze People Manager **Esra**, waarbij ze jou blijft motiveren, uitdagen en ondersteunen om de BootCamp met succes af te ronden. Jouw ambitie is hierbij een belangrijk uitgangspunt.\n\nDe inhoudelijke begeleiding krijg je van onze expert **Gert**. Samen zorgen jullie ervoor dat je je doelen haalt en leert wat je wil leren.\n\nVanaf je eerste dag ben je lid van ons Azure-team. Hiervan is **Barry** de zogeheten Competence Lead. Hij zorgt ervoor dat het team altijd up-to-date is van de laatste technieken, maar ook voor de gezelligheid onderling en de sparringsmomenten.",{"__component":90,"id":91,"quotes":92},"global.quotes",46,[93,99,105],{"id":94,"title":95,"content":96,"customerTitle":97,"customerName":98,"customerCompany":22},31,"IK HEB FIJNE SPARRINGSPARTNERS GEVONDEN IN MIJN COLLEGA’S","Ik vind alles leuk. Toen ik binnenkwam bij ShareValue wist ik vooral veel over Microsoft 365, maar ik wilde graag ook groeien in de wereld van Azure. En die kans krijg ik hier! Ik heb fijne sparringspartners gevonden in mijn collega’s en de Competence Leads. Ook de verschillende kennissessies zorgen ervoor dat ik goed op de hoogte blijf van alle laatste ontwikkelingen. ","Consultant","Manuel",{"id":100,"title":101,"content":102,"customerTitle":103,"customerName":104,"customerCompany":22},32,"HET MAAKT NIET UIT HOE GROOT HET BEDRIJF IS, ELK BEDRIJF HEEFT ZIJN EIGEN UITDAGINGEN EN IK WERK MET VEEL PLEZIER AAN DE OPLOSSING","Alles komt aan bod bij ShareValue. In de afgelopen 8 jaar waren mijn opdrachten heel divers, van werken bij de NS aan Azure beheer, Azure migratie projecten en Azure Kubernetes Services diensten, tot een interessante opdracht bij Stichting Inlichtingenbureau (SIB), waar ik samen met een team een nieuwe Azure platform aan het inrichten ben volgens het \"Microsoft Cloud Foundation Framework\". ","Engineer & architect","Makele",{"id":106,"title":107,"content":108,"customerTitle":109,"customerName":110,"customerCompany":22},33,"HET IS EEN FEEST OM ME TE KUNNEN FOCUSSEN","Werken bij ShareValue is een ongelooflijke reis. Het heeft me in contact gebracht met enkele van de scherpste geesten die er zijn, en samen creëren we Microsoft Azure-oplossingen die echt iets betekenen voor bedrijven.","Engineer & Architect","Gert",{"__component":64,"id":112,"title":113,"asideText":22,"underline":17,"centered":17,"blankAside":17,"aside":22,"content":114,"introductionText":22},1821,"Concreet: wat bieden we je en wat vragen we van je?","Een intensieve periode waarin je wordt klaargestoomd voor het werken in de wereld van Azure. Dat is in het kort deze Azure Engineer BootCamp. We begrijpen dat je graag concreet wil weten wat we je bieden en wat we van je verwachten. Dit zetten we dan ook graag even voor je op een rij:\n\n### Wat we je bieden:\n- **Focus**: Vanaf dag 1 ligt de focus op Azure \n- **Begeleiding**: door Microsoft Certified Trainers, Azure Engineers en Architecten. \n- **6 Certificeringen**: Wekelijkse certificeringen onder begeleiding van o.a. Microsoft Certified Trainers, Azure Engineers en Azure Architecten \n- **Praktijkervaring**: Fulltime bij één van onze opdrachtgevers aan de slag om de opgedane kennis direct toe te passen \n- **Boost voor je carrière**: Een kans om jouw Azure carrière een vliegende start te geven \n- **Specialisatie binnen Azure**: Ná de Azure basis kies je zelf de specialisatie binnen Azure \n- **Part of the team**: Je bent vanaf dag 1 deel van ons Azure Team \n- **Mooi meegenomen**: Een salaris dat na elk behaald certificaat wordt verhoogd. Een vast contract en een auto van de zaak. \n\n### Wat we van je vragen: \n\n- Jij hebt een passie voor Cloudtechnologie en weet dat jouw toekomst in de Azure omgeving ligt. \n- Je hebt minimaal 1 jaar ervaring als intern beheerder, systeembeheerder of werkplekbeheerder. \n- Jij bent bereid om deze intensieve en leerzame periode aan te gaan. \n- Je bent vanaf 1 september 40 uur per week beschikbaar.\n- Je beheerst zowel de Nederlandse als Engelse taal.\n- Je hebt minimaal een mbo4 IT-opleiding afgerond.\n- Je hebt tussen september en november 2024 geen vakantie op de planning staan.",{"__component":116,"id":117,"title":118,"text":119,"darkMode":17,"customerItems":120},"global.customers",5,"Wat voor opdrachten kan je verwachten in de toekomst?","Onze engineers werken verspreid door het hele land bij opdrachtgevers in alle denkbare branches. Graag geven we enkele voorbeelden van de Azure-opdrachten waar we ons voor inzetten. Klik op de logo's hieronder om de klantcases te bekijken!",[121,144,183],{"id":122,"title":123,"linkUrl":124,"imageUrl":125,"imageUrlDark":141},28," Stichting Inlichtingenbureau","https://www.sharevalue.nl/klantcases/stichting-inlichtingenbureau-kiest-voor-migratie-naar-microsoft-azure",{"id":126,"name":127,"alternativeText":22,"caption":22,"width":40,"height":128,"formats":129,"hash":136,"ext":27,"mime":30,"size":137,"url":138,"previewUrl":22,"provider":59,"provider_metadata":22,"createdAt":139,"updatedAt":139,"documentId":140,"publishedAt":62},199,"Logo_SiB.jpg