title":21,"asideText":21,"underline":129,"centered":129,"blankAside":129,"aside":21,"content":21,"introductionText":21},"global.pagesection",4496,{"__component":352,"id":353,"title":354,"callToActionText":355,"callToActionLink":356,"imageUrl":357},"hero.secondary",158,"Leer je collega's alvast kennen","Leer meer over ons","/word-onze-collega/collegas-aan-het-woord",{"id":358,"name":359,"alternativeText":21,"caption":21,"width":22,"height":23,"formats":360,"hash":381,"ext":26,"mime":29,"size":382,"url":383,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":384,"updatedAt":385,"documentId":386,"publishedAt":97},132,"Pooltafel_lees_meer.jpg",{"large":361,"small":366,"medium":371,"thumbnail":376},{"ext":26,"url":362,"hash":363,"mime":29,"name":364,"path":21,"size":365,"width":32,"height":33},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Pooltafel_lees_meer_f0316220c6.jpg","large_Pooltafel_lees_meer_f0316220c6","large_Pooltafel_lees_meer.jpg",43.03,{"ext":26,"url":367,"hash":368,"mime":29,"name":369,"path":21,"size":370,"width":23,"height":40},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Pooltafel_lees_meer_f0316220c6.jpg","small_Pooltafel_lees_meer_f0316220c6","small_Pooltafel_lees_meer.jpg",16.3,{"ext":26,"url":372,"hash":373,"mime":29,"name":374,"path":21,"size":375,"width":47,"height":48},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Pooltafel_lees_meer_f0316220c6.jpg","medium_Pooltafel_lees_meer_f0316220c6","medium_Pooltafel_lees_meer.jpg",28.19,{"ext":26,"url":377,"hash":378,"mime":29,"name":379,"path":21,"size":380,"width":55,"height":56},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Pooltafel_lees_meer_f0316220c6.jpg","thumbnail_Pooltafel_lees_meer_f0316220c6","thumbnail_Pooltafel_lees_meer.jpg",6.07,"Pooltafel_lees_meer_f0316220c6",60.74,"https://incredible-beef-2a6059b946.media.strapiapp.com/Pooltafel_lees_meer_f0316220c6.jpg","2023-08-22T11:10:46.885Z","2026-02-20T13:00:43.471Z","fe5hto6qcmrr5g8ew38f1ac4",{"__component":388,"id":389,"title":390,"steps":391},"global.step-carousel",150,"Solliciteer bij ons in 5 stappen",[392,396,400,404,408],{"id":393,"title":394,"content":395},586,"Solliciteer op jouw manier","Via de website, een brief, een videoboodschap… kies jouw manier en stuur je cv mee.",{"id":397,"title":398,"content":399},587,"Don't call us; we'll call you","We bellen je om je sollicitatie te bespreken en een goed beeld te krijgen van jouw wensen, om te zien of we daar aan kunnen voldoen. En natuurlijk andersom.",{"id":401,"title":402,"content":403},588,"We spreken elkaar","Als we een goed gevoel hebben bij elkaar, gaan we met elkaar in gesprek.\nJe spreekt onze Corporate Recruiter, People Manager, Competence Lead en CEO.",{"id":405,"title":406,"content":407},589,"Aanbiedingsgesprek","We zijn er zeker van dat we een goede match zijn voor elkaar!\nWe bespreken de arbeidsvoorwaarden en je ontvangt van ons een aanbod.",{"id":409,"title":410,"content":411},590,"Je start bij ons","Je gaat akkoord met het voorstel en komt op de afgesproken datum bij ons werken.\nUiteraard word je met open armen welkom geheten op je eerste dag!",{"pagination":413},{"page":67,"pageSize":414},100,{"data":416,"meta":636},[417],{"backDate":21,"publishedAt":418,"createdAt":419,"id":420,"title":421,"excerpt":422,"slug":423,"updatedAt":424,"documentId":425,"imageUrl":426,"expertises":459,"author":515,"blocks":538,"seo":21},"2026-06-02T13:07:49.735Z","2026-06-02T11:58:34.723Z",714,"Waarom Zero Trust faalt zonder grip op non-human identities","Mijn eerdere blog 'De blinde vlek in Zero Trust: identiteiten zonder mens' maakte één ding duidelijk. Veel Zero Trust-implementaties stoppen bij gebruikers.\nDat is geen slordigheid, maar een gevolg van aannames die diep in onze ontwerpen zitten. Zero Trust is in veel organisaties vormgegeven rond loginmomenten, sessies en menselijk gedrag. Maar cloudomgevingen draaien allang niet meer primair op mensen.","waarom-zero-trust-faalt-zonder-grip-op-non-human-identities","2026-06-02T13:07:49.440Z","yy30w2g8idc57mjicjbuh3eb",{"id":427,"name":428,"alternativeText":21,"caption":21,"width":22,"height":23,"formats":429,"hash":454,"ext":26,"mime":29,"size":455,"url":456,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":457,"updatedAt":457,"documentId":458,"publishedAt":457},1468,"Blog hero Waarom Zero Trust faalt.jpg",{"large":430,"small":436,"medium":442,"thumbnail":448},{"ext":26,"url":431,"hash":432,"mime":29,"name":433,"path":21,"size":434,"width":32,"height":33,"sizeInBytes":435},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","large_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","large_Blog hero Waarom Zero Trust faalt.jpg",30,30004,{"ext":26,"url":437,"hash":438,"mime":29,"name":439,"path":21,"size":440,"width":23,"height":40,"sizeInBytes":441},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","small_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","small_Blog hero Waarom Zero Trust faalt.jpg",10.04,10036,{"ext":26,"url":443,"hash":444,"mime":29,"name":445,"path":21,"size":446,"width":47,"height":48,"sizeInBytes":447},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","medium_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","medium_Blog hero Waarom Zero Trust faalt.jpg",19.34,19342,{"ext":26,"url":449,"hash":450,"mime":29,"name":451,"path":21,"size":452,"width":55,"height":56,"sizeInBytes":453},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","thumbnail_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","thumbnail_Blog hero Waarom Zero Trust faalt.jpg",2.95,2948,"Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9",42.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","2026-06-02T11:54: