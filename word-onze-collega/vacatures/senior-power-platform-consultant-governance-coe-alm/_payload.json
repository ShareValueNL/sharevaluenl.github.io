[{"data":1,"prerenderedAt":703},["ShallowReactive",2],{"collection-vacatures--2099887164":3,"collection-blogs-1075856478":458,"_apollo:default":702},{"data":4,"meta":454},[5],{"id":6,"title":7,"educationLevel":8,"location":9,"slug":10,"hours":11,"shortText":12,"mainContent":13,"createdAt":14,"updatedAt":15,"publishedAt":16,"documentId":17,"image":18,"expertises":64,"contactPerson":329,"benefits":368,"blocks":384,"seo":21},149,"Senior Power Platform Consultant","hbo-niveau","Klant locatie/ thuis","senior-power-platform-consultant-governance-coe-alm","32-40","Ben jij een ervaren Power Platform specialist die zowel technisch als functioneel sterk is? Wil jij organisaties helpen hun low-code landschap te professionaliseren? Dan is dit jouw rol!","## Over de rol\nAls Senior Power Platform Consultant ben jij dé expert die organisaties helpt hun Microsoft Power Platform-omgeving naar enterprise-niveau te brengen. Je combineert technische skills (Power Apps, Automate, Dataverse, integraties, agents) met functioneel inzicht.  Daarnaast adviseer je over governance, security en adoptie.\n\n## Waarom is deze rol belangrijk?\n- Organisaties hebben vaak een versnipperd low-code landschap. Jij brengt structuur, governance en ALM-processen.\n- Je implementeert het Center of Excellence (CoE), zodat citizen developers veilig en efficiënt kunnen werken.\n- Je adviseert over omgevingsstrategie (Dev/Test/Prod), securitymodellen en DLP policies.\nKortom: jij zorgt voor duurzame standaarden en adoptie van het Power Platform.\n\n## Wat jij gaat doen\n- Ontwerpen en bouwen van enterprise Power Platform-oplossingen\n- Implementeren van governance en omgevingsstrategie\n- Inrichten van ALM (Application Lifecycle Management) d.m.v. pipelines\n- Inrichten van OTAP/DTAP-omgevingen\n- Integraties realiseren met Azure, SQL, API’s en Microsoft 365\n- Workshops en trainingen geven aan teams en stakeholders\n- CoE Starter Kit installeren en configureren\n\n## Dit neem jij mee\n### Must-haves:\n- Minimaal 3 jaar ervaring met Power Platform (Apps, Automate, Dataverse)\n- Ervaring met ALM, solutions en pipelines\n- Kennis van governance (DLP, security-rollen, environmentstrategie)\n- Certificeringen: PL-200, PL-400 (PL-600 is een pré)\n- Sterke communicatieve vaardigheden\n- Brede kennis van Microsoft 365 en enthousiast om deze ook in te zetten naast Power Platform-projecten\n\n### Nice-to-haves:\n- Ervaring met Logic Apps en AI Builder\n- Sectorervaring: overheid, financiële dienstverlening, semioverheid\n\n## Wat kun je van ons verwachten?\n- Een opleidingsbudget en certificeringstrajecten, en een People Manager die samen met jou een persoonlijk ontwikkelplan (POP) opzet, zodat we jou waar nodig kunnen ondersteunen om die stip aan de horizon te bereiken.\n- Een Competence Lead die zorgt dat de vakinhoudelijke kennis up-to-date blijft en jou daar graag bij betrekt.\n- Een persoonlijk mobiliteitsbudget.\n- Diverse mogelijkheden voor het bezoek van congressen en conferenties (ook in het buitenland).\n- Een Microsoft Partner die investeert in de mens. Welzijn, werkplezier en werkgeluk zorgen dat het werken bij ShareValue een unieke beleving is waar je met plezier jouw wekker voor zet!\n\n## Projectvoorbeelden\n- Governance-implementatie\n- Migratie en Power Platform-adoptie\n- Integratieprojecten\n\n## Over ShareValue\nShareValue bestaat uit een club ondernemende, communicatieve IT-experts met een hoog kennisniveau. Onze architecten, consultants, developers en engineers werken verspreid over het land op uitdagende projecten bij klanten in diverse branches. Onze focus ligt op een aantal specifieke expertises: Azure, Microsoft 365, Power Platform en Development. Dankzij deze focus zijn we erkend Microsoft Solutions Partner.\n\nOnze bedrijfscultuur kent een informele en familiaire sfeer en er is veel ruimte voor persoonlijke aandacht. Wij zijn een hecht team van plusminus 60 enthousiaste experts en hebben de ambitie om verder te groeien. We organiseren, wanneer mogelijk, regelmatig voor het hele kantoor een leuk uitje zoals een BBQ op het strand, een avond karten of een weekendje weg. Een informele, collegiale sfeer vinden wij erg belangrijk.","2026-01-15T13:38:20.205Z","2026-01-26T13:52:21.184Z","2026-01-26T13:52:21.778Z","t35rhm9kyx1uwad98g1hmiz7",{"id":19,"name":20,"alternativeText":21,"caption":21,"width":22,"height":23,"formats":24,"hash":58,"ext":26,"mime":29,"size":59,"url":60,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":62,"updatedAt":62,"documentId":63,"publishedAt":62},1368,"Toscane.jpg",null,1280,500,{"large":25,"small":35,"medium":42,"thumbnail":50},{"ext":26,"url":27,"hash":28,"mime":29,"name":30,"path":21,"size":31,"width":32,"height":33,"sizeInBytes":34},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Toscane_f76f624649.jpg","large_Toscane_f76f624649","image/jpeg","large_Toscane.jpg",96.84,1000,391,96844,{"ext":26,"url":36,"hash":37,"mime":29,"name":38,"path":21,"size":39,"width":23,"height":40,"sizeInBytes":41},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Toscane_f76f624649.jpg","small_Toscane_f76f624649","small_Toscane.jpg",26.01,195,26012,{"ext":26,"url":43,"hash":44,"mime":29,"name":45,"path":21,"size":46,"width":47,"height":48,"sizeInBytes":49},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Toscane_f76f624649.jpg","medium_Toscane_f76f624649","medium_Toscane.jpg",55.39,750,293,55389,{"ext":26,"url":51,"hash":52,"mime":29,"name":53,"path":21,"size":54,"width":55,"height":56,"sizeInBytes":57},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Toscane_f76f624649.jpg","thumbnail_Toscane_f76f624649","thumbnail_Toscane.jpg",6.98,245,96,6980,"Toscane_f76f624649",160.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/Toscane_f76f624649.jpg","strapi-provider-upload-strapi-cloud","2026-01-15T11:09:20.940Z","dz5erru5w7viocy9hj71r6x3",[65],{"id":66,"title":67,"subTitle":68,"description":69,"shortDescription":70,"slug":71,"createdAt":72,"updatedAt":73,"publishedAt":74,"isCoreExpertise":75,"documentId":76,"image":77,"blocks":97,"midPageBlocks":189,"seo":324},7,"Power Platform","Optimaliseer je bedrijfsprocessen met Microsoft Power Platform","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.\n\nBij ShareValue leveren we oplossingen die precies aansluiten op de behoeften van jouw organisatie. Of het nu gaat om het opzetten van een uitgebreide governance- en omgevingsstrategie, het ontwikkelen van een app met bijbehorende automatiseringen of het bevorderen van gebruikersadoptie; wij hebben de juiste expertise in huis.\n\nOnze Power Platform-specialisten, bestaande uit ervaren consultants en developers, hebben een bewezen staat van dienst in diverse sectoren. Zij delen continu hun kennis en passen deze toe op de unieke vraagstukken van onze klanten, waardoor we steeds de meest effectieve en innovatieve oplossingen kunnen bieden.\n","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.","power-platform","2023-10-12T11:27:43.792Z","2025-04-11T13:13:15.099Z","2023-10-12T11:27:43.781Z",true,"prbaerw7gypadu8gfdyg53sy",{"id":78,"name":79,"alternativeText":21,"caption":21,"width":80,"height":81,"formats":82,"hash":91,"ext":84,"mime":87,"size":92,"url":93,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":94,"updatedAt":94,"documentId":95,"publishedAt":96},927,"Logo PowerPlatform 2025 web png.png",282,130,{"thumbnail":83},{"ext":84,"url":85,"hash":86,"mime":87,"name":88,"path":21,"size":89,"width":55,"height":90},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Power_Platform_2025_web_png_4268556f17.png","thumbnail_Logo_Power_Platform_2025_web_png_4268556f17","image/png","thumbnail_Logo PowerPlatform 2025 web png.png",8.26,113,"Logo_Power_Platform_2025_web_png_4268556f17",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Power_Platform_2025_web_png_4268556f17.png","2024-12-16T11:07:06.507Z","a12tjlb3ssr20rrzj9rulb58","2026-01-05T12:38:34.018Z",[98,166],{"__component":99,"id":100,"title":101,"aside":21,"postType":102,"limit":103,"expertise":104},"strapi.related-kennisbank-list",164,"Lees meer over het Power Platform","alle",3,[105],{"id":66,"title":67,"subTitle":68,"description":69,"shortDescription":70,"slug":71,"createdAt":72,"updatedAt":73,"publishedAt":74,"isCoreExpertise":75,"documentId":76,"image":106,"blocks":109,"midPageBlocks":120,"seo":149},{"id":78,"name":79,"alternativeText":21,"caption":21,"width":80,"height":81,"formats":107,"hash":91,"ext":84,"mime":87,"size":92,"url":93,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":94,"updatedAt":94,"documentId":95,"publishedAt":96},{"thumbnail":108},{"ext":84,"url":85,"hash":86,"mime":87,"name":88,"path":21,"size":89,"width":55,"height":90},[110,111],{"__component":99,"id":100,"title":101,"aside":21,"postType":102,"limit":103},{"__component":112,"id":113,"titleLeft":114,"callToActionTextLeft":115,"callToActionLinkUrlLeft":116,"titleRight":117,"callToActionTextRight":118,"callToActionLinkUrlRight":119},"call-to-action.double",235,"Heb je een Power Platform expert nodig?","Neem contact op voor de mogelijkheden","/contact","Zoek je een nieuwe uitdaging?","Bekijk onze vacatures","/word-onze-collega/vacatures",[121,129,134,138,143],{"__component":122,"id":123,"title":124,"subTitle":21,"content":125,"callToActionText":126,"callToActionLink":116,"colorStyle":127,"showAsides":128},"global.alternating-page-section",16,"Power Platform governance: de balans tussen beveiliging en innovatie","Het is belangrijk om een balans te vinden tussen beveiliging en innovatie binnen jouw organisatie. Hoewel governance noodzakelijk is, moeten je medewerkers en teams de ruimte krijgen om waarde te creëren voor zowel henzelf als de onderneming.\n\nOnze Power Platform-specialisten staan klaar om je te adviseren over de diverse mogelijkheden. We begeleiden je tijdens het ontwikkelen en implementeren van een effectieve governance- en omgevingsstrategie, zodat je het beste uit het Microsoft Power Platform kunt halen.","Wil je meer weten? Neem contact met ons op.","Sugar Glaze",false,{"__component":122,"id":130,"title":131,"subTitle":21,"content":132,"callToActionText":21,"callToActionLink":21,"colorStyle":133,"showAsides":128},17,"Snel maatwerktoepassingen creëren met het Power Platform","Het Power Platform is de ideale oplossing om je verouderde processen en applicaties te stroomlijnen met slimme apps, efficiënte werkstromen en geavanceerde, op maat gemaakte formulieren.\n\nOnze specialisten staan klaar om je te adviseren over de vele mogelijkheden. Heb je meer ondersteuning nodig bij het ontwikkelen van je toepassing? Onze ervaren developers ontwikkelen de toepassing volledig voor je.","White",{"__component":122,"id":135,"title":136,"subTitle":21,"content":137,"callToActionText":21,"callToActionLink":21,"colorStyle":127,"showAsides":128},18,"Power Platform staat aan, wat nu?","Het Power Platform wordt al gebruikt in jouw organisatie. Een aantal enthousiaste collega's hebben al mooie apps gemaakt en je staat op het punt om het Power Platform in te zetten voor bedrijfskritische processen. Maar je weet niet precies hoe je dit het beste kunt aanpakken.\n\nWij begeleiden je in dit proces en samen bepalen we de \"next steps\". Onze architecten voeren een volledige omgevings- en securitycheck uit, wat resulteert in een omgevingsstrategie, governance, en een ontwikkel- en adoptieplan.",{"__component":122,"id":139,"title":140,"subTitle":21,"content":141,"callToActionText":142,"callToActionLink":116,"colorStyle":133,"showAsides":128},19,"Is jouw omgeving veilig en secure?","Onze omgevings- en securitycheck geeft je een helder beeld van de huidige status van je omgeving en laat zien wat je nog kunt doen om toepassingen nog veiliger en consistenter te ontwikkelen.","Wil je de check laten doen?",{"__component":144,"id":145,"title":146,"callToActionText":147,"callToActionLinkUrl":148,"body":21},"call-to-action.single",99,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Stork","/klantcases/stork-focust-op-citizen-development-met-het-microsoft-power-platform",{"id":150,"metaTitle":151,"metaDescription":152,"structuredData":153},26,"Power Platform specialisten – ShareValue helpt vooruit","Haal meer uit Power Apps, Automate en Power BI. Wij helpen bij strategie, ontwikkeling en beheer van jouw Power Platform-omgeving.",{"url":154,"@type":155,"@context":156,"provider":157,"areaServed":161,"description":164,"serviceType":165},"https://www.sharevalue.nl/wat-we-doen/power-platform","Service","https://schema.org",{"url":158,"name":159,"@type":160},"https://www.sharevalue.nl","ShareValue","Organization",{"name":162,"@type":163},"Nederland","Country","ShareValue helpt organisaties om Power Platform optimaal in te zetten. Denk aan Power Apps, Power Automate en Power BI. We bieden begeleiding bij strategie, governance, ontwikkeling en beheer.","Power Platform consultancy",{"__component":112,"id":113,"titleLeft":114,"callToActionTextLeft":115,"callToActionLinkUrlLeft":116,"titleRight":117,"callToActionTextRight":118,"callToActionLinkUrlRight":119,"iconUrlLeft":167,"iconUrlRight":180},{"id":168,"name":169,"alternativeText":21,"caption":21,"width":170,"height":171,"formats":21,"hash":172,"ext":173,"mime":174,"size":175,"url":176,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":177,"updatedAt":178,"documentId":179,"publishedAt":96},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":181,"