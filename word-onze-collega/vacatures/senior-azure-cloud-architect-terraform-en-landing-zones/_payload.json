strapi.simple-form",121,"Klaar om jouw stempel te drukken op onze cloudomgeving?","Solliciteer hier",{"__component":351,"id":352,"title":21,"asideText":21,"underline":129,"centered":129,"blankAside":129,"aside":21,"content":21,"introductionText":21},"global.pagesection",4400,{"__component":354,"id":355,"title":356,"callToActionText":357,"callToActionLink":358,"imageUrl":359},"hero.secondary",146,"Leer je collega's alvast kennen","Leer meer over ons","/word-onze-collega/collegas-aan-het-woord",{"id":360,"name":361,"alternativeText":21,"caption":21,"width":22,"height":23,"formats":362,"hash":383,"ext":26,"mime":29,"size":384,"url":385,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":386,"updatedAt":387,"documentId":388,"publishedAt":97},132,"Pooltafel_lees_meer.jpg",{"large":363,"small":368,"medium":373,"thumbnail":378},{"ext":26,"url":364,"hash":365,"mime":29,"name":366,"path":21,"size":367,"width":32,"height":33},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Pooltafel_lees_meer_f0316220c6.jpg","large_Pooltafel_lees_meer_f0316220c6","large_Pooltafel_lees_meer.jpg",43.03,{"ext":26,"url":369,"hash":370,"mime":29,"name":371,"path":21,"size":372,"width":23,"height":40},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Pooltafel_lees_meer_f0316220c6.jpg","small_Pooltafel_lees_meer_f0316220c6","small_Pooltafel_lees_meer.jpg",16.3,{"ext":26,"url":374,"hash":375,"mime":29,"name":376,"path":21,"size":377,"width":47,"height":48},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Pooltafel_lees_meer_f0316220c6.jpg","medium_Pooltafel_lees_meer_f0316220c6","medium_Pooltafel_lees_meer.jpg",28.19,{"ext":26,"url":379,"hash":380,"mime":29,"name":381,"path":21,"size":382,"width":55,"height":56},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Pooltafel_lees_meer_f0316220c6.jpg","thumbnail_Pooltafel_lees_meer_f0316220c6","thumbnail_Pooltafel_lees_meer.jpg",6.07,"Pooltafel_lees_meer_f0316220c6",60.74,"https://incredible-beef-2a6059b946.media.strapiapp.com/Pooltafel_lees_meer_f0316220c6.jpg","2023-08-22T11:10:46.885Z","2026-02-20T13:00:43.471Z","fe5hto6qcmrr5g8ew38f1ac4",{"__component":390,"id":391,"title":392,"steps":393},"global.step-carousel",141,"Solliciteer bij ons in 5 stappen",[394,398,402,406,410],{"id":395,"title":396,"content":397},541,"Solliciteer op jouw manier","Via de website, een brief, een videoboodschap… kies jouw manier en stuur je cv mee.",{"id":399,"title":400,"content":401},542,"Don't call us; we'll call you","We bellen je om je sollicitatie te bespreken en een goed beeld te krijgen van jouw wensen, om te zien of we daar aan kunnen voldoen. En natuurlijk andersom.",{"id":403,"title":404,"content":405},543,"We spreken elkaar","Als we een goed gevoel hebben bij elkaar, gaan we met elkaar in gesprek.\nJe spreekt onze Corporate Recruiter, People Manager, Competence Lead en CEO.",{"id":407,"title":408,"content":409},544,"Aanbiedingsgesprek","We zijn er zeker van dat we een goede match zijn voor elkaar!\nWe bespreken de arbeidsvoorwaarden en je ontvangt van ons een aanbod.",{"id":411,"title":412,"content":413},545,"Je start bij ons","Je gaat akkoord met het voorstel en komt op de afgesproken datum bij ons werken.\nUiteraard word je met open armen welkom geheten op je eerste dag!",{"pagination":415},{"page":67,"pageSize":416},100,{"data":418,"meta":638},[419],{"backDate":21,"publishedAt":420,"createdAt":421,"id":422,"title":423,"excerpt":424,"slug":425,"updatedAt":426,"documentId":427,"imageUrl":428,"expertises":461,"author":517,"blocks":540,"seo":21},"2026-06-02T12:19:17.325Z","2026-06-02T11:58:34.723Z",711,"Waarom Zero Trust faalt zonder grip op non-human identities","De blog ['De blinde vlek in Zero Trust: identiteiten zonder mens'](https://sharevalue.nl/blogs/de-blinde-vlek-in-zero-trust-identiteiten-zonder-mens) maakte één ding duidelijk. Veel Zero Trust-implementaties stoppen bij gebruikers.\nDat is geen slordigheid, maar een gevolg van aannames die diep in onze ontwerpen zitten. Zero Trust is in veel organisaties vormgegeven rond loginmomenten, sessies en menselijk gedrag. Maar cloudomgevingen draaien allang niet meer primair op mensen.","waarom-zero-trust-faalt-zonder-grip-op-non-human-identities","2026-06-02T12:19:17.001Z","yy30w2g8idc57mjicjbuh3eb",{"id":429,"name":430,"alternativeText":21,"caption":21,"width":22,"height":23,"formats":431,"hash":456,"ext":26,"mime":29,"size":457,"url":458,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":459,"updatedAt":459,"documentId":460,"publishedAt":459},1468,"Blog hero Waarom Zero Trust faalt.jpg",{"large":432,"small":438,"medium":444,"thumbnail":450},{"ext":26,"url":433,"hash":434,"mime":29,"name":435,"path":21,"size":436,"width":32,"height":33,"sizeInBytes":437},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","large_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","large_Blog hero Waarom Zero Trust faalt.jpg",30,30004,{"ext":26,"url":439,"hash":440,"mime":29,"name":441,"path":21,"size":442,"width":23,"height":40,"sizeInBytes":443},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","small_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","small_Blog hero Waarom Zero Trust faalt.jpg",10.04,10036,{"ext":26,"url":445,"hash":446,"mime":29,"name":447,"path":21,"size":448,"width":47,"height":48,"sizeInBytes":449},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","medium_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","medium_Blog hero Waarom Zero Trust faalt.jpg",19.34,19342,{"ext":26,"url":451,"hash":452,"mime":29,"name":453,"path":21,"size":454,"width":55,"height":56,"sizeInBytes":455},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","thumbnail_Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9","thumbnail_Blog hero Waarom Zero Trust faalt.jpg",2.95,2948,"Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9",42.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_hero_Waarom_Zero_Trust_faalt_8bfb1140e9.jpg","2026-06-02T11:54:33.456Z","bkry7r7sekupu3txzav9g8hh",[462],{"id":67,"title":68,"subTitle":69,"description":70,"shortDescription":71,"slug":72,"createdAt":73,"updatedAt":74,"publishedAt":75,"isCoreExpertise":76,"documentId":77,"image":463,"blocks":466,"midPageBlocks":488,"seo":512},{"id":79,"name":80,"alternativeText":21,"caption":21,"width":81,"height":82,"formats":464,"hash":92,"ext":85,"mime":88,"size":93,"url":94,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":95,"updatedAt":95,"documentId":96,"publishedAt":97},{"thumbnail":465},{"ext":85,"url":86,"hash":87,"mime":88,"name":89,"path":21,"size":90,"width":55,"height":91},[467,485],{"__component":100,"id":101,"title":102,"aside":21,"postType":103,"limit":104,"expertise":468},[469],{"id":67,"title":68,"subTitle":69,"description":70,"shortDescription":71,"slug":72,"createdAt":73,"updatedAt":74,"publishedAt":75,"isCoreExpertise":76,"documentId":77,"image":470,"blocks":473,"midPageBlocks":476,"seo":481},{"id":79,"name":80,"alternativeText":21,"caption":21,"width":81,"height":82,"formats":471,"hash":92,"ext":85,"mime":88,"size":93,"url":94,"previewUrl":21,"provider":61,"provider_metadata":21,"createdAt":95,"updatedAt":95,"documentId":96,"publishedAt":97},{"thumbnail":472},{"ext":85,"url":86,"hash":87,"mime":88,"name":89,"path":21,"size":90,"width":55,"height":91},[474,475],{"__component":100,"id":101,"title":102,"aside":21,"postType":103,"limit":104},{"__component":113,"id":114,"titleLeft":115,"callToActionTextLeft":116,"callToActionLinkUrlLeft":117,"titleRight":118,"callToActionTextRight":119,"callToActionLinkUrlRight":120},[477,478,479,480],{"__component":123,"id":124,"title":125,"subTitle":21,"content":126,"callToActionText":127,"callToActionLink":117,"colorStyle":128,"showAsides":129},{"__component":123,"id":131,"t