[{"data":1,"prerenderedAt":593},["ShallowReactive",2],{"collection-klantcases--1871332103":3,"_apollo:default":592},{"data":4,"meta":588},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"collegas":15,"image":16,"klant":59,"contentBlocks":85,"seo":104,"expertises":121,"blocks":494},7,"Een digitale maatwerkoplossing voor compliance en certificering","een-digitale-maatwerkoplossing-voor-compliance-en-certificering","QSN Risicomanagement heeft een digitale maatwerkoplossing gebouwd. Het resultaat is een online platform waarin klanten hun processen toegankelijk kunnen maken voor medewerkers en tegelijkertijd compliance kunnen aantonen.","2023-09-01T09:35:28.562Z","2025-04-11T14:03:26.030Z","2023-09-01T09:36:09.418Z","2021-07-20","wx9s56qdw00ahrctaozk9a9c",[],{"id":17,"name":18,"alternativeText":19,"caption":19,"width":20,"height":21,"formats":22,"hash":52,"ext":24,"mime":27,"size":53,"url":54,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":19},211,"QSN_klantcase_foto.jpg",null,1280,500,{"large":23,"small":32,"medium":38,"thumbnail":45},{"ext":24,"url":25,"hash":26,"mime":27,"name":28,"path":19,"size":29,"width":30,"height":31},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_QSN_klantcase_foto_ecc951c1a0.jpg","large_QSN_klantcase_foto_ecc951c1a0","image/jpeg","large_QSN_klantcase_foto.jpg",53.41,1000,391,{"ext":24,"url":33,"hash":34,"mime":27,"name":35,"path":19,"size":36,"width":21,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_QSN_klantcase_foto_ecc951c1a0.jpg","small_QSN_klantcase_foto_ecc951c1a0","small_QSN_klantcase_foto.jpg",19,195,{"ext":24,"url":39,"hash":40,"mime":27,"name":41,"path":19,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_QSN_klantcase_foto_ecc951c1a0.jpg","medium_QSN_klantcase_foto_ecc951c1a0","medium_QSN_klantcase_foto.jpg",34.77,750,293,{"ext":24,"url":46,"hash":47,"mime":27,"name":48,"path":19,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_QSN_klantcase_foto_ecc951c1a0.jpg","thumbnail_QSN_klantcase_foto_ecc951c1a0","thumbnail_QSN_klantcase_foto.jpg",6,245,96,"QSN_klantcase_foto_ecc951c1a0",73.03,"https://incredible-beef-2a6059b946.media.strapiapp.com/QSN_klantcase_foto_ecc951c1a0.jpg","strapi-provider-upload-strapi-cloud","2023-09-01T09:36:24.798Z","hfff907o0wnt821i8dfcbt6k","2026-01-05T12:38:34.018Z",{"id":6,"title":60,"createdAt":61,"updatedAt":62,"publishedAt":63,"documentId":64,"logo":65},"QSN Risicomanagement","2023-09-01T09:35:51.551Z","2023-09-01T09:35:52.327Z","2023-09-01T09:35:52.323Z","tehjfjuynq1uy1rc79walhu5",{"id":66,"name":67,"alternativeText":19,"caption":19,"width":21,"height":68,"formats":69,"hash":79,"ext":71,"mime":74,"size":80,"url":81,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":82,"updatedAt":83,"documentId":84,"publishedAt":58,"focalPoint":19},210,"QSN_logo_png.png",327,{"thumbnail":70},{"ext":71,"url":72,"hash":73,"mime":74,"name":75,"path":19,"size":76,"width":77,"height":78},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_QSN_logo_png_b899226bf5.png","thumbnail_QSN_logo_png_b899226bf5","image/png","thumbnail_QSN_logo_png.png",10.72,239,156,"QSN_logo_png_b899226bf5",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/QSN_logo_png_b899226bf5.png","2023-09-01T09:35:49.115Z","2023-11-08T14:27:28.461Z","b4p677ib8ye0lowissygbia8",[86,92,96,100],{"id":87,"title":19,"asideText":88,"underline":89,"centered":89,"blankAside":89,"aside":19,"content":90,"introductionText":19,"__component":91},1623,"SAMENWERKINGSHOOGTEPUNTEN",false,"- Digitale maatwerkoplossing\n- Klantreis met SharePoint online\n- Volledig geïntegreerd in Microsoft 365 en Microsoft Teams\n- Veilige procesomgeving en overal te gebruiken","global.pagesection",{"id":93,"title":19,"asideText":19,"underline":89,"centered":89,"blankAside":89,"aside":94,"content":95,"introductionText":19,"__component":91},1624,"![QSN_logo_png.png](https://incredible-beef-2a6059b946.media.strapiapp.com/QSN_logo_png_b899226bf5.png)","## QSN Risicomanagement\n[QSN Risicomanagement](https://www.qsn.nl/) helpt organisaties bij het vertalen van normen naar processen. Daarbij gaat het vaak over wetgeving, klanteisen of bijvoorbeeld ISO certificaten als [ISO 9001](https://www.qsn.nl/kwaliteit/iso-9001-kwaliteitsmanagement/) en [ISO 27001](https://www.qsn.nl/informatiebeveiliging/iso-27001/). Zij hanteren daarbij een praktische aanpak en proberen vooral aan te sluiten bij wat er allemaal al is. Compliance en certificatie wordt veelal geassocieerd met procedures en handboeken. Dat past niet goed in de huidige tijd, waarin steeds meer mensen online werken en online registraties bijhouden. Omdat veel klanten Microsoft-gebruiker zijn, is gezocht naar een platform dat past in de bestaande omgeving. Zij zijn daarbij uitgekomen bij SharePoint omdat het op eenvoudige wijze processen toegankelijk maakt en een goede zoekfunctie kent.\n\n## RMS 365\nDit heeft geleid tot het risicomanagement platform [RMS 365](https://www.qsn.nl/managementservices/digitalisering/). Samen met de ShareValue-experts Bert en Gerhard is nagedacht over de inrichting van dit systeem en de wijze waarop we dit systeem zo eenvoudig mogelijk kunnen uitrollen. ShareValue heeft geholpen met de bouw van dit systeem, dat bestaat uit een beheermodule en een gebruikersomgeving.",{"id":97,"title":19,"asideText":98,"underline":89,"centered":89,"blankAside":89,"aside":19,"content":99,"introductionText":19,"__component":91},1625,"M365 Competence Lead Bert en M365 Developer Gerhard","## De rol van ShareValue\nOnze expert Bert heeft meegewerkt aan de eerste versies van RMS 365. Denk hierbij aan de databases, webapplicaties en de klantreis. Daarna is onze expert Gerhard aan de slag gegaan met de Front-End van RMS 365. Er is veel overleg geweest en intensief samengewerkt.",{"id":101,"title":19,"asideText":102,"underline":89,"centered":89,"blankAside":89,"aside":19,"content":103,"introductionText":19,"__component":91},1626,"RMS 365 is volledig geïntegreerd in Microsoft 365 en Microsoft Teams","## De maatwerkoplossing met SharePoint Online\nQSN heeft eerst onderzocht wat de wensen zijn van klanten rondom het digitaliseren van managementsystemen. Samen met de experts van ShareValue is nagedacht over technische en functionele specificaties. Al snel is besloten om de documentopslag SharePoint Online te gebruiken en om klantreizen aan te maken middels een maatwerkoplossing. De klantreis maakt de processen digitaal toegankelijk en zorgt voor herkenning en samenhang.\n\nIn deze maatwerkoplossing kan QSN een SharePoint-portaal inrichten voor klanten, waarbij er drie niveaus aan documentatie kunnen worden gegenereerd en alle noodzakelijke templates in één keer beschikbaar worden gesteld. Daarmee kan compliance worden gedemonstreerd en kunnen signaleringsfuncties op acties of verouderde documenten worden ingericht. Zo kan de klant gebruik maken van de kracht van SharePoint Online, zonder dat kennis van SharePoint Online nodig is.\n\nRMS 365 is volledig geïntegreerd in Microsoft 365 en Microsoft Teams, hierdoor is deze procesomgeving overal en veilig te gebruiken. De klanten kunnen de omgeving ook personaliseren en aan laten sluiten bij de eigen huisstijl. QSN heeft nu een online platform in handen dat voor veel klanten ingezet kan worden en past bij de tijd van nu.\n\nInmiddels werken de eerste klanten met RMS 365 en zijn er nog genoeg ambities voor de nabije toekomst.\n\nZoeken jullie ook hulp bij het digitaliseren van processen en het realiseren van compliance? Neem dan zeker [contact](/contact) met ons op!",{"id":105,"metaTitle":106,"metaDescription":107,"structuredData":108,"metaImage":19,"metaSocial":120},51,"QSN & ShareValue – Digitale compliance met RMS 365","QSN ontwikkelt met ShareValue het platform RMS 365: een SharePoint-oplossing voor digitaal procesbeheer en certificering.",{"url":109,"name":106,"@type":110,"author":111,"@context":115,"publisher":116,"mainEntity":117,"description":107,"datePublished":119},"https://www.sharevalue.nl/klantcases/een-digitale-maatwerkoplossing-voor-compliance-en-certificering","CaseStudy",{"url":112,"name":113,"@type":114},"https://www.sharevalue.nl","ShareValue","Organization","https://schema.org",{"url":112,"name":113,"@type":114},{"url":118,"name":60,"@type":114},"https://www.qsn.nl","2025-01-24",[],[122],{"id":123,"title":124,"subTitle":125,"description":126,"shortDescription":127,"slug":128,"createdAt":129,"updatedAt":130,"publishedAt":131,"isCoreExpertise":132,"documentId":133,"image":134,"seo":151,"blocks":165,"midPageBlocks":202},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":135,"name":136,"alternativeText":19,"caption":19,"width":137,"height":138,"formats":139,"hash":146,"ext":71,"mime":74,"size":147,"url":148,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":149,"updatedAt":149,"documentId":150,"publishedAt":58,"focalPoint":19},16,"microsoft-365.png",282,130,{"thumbnail":140},{"ext":71,"url":141,"hash":142,"mime":74,"name":143,"path":19,"size":144,"width":50,"height":145},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":152,"metaTitle":153,"metaDescription":154,"structuredData":155,"metaImage":19,"metaSocial":164},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":156,"@type":157,"@context":115,"provider":158,"areaServed":159,"description":162,"serviceType":163},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":112,"name":113,"@type":114},{"name":160,"@type":161},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[166,174],{"id":167,"title":168,"aside":19,"postType":169,"limit":170,"expertise":171,"__component":173},166,"Lees meer over Microsoft 365","alle",3,[172],{"id":123,"title":124,"subTitle":125,"description":126,"shortDescription":127,"slug":128,"createdAt":129,"updatedAt":130,"publishedAt":131,"isCoreExpertise":132,"documentId":133},"strapi.related-kennisbank-list",{"id":17,"titleLeft":175,"callToActionTextLeft":176,"callToActionLinkUrlLeft":177,"titleRight":178,"callToActionTextRight":179,"callToActionLinkUrlRight":180,"iconUrlLeft":181,"iconUrlRight":192,"__component":201},"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":49,"name":182,"alternativeText":19,"caption":19,"width":183,"height":184,"formats":19,"hash":185,"ext":186,"mime":187,"size":80,"url":188,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":189,"updatedAt":190,"documentId":191,"publishedAt":58,"focalPoint":19},"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml","https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":193,"name":194,"alternativeText":19,"caption":19,"width":184,"height":184,"formats":19,"hash":195,"ext":186,"mime":187,"size":196,"url":197,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":198,"updatedAt":199,"documentId":200,"publishedAt":58,"focalPoint":19},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[203,244,280,314,348,383,417,453,487],{"id":204,"title":205,"subTitle":206,"content":207,"callToActionText":19,"callToActionLink":19,"colorStyle":208,"showAsides":89,"imageUrl":209,"__component":243},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"id":210,"name":211,"alternativeText":19,"caption":19,"width":20,"height":212,"formats":213,"hash":238,"ext":24,"mime":27,"size":239,"url":240,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":241,"updatedAt":241,"documentId":242,"publishedAt":58,"focalPoint":19},782,"Teams.jpg",850,{"large":214,"small":220,"medium":226,"thumbnail":232},{"ext":24,"url":215,"hash":216,"mime":27,"name":217,"path":19,"size":218,"width":30,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Teams_43eca91eed.jpg","large_Teams_43eca91eed","large_Teams.jpg",75.76,664,{"ext":24,"url":221,"hash":222,"mime":27,"name":223,"path":19,"size":224,"width":21,"height":225},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Teams_43eca91eed.jpg","small_Teams_43eca91eed","small_Teams.jpg",24.28,332,{"ext":24,"url":227,"hash":228,"mime":27,"name":229,"path":19,"size":230,"width":43,"height":231},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Teams_43eca91eed.jpg","medium_Teams_43eca91eed","medium_Teams.jpg",45.38,498,{"ext":24,"url":233,"hash":234,"mime":27,"name":235,"path":19,"size":236,"width":237,"height":78},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Teams_43eca91eed.jpg","thumbnail_Teams_43eca91eed","thumbnail_Teams.jpg",8.28,235,"Teams_43eca91eed",119.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Teams_43eca91eed.jpg","2024-08-08T09:42:56.910Z","ht6rctym4qbbspr1vnahyrg1","global.alternating-page-section",{"id":245,"title":246,"subTitle":247,"content":248,"callToActionText":249,"callToActionLink":177,"colorStyle":250,"showAsides":89,"imageUrl":251,"__component":243},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"id":252,"name":253,"alternativeText":19,"caption":19,"width":20,"height":212,"formats":254,"hash":275,"ext":24,"mime":27,"size":276,"url":277,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":278,"updatedAt":278,"documentId":279,"publishedAt":58,"focalPoint":19},783,"adoptie.jpg",{"large":255,"small":260,"medium":265,"thumbnail":270},{"ext":24,"url":256,"hash":257,"mime":27,"name":258,"path":19,"size":259,"width":30,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_adoptie_dc3bbcacaa.jpg","large_adoptie_dc3bbcacaa","large_adoptie.jpg",140.54,{"ext":24,"url":261,"hash":262,"mime":27,"name":263,"path":19,"size":264,"width":21,"height":225},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_adoptie_dc3bbcacaa.jpg","small_adoptie_dc3bbcacaa","small_adoptie.jpg",46.09,{"ext":24,"url":266,"hash":267,"mime":27,"name":268,"path":19,"size":269,"width":43,"height":231},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_adoptie_dc3bbcacaa.jpg","medium_adoptie_dc3bbcacaa","medium_adoptie.jpg",90.06,{"ext":24,"url":271,"hash":272,"mime":27,"name":273,"path":19,"size":274,"width":237,"height":78},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_adoptie_dc3bbcacaa.jpg","thumbnail_adoptie_dc3bbcacaa","thumbnail_adoptie.jpg",13.08,"adoptie_dc3bbcacaa",204.86,"https://incredible-beef-2a6059b946.media.strapiapp.com/adoptie_dc3bbcacaa.jpg","2024-08-08T09:47:03.256Z","kqdvjnnutm27pjz49n0b8l8r",{"id":281,"title":282,"subTitle":283,"content":284,"callToActionText":19,"callToActionLink":19,"colorStyle":208,"showAsides":89,"imageUrl":285,"__component":243},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"id":286,"name":287,"alternativeText":19,"caption":19,"width":20,"height":212,"formats":288,"hash":309,"ext":24,"mime":27,"size":310,"url":311,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":312,"updatedAt":312,"documentId":313,"publishedAt":58,"focalPoint":19},784,"trends.jpg",{"large":289,"small":294,"medium":299,"thumbnail":304},{"ext":24,"url":290,"hash":291,"mime":27,"name":292,"path":19,"size":293,"width":30,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_trends_e84a321990.jpg","large_trends_e84a321990","large_trends.jpg",198.92,{"ext":24,"url":295,"hash":296,"mime":27,"name":297,"path":19,"size":298,"width":21,"height":225},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_trends_e84a321990.jpg","small_trends_e84a321990","small_trends.jpg",59.76,{"ext":24,"url":300,"hash":301,"mime":27,"name":302,"path":19,"size":303,"width":43,"height":231},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":24,"url":305,"hash":306,"mime":27,"name":307,"path":19,"size":308,"width":237,"height":78},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"id":315,"title":316,"subTitle":317,"content":318,"callToActionText":19,"callToActionLink":19,"colorStyle":250,"showAsides":89,"imageUrl":319,"__component":243},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":320,"name":321,"alternativeText":19,"caption":19,"width":20,"height":212,"formats":322,"hash":343,"ext":24,"mime":27,"size":344,"url":345,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":346,"updatedAt":346,"documentId":347,"publishedAt":58,"focalPoint":19},785,"microsoft development.jpg",{"large":323,"small":328,"medium":333,"thumbnail":338},{"ext":24,"url":324,"hash":325,"mime":27,"name":326,"path":19,"size":327,"width":30,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":24,"url":329,"hash":330,"mime":27,"name":331,"path":19,"size":332,"width":21,"height":225},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":24,"url":334,"hash":335,"mime":27,"name":336,"path":19,"size":337,"width":43,"height":231},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":24,"url":339,"hash":340,"mime":27,"name":341,"path":19,"size":342,"width":237,"height":78},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":349,"title":350,"subTitle":351,"content":352,"callToActionText":353,"callToActionLink":177,"colorStyle":208,"showAsides":89,"imageUrl":354,"__component":243},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":355,"name":356,"alternativeText":19,"caption":19,"width":20,"height":212,"formats":357,"hash":378,"ext":24,"mime":27,"size":379,"url":380,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":381,"updatedAt":381,"documentId":382,"publishedAt":58,"focalPoint":19},786,"migratie.jpg",{"large":358,"small":363,"medium":368,"thumbnail":373},{"ext":24,"url":359,"hash":360,"mime":27,"name":361,"path":19,"size":362,"width":30,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":24,"url":364,"hash":365,"mime":27,"name":366,"path":19,"size":367,"width":21,"height":225},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":24,"url":369,"hash":370,"mime":27,"name":371,"path":19,"size":372,"width":43,"height":231},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":24,"url":374,"hash":375,"mime":27,"name":376,"path":19,"size":377,"width":237,"height":78},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":384,"title":385,"subTitle":386,"content":387,"callToActionText":19,"callToActionLink":19,"colorStyle":250,"showAsides":89,"imageUrl":388,"__component":243},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":389,"name":390,"alternativeText":19,"caption":19,"width":20,"height":212,"formats":391,"hash":412,"ext":24,"mime":27,"size":413,"url":414,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":415,"updatedAt":415,"documentId":416,"publishedAt":58,"focalPoint":19},787,"microsoft security.jpg",{"large":392,"small":397,"medium":402,"thumbnail":407},{"ext":24,"url":393,"hash":394,"mime":27,"name":395,"path":19,"size":396,"width":30,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":24,"url":398,"hash":399,"mime":27,"name":400,"path":19,"size":401,"width":21,"height":225},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":24,"url":403,"hash":404,"mime":27,"name":405,"path":19,"size":406,"width":43,"height":231},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":24,"url":408,"hash":409,"mime":27,"name":410,"path":19,"size":411,"width":237,"height":78},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":418,"title":419,"subTitle":420,"content":421,"callToActionText":422,"callToActionLink":423,"colorStyle":208,"showAsides":89,"imageUrl":424,"__component":243},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor onderst