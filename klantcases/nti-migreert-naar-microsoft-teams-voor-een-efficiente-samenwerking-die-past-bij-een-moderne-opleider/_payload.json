work_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":177,"url":412,"hash":413,"mime":180,"name":414,"path":31,"size":415,"width":204,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":123,"id":124,"title":125,"callToActionText":126,"callToActionLinkUrl":127,"body":31,"imageUrl":422},{"id":147,"name":148,"alternativeText":31,"caption":31,"width":149,"height":150,"formats":31,"hash":151,"ext":152,"mime":153,"size":154,"url":155,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":156,"updatedAt":157,"documentId":158,"publishedAt":50},{"id":129,"metaTitle":130,"metaDescription":131,"structuredData":424,"metaImage":31,"metaSocial":427},{"url":133,"@type":134,"@context":135,"provider":425,"areaServed":426,"description":143,"serviceType":144},{"url":137,"name":138,"@type":139},{"name":141,"@type":142},[],[],{"id":6,"title":430,"createdAt":431,"updatedAt":432,"publishedAt":433,"documentId":434,"logo":435},"NTI","2023-09-01T09:19:59.467Z","2023-09-01T09:20:00.653Z","2023-09-01T09:20:00.647Z","vcwvqqxj94wfswis1ixfs0tu",{"id":436,"name":437,"alternativeText":31,"caption":31,"width":438,"height":439,"formats":31,"hash":440,"ext":36,"mime":39,"size":441,"url":442,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":443,"updatedAt":443,"documentId":444,"publishedAt":50},203,"NTI_Logo.png",202,121,"NTI_Logo_9a74f6913f",1.36,"https://incredible-beef-2a6059b946.media.strapiapp.com/NTI_Logo_9a74f6913f.png","2023-09-01T09:19:56.383Z","yzasagukem2wx6sz5hwjshfc",{"id":446,"name":447,"alternativeText":31,"caption":31,"width":173,"height":190,"formats":448,"hash":473,"ext":177,"mime":180,"size":474,"url":475,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":476,"updatedAt":476,"documentId":477,"publishedAt":50},422,"Klantcase_hero_NTI.jpg",{"large":449,"small":455,"medium":461,"thumbnail":467},{"ext":177,"url":450,"hash":451,"mime":180,"name":452,"path":31,"size":453,"width":183,"height":454},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Klantcase_hero_NTI_7b5719dc16.jpg","large_Klantcase_hero_NTI_7b5719dc16","large_Klantcase_hero_NTI.jpg",42.8,391,{"ext":177,"url":456,"hash":457,"mime":180,"name":458,"path":31,"size":459,"width":190,"height":460},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Klantcase_hero_NTI_7b5719dc16.jpg","small_Klantcase_hero_NTI_7b5719dc16","small_Klantcase_hero_NTI.jpg",15.94,195,{"ext":177,"url":462,"hash":463,"mime":180,"name":464,"path":31,"size":465,"width":197,"height":466},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Klantcase_hero_NTI_7b5719dc16.jpg","medium_Klantcase_hero_NTI_7b5719dc16","medium_Klantcase_hero_NTI.jpg",28.29,293,{"ext":177,"url":468,"hash":469,"mime":180,"name":470,"path":31,"size":471,"width":42,"height":472},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Klantcase_hero_NTI_7b5719dc16.jpg","thumbnail_Klantcase_hero_NTI_7b5719dc16","thumbnail_Klantcase_hero_NTI.jpg",5.39,96,"Klantcase_hero_NTI_7b5719dc16",61.55,"https://incredible-beef-2a6059b946.media.strapiapp.com/Klantcase_hero_NTI_7b5719dc16.jpg","2024-01-10T11:30:22.209Z","wdjo6g3ru9l0w2bk6fwtg49n",[479],{"__component":480,"id":481,"title":31,"asideText":31,"underline":81,"centered":81,"blankAside":81,"aside":482,"content":483,"introductionText":31},"global.pagesection",1632,"![NTI_Logo.png](https://incredible-beef-2a6059b946.media.strapiapp.com/NTI_Logo_9a74f6913f.png)","## Versnelde uitrol Microsoft 365\nWelke organisatie heeft er niet mee te maken gehad: een versnelde digitalisering door corona. Ook bij NTI werd thuiswerken in vogelvlucht mogelijk gemaakt, met onder andere Outlook, SharePoint en Teams. “We waren al bezig met de uitrol van Microsoft 365”, vertelt Annemieke. “Al onze bestanden stonden namelijk op lokale netwerkschijven en we wilden de interne en externe samenwerking structureren en beter faciliteren. Het plan was om dat te doen met SharePoint. Door corona werd dit plan urgent en we hebben toen handmatig alle noodzakelijke documentatie overgezet.”\n\n## Hulp vanuit ShareValue\nEen flinke operatie, want er wordt ontzettend veel content geproduceerd voor alle opleidingen, cursussen en examens. Ondertussen was Annemieke ook op zoek gegaan naar een partner die NTI bij de overstap en inrichting van SharePoint kon helpen. “We hebben meerdere partijen gesproken, maar met ShareValue, en Esra en David, voelde ik de klik”, geeft Annemieke aan. “NTI heeft een platte, informele en innovatieve bedrijfscultuur en daar paste ShareValue goed bij. Dat is belangrijk, want we gingen een langdurige en intensieve samenwerking aan.”\n\n## Van afdelingen naar samenwerkingsverbanden\nNa de versnelde overgang naar SharePoint, ontstond de vraag: hoe nu verder? Annemieke: “Esra suggereerde de overstap naar Teams, omdat Teams écht is bedoeld om samen te werken en SharePoint meer is gericht op documentmanagement. Voor ons was Teams nieuw en deze werkwijze voelde dan ook als tijdelijk. Die was vooral ontstaan door corona. Maar dit nieuwe uitgangspunt, de focus op Teams, vroeg om een heel andere manier van samenwerken. En dat had flinke impact op het project.”\n\n“Ons SharePoint-intranet was ingericht op basis van de afdelingen bij NTI”, vervolgt Annemieke. “Nu gingen we ons richten op afdelingsoverstijgende samenwerkingsverbanden. Dus we zijn eerst met Esra, en later met David, aan de slag gegaan met een projectgroep waarin elke afdeling was vertegenwoordigd door een key user. Vervolgens zijn we gaan inventariseren: welke informatie gebruik je, haal of breng je documentatie, wat is de vertrouwelijkheid van deze informatie en met wie deel je het? Zo ontstonden er blauwdrukken van de teams op basis van de samenwerkingsverbanden, inclusief bijbehorende rollen en rechten.”\n\n## Het resultaat: een efficiënte samenwerking\nOndertussen hebben alle 12 de afdelingen bij NTI een eigen Teams-omgeving én zijn er zeven Teams opgezet voor verschillende samenwerkingsverbanden. Bijvoorbeeld voor Marketing en de Schrijversacademie of Opleidingsmanagement en Inkoop. Ook is er een team waar iedereen binnen de organisatie informatie kan terugvinden over de opleidingen, denk aan de planning en leerdoelen.\n\nAnnemieke: “Ik ben echt trots op waar we nu staan. Onze 160 medewerkers werken volgens het uitgangspunt van één kopie van één document op één locatie. Informatie is nu gewoon te halen via een van de Teams. Hiervoor hoeven we dus niet meer te mailen of naar de laatste versie van een document te zoeken. Op deze manier werken we veel efficiënter samen dan voorheen.”\n\n## Positieve samenwerking met ShareValue\n“Esra kwam aan het begin van onze samenwerking direct met goede adviezen en die zijn nu volledig doorgevoerd”, geeft Annemieke aan. “David nam later het stokje van Esra over en heeft trainingen gegeven aan onze key users en medewerkers, ons begeleidt bij het inrichten van governance, en hij was onze vraagbaak. Ook heeft hij voor ons de samenwerkingsverbanden visueel weergegeven met Power BI. Zo ontstond er in het projectteam een goede combinatie tussen kennis van de organisatie, de processen én de techniek. Zowel met Esra als met David hebben we fijn samengewerkt, dat ging heel goed. Ze voelden dan ook echt als onderdeel van het projectteam.”\n\n \n\n## Laatste loodjes\n \n\n“We gaan nu richting het einde van het project”, vertelt Annemieke. “De meeste afdelingen hebben hun bestanden grotendeels in Teams staan en zijn gewend om op deze manier te werken. Nu is het belangrijk dat we scherp zijn op de gestructureerde samenwerking om dit vast te houden. Verder zijn we nog bezig met het toelaten van externen in Teams. Dit is de laatste efficiëntieslag die we nog moeten maken. Deze nieuwe manier van werken, past in ieder geval perfect bij een vooruitstrevende en innovatieve opleider als NTI!”\n\nHeb je vragen naar aanleiding van deze klantcase? Neem contact met ons op via [communicatie@sharevalue.nl](mailto:communicatie@sharevalue.nl)",{"id":485,"metaTitle":486,"metaDescription":487,"structuredData":488,"metaImage":31,"metaSocial":496},46,"NTI & ShareValue – Samenwerking via Microsoft Teams","NTI moderniseert samenwerking met Microsoft Teams, ondersteund door ShareValue, voor efficiënter documentbeheer en communicatie.",{"url":489,"name":486,"@type":490,"author":491,"@context":135,"publisher":492,"mainEntity":493,"description":487,"datePublished":495},"https://www.sharevalue.nl/klantcases/nti-migreert-naar-microsoft-teams-voor-een-efficiente-samenwerking-die-past-bij-een-moderne-opleider","CaseStudy",{"url":137,"name":138,"@type":139},{"url":137,"name":138,"@type":139},{"url":494,"name":430,"@type":139},"https://www.nti.nl","2023-09-15",[],[498,578],{"__component":53,"id":499,"title":500,"aside":31,"postType":501,"limit":6,"expertise":502},144,"Lees ook deze klantcases","klantcases",[503],{"id":17,"title":18,"subTitle":19,"description":20,"shortDescription":21,"slug":22,"createdAt":23,"updatedAt":24,"publishedAt":25,"isCoreExpertise":26,"documentId":27,"image":504,"blocks":507,"midPageBlocks":514,"seo":573},{"id":29,"name":30,"alternativeText":31,"caption":31,"width":32,"height":33,"formats":505,"hash":44,"ext":36,"mime":39,"size":45,"url":46,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":48,"updatedAt":48,"documentId":49,"publishedAt":50},{"thumbnail":506},{"ext":36,"url":37,"hash":38,"mime":39,"name":40,"path":31,"size":41,"width":42,"height":43},[508,511],{"__component":53,"id":54,"title":55,"aside":31,"postType":56,"limit":6,"expertise":509},[510],{"id":17,"title":18,"subTitle":19,"description":20,"shortDescription":21,"slug":22,"createdAt":23,"updatedAt":24,"publishedAt":25,"isCoreExpertise":26,"documentId":2