[{"data":1,"prerenderedAt":596},["ShallowReactive",2],{"collection-klantcases--1535343210":3,"_apollo:default":595},{"data":4,"meta":591},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"expertises":15,"collegas":428,"klant":429,"image":445,"contentBlocks":478,"seo":484,"blocks":497},3,"NTI migreert naar Microsoft Teams voor een efficiënte samenwerking die past bij een moderne opleider","nti-migreert-naar-microsoft-teams-voor-een-efficiente-samenwerking-die-past-bij-een-moderne-opleider","Opleidingsinstituut NTI biedt meer dan 850 online opleidingen aan en valt onder de Salta Group. Voor een vooruitstrevende opleider is een moderne samenwerking en gestructureerd documentbeheer niet meer dan logisch. Dat vond ook Annemieke Stomps, projectmanager IT bij NTI. De hoogste tijd dus om de overstap te maken van de lokale netwerkschijven naar een hedendaags samenwerkingsplatform.","2023-09-01T09:21:28.316Z","2025-04-11T13:58:12.923Z","2023-09-01T09:21:41.175Z","2023-06-30","wsjnpzyz14k0v0otdp1rju8r",[16],{"id":17,"title":18,"subTitle":19,"description":20,"shortDescription":21,"slug":22,"createdAt":23,"updatedAt":24,"publishedAt":25,"isCoreExpertise":26,"documentId":27,"image":28,"blocks":51,"midPageBlocks":168,"seo":423},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":29,"name":30,"alternativeText":31,"caption":31,"width":32,"height":33,"formats":34,"hash":44,"ext":36,"mime":39,"size":45,"url":46,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":48,"updatedAt":48,"documentId":49,"publishedAt":50},16,"microsoft-365.png",null,282,130,{"thumbnail":35},{"ext":36,"url":37,"hash":38,"mime":39,"name":40,"path":31,"size":41,"width":42,"height":43},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,245,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","strapi-provider-upload-strapi-cloud","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa","2026-01-05T12:38:34.018Z",[52,145],{"__component":53,"id":54,"title":55,"aside":31,"postType":56,"limit":6,"expertise":57},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",[58],{"id":17,"title":18,"subTitle":19,"description":20,"shortDescription":21,"slug":22,"createdAt":23,"updatedAt":24,"publishedAt":25,"isCoreExpertise":26,"documentId":27,"image":59,"blocks":62,"midPageBlocks":73,"seo":128},{"id":29,"name":30,"alternativeText":31,"caption":31,"width":32,"height":33,"formats":60,"hash":44,"ext":36,"mime":39,"size":45,"url":46,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":48,"updatedAt":48,"documentId":49,"publishedAt":50},{"thumbnail":61},{"ext":36,"url":37,"hash":38,"mime":39,"name":40,"path":31,"size":41,"width":42,"height":43},[63,64],{"__component":53,"id":54,"title":55,"aside":31,"postType":56,"limit":6},{"__component":65,"id":66,"titleLeft":67,"callToActionTextLeft":68,"callToActionLinkUrlLeft":69,"titleRight":70,"callToActionTextRight":71,"callToActionLinkUrlRight":72},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[74,82,89,94,99,105,110,117,122],{"__component":75,"id":76,"title":77,"subTitle":78,"content":79,"callToActionText":31,"callToActionLink":31,"colorStyle":80,"showAsides":81},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"__component":75,"id":83,"title":84,"subTitle":85,"content":86,"callToActionText":87,"callToActionLink":69,"colorStyle":88,"showAsides":81},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":75,"id":90,"title":91,"subTitle":92,"content":93,"callToActionText":31,"callToActionLink":31,"colorStyle":80,"showAsides":81},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":75,"id":95,"title":96,"subTitle":97,"content":98,"callToActionText":31,"callToActionLink":31,"colorStyle":88,"showAsides":81},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":75,"id":100,"title":101,"subTitle":102,"content":103,"callToActionText":104,"callToActionLink":69,"colorStyle":80,"showAsides":81},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":75,"id":106,"title":107,"subTitle":108,"content":109,"callToActionText":31,"callToActionLink":31,"colorStyle":88,"showAsides":81},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":75,"id":111,"title":112,"subTitle":113,"content":114,"callToActionText":115,"callToActionLink":116,"colorStyle":80,"showAsides":81},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":75,"id":118,"title":119,"subTitle":120,"content":121,"callToActionText":31,"callToActionLink":31,"colorStyle":88,"showAsides":81},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":123,"id":124,"title":125,"callToActionText":126,"callToActionLinkUrl":127,"body":31},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":129,"metaTitle":130,"metaDescription":131,"structuredData":132},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":133,"@type":134,"@context":135,"provider":136,"areaServed":140,"description":143,"serviceType":144},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":137,"name":138,"@type":139},"https://www.sharevalue.nl","ShareValue","Organization",{"name":141,"@type":142},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":65,"id":66,"titleLeft":67,"callToActionTextLeft":68,"callToActionLinkUrlLeft":69,"titleRight":70,"callToActionTextRight":71,"callToActionLinkUrlRight":72,"iconUrlLeft":146,"iconUrlRight":159},{"id":147,"name":148,"alternativeText":31,"caption":31,"width":149,"height":150,"formats":31,"hash":151,"ex