[{"data":1,"prerenderedAt":624},["ShallowReactive",2],{"collection-klantcases--1580458324":3,"_apollo:default":623},{"data":4,"meta":620},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"collegas":15,"image":16,"klant":59,"contentBlocks":77,"seo":88,"expertises":106,"blocks":510},8,"(Corona)-digitalisering binnen KLM Health Services","corona-digitalisering-binnen-klm-health-services","KLM Health Services is een zelfstandige organisatie op het gebied van werken, reizen en gezondheid. Van eerste hulp en medische ondersteuning tot vaccinaties, health check-ups en lifestyle-programma’s. Om al deze diensten te kunnen leveren is KLM Health Services volop bezig met digitalisering van de processen.","2023-09-01T09:44:28.777Z","2025-04-11T14:04:05.450Z","2023-09-01T09:45:30.239Z","2021-06-15","jrs8zr0ihpponcsrbqncdrh2",[],{"id":17,"name":18,"alternativeText":19,"caption":19,"width":20,"height":21,"formats":22,"hash":52,"ext":24,"mime":27,"size":53,"url":54,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":19},421,"klm_health_services.jpg",null,1280,500,{"large":23,"small":32,"medium":38,"thumbnail":45},{"ext":24,"url":25,"hash":26,"mime":27,"name":28,"path":19,"size":29,"width":30,"height":31},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_klm_health_services_453ce77679.jpg","large_klm_health_services_453ce77679","image/jpeg","large_klm_health_services.jpg",70.91,1000,391,{"ext":24,"url":33,"hash":34,"mime":27,"name":35,"path":19,"size":36,"width":21,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_klm_health_services_453ce77679.jpg","small_klm_health_services_453ce77679","small_klm_health_services.jpg",20.69,195,{"ext":24,"url":39,"hash":40,"mime":27,"name":41,"path":19,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_klm_health_services_453ce77679.jpg","medium_klm_health_services_453ce77679","medium_klm_health_services.jpg",42.1,750,293,{"ext":24,"url":46,"hash":47,"mime":27,"name":48,"path":19,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_klm_health_services_453ce77679.jpg","thumbnail_klm_health_services_453ce77679","thumbnail_klm_health_services.jpg",5.85,245,96,"klm_health_services_453ce77679",109.26,"https://incredible-beef-2a6059b946.media.strapiapp.com/klm_health_services_453ce77679.jpg","strapi-provider-upload-strapi-cloud","2024-01-05T13:04:18.357Z","qhu656tgkufib2k9ic6cihbm","2026-01-05T12:38:34.018Z",{"id":6,"title":60,"createdAt":61,"updatedAt":62,"publishedAt":63,"documentId":64,"logo":65},"KLM","2023-09-01T09:45:15.621Z","2023-09-01T09:45:16.575Z","2023-09-01T09:45:16.567Z","g04o0cm8449p4bk8wbwkrvpm",{"id":66,"name":67,"alternativeText":19,"caption":19,"width":68,"height":69,"formats":19,"hash":70,"ext":71,"mime":72,"size":73,"url":74,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":75,"updatedAt":75,"documentId":76,"publishedAt":58,"focalPoint":19},212,"klm_health_services_logo_1.png",177,100,"klm_health_services_logo_1_e75e740c8a",".png","image/png",3.32,"https://incredible-beef-2a6059b946.media.strapiapp.com/klm_health_services_logo_1_e75e740c8a.png","2023-09-01T09:45:13.316Z","ups822svr4ywommd1a2ui9g6",[78,84],{"id":79,"title":19,"asideText":80,"underline":81,"centered":81,"blankAside":81,"aside":19,"content":82,"introductionText":19,"__component":83},1621,"SAMENWERKINGSHOOGTEPUNTEN",false,"- Meehelpen aan een gezondere wereld\n- Component based platform\n- React Native framework\n- Cross-platform applicaties\n\n\n## PCR afsprakenplanner\nBegin 2020 brak de wereldwijde corona-epidemie uit. Al gauw konden mensen een PCR-test laten afnemen. KLM Health Services heeft een team samengesteld van ontwikkelaars en analisten die meewerkten aan de ontwikkeling van de PCR afsprakenplanner. Op verschillende locaties kunnen de PCR testen afgenomen worden en wordt er nauw samengewerkt met diverse laboratoria waaronder Reinier Haga. Het volledige proces is gedigitaliseerd, van afspraak maken tot het ontvangen van de uitslag.\n\nVoor de ontwikkeling van het platform, had KLM Health Services een developer nodig die expert was op gebied van React en die goed kan samenwerken met requirement engineers, business analisten en Back-End Developers om een state of the art product op te leveren. Hiervoor zochten zij contact met ShareValue en kwamen we tot de conclusie dat onze Developer Rudy hiervoor de ideale kandidaat is.\n\nRudy vertelt: “Het platform is component based ontwikkeld waarbij ieder component zijn eigen verantwoordelijkheid heeft. Hiermee zijn de componenten herbruikbaar, wordt er sneller ontwikkeld, voorkom je onnodige complexiteit en heb je een goed gestructureerde applicatie.","global.pagesection",{"id":85,"title":19,"asideText":19,"underline":81,"centered":81,"blankAside":81,"aside":86,"content":87,"introductionText":19,"__component":83},1622,"![klm_health_services_logo_1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/klm_health_services_logo_1_e75e740c8a.png)","\n## Healthy Me App\nNaast de ontwikkeling van het platform wordt er volop ontwikkeld aan de Healthy Me App. Met deze app heb je altijd en overal toegang tot je medische gegevens en informatie rondom preventie, verzuim en re-integratie. De app is gemaakt met het React Native framework. Met dit framework kunnen cross-platform apps gebouwd worden voor o.a. iOS en Android. De app is ontwikkeld vanuit één set broncode en stelt je in staat om native views te renderen. Hiermee is de app niet te onderscheiden van apps die ontwikkeld zijn met bijvoorbeeld Swift.\n\n“Ik ben blij dat ik met deze interessante innovatie kon bijspringen bij KLM Health Services. Ik mag mooie dingen bouwen in React en kan meehelpen aan een gezondere wereld,” aldus Rudy.\n\nHeb je vragen naar aanleiding van deze klantcase? Neem contact met ons op via [communicatie@sharevalue.nl](mailto:communicatie@sharevalue.nl)",{"id":89,"metaTitle":90,"metaDescription":91,"structuredData":92,"metaImage":19,"metaSocial":105},52,"KLM Health Services & ShareValue – Digitale zorgoplossingen","KLM Health Services versnelt digitalisering met ShareValue: ontwikkeling van een PCR-afsprakenplanner en de Healthy Me App voor efficiënte zorgprocessen.",{"url":93,"name":90,"@type":94,"author":95,"@context":99,"publisher":100,"mainEntity":101,"description":91,"datePublished":104},"https://www.sharevalue.nl/klantcases/corona-digitalisering-binnen-klm-health-services","CaseStudy",{"url":96,"name":97,"@type":98},"https://www.sharevalue.nl","ShareValue","Organization","https://schema.org",{"url":96,"name":97,"@type":98},{"url":102,"name":103,"@type":98},"https://www.klmhealthservices.com","KLM Health Services","2025-01-24",[],[107,323],{"id":108,"title":109,"subTitle":110,"description":111,"shortDescription":112,"slug":113,"createdAt":114,"updatedAt":115,"publishedAt":116,"isCoreExpertise":81,"documentId":117,"image":118,"seo":19,"blocks":135,"midPageBlocks":175},2,"Front-End","Steeds complexer en steeds belangrijker","In een online wereld vol moderne webapplicaties is een goede Front-End onmisbaar. Het is nodig om aan de behoeften en verwachtingen van de gebruikers te voldoen. De interactie voor de gebruiker moet daarbij zo snel en optimaal mogelijk zijn. Met trots kunnen wij zeggen dat juist dáár de kracht van onze Front-End Developers zit.\n\nOnze ervaren Developers staan klaar om jouw team te versterken en te zorgen voor een optimale gebruikerservaring. Of je nu een tijdelijke aanvulling op je team nodig hebt of op zoek bent naar gespecialiseerde kennis voor een specifiek project, onze Front-End Developers zijn uitgerust om de uitdagingen van onze klanten aan te gaan en hun doelen te bereiken.","Onze Front-End developers zijn bedreven in diverse programmeertalen, frameworks en methodieken en daardoor breed inzetbaar.","fron