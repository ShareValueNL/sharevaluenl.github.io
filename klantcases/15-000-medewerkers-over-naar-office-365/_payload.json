[{"data":1,"prerenderedAt":646},["ShallowReactive",2],{"collection-klantcases-941890306":3,"_apollo:default":645},{"data":4,"meta":641},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"expertises":15,"collegas":429,"klant":456,"image":485,"contentBlocks":519,"seo":533,"blocks":547},10,"15.000 medewerkers over naar Office 365","15-000-medewerkers-over-naar-office-365","Veiligere omgang met clientgegevens (privacybescherming) en overstap naar Office 365. Dat was het doel van het project. Het zijn maar een paar woorden, maar het was het grootste IT-project voor zorgorganisatie ’s Heeren Loo in 10 jaar. Ruim 15.000 medewerkers voorzien van een vernieuwde digitale werkplek en meenemen in een nieuwe manier van werken.","2023-09-01T09:47:38.395Z","2025-04-11T14:16:04.292Z","2023-09-01T09:49:36.025Z","2020-07-17","bhjy6wj3u2fw27bdypuvpn05",[16],{"id":17,"title":18,"subTitle":19,"description":20,"shortDescription":21,"slug":22,"createdAt":23,"updatedAt":24,"publishedAt":25,"isCoreExpertise":26,"documentId":27,"image":28,"blocks":51,"midPageBlocks":169,"seo":424},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":29,"name":30,"alternativeText":31,"caption":31,"width":32,"height":33,"formats":34,"hash":44,"ext":36,"mime":39,"size":45,"url":46,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":48,"updatedAt":48,"documentId":49,"publishedAt":50},16,"microsoft-365.png",null,282,130,{"thumbnail":35},{"ext":36,"url":37,"hash":38,"mime":39,"name":40,"path":31,"size":41,"width":42,"height":43},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,245,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","strapi-provider-upload-strapi-cloud","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa","2026-01-05T12:38:34.018Z",[52,146],{"__component":53,"id":54,"title":55,"aside":31,"postType":56,"limit":57,"expertise":58},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",3,[59],{"id":17,"title":18,"subTitle":19,"description":20,"shortDescription":21,"slug":22,"createdAt":23,"updatedAt":24,"publishedAt":25,"isCoreExpertise":26,"documentId":27,"image":60,"blocks":63,"midPageBlocks":74,"seo":129},{"id":29,"name":30,"alternativeText":31,"caption":31,"width":32,"height":33,"formats":61,"hash":44,"ext":36,"mime":39,"size":45,"url":46,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":48,"updatedAt":48,"documentId":49,"publishedAt":50},{"thumbnail":62},{"ext":36,"url":37,"hash":38,"mime":39,"name":40,"path":31,"size":41,"width":42,"height":43},[64,65],{"__component":53,"id":54,"title":55,"aside":31,"postType":56,"limit":57},{"__component":66,"id":67,"titleLeft":68,"callToActionTextLeft":69,"callToActionLinkUrlLeft":70,"titleRight":71,"callToActionTextRight":72,"callToActionLinkUrlRight":73},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[75,83,90,95,100,106,111,118,123],{"__component":76,"id":77,"title":78,"subTitle":79,"content":80,"callToActionText":31,"callToActionLink":31,"colorStyle":81,"showAsides":82},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"__component":76,"id":84,"title":85,"subTitle":86,"content":87,"callToActionText":88,"callToActionLink":70,"colorStyle":89,"showAsides":82},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":76,"id":91,"title":92,"subTitle":93,"content":94,"callToActionText":31,"callToActionLink":31,"colorStyle":81,"showAsides":82},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":76,"id":96,"title":97,"subTitle":98,"content":99,"callToActionText":31,"callToActionLink":31,"colorStyle":89,"showAsides":82},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":76,"id":101,"title":102,"subTitle":103,"content":104,"callToActionText":105,"callToActionLink":70,"colorStyle":81,"showAsides":82},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":76,"id":107,"title":108,"subTitle":109,"content":110,"callToActionText":31,"callToActionLink":31,"colorStyle":89,"showAsides":82},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":76,"id":112,"title":113,"subTitle":114,"content":115,"callToActionText":116,"callToActionLink":117,"colorStyle":81,"showAsides":82},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":76,"id":119,"title":120,"subTitle":121,"content":122,"callToActionText":31,"callToActionLink":31,"colorStyle":89,"showAsides":82},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":124,"id":125,"title":126,"callToActionText":127,"callToActionLinkUrl":128,"body":31},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":130,"metaTitle":131,"metaDescription":132,"structuredData":133},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":134,"@type":135,"@context":136,"provider":137,"areaServed":141,"description":144,"serviceType":145},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":138,"name":139,"@type":140},"https://www.sharevalue.nl","ShareValue","Organization",{"name":142,"@type":143},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":66,"id":67,"titleLeft":68,"callToActionTextLeft":69,"callToActionLinkUrlLeft":70,"titleRight":71,"callToActionTextRight":72,"callToActionLinkUrlRight":73,"iconUrlLeft":147,"iconUrlRight":160},{"id":148,"name":149,"alternativeText":31,"caption":31,"width":150,"height":151,"formats":31,"hash":152,"ext":153,"mime":154,"size":155,"url":156,"previewUrl":31,"provider":47,"provider_metadata":31,"createdAt":157,"updatedAt":158,"documentId":159,"publishedAt":50