[{"data":1,"prerenderedAt":625},["ShallowReactive",2],{"collection-klantcases-1393106327":3,"_apollo:default":624},{"data":4,"meta":620},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"collegas":15,"image":16,"klant":59,"contentBlocks":102,"seo":125,"expertises":142,"blocks":524},11,"De continue bereikbaarheid van een alarmcentrale","de-continue-bereikbaarheid-van-een-alarmcentrale","Een alarmcentrale moet te allen tijde bereikbaar zijn. Ook als er een storing is of als er onderhoud plaatsvindt. Dit heeft dan ook de primaire focus bij het ontwikkelen van de nieuwe meldkamerapplicatie, waar een team van ontwikkelaars van KPN, met hulp van ShareValue-expertise, mee bezig is.","2023-09-01T09:53:11.000Z","2025-04-11T14:16:41.979Z","2023-09-01T09:53:12.600Z","2019-05-21","c8l7ugt3hlswtg8zrog0jjj0",[],{"id":17,"name":18,"alternativeText":19,"caption":19,"width":20,"height":21,"formats":22,"hash":52,"ext":24,"mime":27,"size":53,"url":54,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":19},404,"header_nieuwe_website_kpn (1).jpg",null,1280,500,{"large":23,"small":32,"medium":38,"thumbnail":45},{"ext":24,"url":25,"hash":26,"mime":27,"name":28,"path":19,"size":29,"width":30,"height":31},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_header_nieuwe_website_kpn_1_2eca8b416f.jpg","large_header_nieuwe_website_kpn_1_2eca8b416f","image/jpeg","large_header_nieuwe_website_kpn (1).jpg",45.42,1000,391,{"ext":24,"url":33,"hash":34,"mime":27,"name":35,"path":19,"size":36,"width":21,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_header_nieuwe_website_kpn_1_2eca8b416f.jpg","small_header_nieuwe_website_kpn_1_2eca8b416f","small_header_nieuwe_website_kpn (1).jpg",13.93,195,{"ext":24,"url":39,"hash":40,"mime":27,"name":41,"path":19,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_header_nieuwe_website_kpn_1_2eca8b416f.jpg","medium_header_nieuwe_website_kpn_1_2eca8b416f","medium_header_nieuwe_website_kpn (1).jpg",27.21,750,293,{"ext":24,"url":46,"hash":47,"mime":27,"name":48,"path":19,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_header_nieuwe_website_kpn_1_2eca8b416f.jpg","thumbnail_header_nieuwe_website_kpn_1_2eca8b416f","thumbnail_header_nieuwe_website_kpn (1).jpg",4.65,245,96,"header_nieuwe_website_kpn_1_2eca8b416f",72.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/header_nieuwe_website_kpn_1_2eca8b416f.jpg","strapi-provider-upload-strapi-cloud","2023-11-17T10:17:40.174Z","ftxsk34gfgds95vo6tylwiid","2026-01-05T12:38:34.018Z",{"id":6,"title":60,"createdAt":61,"updatedAt":62,"publishedAt":63,"documentId":64,"logo":65},"KPN","2023-12-18T15:20:49.639Z","2023-12-18T15:20:50.483Z","2023-12-18T15:20:50.477Z","n0wyeq4ualyfl9mwb5lmdt9y",{"id":66,"name":67,"alternativeText":19,"caption":19,"width":68,"height":69,"formats":70,"hash":97,"ext":72,"mime":75,"size":98,"url":99,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":100,"updatedAt":100,"documentId":101,"publishedAt":58,"focalPoint":19},215,"kpn-logo.png",1957,822,{"large":71,"small":79,"medium":85,"thumbnail":91},{"ext":72,"url":73,"hash":74,"mime":75,"name":76,"path":19,"size":77,"width":30,"height":78},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/large_kpn_logo_1981cfeb71.png","large_kpn_logo_1981cfeb71","image/png","large_kpn-logo.png",171.27,420,{"ext":72,"url":80,"hash":81,"mime":75,"name":82,"path":19,"size":83,"width":21,"height":84},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_kpn_logo_1981cfeb71.png","small_kpn_logo_1981cfeb71","small_kpn-logo.png",59.63,210,{"ext":72,"url":86,"hash":87,"mime":75,"name":88,"path":19,"size":89,"width":43,"height":90},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_kpn_logo_1981cfeb71.png","medium_kpn_logo_1981cfeb71","medium_kpn-logo.png",108.7,315,{"ext":72,"url":92,"hash":93,"mime":75,"name":94,"path":19,"size":95,"width":50,"height":96},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_kpn_logo_1981cfeb71.png","thumbnail_kpn_logo_1981cfeb71","thumbnail_kpn-logo.png",21.99,103,"kpn_logo_1981cfeb71",71.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/kpn_logo_1981cfeb71.png","2023-09-01T09:51:14.355Z","dijckdisprrzarxk8mrh22a5",[103,109,113,117,121],{"id":104,"title":19,"asideText":105,"underline":106,"centered":106,"blankAside":106,"aside":19,"content":107,"introductionText":19,"__component":108},1612,"Verstoringen automatisch oplossen",false,"## Geen handwerk meer\nBij het oude systeem was het voorkomen en oplossen van downtime handwerk. Met het nieuwe systeem is dit niet meer zo. Het systeem kan verstoringen automatisch oplossen; als er een onderdeel faalt, neemt een ander onderdeel de werking over. Ook is aan ‘release management’ gedacht. Zo kunnen bijvoorbeeld verschillende versies van de software naast elkaar draaien, zodat de dienst altijd volledig beschikbaar blijft.","global.pagesection",{"id":110,"title":19,"asideText":111,"underline":106,"centered":106,"blankAside":106,"aside":19,"content":112,"introductionText":19,"__component":108},1613,"Nieuwe versie van de Client-applicatie","## Verbetering gebruikerservaring centralisten\nDe centralisten op de meldkamer werken met de client-applicatie. Deze applicatie bestuurt alle functionaliteiten van de telefoon (zoals opnemen, ophangen en contacten bekijken). De applicatie maakt het werk van de centralisten eenvoudiger. En in de toekomst nog prettiger: de nieuwe versie heeft een verbeterde User Interface.",{"id":114,"title":19,"asideText":19,"underline":106,"centered":106,"blankAside":106,"aside":115,"content":116,"introductionText":19,"__component":108},1614,"![kpn-logo.png](https://incredible-beef-2a6059b946.media.strapiapp.com/kpn_logo_1981cfeb71.png)","\n## De rol van ShareValue\nOnze .NET expert Brian is betrokken bij dit project. Hij houdt zich bezig met het uitbreiden van functionaliteit en het oplossen van bevindingen. Dit in een Agile Software Development team, nauw samenwerkend met een Infra- en Telefoon-team.",{"id":118,"title":19,"asideText":119,"underline":106,"centered":106,"blankAside":106,"aside":19,"content":120,"introductionText":19,"__component":108},1616,"Letterlijk van levensbelang","## Professionaliteit is van levensbelang!\nEmiel was in het verleden al betrokken bij de eerste versie van deze meldkamer-oplossing. Vanuit die ervaring was de beslissing snel genomen om hem weer aan het team toe te voegen. Professionaliteit van de betrokken teamleden is in dit geval letterlijk van levensbelang.",{"id":122,"title":19,"asideText":123,"underline":106,"centered":106,"blankAside":106,"aside":19,"content":124,"introductionText":19,"__component":108},1615,"​Geen downtime","## Trots dat we kunnen helpen\nWe zijn als ShareValue trots en blij dat we deel mogen zijn van zo’n complex en maatschappelijk belangrijk project. Dat de alarmcentrale goed werkt en geen downtime heeft is van belang voor de openbare orde en veiligheid in ons land. Goed om aan bij te kunnen dragen.\n\nKunnen we met onze .NET-expertise ook jou helpen bij een interessant vraagstuk? Wellicht wel! [Neem contact met ons op](mailto:communicatie@sharevalue.nl) en wij kijken of we iemand hebben die precies in jouw puzzel past.",{"id":126,"metaTitle":127,"metaDescription":128,"structuredData":129,"metaImage":19,"metaSocial":141},56,"KPN & ShareValue – Alarmcentrale zonder downtime","KPN ontwikkelt met ShareValue een robuuste meldkamerapplicatie met automatische failover en verbeterde gebruikerservaring voor centralisten.",{"url":130,"name":127,"@type":131,"author":132,"@context":136,"publisher":137,"mainEntity":138,"description":128,"datePublished":140},"https://www.sharevalue.nl/klantcases/de-continue-bereikbaarheid-van-een-alarmcentrale","CaseStudy",{"url":133,"name":134,"@type":135},"https://www.sharevalue.nl","ShareValue","Organization","https://schema.org",{"url":133,"name":134,"@type":135},{"url":139,"name":60,"@type":135},"https://www.kpn.com","2025-01-24",[],[143,322],{"id":144,"title":145,"subTitle":146,"description":147,"shortDescription":148,"slug":149,"createdAt":150,"updatedAt":151,"publishedAt":152,"isCoreExpertise":106,"documentId":153,"image":154,"seo":19,"blocks":171,"midPageBlocks":207},3,"Microsoft .NET","Maatwerkoplossingen voor ieder vraagstuk","Ons team van .NET-experts staat niet alleen klaar om onze klanten te ondersteunen bij diverse implementatie uitdagingen, maar we zijn ook gespecialiseerd in het testen van applicaties op verschillende niveaus, zoals unit tests, integratietests en acceptatietests. We streven naar uitmuntende testdekking om de stabiliteit en betrouwbaarheid van de applicaties te waarborgen.\n\nDaarnaast zijn we bedreven in het gebruik van verschillende Azure-services om schaalbare en veilige oplossingen te bieden aan onze klanten. Zo bieden we met Azure DevOps krachtige tools voor het beheren van de ontwikkeling, het automatiseren van tests en het geautomatiseerd uitrollen naar acceptatie- of productieomgevingen met CI/CD-pipelines.\n\nHet samenwerken met onze klanten staat centraal in ons werk, en we denken proactief mee om samen de meest optimale oplossingen te realiseren.","In de praktijk komen de .NET developers van ShareValue terecht in allerlei verschillende branches met uiteenlopende technische uitdagingen.","dotnet","2023-08-17T11:19:57.991Z","2024-12-13T12:16:04.480Z","2023-08-17T11:22:08.050Z","v9pl553hsjk98esvs5gzoso3",{"id":155,"name":156,"alternativeText":19,"caption":19,"width":157,"height":158,"formats":159,"hash":166,"ext":72,"mime":75,"size":167,"url":168,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":169,"updatedAt":169,"documentId":170,"publishedAt":58,"focalPoint":19},17,"dotnet_logo.png",282,130,{"thumbnail":160},{"ext":72,"url":161,"hash":162,"mime":75,"name":163,"path":19,"size":164,"width":50,"height":165},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_dotnet_logo_d38dbc3865.png","thumbnail_dotnet_logo_d38dbc3865","thumbnail_dotnet_logo.png",7.14,113,"dotnet_logo_d38dbc3865",2.93,"https://incredible-beef-2a6059b946.media.strapiapp.com/dotnet_logo_d38dbc3865.png","2023-08-17T09:47:56.313Z","nnimzsossci29qmi8z0texlp",[172,179],{"id":173,"title":174,"aside":19,"postType":175,"limit":144,"expertise":176,"__component":178},167," Lees meer over .NET Development","alle",[177],{"id":144,"title":145,"subTitle":146,"description":147,"shortDescription":148,"slug":149,"createdAt":150,"updatedAt":151,"publishedAt":152,"isCoreExpertise":106,"documentId":153},"strapi.related-kennisbank-list",{"id":180,"titleLeft":181,"callToActionTextLeft":182,"callToActionLinkUrlLeft":183,"titleRight":184,"callToActionTextRight":182,"callToActionLinkUrlRight":183,"iconUrlLeft":185,"iconUrlRight":198,"__component":206},212,"Heb je een .NET expert nodig?","Neem contact met ons op","/contact","Weten welke expert op dit moment beschikbaar is?",{"id":186,"name":187,"alternativeText":19,"caption":19,"width":188,"height":189,"formats":19,"hash":190,"ext":191,"mime":192,"size":193,"url":194,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":195,"updatedAt":196,"documentId":197,"publishedAt":58,"focalPoint":19},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":199,"name":200,"alternativeText":19,"caption":19,"width":189,"height":189,"formats":19,"hash":201,"ext":191,"mime":192,"size":202,"url":203,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":204,"updatedAt":204,"documentId":205,"publishedAt":58,"focalPoint":19},250,"looking-glass.svg","looking_glass_cfa3801802",0.6,"https://incredible-beef-2a6059b946.media.strapiapp.com/looking_glass_cfa3801802.svg","2023-10-11T09:43:10.911Z","suv3p7h0kw7jdnuddk1l2rdu","call-to-action.double",[208,249,282,315],{"id":209,"title":210,"subTitle":19,"content":211,"callToActionText":212,"callToActionLink":183,"colorStyle":19,"showAsides":19,"imageUrl":213,"__component":248},36,"Bouwen en testen","Onze .NET-experts kunnen uiteraard goede en betrouwbare applicaties ontwikkelen met de laatste .NET-versies. Ook zijn onze collega’s ervaren in het onderhouden van oudere software. We kunnen je helpen met het upgraden en uitbreiden van je applicatie zodat deze aan de laatste wensen en eisen voldoet. Het uitvoeren van uitgebreide unit- en integratietests om de stabiliteit van applicaties te waarborgen, wordt meegenomen als standaard onderdeel van het werk. Met een focus op grondige testdekking streven we ernaar om eventuele bugs vroegtijdig op te sporen en op te lossen, waardoor de algehele kwaliteit van jouw product wordt verbeterd.  \n\nVan Blazor Front-End of REST API’s tot database communicatie, onze .NET-experts hebben er ruime ervaring mee.","Weten wat onze experts voor jou kunnen doen?",{"id":214,"name":215,"alternativeText":19,"caption":19,"width":20,"height":216,"formats":217,"hash":243,"ext":24,"mime":27,"size":244,"url":245,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":246,"updatedAt":246,"documentId":247,"publishedAt":58,"focalPoint":19},790,"code matrix.jpg",850,{"large":218,"small":224,"medium":230,"thumbnail":236},{"ext":24,"url":219,"hash":220,"mime":27,"name":221,"path":19,"size":222,"width":30,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_code_matrix_939256fff4.jpg","large_code_matrix_939256fff4","large_code matrix.jpg",164.22,664,{"ext":24,"url":225,"hash":226,"mime":27,"name":227,"path":19,"size":228,"width":21,"height":229},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_code_matrix_939256fff4.jpg","small_code_matrix_939256fff4","small_code matrix.jpg",42.02,332,{"ext":24,