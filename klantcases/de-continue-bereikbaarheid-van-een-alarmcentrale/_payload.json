ze":266,"width":21,"height":229},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_service_bus_2b48e3a7cc.jpg","small_service_bus_2b48e3a7cc","small_service bus.jpg",29.35,{"ext":24,"url":268,"hash":269,"mime":27,"name":270,"path":19,"size":271,"width":43,"height":235},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_service_bus_2b48e3a7cc.jpg","medium_service_bus_2b48e3a7cc","medium_service bus.jpg",54.72,{"ext":24,"url":273,"hash":274,"mime":27,"name":275,"path":19,"size":276,"width":241,"height":242},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_service_bus_2b48e3a7cc.jpg","thumbnail_service_bus_2b48e3a7cc","thumbnail_service bus.jpg",8.71,"service_bus_2b48e3a7cc",117.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/service_bus_2b48e3a7cc.jpg","2024-08-09T08:35:35.231Z","rbpawsulv6vrsistrk2yupwg",{"id":283,"title":284,"subTitle":19,"content":285,"callToActionText":19,"callToActionLink":19,"colorStyle":19,"showAsides":19,"imageUrl":286,"__component":248},35,"Houd het veilig!","Om de toegang tot je producten veilig te houden, kan ons team van .NET-experts je helpen bij het opzetten en onderhouden van authenticatie en autorisatie. Onze experts zijn ervaren in het opzetten de juiste entra diensten zodat de toegang tot zowel Front-End als Back-End of deamon-processen op een juiste manier afgehandeld wordt. Ook kunnen we je helpen met het opzetten van verschillende groepen, rechten en rollen, en deze op de juiste manier toepassen binnen de applicatie zodat onterechte toegang op functieniveau geregeld kan worden. Bij het opzetten en implementeren wordt er rekening gehouden met het reduceren van de administratieve overhead zonder concessies te doen aan de beveiliging.",{"id":287,"name":288,"alternativeText":19,"caption":19,"width":20,"height":216,"formats":289,"hash":310,"ext":24,"mime":27,"size":311,"url":312,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":313,"updatedAt":313,"documentId":314,"publishedAt":58,"focalPoint":19},792,"security dotnet.jpg",{"large":290,"small":295,"medium":300,"thumbnail":305},{"ext":24,"url":291,"hash":292,"mime":27,"name":293,"path":19,"size":294,"width":30,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_dotnet_a65d687baf.jpg","large_security_dotnet_a65d687baf","large_security dotnet.jpg",38.7,{"ext":24,"url":296,"hash":297,"mime":27,"name":298,"path":19,"size":299,"width":21,"height":229},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_dotnet_a65d687baf.jpg","small_security_dotnet_a65d687baf","small_security dotnet.jpg",13.37,{"ext":24,"url":301,"hash":302,"mime":27,"name":303,"path":19,"size":304,"width":43,"height":235},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_dotnet_a65d687baf.jpg","medium_security_dotnet_a65d687baf","medium_security dotnet.jpg",24.75,{"ext":24,"url":306,"hash":307,"mime":27,"name":308,"path":19,"size":309,"width":241,"height":242},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_dotnet_a65d687baf.jpg","thumbnail_security_dotnet_a65d687baf","thumbnail_security dotnet.jpg",4.63,"security_dotnet_a65d687baf",57.25,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_dotnet_a65d687baf.jpg","2024-08-09T08:36:56.895Z","srupv8bm7kvcgseu2efeadhk",{"id":316,"title":317,"callToActionText":318,"callToActionLinkUrl":319,"body":19,"imageUrl":320,"__component":321},46,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij KPN","/klantcases/de-continue-bereikbaarheid-van-een-alarmcentrale",{"id":186,"name":187,"alternativeText":19,"caption":19,"width":188,"height":189,"formats":19,"hash":190,"ext":191,"mime":192,"size":193,"url":194,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":195,"updatedAt":196,"documentId":197,"publishedAt":58,"focalPoint":19},"call-to-action.single",{"id":323,"title":324,"subTitle":146,"description":325,"shortDescription":326,"slug":327,"createdAt":328,"updatedAt":329,"publishedAt":330,"isCoreExpertise":331,"documentId":332,"image":333,"seo":348,"blocks":362,"midPageBlocks":406},10,"Development","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. Van gebruiksvriendelijke interfaces tot krachtige Back-End-architecturen: wij hebben de kennis en ervaring om jouw project tot een succes te maken.","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. ","development","2024-12-13T12:15:40.484Z","2025-04-11T13:13:55.384Z","2024-12-13T12:15:42.976Z",true,"lpzfadokpxn5sdnx9czcdg47",{"id":334,"name":335,"alternativeText":19,"caption":19,"width":157,"height":158,"formats":336,"hash":342,"ext":72,"mime":75,"size":343,"url":344,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":345,"updatedAt":346,"documentId":347,"publishedAt":58,"focalPoint":19},950,"Logo Development 2025 web.png",{"thumbnail":337},{"ext":72,"url":338,"hash":339,"mime":75,"name":340,"path":19,"size":341,"width":50,"height":165},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Development_2025_web_d7711df072.png","thumbnail_Logo_Development_2025_web_d7711df072","thumbnail_Logo Development 2025 web.png",8.58,"Logo_Development_2025_web_d7711df072",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Development_2025_web_d7711df072.png","2024-12-17T15:02:47.479Z","2024-12-19T08:35:22.054Z","okwfs117fps338v5fj5dnrpb",{"id":349,"metaTitle":350,"metaDescription":351,"structuredData":352,"metaImage":19,"metaSocial":361},27,"Maatwerk software & integraties – ShareValue Development","Van webapps tot koppelingen: onze developers bouwen slimme oplossingen die passen bij jouw Microsoft-omgeving.",{"url":353,"@type":354,"@context":136,"provider":355,"areaServed":356,"description":359,"serviceType":360},"https://www.sharevalue.nl/wat-we-doen/development","Service",{"url":133,"name":134,"@type":135},{"name":357,"@type":358},"Nederland","Country","Onze developers realiseren maatwerkoplossingen binnen Microsoft-omgevingen. Denk aan webapplicaties, API-integraties, extensies voor Microsoft 365 en koppelingen met externe systemen. Technisch sterk én begrijpelijk ingericht.","Maatwerk softwareontwikkeling en integraties",[],[363,379],{"id":364,"title":365,"aside":19,"postType":175,"limit":144,"expertise":366,"__component":178},179,"Lees meer over Development",[367,368,378],{"id":323,"title":324,"subTitle":146,"description":325,"shortDescription":326,"slug":327,"createdAt":328,"updatedAt":329,"publishedAt":330,"isCoreExpertise":331,"documentId":332},{"id":343,"title":369,"subTitle":370,"description":371,"shortDescription":372,"slug":373,"createdAt":374,"updatedAt":375,"publishedAt":376,"isCoreExpertise":106,"documentId":377},"Front-End","Steeds complexer en steeds belangrijker","In een online wereld vol moderne webapplicaties is een goede Front-End onmisbaar. Het is nodig om aan de behoeften en verwachtingen van de gebruikers te voldoen. De interactie voor de gebruiker moet daarbij zo snel en optimaal mogelijk zijn. Met trots kunnen wij zeggen dat juist dáár de kracht van onze Front-End Developers zit.\n\nOnze ervaren Developers staan klaar om jouw team te versterken en te zorgen voor een optimale gebruikerservaring. Of je nu een tijdelijke aanvulling op je team nodig hebt of op zoek bent naar gespecialiseerde kennis voor een specifiek project, onze Front-End Developers zijn uitgerust om de uitdagingen van onze klanten aan te gaan en hun doelen te bereiken.","Onze Front-End developers zijn bedreven in diverse programmeertalen, frameworks en methodieken en daardoor breed inzetbaar.","front-end","2023-08-17T09:50:12.632Z","2024-12-13T12:15:57.609Z","2023-08-17T09:50:14.418Z","l6bdicvjcb7ue03zpciuc888",{"id":144,"title":145,"subTitle":146,"description":147,"shortDescription":148,"slug":149,"createdAt":150,"updatedAt":151,"publishedAt":152,"isCoreExpertise":106,"documentId":153},{"id":380,"titleLeft":381,"callToActionTextLeft":182,"callToActionLinkUrlLeft":183,"titleRight":382,"callToActionTextRight":383,"callToActionLinkUrlRight":384,"iconUrlLeft":385,"iconUrlRight":396,"__component":206},251,"Heb je een Developer nodig?","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":386,"name":387,"alternativeText":19,"caption":19,"width":388,"height":389,"formats":19,"hash":390,"ext":191,"mime":192,"size":391,"url":392,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":393,"updatedAt":394,"documentId":395,"publishedAt":58,"focalPoint":19},7,"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":397,"name":398,"alternativeText":19,"caption":19,"width":399,"height":389,"formats":19,"hash":400,"ext":191,"mime":192,"size":401,"url":402,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":403,"updatedAt":404,"documentId":405,"publishedAt":58,"focalPoint":19},372,"magnifier.svg",49,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",[407,441,451,485,519],{"id":408,"title":409,"subTitle":19,"content":410,"callToActionText":19,"callToActionLink":19,"colorStyle":411,"showAsides":106,"imageUrl":412,"__component":248},47,"Optimale gebruikerservaring","Een goede Front-End is meer dan alleen een aantrekkelijke interface; het vormt de schakel tussen technologie en eindgebruiker. Onze Developers combineren hun kennis van frameworks zoals React, Angular en Vue met ervaring in geavanceerde technologieën zoals GraphQL en CI/CD pipelines. Dit stelt ons in staat om interactieve, intuïtieve en betrouwbare applicaties te ontwikkelen die voldoen aan de hoogste standaarden.\n\nWij werken nauw samen met UX-designers om via design patterns en design tokens een naadloze integratie van ontwerp naar functionaliteit te realiseren. Dankzij regelmatige LevelUp-sessies, interne projecten en kennisdeling blijven onze Front-End specialisten altijd up-to-date.","Sugar Glaze",{"id":413,"name":414,"alternativeText":19,"caption":19,"width":20,"height":216,"formats":415,"hash":436,"ext":24,"mime":27,"size":437,"url":438,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":439,"updatedAt":439,"documentId":440,"publishedAt":58,"focalPoint":19},904,"development.jpg",{"large":416,"small":421,"medium":426,"thumbnail":431},{"ext":24,"url":417,"hash":418,"mime":27,"name":419,"path":19,"size":420,"width":30,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_development_6e5abdca44.jpg","large_development_6e5abdca44","large_development.jpg",129.5,{"ext":24,"url":422,"hash":423,"mime":27,"name":424,"path":19,"size":425,"width":21,"height":229},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_development_6e5abdca44.jpg","small_development_6e5abdca44","small_development.jpg",47.86,{"ext":24,"url":427,"hash":428,"mime":27,"name":429,"path":19,"size":430,"width":43,"height":235},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_development_6e5abdca44.jpg","medium_development_6e5abdca44","medium_development.jpg",86.06,{"ext":24,"url":432,"hash":433,"mime":27,"name":434,"path":19,"size":435,"width":241,"height":242},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_development_6e5abdca44.jpg","thumbnail_development_6e5abdca44","thumbnail_development.jpg",14.65,"development_6e5abdca44",184.35,"https://incredible-beef-2a6059b946.media.strapiapp.com/development_6e5abdca44.jpg","2024-12-13T12:36:11.969Z","qqi9wubjpzs8w6daj98mtc7a",{"id":399,"title":442,"subTitle":19,"content":443,"callToActionText":19,"callToActionLink":19,"colorStyle":444,"showAsides":106,"imageUrl":445,"__component":248},"Betrouwbaarheid en schaalbaarheid","Voor robuuste Back-End-oplossingen vertrouwen we op onze kennis van .NET. Of het nu gaat om het bouwen van nieuwe applicaties, het onderhouden van bestaande software of het implementeren van geavanceerde authenticatie- en autorisatiesystemen: ons team levert maatwerk dat aansluit bij de specifieke wensen en behoeften van jouw organisatie.\n\nHierbij maken we onder andere gebruik van onze kennis van Azure-services zoals Function Apps, Service Bus en App Services, maar ook tools als Docker en Kubernetes om veilige, schaalbare oplossingen te realiseren.\n\nOnze focus op grondige tests – van unit tests tot integratietests – garandeert stabiliteit en betrouwbaarheid.","White",{"id":254,"name":255,"alternativeText":19,"caption":19,"width":20,"height":216,"formats":446,"hash":277,"ext":24,"mime":27,"size":278,"url":279,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":280,"updatedAt":280,"documentId":281,"publishedAt":58,"focalPoint":19},{"large":447,"small":448,"medium":449,"thumbnail":450},{"ext":24,"url":258,"hash":259,"mime":27,"name":260,"path":19,"size":261,"width":30,"height":223},{"ext":24,"url":263,"hash":264,"mime":27,"name":265,"path":19,"size":266,"width":21,"height":229},{"ext":24,"url":268,"hash":269,"mime":27,"name":270,"path":19,"size":271,"width":43,"height":235},{"ext":24,"url":273,"hash":274,"mime":27,"name":275,"path":19,"size":276,"width":241,"height":242},{"id":452,"title":453,"subTitle":19,"content":454,"callToActionText":19,"callToActionLink":19,"colorStyle":411,"showAsides":106,"imageUrl":455,"__component":248},50,"Full-Stack mogelijkheden","Wat ons uniek maakt, is onze combinatie van Front-End en .NET-expertise. Onze Developers zijn niet alleen gespecialiseerd in het creëren van intuïtieve interfaces, maar beheersen ook de complexiteit van Back-End-architectuur en Azure-integraties. Dit maakt hen volwaardige Full-Stack Developers die moeiteloos schakelen tussen de verschillende onderdelen van jouw project.",{"id":456,"name":457,"alternativeText":19,"caption":19,"width":20,"height":216,"formats":458,"hash":479,"ext":24,"mime":27,"size":480,"url":481,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":482,"updatedAt":483,"documentId":484,"publishedAt":58,"focalPoint":19},778,"stack.jpg",{"large":459,"small":464,"medium":469,"thumbnail":474},{"ext":24,"url":460,"hash":461,"mime":27,"name":462,"path":19,"size":463,"width":30,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_stack_fec3a2bfae.jpg","large_stack_fec3a2bfae","large_stack.jpg",95.19,{"ext":24,"url":465,"hash":466,"mime":27,"name":467,"path":19,"size":468,"width":21,"height":229},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_stack_fec3a2bfae.jpg","small_stack_fec3a2bfae","small_stack.jpg",29.21,{"ext":24,"url":470,"hash":471,"mime":27,"name":472,"path":19,"size":473,"width":43,"height":235},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_stack_fec3a2bfae.jpg","medium_stack_fec3a2bfae","medium_stack.jpg",58.57,{"ext":24,"url":475,"hash":476,"mime":27,"name":477,"path":19,"size":478,"width":241,"height":242},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_stack_fec3a2bfae.jpg","thumbnail_stack_fec3a2bfae","thumbnail_stack.jpg",8.24,"stack_fec3a2bfae",143.32,"https://incredible-beef-2a6059b946.media.strapiapp.com/stack_fec3a2bfae.jpg","2024-08-08T08:26:50.506Z","2024-12-09T10:18:46.269Z","kpz9iiz9dr551k3umhmtwy3k",{"id":486,"title":487,"subTitle":19,"content":488,"callToActionText":489,"callToActionLink":183,"colorStyle":444,"showAsides":106,"imageUrl":490,"__component":248},48,"Samen naar succes","Onze aanpak is erop gericht om samen met jou het optimale resultaat te behalen. Door proactief mee te denken en onze kennis te delen, zorgen we ervoor dat jouw project voldoet aan de hoogste standaarden van gebruiksvriendelijkheid, betrouwbaarheid en veiligheid. Of het nu gaat om een tijdelijke versterking van je team of volledige projectondersteuning: ons Development-team staat voor je klaar.\n\nOntdek wat wij voor jouw project kunnen betekenen."," Neem contact met ons op voor meer informatie!",{"id":491,"name":492,"alternativeText":19,"caption":19,"width":20,"height":216,"formats":493,"hash":514,"ext":24,"mime":27,"size":515,"url":516,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":517,"updatedAt":517,"documentId":518,"publishedAt":58,"focalPoint":19},789,"teamwork.jpg",{"large":494,"small":499,"medium":504,"thumbnail":509},{"ext":24,"url":495,"hash":496,"mime":27,"name":497,"path":19,"size":498,"width":30,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":24,"url":500,"hash":501,"mime":27,"name":502,"path":19,"size":503,"width":21,"height":229},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":24,"url":505,"hash":506,"mime":27,"name":507,"path":19,"size":508,"width":43,"height":235},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":24,"url":510,"hash":511,"mime":27,"name":512,"path":19,"size":513,"width":241,"height":242},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":96,"title":520,"callToActionText":521,"callToActionLinkUrl":522,"body":19,"imageUrl":523,"__compon