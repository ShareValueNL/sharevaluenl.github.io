[{"data":1,"prerenderedAt":590},["ShallowReactive",2],{"collection-klantcases--1969955324":3,"_apollo:default":589},{"data":4,"meta":585},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"collegas":15,"image":16,"klant":59,"contentBlocks":92,"seo":99,"expertises":115,"blocks":491},17,"Adviesbureau NLO rolt Microsoft Teams uit en zet een nieuw intranet op in SharePoint","adviesbureau-nlo-rolt-microsoft-teams-uit-en-zet-een-nieuw-intranet-op-in-share-point","Heb je een fantastische innovatie of wil je graag je merk vastleggen? Dan ben je bij NLO aan het juiste adres. NLO is voor het beschermen van het intellectuele eigendom het grootste adviesbureau in Nederland en België en toonaangevend in de rest van Europa. Hoewel ze Microsoft 365 hadden binnen de organisatie, werd hier nog maar weinig gebruik van gemaakt. Daarom riep NLO de hulp in van ShareValue voor de implementatie, uitrol en adoptie van Microsoft Teams en het opzetten van een nieuw intranet in SharePoint.","2023-12-18T15:59:17.282Z","2025-04-11T13:56:30.525Z","2023-12-18T16:00:55.342Z","2023-11-06","kccpugwx8jof3r2yhw3mnvtd",[],{"id":17,"name":18,"alternativeText":19,"caption":19,"width":20,"height":21,"formats":22,"hash":52,"ext":24,"mime":27,"size":53,"url":54,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":19},418,"KLantcase_NLO_headerafbeelding.jpg",null,1280,500,{"large":23,"small":32,"medium":38,"thumbnail":45},{"ext":24,"url":25,"hash":26,"mime":27,"name":28,"path":19,"size":29,"width":30,"height":31},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_K_Lantcase_NLO_headerafbeelding_9744ce01f6.jpg","large_K_Lantcase_NLO_headerafbeelding_9744ce01f6","image/jpeg","large_KLantcase_NLO_headerafbeelding.jpg",132.07,1000,391,{"ext":24,"url":33,"hash":34,"mime":27,"name":35,"path":19,"size":36,"width":21,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_K_Lantcase_NLO_headerafbeelding_9744ce01f6.jpg","small_K_Lantcase_NLO_headerafbeelding_9744ce01f6","small_KLantcase_NLO_headerafbeelding.jpg",33.93,195,{"ext":24,"url":39,"hash":40,"mime":27,"name":41,"path":19,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_K_Lantcase_NLO_headerafbeelding_9744ce01f6.jpg","medium_K_Lantcase_NLO_headerafbeelding_9744ce01f6","medium_KLantcase_NLO_headerafbeelding.jpg",74.89,750,293,{"ext":24,"url":46,"hash":47,"mime":27,"name":48,"path":19,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_K_Lantcase_NLO_headerafbeelding_9744ce01f6.jpg","thumbnail_K_Lantcase_NLO_headerafbeelding_9744ce01f6","thumbnail_KLantcase_NLO_headerafbeelding.jpg",8.44,245,96,"K_Lantcase_NLO_headerafbeelding_9744ce01f6",215.32,"https://incredible-beef-2a6059b946.media.strapiapp.com/K_Lantcase_NLO_headerafbeelding_9744ce01f6.jpg","strapi-provider-upload-strapi-cloud","2023-12-18T15:59:46.526Z","eu5638kk3tgzsy0z6cffq4gv","2026-01-05T12:38:34.018Z",{"id":60,"title":61,"createdAt":62,"updatedAt":63,"publishedAt":64,"documentId":65,"logo":66},12,"NLO","2023-12-18T15:59:12.715Z","2023-12-18T15:59:14.267Z","2023-12-18T15:59:14.259Z","etww5guakwd4978igs9exqop",{"id":67,"name":68,"alternativeText":19,"caption":19,"width":69,"height":70,"formats":71,"hash":87,"ext":73,"mime":76,"size":88,"url":89,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":90,"updatedAt":90,"documentId":91,"publishedAt":58,"focalPoint":19},417,"Logo_NLO_verkleind.png",558,400,{"small":72,"thumbnail":80},{"ext":73,"url":74,"hash":75,"mime":76,"name":77,"path":19,"size":78,"width":21,"height":79},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/small_Logo_NLO_verkleind_774434cc81.png","small_Logo_NLO_verkleind_774434cc81","image/png","small_Logo_NLO_verkleind.png",49.96,358,{"ext":73,"url":81,"hash":82,"mime":76,"name":83,"path":19,"size":84,"width":85,"height":86},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_NLO_verkleind_774434cc81.png","thumbnail_Logo_NLO_verkleind_774434cc81","thumbnail_Logo_NLO_verkleind.png",18.73,218,156,"Logo_NLO_verkleind_774434cc81",9.63,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_NLO_verkleind_774434cc81.png","2023-12-18T15:58:34.783Z","nk5bni6bq42gje1muacm5ovx",[93],{"id":94,"title":19,"asideText":19,"underline":95,"centered":95,"blankAside":95,"aside":96,"content":97,"introductionText":19,"__component":98},1638,false,"![Logo_NLO_verkleind.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_NLO_verkleind_774434cc81.png)","## Het nieuwe werken: tijd voor een inhaalslag\n“Met onze ICT-infrastructuur maken we een behoorlijke inhaalslag”, vertelt Naresh Malgie, manager ICT bij NLO. “We wilden serieus aan de slag met Microsoft 365 en specifiek Teams. Daarbij riepen we de hulp in van ShareValue. Ik kende hen al vanuit een eerdere samenwerking en voor mij was het niet meer dan logisch om ook dit project met hen op te pakken.”\n\n## Een nieuw intranet met SharePoint\nTegelijk met de uitrol van Teams wilde NLO ook een nieuw intranet opzetten, met relevante nieuwsberichten en verschillende applicaties die medewerkers dagelijks voor hun werk nodig hebben. Naresh: “Ook hierbij betrokken we ShareValue, voor het maken van dit plan en de uitrol ervan.” Er liep al een gigantisch project dat veel vroeg van NLO’s ICT-medewerkers. “Dus hebben we besloten om stapsgewijs te werk te gaan”, vertelt Naresh. “Zo zijn we begonnen met de migratie van de vaste schijven naar SharePoint bij de ondersteunende afdelingen. Andere afdelingen zagen dat dit een fijne werkwijze was en wilden ook hiermee aan de slag. Dit sneeuwbaleffect was exact wat we wilden bereiken.”  \n\n## Actieve SharePoint community\nNa een paar weken werd besloten om het Microsoft 365-traject tijdelijk stop te zetten om alle ruimte te creëren voor de nazorg van het andere grote project. Maar een goedlopend traject stilleggen, dat kan niet, vond Naresh. “Daarom ben ik gaan kijken naar wat we wél konden doen. Zo zijn we samen met de afdeling Marketing & Communicatie (M&C) het intranet gaan opzetten. Zij waren namelijk niet betrokken bij het andere project.” Naresh: “Met hulp van ShareValue heeft het M&C-team de SharePoint-sites helemaal zelf naar wens kunnen configureren. Het M&C-team werd getraind door ShareValue en op hun beurt trainden zij diverse collega’s van afdelingen die ook een SharePoint-site startten. Zo ontstond er een actieve community van betrokken collega’s die feedback gaven en binnen hun team als ambassadeur van SharePoint optraden. Begin oktober zijn we live gegaan met het intranet en het wordt dagelijks volop gebruikt.”\n\n## Uitrol naar de rest van de organisatie\n“Op dit moment is de helft van de NLO-organisatie over op Teams. Dat traject loopt dus nog door. Voor het intranet krijgen we steeds meer aanvragen voor team- of projectsites. Ook zijn we bezig met het opzetten van een ‘smoelenboek’ in Microsoft Power Apps. We vinden het belangrijk dat wanneer je contact hebt met een collega je weet wie het is. Dat praat toch een stuk gemakkelijker in een Teams-meeting. En we zijn bezig met het borgen van alle technische kennis binnen de ICT-afdeling. Zodat dit niet alleen bij de afdeling M&C ligt.”\n\n## De samenwerking met ShareValue\n“Vanuit ShareValue hebben we hulp gehad van diverse specialisten” vertelt Naresh. “Aan de voorkant hielp Ron ons met het opzetten van alle plannen voor de implementatie en uitrol van Microsoft 365. En David ondersteunde ons weer op technisch vlak met de migratie naar Microsoft Teams en SharePoint. Marieke hielp bij de uitrol en het beantwoorden van vragen en Wendy was er voor de medewerkers om ze over hun weerstand of angst te helpen. De kennisoverdracht was goed geregeld en zo alles samen deed het ShareValue-team dit echt fantastisch.” \n\n \n\nHeb je vragen naar aanleiding van deze klantcase? Neem contact met ons op via [communicatie@sharevalue.nl](mailto:communicatie@sharevalue.nl)","global.pagesection",{"id":100,"metaTitle":101,"metaDescription":102,"structuredData":103,"metaImage":19,"metaSocial":114},45,"NLO & ShareValue – Teams en SharePoint implementatie","NLO verbetert samenwerking met Microsoft Teams en een nieuw intranet in SharePoint, ondersteund door ShareValue.",{"url":104,"name":101,"@type":105,"author":106,"@context":110,"publisher":111,"mainEntity":112,"description":102,"datePublished":13},"https://www.sharevalue.nl/klantcases/adviesbureau-nlo-rolt-microsoft-teams-uit-en-zet-een-nieuw-intranet-op-in-share-point","CaseStudy",{"url":107,"name":108,"@type":109},"https://www.sharevalue.nl","ShareValue","Organization","https://schema.org",{"url":107,"name":108,"@type":109},{"url":113,"name":61,"@type":109},"https://www.nlo.eu",[],[116],{"id":117,"title":118,"subTitle":119,"description":120,"shortDescription":121,"slug":122,"createdAt":123,"updatedAt":124,"publishedAt":125,"isCoreExpertise":126,"documentId":127,"image":128,"seo":145,"blocks":159,"midPageBlocks":199},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":129,"name":130,"alternativeText":19,"caption":19,"width":131,"height":132,"formats":133,"hash":140,"ext":73,"mime":76,"size":141,"url":142,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":143,"updatedAt":143,"documentId":144,"publishedAt":58,"focalPoint":19},16,"microsoft-365.png",282,130,{"thumbnail":134},{"ext":73,"url":135,"hash":136,"mime":76,"name":137,"path":19,"size":138,"width":50,"height":139},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":146,"metaTitle":147,"metaDescription":148,"structuredData":149,"metaImage":19,"metaSocial":158},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":150,"@type":151,"@context":110,"provider":152,"areaServed":153,"description":156,"serviceType":157},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":107,"name":108,"@type":109},{"name":154,"@type":155},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[160,168],{"id":161,"title":162,"aside":19,"postType":163,"limit":164,"expertise":165,"__component":167},166,"Lees meer over Microsoft 365","alle",3,[166],{"id":117,"title":118,"subTitle":119,"description":120,"shortDescription":121,"slug":122,"createdAt":123,"updatedAt":124,"publishedAt":125,"isCoreExpertise":126,"documentId":127},"strapi.related-kennisbank-list",{"id":169,"titleLeft":170,"callToActionTextLeft":171,"callToActionLinkUrlLeft":172,"titleRight":173,"callToActionTextRight":174,"callToActionLinkUrlRight":175,"iconUrlLeft":176,"iconUrlRight":189,"__component":198},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":177,"name":178,"alternativeText":19,"caption":19,"width":179,"height":180,"formats":19,"hash":181,"ext":182,"mime":183,"size":184,"url":185,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":186,"updatedAt":187,"documentId":188,"publishedAt":58,"focalPoint":19},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":190,"name":191,"alternativeText":19,"caption":19,"width":180,"height":180,"formats":19,"hash":192,"ext":182,"mime":183,"size":193,"url":194,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":195,"updatedAt":196,"documentId":197,"publishedAt":58,"focalPoint":19},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[200,241,277,311,345,380,414,450,484],{"id":201,"title":202,"subTitle":203,"content":204,"callToActionText":19,"callToActionLink":19,"colorStyle":205,"showAsides":95,"imageUrl":206,"__component":240},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"id":207,"name":208,"alternativeText":19,"caption":19,"width":20,"height":209,"formats":210,"hash":235,"ext":24,"mime":27,"size":236,"url":237,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":238,"updatedAt":238,"documentId":239,"publishedAt":58,"focalPoint":19},782,"Teams.jpg",850,{"large":211,"small":217,"medium":223,"thumbnail":229},{"ext":24,"url":212,"hash":213,"mime":27,"name":214,"path":19,"size":215,"width":30,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Teams_43eca91eed.jpg","large_Teams_43eca91eed","large_Teams.jpg",75.76,664,{"ext":24,"url":218,"hash":219,"mime":27,"name":220,"path":19,"size":221,"width":21,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Teams_43eca91eed.jpg","small_Teams_43eca91eed","small_Teams.jpg",24.28,332,{"ext":24,"url":224,"hash":225,"mime":27,"name":226,"path":19,"size":227,"width":43,"height":228},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Teams_43eca91eed.jpg","medium_Teams_43eca91eed","medium_Teams.jpg",45.38,498,{"ext":24,"url":230,"hash":231,"mime":27,"name":232,"path":19,"size":233,"width":234,"height":86},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Teams_43eca91eed.jpg","thumbnail_Teams_43eca91eed","thumbnail_Teams.jpg",8.28,235,"Teams_43eca91eed",119.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Teams_43eca91eed.jpg","2024-08-08T09:42:56.910Z","ht6rctym4qbbspr1vnahyrg1","global.alternating-page-section",{"id":242,"title":243,"subTitle":244,"content":245,"callToActionText":246,"callToActionLink":172,"colorStyle":247,"showAsides":95,"imageUrl":248,"__component":240},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"id":249,"name":250,"alternativeText":19,"caption":19,"width":20,"height":209,"formats":251,"hash":272,"ext":24,"mime":27,"size":273,"url":274,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":275,"updatedAt":275,"documentId":276,"publishedAt":58,"focalPoint":19},783,"adoptie.jpg",{"large":252,"small":257,"medium":262,"thumbnail":267},{"ext":24,"url":253,"hash":254,"mime":27,"name":255,"path":19,"size":256,"width":30,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_adoptie_dc3bbcacaa.jpg","large_adoptie_dc3bbcacaa","large_adoptie.jpg",140.54,{"ext":24,"url":258,"hash":259,"mime":27,"name":260,"path":19,"size":261,"width":21,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_adoptie_dc3bbcacaa.j