347,"logo_Dichterbij_png_e40f29d6ac",1.64,"https://incredible-beef-2a6059b946.media.strapiapp.com/logo_Dichterbij_png_e40f29d6ac.png","2026-05-07T09:30:22.029Z","eropohyobe893b3z7wmeg7n9",{"id":454,"name":455,"alternativeText":13,"caption":13,"width":456,"height":183,"formats":457,"hash":486,"ext":177,"mime":180,"size":487,"url":488,"previewUrl":13,"provider":46,"provider_metadata":13,"createdAt":489,"updatedAt":489,"documentId":490,"publishedAt":489},1453,"Klantcase Dichterbij hero.jpg",2560,{"large":458,"small":465,"medium":472,"thumbnail":479},{"ext":177,"url":459,"hash":460,"mime":180,"name":461,"path":13,"size":462,"width":183,"height":463,"sizeInBytes":464},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Klantcase_Dichterbij_hero_f2828c1caf.jpg","large_Klantcase_Dichterbij_hero_f2828c1caf","large_Klantcase Dichterbij hero.jpg",137.81,391,137814,{"ext":177,"url":466,"hash":467,"mime":180,"name":468,"path":13,"size":469,"width":190,"height":470,"sizeInBytes":471},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Klantcase_Dichterbij_hero_f2828c1caf.jpg","small_Klantcase_Dichterbij_hero_f2828c1caf","small_Klantcase Dichterbij hero.jpg",36.1,195,36095,{"ext":177,"url":473,"hash":474,"mime":180,"name":475,"path":13,"size":476,"width":197,"height":477,"sizeInBytes":478},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Klantcase_Dichterbij_hero_f2828c1caf.jpg","medium_Klantcase_Dichterbij_hero_f2828c1caf","medium_Klantcase Dichterbij hero.jpg",80.78,293,80780,{"ext":177,"url":480,"hash":481,"mime":180,"name":482,"path":13,"size":483,"width":41,"height":484,"sizeInBytes":485},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Klantcase_Dichterbij_hero_f2828c1caf.jpg","thumbnail_Klantcase_Dichterbij_hero_f2828c1caf","thumbnail_Klantcase Dichterbij hero.jpg",8.83,96,8829,"Klantcase_Dichterbij_hero_f2828c1caf",601.96,"https://incredible-beef-2a6059b946.media.strapiapp.com/Klantcase_Dichterbij_hero_f2828c1caf.jpg","2026-05-07T09:30:35.683Z","x9e63tl5z6y8r6ddexlexng2",[492],{"__component":493,"id":494,"title":13,"asideText":13,"underline":81,"centered":81,"blankAside":81,"aside":495,"content":496,"introductionText":13},"global.pagesection",4997,"![logo Dichterbij png verkleind.png](https://incredible-beef-2a6059b946.media.strapiapp.com/logo_Dichterbij_png_verkleind_98c391f5e9.png)\n","## Van lokale netwerkschijven naar de Cloud\nVoor [Dichterbij](https://www.dichterbij.nl/) geldt wat voor veel zorgorganisaties geldt: de prioriteit ligt bij de mensen die ze begeleiden, niet bij technologische vernieuwing. Toch was een gerichte digitale stap nodig, vertelt Frans Jurjaanz, projectleider bij Dichterbij. “We hadden nog traditionele dataopslag in een lokaal datacenter. De wendbaarheid van de Cloud is waar je als organisatie naartoe wilt. Altijd in hetzelfde document actueel kunnen samenwerken, dat was een van de grote drijfveren.”\n\nHet digitaliseringstraject Digibij verloopt in fases, zoals de stap naar Microsoft 365 en de vernieuwde werkplekken. In Digibij 3 stond de migratie van de netwerkschijven en mediabibliotheek van het sociaal intranet naar SharePoint centraal. Een project met de nodige complexiteit: 1.200 netwerkschijven, 1.700 groepen en ruim 4.000 medewerkers die gewend zijn aan hun vertrouwde digitale werkomgeving.\n\n## Sociaal intranet als vertrouwd vertrekpunt\nEen bewuste keuze in het project was om de zorgmedewerkers zo min mogelijk te confronteren met nieuwe interfaces. SharePoint zou de technische ruggengraat worden, maar medewerkers werken er niet direct mee. Frans: “Het sociaal intranet is het welkomstplein. Daar vinden medewerkers hun applicaties, protocollen, nieuws en andere informatie. De logische stap was om de gedeelde documenten daar ook aan te koppelen. Zo hoeven medewerkers niet naar SharePoint of Teams te gaan. Ze werken gewoon via hun sociaal intranet, zonder dat ze merken wat er achter de schermen veranderd is.”\n\nDie aanpak klinkt eenvoudig, maar was technisch een stuk uitdagender. Via het sociaal intranet werken medewerkers in zorgteams, maar ook in andere samenwerkingsverbanden. De inrichting van rollen en rechten via het sociaal intranet vroeg om specifieke kennis die intern niet aanwezig was. Daarom schakelde Dichterbij ShareValue in.\n\n>De inrichting van rollen en rechten via het sociaal intranet vroeg om specifieke kennis die intern niet aanwezig was. Daarom schakelde Dichterbij ShareValue in.\n\n## Technische kennis op de juiste plek\nVanuit ShareValue sloot Jordy van Veelen, Senior M365 Consultant en Competence Lead M365, aan als specialist. De rol van Jordy rol was veelzijdig. Hij dacht mee bij de inrichting van SharePoint, werkte de governance uit, legde het migratiebeleid vast en dacht na over wat er moest gebeuren met de data die na de migratie achterblijft. Technisch uitvoerder SLTN verzorgt de feitelijke migratie; Jordy vertaalde de wensen van Dichterbij naar concrete keuzes en richtlijnen.\n\nFrans: “We hadden twee uitdagingen. Hoe pak je de migratie technisch aan? En hoe zorg je ervoor dat SharePoint goed is ingericht? Die kennis was intern niet aanwezig, dus waren we erg blij met de komst van Jordy. Op technisch vlak hebben we enorm veel aan hem gehad. Zijn kennis, inzicht en oplossingsgerichtheid waren noodzakelijk om tot een goede aanpak te komen.”\n\nBijzonder aan Jordy’s manier van werken is hoe hij omgaat met de organisatiecultuur. Frans: “Wat ik knap vind, is dat iemand als Jordy enorm veel technische kennis heeft, maar tegelijkertijd heel sensitief is. Hoe snel kunnen we gaan? Wat kan en wil de organisatie? Hij neemt zijn autoriteit, maar luistert ook goed. Zeker in een organisatie als Dichterbij, die niet IT-minded is, heb je iemand nodig die mensen meeneemt in wat de toekomst hen kan brengen.”\n\n## Pilotgroepen als oefengrond\nDe uitrol van de migratie verloopt gefaseerd. In ieder van de vier zorgregio’s van Dichterbij zijn eerst pilotgroepen opgezet, met medewerkers die oefenen met het opschonen van de netwerkschijven en de mediabibliotheek van sociaal intranet. Frans: “We hebben allerlei situaties met ze doorlopen.  Welke uitdagingen komen we zoal tegen? Welke niveaus van digitale vaardigheid zijn er? En hoe gaan we hier mee om? Deze ervaringen geven ons inzicht in hoe we het project in de rest van de organisatie moeten aanpakken. Zo kwamen we er onder andere achter, dat medewerkers liever de term ‘opruimen’ gebruiken dan ‘opschonen’. Dit lijkt een detail, maar het maakt het verschil in hoe mensen de informatie tot zich nemen en begrijpen. Door deze term aan te passen voelen de medewerkers uit de pilotgroepen zich bovendien gezien en gehoord.”\n\nDe pilotgroepen testen ook het proefmigreren naar SharePoint. Het resultaat is veelbelovend. Frans: “Iedereen is betrokken en ziet de noodzaak. De een heeft er meer handigheid in dan de ander, maar de bereidheid is er.”\n\n## Op koers\nHet streven is om na de zomer van 2026 de volledige migratie te hebben afgerond. De bredere uitrol wordt ondersteund door communicatie over hoe medewerkers straks hun weg kunnen vinden in de nieuwe werkomgeving en hoe ze het beste digitaal kunnen samenwerken. Frans: “Het verzoek vanuit de zorgregio’s is duidelijk: laten we dit zo snel mogelijk doen. Ze hebben zin om er de schouders onder te zetten. Daarna volgen de medewerkers van de serviceorganisatie. Zo zorgen we ervoor dat elke afdeling met de juiste ondersteuning de migratie kan gaan doen.”\n\nVoor ShareValue betekent dit migratieproject een bevestiging van hoe waardevolle IT-ondersteuning eruitziet in de zorgsector: technische diepgang gecombineerd met oog voor de mens en de organisatie(cultuur). Frans sluit af: “Jordy is een kritische succesfactor geweest. Zonder zijn kennis zou dit project veel trager verlopen.”",{"id":498,"metaTitle":499,"metaDescription":500,"structuredData":501,"metaImage":528,"metaSocial":567},636,"Dichterbij migreert naar SharePoint met ShareValue","Lees hoe ShareValue zorgorganisatie Dichterbij ondersteunde bij de migratie van 1.200 netwerkschijven naar SharePoint",{"url":502,"name":7,"@type":503,"about":504,"author":513,"@context":135,"headline":7,"isPartOf":514,"mentions":518,"publisher":520,"inLanguage":525,"mainEntity":526,"description":527},"https://sharevalue.nl/klantcases/dichterbij-migreert-naar-share-point-met-share-value-als-technische-gids","CaseStudy",[505,508,509,511],{"name":506,"@type":507},"SharePoint","Thing",{"name":18,"@type":507},{"name":510,"@type":507},"Datamigratie",{"name":512,"@type":507},"Digitale werkplek",{"name":138,"@type":139},{"url":515,"name":516,"@type":517},"https://sharevalue.nl/klantcases","Klantcases","CollectionPage",[519],{"name":431,"@type":139},{"url":521,"logo":522,"name":138,"@type":139},"https://sharevalue.nl",{"url":523,"@type":524},"https://sharevalue.nl/assets/images/logo.svg","ImageObject","nl-NL",{"name":431,"@type":139},"Klantcase over de migratie naar SharePoint waarbij ShareValue ondersteuning bood als technische gids voor een moderne en veilige digitale werkomgeving.",{"id":529,"name":530,"alternativeText":13,"caption":13,"width":531,"height":532,"formats":533,"hash":561,"ext":177,"mime":180,"size":562,"url":563,"previewUrl":13,"provider":46,"provider_metadata":13,"createdAt":564,"updatedAt":564,"documentId":565,"publishedAt":566},1455,"OP afb Klantcase Dichterbij.jpg",1200,600,{"large":534,"small":540,"medium":547,"thumbnail":554},{"ext":177,"url":535,"hash":536,"mime":180,"name":537,"path":13,"size":538,"width":183,"height":190,"sizeInBytes":539},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_OP_afb_Klantcase_Dichterbij_f5ab9e8a0d.jpg","large_OP_afb_Klantcase_Dichterbij_f5ab9e8a0d","large_OP afb Klantcase Dichterbij.jpg",155.02,155020,{"ext":177,"url":541,"hash":542,"mime":180,"name":543,"path":13,"size":544,"width":190,"height":545,"sizeInBytes":546},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_OP_afb_Klantcase_Dichterbij_f5ab9e8a0d.jpg","small_OP_afb_Klantcase