/large_adoptie_dc3bbcacaa.jpg","large_adoptie_dc3bbcacaa","large_adoptie.jpg",140.54,{"ext":24,"url":270,"hash":271,"mime":27,"name":272,"path":19,"size":273,"width":21,"height":234},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_adoptie_dc3bbcacaa.jpg","small_adoptie_dc3bbcacaa","small_adoptie.jpg",46.09,{"ext":24,"url":275,"hash":276,"mime":27,"name":277,"path":19,"size":278,"width":43,"height":240},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_adoptie_dc3bbcacaa.jpg","medium_adoptie_dc3bbcacaa","medium_adoptie.jpg",90.06,{"ext":24,"url":280,"hash":281,"mime":27,"name":282,"path":19,"size":283,"width":246,"height":79},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_adoptie_dc3bbcacaa.jpg","thumbnail_adoptie_dc3bbcacaa","thumbnail_adoptie.jpg",13.08,"adoptie_dc3bbcacaa",204.86,"https://incredible-beef-2a6059b946.media.strapiapp.com/adoptie_dc3bbcacaa.jpg","2024-08-08T09:47:03.256Z","kqdvjnnutm27pjz49n0b8l8r",{"id":290,"title":291,"subTitle":292,"content":293,"callToActionText":19,"callToActionLink":19,"colorStyle":217,"showAsides":106,"imageUrl":294,"__component":252},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"id":295,"name":296,"alternativeText":19,"caption":19,"width":20,"height":221,"formats":297,"hash":318,"ext":24,"mime":27,"size":319,"url":320,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":321,"updatedAt":321,"documentId":322,"publishedAt":58,"focalPoint":19},784,"trends.jpg",{"large":298,"small":303,"medium":308,"thumbnail":313},{"ext":24,"url":299,"hash":300,"mime":27,"name":301,"path":19,"size":302,"width":30,"height":228},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_trends_e84a3219