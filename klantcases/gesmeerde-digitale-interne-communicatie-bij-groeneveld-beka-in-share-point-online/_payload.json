ft security.jpg",{"large":401,"small":406,"medium":411,"thumbnail":416},{"ext":24,"url":402,"hash":403,"mime":27,"name":404,"path":19,"size":405,"width":30,"height":228},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":24,"url":407,"hash":408,"mime":27,"name":409,"path":19,"size":410,"width":21,"height":234},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":24,"url":412,"hash":413,"mime":27,"name":414,"path":19,"size":415,"width":43,"height":240},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":24,"url":417,"hash":418,"mime":27,"name":419,"path":19,"size":420,"width":246,"height":79},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":427,"title":428,"subTitle":429,"content":430,"callToActionText":431,"callToActionLink":432,"colorStyle":217,"showAsides":106,"imageUrl":433,"__component":252},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":434,"name":435,"alternativeText":19,"caption":19,"width":20,"height":221,"formats":436,"hash":457,"ext":24,"mime":27,"size":458,"url":459,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":460,"updatedAt":460,"documentId":461,"publishedAt":58,"focalPoint":19},788,"vergaderruimte.jpg",{"large":437,"small":442,"medium":447,"thumbnail":452},{"ext":24,"url":438,"hash":439,"mime":27,"name":440,"path":19,"size":441,"width":30,"height":228},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":24,"url":443,"hash":444,"mime":27,"name":445,"path":19,"size":446,"width":21,"height":234},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":24,"url":448,"hash":449,"mime":27,"name":450,"path":19,"size":451,"width":43,"height":240},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":24,"url":453,"hash":454,"mime":27,"name":455,"path":19,"size":456,"width":246,"height":79},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","th