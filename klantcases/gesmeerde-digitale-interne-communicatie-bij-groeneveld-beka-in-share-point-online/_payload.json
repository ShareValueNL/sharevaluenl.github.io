[{"data":1,"prerenderedAt":602},["ShallowReactive",2],{"collection-klantcases-299251811":3,"_apollo:default":601},{"data":4,"meta":597},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"collegas":15,"image":16,"klant":59,"contentBlocks":103,"seo":110,"expertises":127,"blocks":503},18,"Gesmeerde digitale interne communicatie bij Groeneveld-BEKA in SharePoint Online","gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online","Groeneveld-BEKA biedt automatische smeer-, oliemanagement- en veiligheidssystemen voor diverse voertuigen en machines en voor industriële toepassingen. De toepassing van deze hoogwaardige systemen leidt tot minder slijtage van essentiële onderdelen, lagere bedrijfskosten en een verhoogde inzetbaarheid van materieel. Jasper Huurman, Group IT Manager bij Groeneveld-BEKA, vertelt over de samenwerking met ShareValue: “Naast ons hoofdkantoor in Gorinchem hebben we zes productielocaties in Europa, het VK en de VS en een wereldwijd netwerk van klanten, dealers en distributeurs. Doordat BEKA erbij kwam, was de capaciteit van onze fysieke exchange-server in Gorinchem niet meer voldoende. Meerdere keren per week crashte deze server. Daarom moesten wij elke dag onze e-mail en ons archief opschonen.”","2023-12-18T16:04:33.201Z","2025-04-11T13:54:41.540Z","2023-12-18T16:05:55.210Z","2023-12-11","u0cghl98ntunwjpu0e82f1hp",[],{"id":17,"name":18,"alternativeText":19,"caption":19,"width":20,"height":21,"formats":22,"hash":52,"ext":24,"mime":27,"size":53,"url":54,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":19},419,"Headerfoto_klantcase_Groeneveld_BEKA.jpg",null,1280,500,{"large":23,"small":32,"medium":38,"thumbnail":45},{"ext":24,"url":25,"hash":26,"mime":27,"name":28,"path":19,"size":29,"width":30,"height":31},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305.jpg","large_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305","image/jpeg","large_Headerfoto_klantcase_Groeneveld_BEKA.jpg",70.58,1000,391,{"ext":24,"url":33,"hash":34,"mime":27,"name":35,"path":19,"size":36,"width":21,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305.jpg","small_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305","small_Headerfoto_klantcase_Groeneveld_BEKA.jpg",21.21,195,{"ext":24,"url":39,"hash":40,"mime":27,"name":41,"path":19,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305.jpg","medium_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305","medium_Headerfoto_klantcase_Groeneveld_BEKA.jpg",42.95,750,293,{"ext":24,"url":46,"hash":47,"mime":27,"name":48,"path":19,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305.jpg","thumbnail_Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305","thumbnail_Headerfoto_klantcase_Groeneveld_BEKA.jpg",6.04,245,96,"Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305",107.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/Headerfoto_klantcase_Groeneveld_BEKA_3ff2111305.jpg","strapi-provider-upload-strapi-cloud","2023-12-18T16:02:21.683Z","o9pbm8o5yqncncqmwy5zy596","2026-01-05T12:38:34.018Z",{"id":60,"title":61,"createdAt":62,"updatedAt":63,"publishedAt":64,"documentId":65,"logo":66},13,"Groeneveld-BEKA","2023-12-18T16:05:30.286Z","2023-12-18T16:05:31.287Z","2023-12-18T16:05:31.282Z","yqja1jkrb6wg6y3cceykwa5j",{"id":67,"name":68,"alternativeText":19,"caption":19,"width":69,"height":70,"formats":71,"hash":98,"ext":73,"mime":76,"size":99,"url":100,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":101,"updatedAt":101,"documentId":102,"publishedAt":58,"focalPoint":19},420,"GroeneveldBeka_Logo_png.png",2400,375,{"large":72,"small":80,"medium":86,"thumbnail":92},{"ext":73,"url":74,"hash":75,"mime":76,"name":77,"path":19,"size":78,"width":30,"height":79},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Groeneveld_Beka_Logo_png_e66a58a734.png","large_Groeneveld_Beka_Logo_png_e66a58a734","image/png","large_GroeneveldBeka_Logo_png.png",28.3,156,{"ext":73,"url":81,"hash":82,"mime":76,"name":83,"path":19,"size":84,"width":21,"height":85},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Groeneveld_Beka_Logo_png_e66a58a734.png","small_Groeneveld_Beka_Logo_png_e66a58a734","small_GroeneveldBeka_Logo_png.png",15.11,78,{"ext":73,"url":87,"hash":88,"mime":76,"name":89,"path":19,"size":90,"width":43,"height":91},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Groeneveld_Beka_Logo_png_e66a58a734.png","medium_Groeneveld_Beka_Logo_png_e66a58a734","medium_GroeneveldBeka_Logo_png.png",21.06,117,{"ext":73,"url":93,"hash":94,"mime":76,"name":95,"path":19,"size":96,"width":50,"height":97},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Groeneveld_Beka_Logo_png_e66a58a734.png","thumbnail_Groeneveld_Beka_Logo_png_e66a58a734","thumbnail_GroeneveldBeka_Logo_png.png",7.48,38,"Groeneveld_Beka_Logo_png_e66a58a734",15.26,"https://incredible-beef-2a6059b946.media.strapiapp.com/Groeneveld_Beka_Logo_png_e66a58a734.png","2023-12-18T16:05:27.248Z","yt44cnr6qm89c6fmjp6xr9nj",[104],{"id":105,"title":19,"asideText":19,"underline":106,"centered":106,"blankAside":106,"aside":107,"content":108,"introductionText":19,"__component":109},1639,false,"![GroeneveldBeka_Logo_png.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Groeneveld_Beka_Logo_png_e66a58a734.png)","\n## Stroeve digitale interne communicatie door versnipperde en verouderde content “Te veel tijd kwijt aan zoeken naar content”\nDe digitale interne communicatie bij [Groeneveld-BEKA](https://www.groeneveld-beka.com/nl) liep vanwege de groei niet zo gesmeerd. Door de samenvoeging stond alle content versnipperd over diverse plaatsen, zowel offline als online. Jasper: “Veel content was verouderd en een heldere structuur, overzicht en regie ontbraken. Aan de security en privacy was niet veel aandacht besteed. Daardoor verloor Marketing veel tijd met het zoeken naar en aanpassen van content. De roep om een modern portaal voor de interne communicatie, gestructureerd opgezet en in lijn met alle veiligheids- en privacyrichtlijnen, werd steeds luider.”\n\n## Nieuw, modern communicatieportaal in SharePoint Online “Toekomstbestendig platform neerzetten en verschillen en achterstand wegwerken”\nNa de introductie en adoptie van Microsoft Exchange Online in 2009, nam Groeneveld-BEKA ook andere producten uit het Microsoft Cloud portfolio (nu Office 365) in gebruik. ShareValue, die beheer, support en nieuwe implementaties doet voor Groeneveld-BEKA, werd gevraagd om advies en om het nieuwe communicatieportaal samen met hen te realiseren en implementeren. Op basis van een Sanity Check schreef ShareValue een adviesrapport, dat door Groeneveld-BEKA intern werd opgevolgd.\nJasper: “Door reorganisatie van onze IT-afdeling hebben wij nu meer behoefte aan functionele kennis om te zorgen dat ons huidige Office365 portfolio aan de laatste maatstaven (best practices) voldoet. Jordi van ShareValue heeft een roadmap ontwikkeld om OneDrive, verouderde SharePoint-sites en afdelingsschijven te consolideren naar een moderne SharePoint-omgeving. Op IT-gebied zijn de verschillen tussen de bedrijven erg groot. In vergelijking met Groeneveld liep BEKA zo’n tien jaar achter. Zij hebben één grote netwerkdrive met 500 man. Onze grootste uitdaging is nu om een toekomstbestendig platform neer te zetten, verschillen en achterstanden weg te werken en een uniforme manier van werken ontwerpen. ShareValue helpt ons om een strategie te bedenken, vast te leggen, te implementeren en uit te dragen.”\nVoor het nieuwe intranet werd een prototype ontwikkeld, gebaseerd op het Microsoft SharePoint Online Hub structuurconcept. Het werd opgedeeld in vier onderdelen: home, landen en afdelingen voor de content, en MS Teams voor samenwerking.\n\n## Meer en beter werken in de cloud\nOp dit moment wordt het IT-beheer verplaatst naar moederbedrijf Timken. “Uitdagend”, noemt Jasper het. “Want tussen ons en Timken zat een groot verschil in digitaal werken. Ik wil Groeneveld-BEKA het liefst zo autonoom en flexibel mogelijk houden, maar Timken wil met één Microsoft 365- en Azure-tenant gaan werken. Gelukkig denkt ShareValue hierin goed mee.”\nWat staat er de komende tijd op stapel?\n\n- Uitfaseren en omzetten van het oude Groeneveld-BEKA intranet.\n- Uitfaseren en migreren van de overige oude SharePoint-sites en netwerkdata naar het portaal.\n- MS Teams opzetten voor samenwerking en aansluiten op het portal met aggregatiemogelijkheden, inclusief governance.\n- Microsoft 365 Governance advies op subscription level aan IT: bedrijfskritische applicaties supporten.\n- Een urenregistratiesysteem opzetten met Power Apps.\n\nJasper: “Alle plannen die we samen met ShareValue gaan realiseren, helpen ons om meer en beter te werken in de cloud. En toekomstgericht te innoveren. Door onze ERP-systemen in de cloud te zetten en onze data en opslag te consolideren, zijn we niet meer zelf verantwoordelijk voor alle updates. Dat laten we over aan ons moederbedrijf Timken. Wij gaan ons meer richten op het toepassen van AI en AR in onze producten.”\n\n## Prettige samenwerking met Jordi\n“Bij ons en dus ook ‘van ons’“\nJasper is enthousiast over de samenwerking: “Jordi hoort bij het team, zo stelt hij zich ook op. Hij zit bij ons en is dus ook ‘van ons’. Fijn dat hij bij ons op kantoor werkt en niet op afstand. Dat praat toch een stuk makkelijker. Via een intern ticketsysteem komt alles over Microsoft 365 bij Jordi. Wij vertrouwen er 100% op dat hij het goed en snel oppakt.”\n\n“Toen ShareValue begon was onze IT-omgeving heel eenvoudig. Nu gebruiken we steeds meer uit het Microsoft-portfolio en werken we meer online. Ik ben trots op wat we samen hebben neergezet”, lacht Jasper.\n\n \n\nHeb je vragen naar aanleiding van deze klantcase? Neem contact met ons op via [communicatie@sharevalue.nl ](mailto:communicatie@sharevalue.nl)","global.pagesection",{"id":111,"metaTitle":112,"metaDescription":113,"structuredData":114,"metaImage":19,"metaSocial":126},44,"Groeneveld-BEKA & ShareValue – SharePoint communicatie","Groeneveld-BEKA verbetert interne communicatie met SharePoint Online, ondersteund door ShareValue, voor efficiëntere samenwerking en informatiebeheer.",{"url":115,"name":116,"@type":117,"author":118,"@context":122,"publisher":123,"mainEntity":124,"description":113,"datePublished":13},"https://www.sharevalue.nl/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online","Groeneveld-BEKA & ShareValue – Interne communicatie in SharePoint","CaseStudy",{"url":119,"name":120,"@type":121},"https://www.sharevalue.nl","ShareValue","Organization","https://schema.org",{"url":119,"name":120,"@type":121},{"url":125,"name":61,"@type":121},"https://www.groeneveld-beka.com",[],[128],{"id":129,"title":130,"subTitle":131,"description":132,"shortDescription":133,"slug":134,"createdAt":135,"updatedAt":136,"publishedAt":137,"isCoreExpertise":138,"documentId":139,"image":140,"seo":157,"blocks":171,"midPageBlocks":211},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":141,"name":142,"alternativeText":19,"caption":19,"width":143,"height":144,"formats":145,"hash":152,"ext":73,"mime":76,"size":153,"url":154,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":155,"updatedAt":155,"documentId":156,"publishedAt":58,"focalPoint":19},16,"microsoft-365.png",282,130,{"thumbnail":146},{"ext":73,"url":147,"hash":148,"mime":76,"name":149,"path":19,"size":150,"width":50,"height":151},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":158,"metaTitle":159,"metaDescription":160,"structuredData":161,"metaImage":19,"metaSocial":170},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":162,"@type":163,"@context":122,"provider":164,"areaServed":165,"description":168,"serviceType":169},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":119,"name":120,"@type":121},{"name":166,"@type":167},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[172,180],{"id":173,"title":174,"aside":19,"postType":175,"limit":176,"expertise":177,"__component":179},166,"Lees meer over Microsoft 365","alle",3,[178],{"id":129,"title":130,"subTitle":131,"description":132,"shortDescription":133,"slug":134,"createdAt":135,"updatedAt":136,"publishedAt":137,"isCoreExpertise":138,"documentId":139},"strapi.related-kennisbank-list",{"id":181,"titleLeft":182,"callToActionTextLeft":183,"callToActionLinkUrlLeft":184,"titleRight":185,"callToActionTextRight":186,"callToActionLinkUrlRight":187,"iconUrlLeft":188,"iconUrlRight":201,"__component":210},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":189,"name":190,"alternativeText":19,"caption":19,"width":191,"height":192,"formats":19,"hash":193,"ext":194,"mime":195,"size":196,"url":197,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":198,"updatedAt":199,"documentId":200,"publishedAt":58,"focalPoint":19},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":202,"name":203,"alternativeText":19,"caption":19,"width":192,"height":192,"formats":19,"hash":204,"ext":194,"mime":195,"size":205,"url":206,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":58,"focalPoint":19},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[212,253,289,323,357,392,426,462,496],{"id":213,"title":214,"subTitle":215,"content":216,"callToActionText":19,"callToActionLink":19,"colorStyle":217,"showAsides":106,"imageUrl":218,"__component":252},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"id":219,"name":220,"alternativeText":19,"caption":19,"width":20,"height":221,"formats":222,"hash":247,"ext":24,"mime":27,"size":248,"url":249,"previewUrl":19,"provider":55,"provider_metadata":19,"createdAt":250,"updatedAt":250,"documentId":251,"publishedAt":58,"focalPoint":19},782,"Teams.jpg",850,{"large":223,"small":229,"medium":235,"thumbnail":241},{"ext":24,"url":224,"hash":225,"mime":27,"name":226,"path":19,"size":227,"width":30,"height":228},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Teams_43eca91eed.jpg","large_Teams_43eca91eed","large_Teams.jpg",75.76,664,{"ext":24,"url":230,"hash":231,"mime":27,"name":232,"path":19,"size":233,"width":21,"height":234},"https: