[{"data":1,"prerenderedAt":524},["ShallowReactive",2],{"collection-klantcases-287902175":3,"_apollo:default":523},{"data":4,"meta":519},[5],{"id":6,"title":7,"slug":8,"summary":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"expertises":15,"collegas":28,"klant":25,"image":60,"contentBlocks":101,"seo":107,"blocks":126},13,"Proces digitaliseren met Office 365 en Dynamics 365 for Sales","proces-digitaliseren-met-office-365-en-dynamics-365-for-sales","Onze klant, deze keer een ambachtelijk familiebedrijf, heeft gekozen om haar proces te digitaliseren met Office 365 en Dynamics 365 for Sales (voorheen bekend als Dynamics CRM). De belangrijkste reden om deze onlineproducten te gebruiken is de beschikbaarheid van de systemen te hebben los van plaats of apparaat. Hierdoor wordt het systeem overal en altijd beschikbaar.","2023-09-01T10:04:24.196Z","2025-04-11T14:20:41.652Z","2023-09-01T10:04:26.020Z","2017-11-12","sidr6i1pr4hbzx3aq1oww03w",[16],{"id":17,"title":18,"subTitle":19,"description":19,"shortDescription":19,"slug":20,"createdAt":21,"updatedAt":21,"publishedAt":22,"isCoreExpertise":23,"documentId":24,"image":25,"blocks":26,"midPageBlocks":27,"seo":25},8,"Dynamics 365","","dynamics-365","2023-10-12T11:27:58.808Z","2023-10-12T11:27:58.783Z",false,"dja519itovgg9wq8euq4uocb",null,[],[],[29],{"id":30,"name":31,"jobTitle":32,"about":25,"createdAt":33,"updatedAt":34,"publishedAt":35,"documentId":36,"image":37,"contactOptions":59},32,"Jaap","Consultant & Architect","2023-08-18T08:37:46.142Z","2024-04-18T14:14:47.615Z","2023-08-18T08:37:45.364Z","ylun9zjxpvjd4rq1teczcwna",{"id":38,"name":39,"alternativeText":25,"caption":25,"width":40,"height":41,"formats":42,"hash":52,"ext":44,"mime":47,"size":53,"url":54,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58},685,"Jaap websitefoto.png",278,326,{"thumbnail":43},{"ext":44,"url":45,"hash":46,"mime":47,"name":48,"path":25,"size":49,"width":50,"height":51},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Jaap_websitefoto_b7bbefc0bd.png","thumbnail_Jaap_websitefoto_b7bbefc0bd","image/png","thumbnail_Jaap websitefoto.png",19.14,133,156,"Jaap_websitefoto_b7bbefc0bd",19.61,"https://incredible-beef-2a6059b946.media.strapiapp.com/Jaap_websitefoto_b7bbefc0bd.png","strapi-provider-upload-strapi-cloud","2024-04-18T14:13:38.415Z","cvbav3qa5a84m18w8fmg5l5c","2026-01-05T12:38:34.018Z",[],{"id":61,"name":62,"alternativeText":25,"caption":25,"width":63,"height":64,"formats":65,"hash":95,"ext":67,"mime":70,"size":96,"url":97,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":98,"updatedAt":99,"documentId":100,"publishedAt":58},217,"header_klantcase_jaap.jpg",1280,500,{"large":66,"small":75,"medium":81,"thumbnail":88},{"ext":67,"url":68,"hash":69,"mime":70,"name":71,"path":25,"size":72,"width":73,"height":74},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_header_klantcase_jaap_62c19600b3.jpg","large_header_klantcase_jaap_62c19600b3","image/jpeg","large_header_klantcase_jaap.jpg",84.66,1000,391,{"ext":67,"url":76,"hash":77,"mime":70,"name":78,"path":25,"size":79,"width":64,"height":80},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_header_klantcase_jaap_62c19600b3.jpg","small_header_klantcase_jaap_62c19600b3","small_header_klantcase_jaap.jpg",20.21,195,{"ext":67,"url":82,"hash":83,"mime":70,"name":84,"path":25,"size":85,"width":86,"height":87},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_header_klantcase_jaap_62c19600b3.jpg","medium_header_klantcase_jaap_62c19600b3","medium_header_klantcase_jaap.jpg",46.34,750,293,{"ext":67,"url":89,"hash":90,"mime":70,"name":91,"path":25,"size":92,"width":93,"height":94},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_header_klantcase_jaap_62c19600b3.jpg","thumbnail_header_klantcase_jaap_62c19600b3","thumbnail_header_klantcase_jaap.jpg",5.26,245,96,"header_klantcase_jaap_62c19600b3",139.09,"https://incredible-beef-2a6059b946.media.strapiapp.com/header_klantcase_jaap_62c19600b3.jpg","2023-09-01T10:02:18.606Z","2023-10-25T14:34:29.601Z","sl2lzgxpcpbrwvfuct1wu18c",[102],{"__component":103,"id":104,"title":25,"asideText":25,"underline":105,"centered":23,"blankAside":23,"aside":25,"content":106,"introductionText":25},"global.pagesection",1606,true,"\nDe grote voordelen zijn:\n\n1. de mogelijkheid voor kantoorpersoneel om thuis te werken\n2. de beschikbaarheid van het systeem buiten kantooruren voor sales en directie\n3. toegang tot contactgegevens en orderdetails op locatie\n4. toegang tot alle gegevens voor medewerkers in de werkplaats\n5. registreren van klantverzoeken en nieuwe verkoopkansen op locatie bij de klant\n\n## De oplossing\nVoor de oplossing is gebruikgemaakt van de volgende onderdelen van Dynamics 365:\n\n- accounts, contacts, opportunities, quotes, orders, invoices, products\n- maatwerk Fetch XML rapporten\n- MS Word sjablonen voor prijsopgaves, orders en facturen\n- eenvoudige workflows om business logica af te dwingen\n- business rules, om btw-tarieven en kortingen te berekenen\n\nMicrosoft Dynamics is heel generiek en flexibel, zodat het over de hele wereld gebruikt kan worden in allerlei markten. Nadeel is wel dat sommige zaken die klanten wel verwachten, toch missen of afwijken. Voorbeelden die we in dit project tegen kwamen:\n\n- Je kunt belastingen opvoeren, maar er zijn geen btw-tarieven gedefinieerd, dus je kunt ook niet tarieven aan een product of dienst koppelen. Het was niet ingewikkeld om te bouwen, maar het komt wel op veel plekken terug, in prijsopgaves, in facturen, op overzichten etc.\n- het systeem kent wel unieke factuurnummers, maar ze zijn niet opvolgend. Dit moest dus aangepast worden omdat opeenvolgende nummers in Nederland vereist zijn.\n\nDeze zaken waren eenvoudig aan te passen, maar het waren kosten die de klant niet meteen had verwacht.\n\nTot slot is er geen koppeling met een postcode-tabel beschikbaar met adressen. De klant was dat wel gewend, maar vond het niet belangrijk genoeg om in te laten bouwen.\n\n## De uitdagingen in het project\nDe grootste uitdaging die we tegen zijn gekomen heeft te maken met de beperkte aanpasbaarheid van order regels zoals detailregels van opportunity’s, quotes, orders en invoices.\n\nOm de marge te kunnen tonen van een prijsopgave wilden we de inkoopprijs van de producten erop zetten, maar dat bleek niet mogelijk:\n\n- Het is niet mogelijk om de mapping tussen product en orderregel te gebruiken om extra details van producten op de order regel te zetten.\n- Het is wel mogelijk om een workflow te schrijven op orderregels, maar het is niet mogelijk om de orderregels bij te werken in de workflow.\n\nUiteindelijk heb ik gekozen om een rapport te bouwen die alle gegevens ophaalt om de marge van een prijsopgave te tonen.\n\n## Conclusie\nDe klant is erg tevreden over de compleetheid en bruikbaarheid van Dynamics 365.\n\nDe meeste aanpassingen waren meer bedoeld om het gebruikersvriendelijker te maken, specifiek voor deze klant, dan om hiaten in de functionaliteit te vullen.\n\nHeb je vragen naar aanleiding van deze klantcase? Neem contact met ons op via [communicatie@sharevalue.nl](mailto:communicatie@sharevalue.nl)",{"id":108,"metaTitle":109,"metaDescription":110,"structuredData":111,"metaImage":25,"metaSocial":125},58,"ShareValue & familiebedrijf – Dynamics 365 digitalisering","Samen met ShareValue digitaliseert een familiebedrijf processen met Office 365 en Dynamics 365 for Sales voor meer overzicht en efficiëntie.",{"url":112,"name":113,"@type":114,"author":115,"@context":119,"publisher":120,"mainEntity":121,"description":123,"datePublished":124},"https://www.sharevalue.nl/klantcases/proces-digitaliseren-met-office-365-en-dynamics-365-for-sales","Familiebedrijf & ShareValue – Digitalisering met Dynamics 365","CaseStudy",{"url":116,"name":117,"@type":118},"https://www.sharevalue.nl","ShareValue","Organization","https://schema.org",{"url":116,"name":117,"@type":118},{"name":122,"@type":118},"Ambachtelijk familiebedrijf","Een ambachtelijk familiebedrijf digitaliseert samen met ShareValue bedrijfsprocessen met Office 365 en Dynamics 365 for Sales voor meer flexibiliteit en efficiëntie.","2025-01-24",[],[127,506],{"__component":128,"id":129,"title":130,"aside":25,"postType":131,"limit":132,"expertise":133},"strapi.related-kennisbank-list",134,"Lees ook deze klantcases","alle",3,[134,503],{"id":135,"title":136,"subTitle":137,"description":138,"shortDescription":139,"slug":140,"createdAt":141,"updatedAt":142,"publishedAt":143,"isCoreExpertise":105,"documentId":144,"image":145,"blocks":162,"midPageBlocks":198,"seo":489},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z","ci9jcjkdq0gjpkaebdvdf08c",{"id":146,"name":147,"alternativeText":25,"caption":25,"width":148,"height":149,"formats":150,"hash":157,"ext":44,"mime":47,"size":158,"url":159,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":160,"updatedAt":160,"documentId":161,"publishedAt":58},16,"microsoft-365.png",282,130,{"thumbnail":151},{"ext":44,"url":152,"hash":153,"mime":47,"name":154,"path":25,"size":155,"width":93,"height":156},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",[163,168],{"__component":128,"id":164,"title":165,"aside":25,"postType":131,"limit":132,"expertise":166},166,"Lees meer over Microsoft 365",[167],{"id":135,"title":136,"subTitle":137,"description":138,"shortDescription":139,"slug":140,"createdAt":141,"updatedAt":142,"publishedAt":143,"isCoreExpertise":105,"documentId":144},{"__component":169,"id":170,"titleLeft":171,"callToActionTextLeft":172,"callToActionLinkUrlLeft":173,"titleRight":174,"callToActionTextRight":175,"callToActionLinkUrlRight":176,"iconUrlLeft":177,"iconUrlRight":190},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":178,"name":179,"alternativeText":25,"caption":25,"width":180,"height":181,"formats":25,"hash":182,"ext":183,"mime":184,"size":185,"url":186,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":187,"updatedAt":188,"documentId":189,"publishedAt":58},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":17,"name":191,"alternativeText":25,"caption":25,"width":181,"height":181,"formats":25,"hash":192,"ext":183,"mime":184,"size":193,"url":194,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":195,"updatedAt":196,"documentId":197,"publishedAt":58},"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",[199,240,276,310,344,379,413,448,482],{"__component":200,"id":201,"title":202,"subTitle":203,"content":204,"callToActionText":25,"callToActionLink":25,"colorStyle":205,"showAsides":23,"imageUrl":206},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"id":207,"name":208,"alternativeText":25,"caption":25,"width":63,"height":209,"formats":210,"hash":235,"ext":67,"mime":70,"size":236,"url":237,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":238,"updat