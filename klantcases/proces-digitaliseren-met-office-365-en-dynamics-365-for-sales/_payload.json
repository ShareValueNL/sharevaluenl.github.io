:70,"size":306,"url":307,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":308,"updatedAt":308,"documentId":309,"publishedAt":58},784,"trends.jpg",{"large":285,"small":290,"medium":295,"thumbnail":300},{"ext":67,"url":286,"hash":287,"mime":70,"name":288,"path":25,"size":289,"width":73,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_trends_e84a321990.jpg","large_trends_e84a321990","large_trends.jpg",198.92,{"ext":67,"url":291,"hash":292,"mime":70,"name":293,"path":25,"size":294,"width":64,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_trends_e84a321990.jpg","small_trends_e84a321990","small_trends.jpg",59.76,{"ext":67,"url":296,"hash":297,"mime":70,"name":298,"path":25,"size":299,"width":86,"height":228},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":67,"url":301,"hash":302,"mime":70,"name":303,"path":25,"size":304,"width":234,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"__component":200,"id":311,"title":312,"subTitle":313,"content":314,"callToActionText":25,"callToActionLink":25,"colorStyle":246,"showAsides":23,"imageUrl":315},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":316,"name":317,"alternativeText":25,"caption":25,"width":63,"height":209,"formats":318,"hash":339,"ext":67,"mime":70,"size":340,"url":341,"previewUrl":25,"provider":55,"provider_metadata":25,"createdAt":342,"updatedAt":342,"documentId":343,"publishedAt":58},785,"microsoft development.jpg",{"large":319,"small":324,"medium":329,"thumbnail":334},{"ext":67,"url":320,"hash":321,"mime":70,"name":322,"path":25,"size":323,"width":73,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":67,"url":325,"hash":326,"mime":70,"name":327,"path":25,"size":328,"width":64,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":67,"url":330,"hash":331,"mime":70,"name":332,"path":25,"size":333,"width":86,"height":228},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":67,"url":335,"hash":336,"mime":70,"name":337,"path":25,"size":338,"width":234,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"__component":200,"id":345,"title":346,"subTitle":347,"content":348,"callToActionText":349,"callToActionLink":173,"colorStyle":205,"showAsides":23,"imageUrl":350},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaa