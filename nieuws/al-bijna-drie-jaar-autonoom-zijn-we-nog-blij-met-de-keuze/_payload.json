[{"data":1,"prerenderedAt":131},["ShallowReactive",2],{"collection-nieuws-328861793":3,"_apollo:default":130},{"data":4,"meta":126},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":60,"blocks":61,"seo":108},9,"Al bijna drie jaar autonoom: zijn we nog blij met de keuze?","Het is al bijna drie jaar geleden dat alle aandelen van ShareValue overgingen naar onze CEO Peter Goedhart; vanaf dat moment gingen we volledig autonoom verder. Achteraf bleek het met de corona-pandemie een rare tijd om als zelfstandig bedrijf te groeien, maar wanneer we terugkijken naar de keuze die we destijds gemaakt hebben, zijn we er nog steeds blij mee. Peter vertelt:","al-bijna-drie-jaar-autonoom-zijn-we-nog-blij-met-de-keuze","2023-09-29T10:34:33.496Z","2025-05-08T09:53:58.128Z","2023-09-29T10:34:42.128Z","2022-01-24","d1b1e2dquacyr47f1pb0hgnv",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":57,"documentId":58,"publishedAt":59},228,"autonomie_zijn_we_nog_blij.jpg",null,1200,628,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_autonomie_zijn_we_nog_blij_470c6f0f79.jpg","large_autonomie_zijn_we_nog_blij_470c6f0f79","image/jpeg","large_autonomie_zijn_we_nog_blij.jpg",75.87,1000,523,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_autonomie_zijn_we_nog_blij_470c6f0f79.jpg","small_autonomie_zijn_we_nog_blij_470c6f0f79","small_autonomie_zijn_we_nog_blij.jpg",24.67,500,262,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_autonomie_zijn_we_nog_blij_470c6f0f79.jpg","medium_autonomie_zijn_we_nog_blij_470c6f0f79","medium_autonomie_zijn_we_nog_blij.jpg",48.63,750,393,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_autonomie_zijn_we_nog_blij_470c6f0f79.jpg","thumbnail_autonomie_zijn_we_nog_blij_470c6f0f79","thumbnail_autonomie_zijn_we_nog_blij.jpg",7.54,245,128,"autonomie_zijn_we_nog_blij_470c6f0f79",83.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/autonomie_zijn_we_nog_blij_470c6f0f79.jpg","strapi-provider-upload-strapi-cloud","2023-09-29T10:33:25.918Z","2023-09-29T10:41:40.873Z","tab4ziq6a7nvjp9hsygatpx4","2026-01-05T12:38:34.018Z",[],[62,68,72,76],{"__component":63,"id":64,"title":18,"asideText":18,"underline":65,"centered":65,"blankAside":66,"aside":18,"content":67,"introductionText":18},"global.pagesection",170,false,true,"\n“Ons zusterbedrijf Ettu ging destijds fuseren met Wortell. Hierdoor werd het onderdeel van een groot bedrijf. Dat biedt natuurlijk mooie kansen voor de medewerkers om door te groeien, maar er zijn zaken die minstens net zo belangrijk zijn. In een kleiner bedrijf, wat ShareValue met zijn bijna 70 medewerkers is, ken je elkaar. En met voldoende aandacht voor onderlinge communicatie en bijeenkomsten, zorg je voor een familiaire sfeer. Als ShareValue zijn we heel trots op de familiaire sfeer die er hangt, en die willen we graag behouden! Vandaar dat we er toen voor hebben gekozen om autonoom verder te gaan, want die sfeer hangt er - ondanks de afwezigheid van live bijeenkomsten de afgelopen twee jaar - nog steeds.\n\nNatuurlijk willen wij ook groeien als bedrijf, om er zo voor te zorgen dat er doorgroeimogelijkheden ontstaan voor onze collega’s. Maar dat mag nooit ten koste gaan van de sfeer. Dat is een ding dat zeker is.”",{"__component":69,"id":70,"title":71,"showBlankAside":65},"global.s