[{"data":1,"prerenderedAt":470},["ShallowReactive",2],{"collection-nieuws-1275446621":3,"_apollo:default":469},{"data":4,"meta":465},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"seo":18,"blocks":58,"expertises":97},30,"Nieuwe aanpak: stapsgewijze implementatie van Microsoft 365 Copilot","Veel organisaties willen aan de slag met Microsoft 365 Copilot, maar lopen vast op vragen als: Waar begin je? Is de organisatie er klaar voor? Hoe borg je security en compliance? Bij ShareValue hebben we vanuit onze praktijkervaring een gestructureerde aanpak ontwikkeld: de M365 Copilot-straat. Deze aanpak begeleidt organisaties stapsgewijs bij een veilige, effectieve implementatie van Copilot, met aandacht voor governance, adoptie en strategische inbedding.","nieuwe-aanpak-microsoft-365-copilot-straat","2025-05-09T13:26:55.312Z","2025-05-12T07:29:06.275Z","2025-05-12T07:29:06.259Z","2025-05-12","l725qe27ebodieoblxglgvwh",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},1078,"OP M365 Copilot-straat.jpg",null,1200,600,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_OP_M365_Copilot_straat_fd74f2ce9b.jpg","large_OP_M365_Copilot_straat_fd74f2ce9b","image/jpeg","large_OP M365 Copilot-straat.jpg",54.49,1000,500,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":30,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_OP_M365_Copilot_straat_fd74f2ce9b.jpg","small_OP_M365_Copilot_straat_fd74f2ce9b","small_OP M365 Copilot-straat.jpg",21.2,250,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_OP_M365_Copilot_straat_fd74f2ce9b.jpg","medium_OP_M365_Copilot_straat_fd74f2ce9b","medium_OP M365 Copilot-straat.jpg",37.66,750,375,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_OP_M365_Copilot_straat_fd74f2ce9b.jpg","thumbnail_OP_M365_Copilot_straat_fd74f2ce9b","thumbnail_OP M365 Copilot-straat.jpg",7.44,245,123,"OP_M365_Copilot_straat_fd74f2ce9b",69.84,"https://incredible-beef-2a6059b946.media.strapiapp.com/OP_M365_Copilot_straat_fd74f2ce9b.jpg","strapi-provider-upload-strapi-cloud","2025-05-09T13:50:40.492Z","va3a8d0lrx0m3w6dz162lzdc","2026-01-05T12:38:34.018Z",[59,64],{"id":60,"title":18,"asideText":18,"underline":61,"centered":61,"blankAside":61,"aside":18,"content":62,"introductionText":18,"__component":63},2064,false,"De aanpak bestaat uit meerdere onderdelen: van readiness-analyse en strategie tot adoptie en doorlopende ondersteuning. Uniek is onze focus op het opzetten van een Copilot Advisory Board, waarbij IT, security, legal en compliance vanaf het begin worden betrokken. Zo borgen we draagvlak én grip op risico’s.\n\nWil je weten of jouw organisatie klaar is voor Microsoft 365 Copilot? Vraag dan onze gratis Readiness Assessment aan. Op basis van jouw situatie krijg je gericht advies over de mogelijkheden, risico’s en vervolgstappen.\n\nOntdek de M365 Copilot-straat en vraag de Readiness Assessment aan op onze nieuwe pagina:\n\n\u003Ca class=\"btn-primary\" href=\"/onze-aanpak/microsoft-365-copilot-straat\">Ga naar De Microsoft 365 Copilot-straat\u003C/a>","global.pagesection",{"id":65,"titleLeft":66,"callToActionTextLeft":67,"callToActionLinkUrlLeft":68,"titleRight":69,"callToActionTextRight":70,"callToActionLinkUrlRight":71,"iconUrlLeft":72,"iconUrlRight":85,"__component":96},274,"Meer weten over onze andere aanpakken?","Lees hier meer","/onze-aanpak","Heb je een Microsoft 365 Consultant nodig?","Neem contact met ons op","/contact",{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":18,"hash":77,"ext":78,"mime":79,"size":80,"url":81,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":82,"updatedAt":83,"documentId":84,"publishedAt":57,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":86,"name":87,"alternativeText":18,"caption":18,"width":88,"height":89,"formats":18,"hash":90,"ext":78,"mime":79,"size":91,"url":92,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":93,"updatedAt":94,"documentId":95,"publishedAt":57,"focalPoint":18},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz","call-to-action.double",[98],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109,"image":110,"seo":129,"blocks":147,"midPageBlocks":172},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":111,"name":112,"alternativeText":18,"caption":18,"width":113,"height":114,"formats":115,"hash":124,"ext":117,"mime":120,"size":125,"url":126,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":127,"updatedAt":127,"documentId":128,"publishedAt":57,"focalPoint":18},16,"microsoft-365.png",282,130,{"thumbnail":116},{"ext":117,"url":118,"hash":119,"mime":120,"name":121,"path":18,"size":122,"width":49,"height":123},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":130,"metaTitle":131,"metaDescription":132,"structuredData":133,"metaImage":18,"metaSocial":146},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":134,"@type":135,"@context":136,"provider":137,"areaServed":141,"description":144,"serviceType":145},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":138,"name":139,"@type":140},"https://www.sharevalue.nl","ShareValue","Organization",{"name":142,"@type":143},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[148,156],{"id":149,"title":150,"aside":18,"postType":151,"limit":152,"expertise":153,"__component":155},166,"Lees meer over Microsoft 365","alle",3,[154],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109},"strapi.related-kennisbank-list",{"id":157,"titleLeft":158,"callToActionTextLeft":70,"callToActionLinkUrlLeft":71,"titleRight":159,"callToActionTextRight":160,"callToActionLinkUrlRight":161,"iconUrlLeft":162,"iconUrlRight":163,"__component":96},211,"Heb je een Microsoft 365 expert nodig?","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":18,"hash":77,"ext":78,"mime":79,"size":80,"url":81,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":82,"updatedAt":83,"documentId":84,"publishedAt":57,"focalPoint":18},{"id":164,"name":165,"alternativeText":18,"caption":18,"width":76,"height":76,"formats":18,"hash":166,"ext":78,"mime":79,"size":167,"url":168,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":169,"updatedAt":170,"documentId":171,"publishedAt":57,"focalPoint":18},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",[173,216,252,286,320,354,388,424,458],{"id":174,"title":175,"subTitle":176,"content":177,"callToActionText":18,"callToActionLink":18,"colorStyle":178,"showAsides":61,"imageUrl":179,"__component":215},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"id":180,"name":181,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":184,"hash":210,"ext":23,"mime":26,"size":211,"url":212,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":213,"updatedAt":213,"documentId":214,"publishedAt":57,"focalPoint":18},782,"Teams.jpg",1280,850,{"large":185,"small":191,"medium":197,"thumbnail":203},{"ext":23,"url":186,"hash":187,"mime":26,"name":188,"path":18,"size":189,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Teams_43eca91eed.jpg","large_Teams_43eca91eed","large_Teams.jpg",75.76,664,{"ext":23,"url":192,"hash":193,"mime":26,"name":194,"path":18,"size":195,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Teams_43eca91eed.jpg","small_Teams_43eca91eed","small_Teams.jpg",24.28,332,{"ext":23,"url":198,"hash":199,"mime":26,"name":200,"path":18,"size":201,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Teams_43eca91eed.jpg","medium_Teams_43eca91eed","medium_Teams.jpg",45.38,498,{"ext":23,"url":204,"hash":205,"mime":26,"name":206,"path":18,"size":207,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Teams_43eca91eed.jpg","thumbnail_Teams_43eca91eed","thumbnail_Teams.jpg",8.28,235,156,"Teams_43eca91eed",119.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Teams_43eca91eed.jpg","2024-08-08T09:42:56.910Z","ht6rctym4qbbspr1vnahyrg1","global.alternating-page-section",{"id":217,"title":218,"subTitle":219,"content":220,"callToActionText":221,"callToActionLink":71,"colorStyle":222,"showAsides":61,"imageUrl":223,"__component":215},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"id":224,"name":225,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":226,"hash":247,"ext":23,"mime":26,"size":248,"url":249,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":250,"updatedAt":250,"documentId":251,"publishedAt":57,"focalPoint":18},783,"adoptie.jpg",{"large":227,"small":232,"medium":237,"thumbnail":242},{"ext":23,"url":228,"hash":229,"mime":26,"name":230,"path":18,"size":231,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_adoptie_dc3bbcacaa.jpg","large_adoptie_dc3bbcacaa","large_adoptie.jpg",140.54,{"ext":23,"url":233,"hash":234,"mime":26,"name":235,"path":18,"size":236,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_adoptie_dc3bbcacaa.jpg","small_adoptie_dc3bbcacaa","small_adoptie.jpg",46.09,{"ext":23,"url":238,"hash":239,"mime":26,"name":240,"path":18,"size":241,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_adoptie_dc3bbcacaa.jpg","medium_adoptie_dc3bbcacaa","medium_adoptie.jpg",90.06,{"ext":23,"url":243,"hash":244,"mime":26,"name":245,"path":18,"size":246,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_adoptie_dc3bbcacaa.jpg","thumbnail_adoptie_dc3bbcacaa","thumbnail_adoptie.jpg",13.08,"adoptie_dc3bbcacaa",204.86,"https://incredible-beef-2a6059b946.media.strapiapp.com/adoptie_dc3bbcacaa.jpg","2024-08-08T09:47:03.256Z","kqdvjnnutm27pjz49n0b8l8r",{"id":253,"title":254,"subTitle":255,"content":256,"callToActionText":18,"callToActionLink":18,"colorStyle":178,"showAsides":61,"imageUrl":257,"__component":215},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"id":258,"name":259,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":260,"hash":281,"ext":23,"mime":26,"size":282,"url":283,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":284,"updatedAt":284,"documentId":285,"publishedAt":57,"focalPoint":18},784,"trends.jpg",{"large":261,"small":266,"medium":271,"thumbnail":276},{"ext":23,"url":262,"hash":263,"mime":26,"name":264,"path":18,"size":265,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_trends_e84a321990.jpg","large_trends_e84a321990","large_trends.jpg",198.92,{"ext":23,"url":267,"hash":268,"mime":26,"name":269,"path":18,"size":270,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_trends_e84a321990.jpg","small_trends_e84a321990","small_trends.jpg",59.76,{"ext":23,"url":272,"hash":273,"mime":26,"name":274,"path":18,"size":275,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":23,"url":277,"hash":278,"mime":26,"name":279,"path":18,"size":280,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"id":287,"title":288,"subTitle":289,"content":290,"callToActionText":18,"callToActionLink":18,"colorStyle":222,"showAsides":61,"imageUrl":291,"__component":215},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":292,"name":293,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":294,"hash":315,"ext":23,"mime":26,"size":316,"url":317,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":318,"updatedAt":318,"documentId":319,"publishedAt":57,"focalPoint":18},785,"microsoft development.jpg",{"large":295,"small":300,"medium":305,"thumbnail":310},{"ext":23,"url":296,"hash":297,"mime":26,"name":298,"path":18,"size":299,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":23,"url":301,"hash":302,"mime":26,"name":303,"path":18,"size":304,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":23,"url":306,"hash":307,"mime":26,"name":308,"path":18,"size":309,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":311,"hash":312,"mime":26,"name":313,"path":18,"size":314,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":6,"title":321,"subTitle":322,"content":323,"callToActionText":324,"callToActionLink":71,"colorStyle":178,"showAsides":61,"imageUrl":325,"__component":215},"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":326,"name":327,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":328,"hash":349,"ext":23,"mime":26,"size":350,"url":351,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":352,"updatedAt":352,"documentId":353,"publishedAt":57,"focalPoint":18},786,"migratie.jpg",{"large":329,"small":334,"medium":339,"thumbnail":344},{"ext":23,"url":330,"hash":331,"mime":26,"name":332,"path":18,"size":333,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":335,"hash":336,"mime":26,"name":337,"path":18,"size":338,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":340,"hash":341,"mime":26,"name":342,"path":18,"size":343,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":345,"hash":346,"mime":26,"name":347,"path":18,"size":348,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":355,"title":356,"subTitle":357,"content":358,"callToActionText":18,"callToActionLink":18,"colorStyle":222,"showAsides":61,"imageUrl":359,"__component":215},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":360,"name":361,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":362,"hash":383,"ext":23,"mime":26,"size":384,"url":385,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":386,"updatedAt":386,"documentId":387,"publishedAt":57,"focalPoint":18},787,"microsoft security.jpg",{"large":363,"small":368,"medium":373,"thumbnail":378},{"ext":23,"url":364,"hash":365,"mime":26,"name":366,"path":18,"size":367,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":369,"hash":370,"mime":26,"name":371,"path":18,"size":372,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":374,"hash":375,"mime":26,"name":376,"path":18,"size":377,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":379,"hash":380,"mime":26,"name":381,"path":18,"size":382,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":389,"title":390,"subTitle":391,"content":392,"callToActionText":393,"callToActionLink":394,"colorStyle":178,"showAsides":61,"imageUrl":395,"__component":215},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":396,"name":397,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":398,"hash":419,"ext":23,"mime":26,"size":420,"url":421,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":422,"updatedAt":422,"documentId":423,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":399,"small":404,"medium":409,"thumbnail":414},{"ext":23,"url":400,"hash":401,"mime":26,"name":402,"path":18,"size":403,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":405,"hash":406,"mime":26,"name":407,"path":18,"size":408,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":410,"hash":411,"mime":26,"name":412,"path":18,"size":413,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":415,"hash":416,"mime":26,"name":417,"path":18,"size":418,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":425,"title":426,"subTitle":427,"content":428,"callToActionText":18,"callToActionLink":18,"colorStyle":222,"showAsides":61,"imageUrl":429,"__component":215},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":430,"name":431,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":432,"hash":453,"ext":23,"mime":26,"size":454,"url":455,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":456,"updatedAt":456,"documentId":457,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":433,"small":438,"medium":443,"thumbnail":448},{"ext":23,"url":434,"hash":435,"mime":26,"name":436,"path":18,"size":437,"width":29,"height":190},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":439,"hash":440,"mime":26,"name":441,"path":18,"size":442,"width":30,"height":196},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":444,"hash":445,"mime":26,"name":446,"path":18,"size":447,"width":42,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":449,"hash":450,"mime":26,"name":451,"path":18,"size":452,"width":208,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116