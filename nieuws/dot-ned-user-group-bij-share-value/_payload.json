[{"data":1,"prerenderedAt":649},["ShallowReactive",2],{"collection-nieuws--516584289":3,"_apollo:default":648},{"data":4,"meta":645},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"seo":59,"blocks":77,"expertises":125},18,"DotNed UserGroup bij ShareValue","Op dinsdag 26 september vindt op ons gezellige kantoor de DotNed Usergroup Meeting plaats! Na een goed buffet houdt MVP Erwin Staal een sessie over Infra as Code: ","dot-ned-user-group-bij-share-value","2023-09-29T11:12:59.018Z","2025-05-08T09:35:45.338Z","2023-09-29T11:13:00.377Z","2023-09-13","h9vlo15c2xsbeo6jk67hefng",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":18},237,"dotned_usergroup.jpg",null,1200,628,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_dotned_usergroup_26b7d728d2.jpg","large_dotned_usergroup_26b7d728d2","image/jpeg","large_dotned_usergroup.jpg",92.36,1000,523,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_dotned_usergroup_26b7d728d2.jpg","small_dotned_usergroup_26b7d728d2","small_dotned_usergroup.jpg",27.86,500,262,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_dotned_usergroup_26b7d728d2.jpg","medium_dotned_usergroup_26b7d728d2","medium_dotned_usergroup.jpg",57.32,750,393,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_dotned_usergroup_26b7d728d2.jpg","thumbnail_dotned_usergroup_26b7d728d2","thumbnail_dotned_usergroup.jpg",7.22,245,128,"dotned_usergroup_26b7d728d2",125.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/dotned_usergroup_26b7d728d2.jpg","strapi-provider-upload-strapi-cloud","2023-09-29T11:11:47.276Z","dypnstzfswzj4mmfylvj49sj","2026-01-05T12:38:34.018Z",{"id":60,"metaTitle":61,"metaDescription":62,"structuredData":63,"metaImage":18,"metaSocial":76},218,"Dot.Ned User Group bij ShareValue | ShareValue","Bekijk het evenement van de Dot.Ned User Group bij ShareValue. Lees hoe Microsoft-experts samenkwamen om kennis te delen en te netwerken.",{"url":64,"@type":65,"author":66,"@context":67,"headline":61,"publisher":68,"description":62,"datePublished":75},"https://www.sharevalue.nl/nieuws/dot-ned-user-group-bij-share-value","NewsArticle","","https://schema.org",{"url":69,"logo":70,"name":73,"@type":74},"https://www.sharevalue.nl",{"url":71,"@type":72},"https://www.sharevalue.nl/assets/logo.png","ImageObject","ShareValue","Organization","2024-06-25",[],[78,84,88,93],{"id":79,"title":18,"asideText":18,"underline":80,"centered":80,"blankAside":81,"aside":18,"content":82,"introductionText":18,"__component":83},177,false,true,"\nOp Azure zijn drie van de meest voor de hand liggende keuzes voor Infrastructure as Code Bicep, Terraform en Pulumi. Bicep is Microsofts eigen domeinspecifieke taal, terwijl Terraform een open-source tool is die cloudagnostisch is. Waar Bicep en Terraform beide hun eigen taal hebben, stelt Pulumi je in staat om je Infrastructure as Code te schrijven met je favoriete taal zoals C#, Python of Go. In deze sessie zullen we ontdekken waar ze vergelijkbaar zijn en waar ze dat niet zijn, en kijken naar hun voor- en nadelen. We zullen het ecosysteem rond deze tools onderzoeken om te zien hoe goed ze integreren met andere tools zoals beveiligingsscanners en CI/CD-pipelines. Aan het einde van deze presentatie kun je een weloverwogen beslissing nemen over welke tool je in je volgende project wilt gebruiken!\n\nHierna gaan we natuurlijk nog even borrelen! 🍻","global.pagesection",{"id":85,"title":86,"showBlankAside":81,"__component":87},40,"Diversiteit aan klanten","global.social-sharing",{"id":89,"asideText":18,"title":90,"underline":81,"centered":81,"limit":91,"__component":92},12,"Gerelateerde artikelen",3,"strapi.latest-posts",{"id":94,"titleLeft":95,"callToActionTextLeft":96,"callToActionLinkUrlLeft":97,"titleRight":98,"callToActionTextRight":99,"callToActionLinkUrlRight":100,"iconUrlLeft":101,"iconUrlRight":113,"__component":124},66,"Wil je onze collega worden?","Bekijk onze vacatures","/word-onze-collega/vacatures","Hoor van onze experts hoe leuk ShareValue is ","Lees de verhalen van onze collega's","/word-onze-collega/collegas-aan-het-woord",{"id":102,"name":103,"alternativeText":18,"caption":18,"width":104,"height":104,"formats":18,"hash":105,"ext":106,"mime":107,"size":108,"url":109,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":110,"updatedAt":111,"documentId":112,"publishedAt":58,"focalPoint":18},8,"briefcase.svg",70,"briefcase_679abae475",".svg","image/svg+xml",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",{"id":114,"name":115,"alternativeText":18,"caption":18,"width":116,"height":117,"formats":18,"hash":118,"ext":106,"mime":107,"size":119,"url":120,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":121,"updatedAt":122,"documentId":123,"publishedAt":58,"focalPoint":18},7,"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf","call-to-action.double",[126,303,461],{"id":91,"title":127,"subTitle":128,"description":129,"shortDescription":130,"slug":131,"createdAt":132,"updatedAt":133,"publishedAt":134,"isCoreExpertise":80,"documentId":135,"image":136,"seo":18,"blocks":155,"midPageBlocks":187},"Microsoft .NET","Maatwerkoplossingen voor ieder vraagstuk","Ons team van .NET-experts staat niet alleen klaar om onze klanten te ondersteunen bij diverse implementatie uitdagingen, maar we zijn ook gespecialiseerd in het testen van applicaties op verschillende niveaus, zoals unit tests, integratietests en acceptatietests. We streven naar uitmuntende testdekking om de stabiliteit en betrouwbaarheid van de applicaties te waarborgen.\n\nDaarnaast zijn we bedreven in het gebruik van verschillende Azure-services om schaalbare en veilige oplossingen te bieden aan onze klanten. Zo bieden we met Azure DevOps krachtige tools voor het beheren van de ontwikkeling, het automatiseren van tests en het geautomatiseerd uitrollen naar acceptatie- of productieomgevingen met CI/CD-pipelines.\n\nHet samenwerken met onze klanten staat centraal in ons werk, en we denken proactief mee om samen de meest optimale oplossingen te realiseren.","In de praktijk komen de .NET developers van ShareValue terecht in allerlei verschillende branches met uiteenlopende technische uitdagingen.","dotnet","2023-08-17T11:19:57.991Z","2024-12-13T12:16:04.480Z","2023-08-17T11:22:08.050Z","v9pl553hsjk98esvs5gzoso3",{"id":137,"name":138,"alternativeText":18,"caption":18,"width":139,"height":140,"formats":141,"hash":150,"ext":143,"mime":146,"size":151,"url":152,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":153,"updatedAt":153,"documentId":154,"publishedAt":58,"focalPoint":18},17,"dotnet_logo.png",282,130,{"thumbnail":142},{"ext":143,"url":144,"hash":145,"mime":146,"name":147,"path":18,"size":148,"width":50,"height":149},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_dotnet_logo_d38dbc3865.png","thumbnail_dotnet_logo_d38dbc3865","image/png","thumbnail_dotnet_logo.png",7.14,113,"dotnet_logo_d38dbc3865",2.93,"https://incredible-beef-2a6059b946.media.strapiapp.com/dotnet_logo_d38dbc3865.png","2023-08-17T09:47:56.313Z","nnimzsossci29qmi8z0texlp",[156,163],{"id":157,"title":158,"aside":18,"postType":159,"limit":91,"expertise":160,"__component":162},167," Lees meer over .NET Development","alle",[161],{"id":91,"title":127,"subTitle":128,"description":129,"shortDescription":130,"slug":131,"createdAt":132,"updatedAt":133,"publishedAt":134,"isCoreExpertise":80,"documentId":135},"strapi.related-kennisbank-list",{"id":164,"titleLeft":165,"callToActionTextLeft":166,"callToActionLinkUrlLeft":167,"titleRight":168,"callToActionTextRight":166,"callToActionLinkUrlRight":167,"iconUrlLeft":169,"iconUrlRight":179,"__component":124},212,"Heb je een .NET expert nodig?","Neem contact met ons op","/contact","Weten welke expert op dit moment beschikbaar is?",{"id":170,"name":171,"alternativeText":18,"caption":18,"width":172,"height":104,"formats":18,"hash":173,"ext":106,"mime":107,"size":174,"url":175,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":176,"updatedAt":177,"documentId":178,"publishedAt":58,"focalPoint":18},6,"bulb.svg",71,"bulb_dd2e1d4efb",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":180,"name":181,"alternativeText":18,"caption":18,"width":104,"height":104,"formats":18,"hash":182,"ext":106,"mime":107,"size":183,"url":184,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":185,"updatedAt":185,"documentId":186,"publishedAt":58,"focalPoint":18},250,"looking-glass.svg","looking_glass_cfa3801802",0.6,"https://incredible-beef-2a6059b946.media.strapiapp.com/looking_glass_cfa3801802.svg","2023-10-11T09:43:10.911Z","suv3p7h0kw7jdnuddk1l2rdu",[188,230,263,296],{"id":189,"title":190,"subTitle":18,"content":191,"callToActionText":192,"callToActionLink":167,"colorStyle":18,"showAsides":18,"imageUrl":193,"__component":229},36,"Bouwen en testen","Onze .NET-experts kunnen uiteraard goede en betrouwbare applicaties ontwikkelen met de laatste .NET-versies. Ook zijn onze collega’s ervaren in het onderhouden van oudere software. We kunnen je helpen met het upgraden en uitbreiden van je applicatie zodat deze aan de laatste wensen en eisen voldoet. Het uitvoeren van uitgebreide unit- en integratietests om de stabiliteit van applicaties te waarborgen, wordt meegenomen als standaard onderdeel van het werk. Met een focus op grondige testdekking streven we ernaar om eventuele bugs vroegtijdig op te sporen en op te lossen, waardoor de algehele kwaliteit van jouw product wordt verbeterd.  \n\nVan Blazor Front-End of REST API’s tot database communicatie, onze .NET-experts hebben er ruime ervaring mee.","Weten wat onze experts voor jou kunnen doen?",{"id":194,"name":195,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":198,"hash":224,"ext":23,"mime":26,"size":225,"url":226,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":227,"updatedAt":227,"documentId":228,"publishedAt":58,"focalPoint":18},790,"code matrix.jpg",1280,850,{"large":199,"small":205,"medium":211,"thumbnail":217},{"ext":23,"url":200,"hash":201,"mime":26,"name":202,"path":18,"size":203,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_code_matrix_939256fff4.jpg","large_code_matrix_939256fff4","large_code matrix.jpg",164.22,664,{"ext":23,"url":206,"hash":207,"mime":26,"name":208,"path":18,"size":209,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_code_matrix_939256fff4.jpg","small_code_matrix_939256fff4","small_code matrix.jpg",42.02,332,{"ext":23,"url":212,"hash":213,"mime":26,"name":214,"path":18,"size":215,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_code_matrix_939256fff4.jpg","medium_code_matrix_939256fff4","medium_code matrix.jpg",97.04,498,{"ext":23,"url":218,"hash":219,"mime":26,"name":220,"path":18,"size":221,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_code_matrix_939256fff4.jpg","thumbnail_code_matrix_939256fff4","thumbnail_code matrix.jpg",8.35,235,156,"code_matrix_939256fff4",258.04,"https://incredible-beef-2a6059b946.media.strapiapp.com/code_matrix_939256fff4.jpg","2024-08-09T08:30:59.615Z","s5v68ezvz0ho9m6ot0mbk8z2","global.alternating-page-section",{"id":231,"title":232,"subTitle":18,"content":233,"callToActionText":18,"callToActionLink":18,"colorStyle":18,"showAsides":18,"imageUrl":234,"__component":229},37,"Combineren met Azure","Wil je profiteren van Azure-services voor jouw project? Ons team van experts kan je helpen met het selecteren en opzetten van de juiste services. Of je gebruik wil maken van App services, Function Apps, storage of database oplossingen of bijvoorbeeld een Service Bus, onze experts kunnen je helpen bij het kiezen en het realiseren van stabiele, schaalbare en veilige oplossingen die voldoen aan jouw specifieke behoeften.",{"id":235,"name":236,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":237,"hash":258,"ext":23,"mime":26,"size":259,"url":260,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":261,"updatedAt":261,"documentId":262,"publishedAt":58,"focalPoint":18},791,"service bus.jpg",{"large":238,"small":243,"medium":248,"thumbnail":253},{"ext":23,"url":239,"hash":240,"mime":26,"name":241,"path":18,"size":242,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_service_bus_2b48e3a7cc.jpg","large_service_bus_2b48e3a7cc","large_service bus.jpg",82.82,{"ext":23,"url":244,"hash":245,"mime":26,"name":246,"path":18,"size":247,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_service_bus_2b48e3a7cc.jpg","small_service_bus_2b48e3a7cc","small_service bus.jpg",29.35,{"ext":23,"url":249,"hash":250,"mime":26,"name":251,"path":18,"size":252,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_service_bus_2b48e3a7cc.jpg","medium_service_bus_2b48e3a7cc","medium_service bus.jpg",54.72,{"ext":23,"url":254,"hash":255,"mime":26,"name":256,"path":18,"size":257,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_service_bus_2b48e3a7cc.jpg","thumbnail_service_bus_2b48e3a7cc","thumbnail_service bus.jpg",8.71,"service_bus_2b48e3a7cc",117.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/service_bus_2b48e3a7cc.jpg","2024-08-09T08:35:35.231Z","rbpawsulv6vrsistrk2yupwg",{"id":264,"title":265,"subTitle":18,"content":266,"callToActionText":18,"callToActionLink":18,"colorStyle":18,"showAsides":18,"imageUrl":267,"__component":229},35,"Houd het veilig!","Om de toegang tot je producten veilig te houden, kan ons team van .NET-experts je helpen bij het opzetten en onderhouden van authenticatie en autorisatie. Onze experts zijn ervaren in het opzetten de juiste entra diensten zodat de toegang tot zowel Front-End als Back-End of deamon-processen op een juiste manier afgehandeld wordt. Ook kunnen we je helpen met het opzetten van verschillende groepen, rechten en rollen, en deze op de juiste manier toepassen binnen de applicatie zodat onterechte toegang op functieniveau geregeld kan worden. Bij het opzetten en implementeren wordt er rekening gehouden met het reduceren van de administratieve overhead zonder concessies te doen aan de beveiliging.",{"id":268,"name":269,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":270,"hash":291,"ext":23,"mime":26,"size":292,"url":293,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":294,"updatedAt":294,"documentId":295,"publishedAt":58,"focalPoint":18},792,"security dotnet.jpg",{"large":271,"small":276,"medium":281,"thumbnail":286},{"ext":23,"url":272,"hash":273,"mime":26,"name":274,"path":18,"size":275,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_dotnet_a65d687baf.jpg","large_security_dotnet_a65d687baf","large_security dotnet.jpg",38.7,{"ext":23,"url":277,"hash":278,"mime":26,"name":279,"path":18,"size":280,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_dotnet_a65d687baf.jpg","small_security_dotnet_a65d687baf","small_security dotnet.jpg",13.37,{"ext":23,"url":282,"hash":283,"mime":26,"name":284,"path":18,"size":285,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_dotnet_a65d687baf.jpg","medium_security_dotnet_a65d687baf","medium_security dotnet.jpg",24.75,{"ext":23,"url":287,"hash":288,"mime":26,"name":289,"path":18,"size":290,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_dotnet_a65d687baf.jpg","thumbnail_security_dotnet_a65d687baf","thumbnail_security dotnet.jpg",4.63,"security_dotnet_a65d687baf",57.25,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_dotnet_a65d687baf.jpg","2024-08-09T08:36:56.895Z","srupv8bm7kvcgseu2efeadhk",{"id":297,"title":298,"callToActionText":299,"callToActionLinkUrl":300,"body":18,"imageUrl":301,"__component":302},46,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij KPN","/klantcases/de-continue-bereikbaarheid-van-een-alarmcentrale",{"id":170,"name":171,"alternativeText":18,"caption":18,"width":172,"height":104,"formats":18,"hash":173,"ext":106,"mime":107,"size":174,"url":175,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":176,"updatedAt":177,"documentId":178,"publishedAt":58,"focalPoint":18},"call-to-action.single",{"id":304,"title":305,"subTitle":306,"description":307,"shortDescription":308,"slug":309,"createdAt":310,"updatedAt":311,"publishedAt":312,"isCoreExpertise":81,"documentId":313,"image":314,"seo":328,"blocks":342,"midPageBlocks":354},1,"Azure","Hét cloudcomputing platform van Microsoft","Azure is het cloudcomputing platform van Microsoft, dat zowel Infrastructure as a Service (IaaS) als Platform as a Service (PaaS) biedt. Met dit platform kun je applicaties ontwikkelen of een compleet netwerk hosten, en dit alles op een relatief eenvoudige manier beheren. Omdat Azure wordt gehost in managed datacenters over de hele wereld, kun je jouw netwerk of applicatie wereldwijd beschikbaar maken. Microsoft biedt daarnaast een breed scala aan services, zoals Internet of Things (IoT), Azure Kubernetes, Artificial Intelligence (AI) en oplossingen voor het gebruik van Big Data.\n\nOnze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt. Hierbij leveren wij iedere keer maatwerk, want het programma van eisen ziet er telkens anders uit. Of het nu gaat om de ondersteuning van een Azure team of het volledige beheer, onze Azure experts staan voor je klaar. Meer over ons werk lees je onder andere in onze Azure [klantcases](/kennisbank/klantcases/azure) en [blogs](/kennisbank/blogs/azure).\n\n","Onze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt.","azure","2023-08-17T09:47:20.996Z","2025-04-11T13:11:55.618Z","2023-08-17T09:50:22.095Z","eubwn704tlyata6v2q819fn7",{"id":315,"name":316,"alternativeText":18,"caption":18,"width":139,"height":140,"formats":317,"hash":323,"ext":143,"mime":146,"size":324,"url":325,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":326,"updatedAt":326,"documentId":327,"publishedAt":58,"focalPoint":18},657,"mircosoft azure web.png",{"thumbnail":318},{"ext":143,"url":319,"hash":320,"mime":146,"name":321,"path":18,"size":322,"width":50,"height":149},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_mircosoft_azure_web_031897ebac.png","thumbnail_mircosoft_azure_web_031897ebac","thumbnail_mircosoft azure web.png",5.54,"mircosoft_azure_web_031897ebac",1.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/mircosoft_azure_web_031897ebac.png","2024-04-05T12:52:48.184Z","z9c21qscgi7eh5jijkc40fzv",{"id":329,"metaTitle":330,"metaDescription":331,"structuredData":332,"metaImage":18,"metaSocial":341},24,"Microsoft Azure-expertise – ShareValue helpt je vooruit","Van beheer tot DevOps: onze Azure-specialisten helpen je om cloudoplossingen slim en veilig in te richten en te optimaliseren.",{"url":333,"@type":334,"@context":67,"provider":335,"areaServed":336,"description":339,"serviceType":340},"https://www.sharevalue.nl/wat-we-doen/azure","Service",{"url":69,"name":73,"@type":74},{"name":337,"@type":338},"Nederland","Country","ShareValue helpt organisaties om Microsoft Azure effectief in te zetten. Onze specialisten werken aan cloudmigraties, infrastructuur, security, automation en DevOps-oplossingen.","Microsoft Azure consultancy",[],[343,348],{"id":344,"title":345,"aside":18,"postType":159,"limit":91,"expertise":346,"__component":162},165,"Lees meer over Azure",[347],{"id":304,"title":305,"subTitle":306,"description":307,"shortDescription":308,"slug":309,"createdAt":310,"updatedAt":311,"publishedAt":312,"isCoreExpertise":81,"documentId":313},{"id":349,"titleLeft":350,"callToActionTextLeft":166,"callToActionLinkUrlLeft":167,"titleRight":351,"callToActionTextRight":96,"callToActionLinkUrlRight":97,"iconUrlLeft":352,"iconUrlRight":353,"__component":124},209,"Heb je een Azure expert nodig?","Zoek je een nieuwe baan?",{"id":170,"name":171,"alternativeText":18,"caption":18,"width":172,"height":104,"formats":18,"hash":173,"ext":106,"mime":107,"size":174,"url":175,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":176,"updatedAt":177,"documentId":178,"publishedAt":58,"focalPoint":18},{"id":102,"name":103,"alternativeText":18,"caption":18,"width":104,"height":104,"formats":18,"hash":105,"ext":106,"mime":107,"size":108,"url":109,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":110,"updatedAt":111,"documentId":112,"publishedAt":58,"focalPoint":18},[355,390,424,456],{"id":356,"title":357,"subTitle":18,"content":358,"callToActionText":359,"callToActionLink":167,"colorStyle":360,"showAsides":80,"imageUrl":361,"__component":229},25,"Azure Security: veiligheid in de cloud ","Voor organisaties is het belangrijk om de digitale infrastructuur te beveiligen in een steeds complexer wordend cyberlandschap. Onze experts helpen graag met behulp van Azure Security; een reeks beveiligingsdiensten en -functies die door Microsoft Azure wordt aangeboden om bedreigingen te detecteren, te voorkomen en erop te reageren. Enkele belangrijke componenten en functies van Azure Security waarmee wij werken zijn Azure Security Center, Microsoft Entra ID, Azure DDoS Protection en Azure Sentinel.","Neem contact op voor meer informatie","Sugar Glaze",{"id":362,"name":363,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":364,"hash":385,"ext":23,"mime":26,"size":386,"url":387,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":388,"updatedAt":388,"documentId":389,"publishedAt":58,"focalPoint":18},779,"security azure.jpg",{"large":365,"small":370,"medium":375,"thumbnail":380},{"ext":23,"url":366,"hash":367,"mime":26,"name":368,"path":18,"size":369,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_azure_b1610cf1cb.jpg","large_security_azure_b1610cf1cb","large_security azure.jpg",107.3,{"ext":23,"url":371,"hash":372,"mime":26,"name":373,"path":18,"size":374,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_azure_b1610cf1cb.jpg","small_security_azure_b1610cf1cb","small_security azure.jpg",39.16,{"ext":23,"url":376,"hash":377,"mime":26,"name":378,"path":18,"size":379,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_azure_b1610cf1cb.jpg","medium_security_azure_b1610cf1cb","medium_security azure.jpg",71.35,{"ext":23,"url":381,"hash":382,"mime":26,"name":383,"path":18,"size":384,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_azure_b1610cf1cb.jpg","thumbnail_security_azure_b1610cf1cb","thumbnail_security azure.jpg",12.37,"security_azure_b1610cf1cb",150.42,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_azure_b1610cf1cb.jpg","2024-08-08T08:50:26.921Z","z3xlbivuior2upad6adbxjgz",{"id":391,"title":392,"subTitle":18,"content":393,"callToActionText":18,"callToActionLink":18,"colorStyle":394,"showAsides":80,"imageUrl":395,"__component":229},26,"Azure Kubernetes Service (AKS)","Azure Kubernetes Service (AKS) helpt bij het beheren van applicaties die in containers draaien. Het vereenvoudigt en automatiseert de implementatie, het beheer en de operationele taken van Kubernetes-clusters. Door gebruik te maken van AKS kunnen organisaties zich richten op het ontwikkelen en beheren van hun applicaties, terwijl Microsoft de complexiteit van de Kubernetes-infrastructuur beheert. Hierdoor kunnen organisaties hun software efficiënt, betrouwbaar en kosteneffectief beheren. Doordat onze experts ruime kennis en ervaring hebben met AKS kunnen ze de klanten op een juiste manier helpen.","White",{"id":396,"name":397,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":398,"hash":419,"ext":23,"mime":26,"size":420,"url":421,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":422,"updatedAt":422,"documentId":423,"publishedAt":58,"focalPoint":18},780,"containers.jpg",{"large":399,"small":404,"medium":409,"thumbnail":414},{"ext":23,"url":400,"hash":401,"mime":26,"name":402,"path":18,"size":403,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_containers_2e766510ad.jpg","large_containers_2e766510ad","large_containers.jpg",163.19,{"ext":23,"url":405,"hash":406,"mime":26,"name":407,"path":18,"size":408,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_containers_2e766510ad.jpg","small_containers_2e766510ad","small_containers.jpg",49.69,{"ext":23,"url":410,"hash":411,"mime":26,"name":412,"path":18,"size":413,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_containers_2e766510ad.jpg","medium_containers_2e766510ad","medium_containers.jpg",101.49,{"ext":23,"url":415,"hash":416,"mime":26,"name":417,"path":18,"size":418,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_containers_2e766510ad.jpg","thumbnail_containers_2e766510ad","thumbnail_containers.jpg",12.65,"containers_2e766510ad",240.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/containers_2e766510ad.jpg","2024-08-08T08:54:58.426Z","idshbfmg66aak9yxdr9d22c7",{"id":329,"title":425,"subTitle":18,"content":426,"callToActionText":18,"callToActionLink":18,"colorStyle":360,"showAsides":80,"imageUrl":427,"__component":229},"Infrastructure as Code (IaC)","Infrastructure as Code (IaC) is het beheren van een Azure cloud-omgeving door middel van code en softwareontwikkelingstechnieken om infrastructuur te automatiseren, te configureren en te beheren. Het biedt versiebeheer voor configuraties, wat samenwerking en terugkeer naar eerdere versies vergemakkelijkt. Bovendien zorgt IaC voor consistentie in verschillende omgevingen en maakt het schaalvergroting eenvoudiger door configuraties te herhalen zonder handmatige ingrepen. \n\nAls je vragen hebt of ondersteuning nodig hebt, kunnen de Azure Experts je alles vertellen over Infrastructure as Code.",{"id":428,"name":429,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":430,"hash":451,"ext":23,"mime":26,"size":452,"url":453,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":454,"updatedAt":454,"documentId":455,"publishedAt":58,"focalPoint":18},781,"infrastructure.jpg",{"large":431,"small":436,"medium":441,"thumbnail":446},{"ext":23,"url":432,"hash":433,"mime":26,"name":434,"path":18,"size":435,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_infrastructure_bf66532759.jpg","large_infrastructure_bf66532759","large_infrastructure.jpg",246.61,{"ext":23,"url":437,"hash":438,"mime":26,"name":439,"path":18,"size":440,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_infrastructure_bf66532759.jpg","small_infrastructure_bf66532759","small_infrastructure.jpg",69.57,{"ext":23,"url":442,"hash":443,"mime":26,"name":444,"path":18,"size":445,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_infrastructure_bf66532759.jpg","medium_infrastructure_bf66532759","medium_infrastructure.jpg",149.51,{"ext":23,"url":447,"hash":448,"mime":26,"name":449,"path":18,"size":450,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_infrastructure_bf66532759.jpg","thumbnail_infrastructure_bf66532759","thumbnail_infrastructure.jpg",15.74,"infrastructure_bf66532759",374.88,"https://incredible-beef-2a6059b946.media.strapiapp.com/infrastructure_bf66532759.jpg","2024-08-08T08:58:52.414Z","bmkl03ingwf6ms8pdk5jvmx5",{"id":457,"title":298,"callToActionText":458,"callToActionLinkUrl":459,"body":18,"imageUrl":460,"__component":302},94,"Lees de klantcase over ons werk bij Stichting Inlichtingenbureau","/klantcases/stichting-inlichtingenbureau-kiest-voor-migratie-naar-microsoft-azure",{"id":170,"name":171,"alternativeText":18,"caption":18,"width":172,"height":104,"formats":18,"hash":173,"ext":106,"mime":107,"size":174,"url":175,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":176,"updatedAt":177,"documentId":178,"publishedAt":58,"focalPoint":18},{"id":462,"title":463,"subTitle":128,"description":464,"shortDescription":465,"slug":466,"createdAt":467,"updatedAt":468,"publishedAt":469,"isCoreExpertise":81,"documentId":470,"image":471,"seo":486,"blocks":497,"midPageBlocks":528},10,"Development","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. Van gebruiksvriendelijke interfaces tot krachtige Back-End-architecturen: wij hebben de kennis en ervaring om jouw project tot een succes te maken.","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. ","development","2024-12-13T12:15:40.484Z","2025-04-11T13:13:55.384Z","2024-12-13T12:15:42.976Z","lpzfadokpxn5sdnx9czcdg47",{"id":472,"name":473,"alternativeText":18,"caption":18,"width":139,"height":140,"formats":474,"hash":480,"ext":143,"mime":146,"size":481,"url":482,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":483,"updatedAt":484,"documentId":485,"publishedAt":58,"focalPoint":18},950,"Logo Development 2025 web.png",{"thumbnail":475},{"ext":143,"url":476,"hash":477,"mime":146,"name":478,"path":18,"size":479,"width":50,"height":149},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Development_2025_web_d7711df072.png","thumbnail_Logo_Development_2025_web_d7711df072","thumbnail_Logo Development 2025 web.png",8.58,"Logo_Development_2025_web_d7711df072",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Development_2025_web_d7711df072.png","2024-12-17T15:02:47.479Z","2024-12-19T08:35:22.054Z","okwfs117fps338v5fj5dnrpb",{"id":487,"metaTitle":488,"metaDescription":489,"structuredData":490,"metaImage":18,"metaSocial":496},27,"Maatwerk software & integraties – ShareValue Development","Van webapps tot koppelingen: onze developers bouwen slimme oplossingen die passen bij jouw Microsoft-omgeving.",{"url":491,"@type":334,"@context":67,"provider":492,"areaServed":493,"description":494,"serviceType":495},"https://www.sharevalue.nl/wat-we-doen/development",{"url":69,"name":73,"@type":74},{"name":337,"@type":338},"Onze developers realiseren maatwerkoplossingen binnen Microsoft-omgevingen. Denk aan webapplicaties, API-integraties, extensies voor Microsoft 365 en koppelingen met externe systemen. Technisch sterk én begrijpelijk ingericht.","Maatwerk softwareontwikkeling en integraties",[],[498,514],{"id":499,"title":500,"aside":18,"postType":159,"limit":91,"expertise":501,"__component":162},179,"Lees meer over Development",[502,503,513],{"id":462,"title":463,"subTitle":128,"description":464,"shortDescription":465,"slug":466,"createdAt":467,"updatedAt":468,"publishedAt":469,"isCoreExpertise":81,"documentId":470},{"id":481,"title":504,"subTitle":505,"description":506,"shortDescription":507,"slug":508,"createdAt":509,"updatedAt":510,"publishedAt":511,"isCoreExpertise":80,"documentId":512},"Front-End","Steeds complexer en steeds belangrijker","In een online wereld vol moderne webapplicaties is een goede Front-End onmisbaar. Het is nodig om aan de behoeften en verwachtingen van de gebruikers te voldoen. De interactie voor de gebruiker moet daarbij zo snel en optimaal mogelijk zijn. Met trots kunnen wij zeggen dat juist dáár de kracht van onze Front-End Developers zit.\n\nOnze ervaren Developers staan klaar om jouw team te versterken en te zorgen voor een optimale gebruikerservaring. Of je nu een tijdelijke aanvulling op je team nodig hebt of op zoek bent naar gespecialiseerde kennis voor een specifiek project, onze Front-End Developers zijn uitgerust om de uitdagingen van onze klanten aan te gaan en hun doelen te bereiken.","Onze Front-End developers zijn bedreven in diverse programmeertalen, frameworks en methodieken en daardoor breed inzetbaar.","front-end","2023-08-17T09:50:12.632Z","2024-12-13T12:15:57.609Z","2023-08-17T09:50:14.418Z","l6bdicvjcb7ue03zpciuc888",{"id":91,"title":127,"subTitle":128,"description":129,"shortDescription":130,"slug":131,"createdAt":132,"updatedAt":133,"publishedAt":134,"isCoreExpertise":80,"documentId":135},{"id":515,"titleLeft":516,"callToActionTextLeft":166,"callToActionLinkUrlLeft":167,"titleRight":351,"callToActionTextRight":96,"callToActionLinkUrlRight":97,"iconUrlLeft":517,"iconUrlRight":518,"__component":124},251,"Heb je een Developer nodig?",{"id":114,"name":115,"alternativeText":18,"caption":18,"width":116,"height":117,"formats":18,"hash":118,"ext":106,"mime":107,"size":119,"url":120,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":121,"updatedAt":122,"documentId":123,"publishedAt":58,"focalPoint":18},{"id":519,"name":520,"alternativeText":18,"caption":18,"width":521,"height":117,"formats":18,"hash":522,"ext":106,"mime":107,"size":523,"url":524,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":525,"updatedAt":526,"documentId":527,"publishedAt":58,"focalPoint":18},372,"magnifier.svg",49,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",[529,562,571,605,639],{"id":530,"title":531,"subTitle":18,"content":532,"callToActionText":18,"callToActionLink":18,"colorStyle":360,"showAsides":80,"imageUrl":533,"__component":229},47,"Optimale gebruikerservaring","Een goede Front-End is meer dan alleen een aantrekkelijke interface; het vormt de schakel tussen technologie en eindgebruiker. Onze Developers combineren hun kennis van frameworks zoals React, Angular en Vue met ervaring in geavanceerde technologieën zoals GraphQL en CI/CD pipelines. Dit stelt ons in staat om interactieve, intuïtieve en betrouwbare applicaties te ontwikkelen die voldoen aan de hoogste standaarden.\n\nWij werken nauw samen met UX-designers om via design patterns en design tokens een naadloze integratie van ontwerp naar functionaliteit te realiseren. Dankzij regelmatige LevelUp-sessies, interne projecten en kennisdeling blijven onze Front-End specialisten altijd up-to-date.",{"id":534,"name":535,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":536,"hash":557,"ext":23,"mime":26,"size":558,"url":559,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":560,"updatedAt":560,"documentId":561,"publishedAt":58,"focalPoint":18},904,"development.jpg",{"large":537,"small":542,"medium":547,"thumbnail":552},{"ext":23,"url":538,"hash":539,"mime":26,"name":540,"path":18,"size":541,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_development_6e5abdca44.jpg","large_development_6e5abdca44","large_development.jpg",129.5,{"ext":23,"url":543,"hash":544,"mime":26,"name":545,"path":18,"size":546,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_development_6e5abdca44.jpg","small_development_6e5abdca44","small_development.jpg",47.86,{"ext":23,"url":548,"hash":549,"mime":26,"name":550,"path":18,"size":551,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_development_6e5abdca44.jpg","medium_development_6e5abdca44","medium_development.jpg",86.06,{"ext":23,"url":553,"hash":554,"mime":26,"name":555,"path":18,"size":556,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_development_6e5abdca44.jpg","thumbnail_development_6e5abdca44","thumbnail_development.jpg",14.65,"development_6e5abdca44",184.35,"https://incredible-beef-2a6059b946.media.strapiapp.com/development_6e5abdca44.jpg","2024-12-13T12:36:11.969Z","qqi9wubjpzs8w6daj98mtc7a",{"id":521,"title":563,"subTitle":18,"content":564,"callToActionText":18,"callToActionLink":18,"colorStyle":394,"showAsides":80,"imageUrl":565,"__component":229},"Betrouwbaarheid en schaalbaarheid","Voor robuuste Back-End-oplossingen vertrouwen we op onze kennis van .NET. Of het nu gaat om het bouwen van nieuwe applicaties, het onderhouden van bestaande software of het implementeren van geavanceerde authenticatie- en autorisatiesystemen: ons team levert maatwerk dat aansluit bij de specifieke wensen en behoeften van jouw organisatie.\n\nHierbij maken we onder andere gebruik van onze kennis van Azure-services zoals Function Apps, Service Bus en App Services, maar ook tools als Docker en Kubernetes om veilige, schaalbare oplossingen te realiseren.\n\nOnze focus op grondige tests – van unit tests tot integratietests – garandeert stabiliteit en betrouwbaarheid.",{"id":235,"name":236,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":566,"hash":258,"ext":23,"mime":26,"size":259,"url":260,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":261,"updatedAt":261,"documentId":262,"publishedAt":58,"focalPoint":18},{"large":567,"small":568,"medium":569,"thumbnail":570},{"ext":23,"url":239,"hash":240,"mime":26,"name":241,"path":18,"size":242,"width":29,"height":204},{"ext":23,"url":244,"hash":245,"mime":26,"name":246,"path":18,"size":247,"width":36,"height":210},{"ext":23,"url":249,"hash":250,"mime":26,"name":251,"path":18,"size":252,"width":43,"height":216},{"ext":23,"url":254,"hash":255,"mime":26,"name":256,"path":18,"size":257,"width":222,"height":223},{"id":572,"title":573,"subTitle":18,"content":574,"callToActionText":18,"callToActionLink":18,"colorStyle":360,"showAsides":80,"imageUrl":575,"__component":229},50,"Full-Stack mogelijkheden","Wat ons uniek maakt, is onze combinatie van Front-End en .NET-expertise. Onze Developers zijn niet alleen gespecialiseerd in het creëren van intuïtieve interfaces, maar beheersen ook de complexiteit van Back-End-architectuur en Azure-integraties. Dit maakt hen volwaardige Full-Stack Developers die moeiteloos schakelen tussen de verschillende onderdelen van jouw project.",{"id":576,"name":577,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":578,"hash":599,"ext":23,"mime":26,"size":600,"url":601,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":602,"updatedAt":603,"documentId":604,"publishedAt":58,"focalPoint":18},778,"stack.jpg",{"large":579,"small":584,"medium":589,"thumbnail":594},{"ext":23,"url":580,"hash":581,"mime":26,"name":582,"path":18,"size":583,"width":29,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_stack_fec3a2bfae.jpg","large_stack_fec3a2bfae","large_stack.jpg",95.19,{"ext":23,"url":585,"hash":586,"mime":26,"name":587,"path":18,"size":588,"width":36,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_stack_fec3a2bfae.jpg","small_stack_fec3a2bfae","small_stack.jpg",29.21,{"ext":23,"url":590,"hash":591,"mime":26,"name":592,"path":18,"size":593,"width":43,"height":216},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_stack_fec3a2bfae.jpg","medium_stack_fec3a2bfae","medium_stack.jpg",58.57,{"ext":23,"url":595,"hash":596,"mime":26,"name":597,"path":18,"size":598,"width":222,"height":223},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_stack_fec3a2bfae.jpg","thumbnail_stack_fec3a2bfae","thumbnail_stack.jpg",8.24,"stack_fec3a2bfae",143.32,"https://incredible-beef-2a6059b946.media.strapiapp.com/stack_fec3a2bfae.jpg","2024-08-08T08:26:50.506Z","2024-12-09T10:18:46.269Z","kpz9iiz9dr551k3umhmtwy3k",{"id":606,"title":607,"subTitle":18,"content":608,"callToActionText":609,"callToActionLink":167,"colorStyle":394,"showAsides":80,"imageUrl":610,"__component":229},48,"Samen naar succes","Onze aanpak is erop gericht om samen met jou het optimale resultaat te behalen. Door proactief mee te denken en onze kennis te delen, zorgen we ervoor dat jouw project voldoet aan de hoogste standaarden van gebruiksvriendelijkheid, betrouwbaarheid en veiligheid. Of het nu gaat om een tijdelijke versterking van je team of volledige projectondersteuning: ons Development-team staat voor je klaar.\n\nOntdek wat wij voor jouw project kunnen betekenen."," Neem contact met ons op voor meer informatie!",{"id":611,"name":612,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":613,"hash":634,"ext":23,"mime":26,"size":635,"url":636,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":637,"updatedAt":637,"documentId":638,"publishedAt":5