_OP_Rick_Bakker_MVP_award.jpg",38.18,750,393,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_OP_Rick_Bakker_MVP_award_43e87180af.jpg","thumbnail_OP_Rick_Bakker_MVP_award_43e87180af","thumbnail_OP_Rick_Bakker_MVP_award.jpg",6.96,245,128,"OP_Rick_Bakker_MVP_award_43e87180af",73.33,"https://incredible-beef-2a6059b946.media.strapiapp.com/OP_Rick_Bakker_MVP_award_43e87180af.jpg","strapi-provider-upload-strapi-cloud","2023-09-01T10:57:00.886Z","wmej8be5ndtt1o8ch3047l0j","2026-01-05T12:38:34.018Z",[60],{"id":61,"title":62,"showBlankAside":63,"__component":64},23,"Deel deze pagina:",true,"global.social-sharing",{"id":66,"metaTitle":67,"metaDescription":68,"structuredData":69,"metaImage":18,"metaSocial":82},219,"Rick Bakker ontvangt opnieuw MVP Award | ShareValue","Rick Bakker van ShareValue ontvangt opnieuw de Microsoft MVP Award. Lees over zijn prestaties en hoe hij bijdraagt aan de Microsoft-community.",{"url":70,"@type":71,"author":72,"@context":73,"headline":67,"publisher":74,"description":68,"datePublished":81},"https://www.sharevalue.nl/nieuws/rick-bakker-ontvangt-opnieuw-mvp-award","NewsArticle","","https://schema.org",{"url":75,"logo":76,"name":79,"@type":80},"https://www.sharevalue.nl",{"url":77,"@type":78},"https://www.sharevalue.nl/assets/logo.png","ImageObject","ShareValue","Organization","2024-07-01",[],[84,463],{"id":85,"title":86,"subTitle":87,"description":88,"shortDescription":89,"slug":90,"createdAt":91,"updatedAt":92,"publishedAt":93,"isCoreExpertise":63,"documentId":94,"image":95,"seo":114,"blocks":128,"midPageBlocks":168},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z","ci9jcjkdq0gjpkaebdvdf08c",{"id":96,"name":97,"alternativeText":18,"caption":18,"width":98,"height":99,"formats":100,"hash":109,"ext":102,"mime":105,"size":110,"url":111,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":112,"updatedAt":112,"documentId":113,"publishedAt":58,"focalPoint":18},16,"microsoft-365.png",282,130,{"thumbnail":101},{"ext":102,"url":103,"hash":104,"mime":105,"name":106,"path":18,"size":107,"width":50,"height":108},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":115,"metaTitle":116,"metaDescription":117,"structuredData":118,"metaImage":18,"metaSocial":127},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":119,"@type":120,"@context":73,"provider":121,"areaServed":122,"description":125,"serviceType":126},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":75,"name":79,"@type":80},{"name":123,"@type":124},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[129,137],{"id":130,"title":131,"aside":18,"postType":132,"limit":133,"expertise":134,"__component":136},166,"Lees meer over Microsoft 365","alle",3,[135],{"id":85,"title":86,"subTitle":87,"description":88,"shortDescription":89,"slug":90,"createdAt":91,"updatedAt":92,"publishedAt":93,"isCoreExpertise":63,"documentId":94},"strapi.related-kennisbank-list",{"id":138,"titleLeft":139,"callToActionTextLeft":140,"callToActionLinkUrlLeft":141,"titleRight":142,"callToActionTextRight":143,"callToActionLinkUrlRight":144,"iconUrlLeft":145,"iconUrlRight":158,"__component":167},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":146,"name":147,"alternativeText":18,"caption":18,"width":148,"height":149,"formats":18,"hash":150,"ext":151,"mime":152,"size":153,"url":154,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":155,"updatedAt":156,"documentId":157,"publishedAt":58,"focalPoi