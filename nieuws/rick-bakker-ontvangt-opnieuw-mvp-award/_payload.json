ll_teamwork.jpg",27.14,{"ext":23,"url":442,"hash":443,"mime":26,"name":444,"path":18,"size":445,"width":43,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":447,"hash":448,"mime":26,"name":449,"path":18,"size":450,"width":205,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":457,"title":458,"callToActionText":459,"callToActionLinkUrl":460,"body":18,"imageUrl":461,"__component":462},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":146,"name":147,"alternativeText":18,"caption":18,"width":148,"height":149,"formats":18,"hash":150,"ext":151,"mime":152,"size":153,"url":154,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":155,"updatedAt":156,"documentId":157,"publishedAt":58,"focalPoint":18},"call-to-action.single",{"id":464,"title":465,"subTitle":466,"description":467,"shortDescription":468,"slug":469,"createdAt":470,"updatedAt":471,"publishedAt":472,"isCoreExpertise":63,"documentId":473,"image":474,"seo":488,"blocks":499,"midPageBlocks":511},7,"Power Platform","Optimaliseer je bedrijfsprocessen met Microsoft Power Platform","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.\n\nBij ShareValue leveren we oplossingen die precies aansluiten op de behoeften van jouw organisatie. Of het nu gaat om het opzetten van een uitgebreide governance- en omgevingsstrategie, het ontwikkelen van een app met bijbehorende automatiseringen of het bevorderen van gebruikersadoptie; wij hebben de juiste expertise in huis.\n\nOnze Power Platform-specialisten, bestaande uit ervaren consultants en developers, hebben een bewezen staat van dienst in diverse sectoren. Zij delen continu hun kennis en passen deze toe op de unieke vraagstukken van onze klanten, waardoor we steeds de meest effectieve en innovatieve oplossingen kunnen bieden.\n","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.","power-platform","2023-10-12T11:27:43.792Z","2025-04-11T13:13:15.099Z","2023-10-12T11:27:43.781Z","prbaerw7gypadu8gfdyg53sy",{"id":475,"name":476,"alternativeText":18,"caption":18,"width":98,"height":99,"formats":477,"hash":483,"ext":102,"mime":105,"size":484,"url":485,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":486,"updatedAt":486,"documentId":487,"publishedAt":58,"focalPoint":18},927,"Logo PowerPlatform 2025 web png.png",{"thumbnail":478},{"ext":102,"url":479,"hash":480,"mime":105,"name":481,"path":18,"size":482,"width":50,"height":108},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Power_Platform_2025_web_png_4268556f17.png","thumbnail_Logo_Power_Platform_2025_web_png_4268556f17","thumbnail_Logo PowerPlatform 2025 web png.png",8.26,"Logo_Power_Platform_2025_web_png_4268556f17",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Power_Platform_2025_web_png_4268556f17.png","2024-12-16T11:07:06.507Z","a12tjlb3ssr20rrzj9rulb58",{"id":489,"metaTitle":490,"metaDescription":491,"structuredData":492,"metaImage":18,"metaSocial":498},26,"Power Platform specialisten – ShareValue helpt vooruit","Haal meer uit Power Apps, Automate en Power BI. Wij helpen bij strategie, ontwikkeling en beheer van jouw Power Platform-omgeving.",{"url":493,"@type":120,"@context":73,"provider":494,"areaServed":495,"description":496,"serviceType":497},"https://www.sharevalue.nl/wat-we-doen/power-platform",{"url":75,"name":79,"@type":80},{"name":123,"@type":124},"ShareValue helpt organisaties om Power Platform optimaal in te zetten. Denk aan Power Apps, Power Automate en Power BI. We bieden begeleiding bij strategie, governance, ontwikkeling en beheer.","Power Platform consultancy",[],[500,505],{"id":501,"title":502,"aside":18,"postType":132,"limit":133,"expertise":503,"__component":136},164,"Lees meer over het Power Platform",[504],{"id":464,"title":465,"subTitle":466,"description":467,"shortDescription":468,"slug":469,"createdAt":470,"updatedAt":471,"publishedAt":472,"isCoreExpertise":63,"documentId":473},{"id":205,"titleLeft":506,"callToActionTextLeft":507,"callToActionLinkUrlLeft":141,"titleRight":508,"callToActionTextRight":143,"callToActionLinkUrlRight":144,"iconUrlLeft":509,"iconUrlRight":510,"__component":167},"Heb je een Power Platform expert nodig?","Neem contact op voor de mogelijkheden","Zoek je een nieuwe uitdaging?",{"id":146,"name":147,"alternativeText":18,"caption":18,"width":148,"height":149,"formats":18,"hash":150,"ext":151,"mime":152,"size":153,"url":154,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":155,"updatedAt":156,"documentId":157,"publishedAt":58,"focalPoint":18},{"id":159,"name":160,"alternativeText":18,"caption":18,"width":149,"height":149,"formats":18,"hash":161,"ext":151,"mime":152,"size":162,"url":163,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":164,"updatedAt":165,"documentId":166,"publishedAt":58,"focalPoint":18},[512,551,584,618,652],{"id":96,"title":513,"subTitle":18,"content":514,"callToActionText":515,"callToActionLink":141,"colorStyle":174,"showAsides":175,"imageUrl":516,"__component":212},"Power Platform governance: de balans tussen beveiliging en innovatie","Het is belangrijk om een balans te vinden tussen beveiliging en innovatie binnen jouw organisatie. Hoewel governance noodzakelijk is, moeten je medewerkers en teams de ruimte krijgen om waarde te creëren voor zowel henzelf als de onderneming.\n\nOnze Power Platform-specialisten staan klaar om je te adviseren over de diverse mogelijkheden. We begeleiden je tijdens het ontwikkelen en implementeren van een effectieve governance- en omgevingsstrategie, zodat je het beste uit het Microsoft Power Platform kunt halen.","Wil je meer weten? Neem contact met ons op.",{"id":517,"name":518,"alternativeText":18,"caption":18,"width":519,"height":520,"formats":521,"hash":546,"ext":102,"mime":105,"size":547,"url":548,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":549,"updatedAt":549,"documentId":550,"publishedAt":58,"focalPoint":18},793,"Power Platform update.png",2234,2000,{"large":522,"small":528,"medium":534,"thumbnail":540},{"ext":102,"url":523,"hash":524,"mime":105,"name":525,"path":18,"size":526,"width":29,"height":527},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Power_Platform_update_efa8d3f613.png","large_Power_Platform_update_efa8d3f613","large_Power Platform update.png",192.25,895,{"ext":102,"url":529,"hash":530,"mime":105,"name":531,"path":18,"size":532,"width":36,"height":533},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Power_Platform_update_efa8d3f613.png","small_Power_Platform_update_efa8d3f613","small_Power Platform update.png",70.05,448,{"ext":102,"url":535,"hash":536,"mime":105,"name":537,"path":18,"size":538,"width":43,"height":539},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Power_Platform_update_efa8d3f613.png","medium_Power_Platform_update_efa8d3f613","medium_Power Platform update.png",123.16,671,{"ext":102,"url":541,"hash":542,"mime":105,"name":543,"path":18,"size":544,"width":545,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Power_Platform_update_efa8d3f613.png","thumbnail_Power_Platform_update_efa8d3f613","thumbnail_Power Platform update.png",15.87,174,"Power_Platform_update_efa8d3f613",123.72,"https://incredible-beef-2a6059b946.media.strapiapp.com/Power_Platform_update_efa8d3f613.png","2024-08-23T10:10:52.001Z","fhjzo2hukt6rcge2ifll29ld",{"id":552,"title":553,"subTitle":18,"content":554,"callToActionText":18,"callToActionLink":18,"colorStyle":219,"showAsides":175,"imageUrl":555,"__component":212},17,"Snel maatwerktoepassingen creëren met het Power Platform","Het Power Platform is de ideale oplossing om je verouderde processen en applicaties te stroomlijnen met slimme apps, efficiënte werkstromen en geavanceerde, op maat gemaakte formulieren.\n\nOnze specialisten staan klaar om je te adviseren over de vele mogelijkheden. Heb je meer ondersteuning nodig bij het ontwikkelen van je toepassing? Onze ervaren developers ontwikkelen de toepassing volledig voor je.",{"id":556,"name":557,"alternativeText":18,"caption":18,"width":179,"height":180,"formats":558,"hash":579,"ext":23,"mime":26,"size":580,"url":581,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":582,"updatedAt":582,"documentId":583,"publishedAt":58,"focalPoint":18},764,"maatwerk.jpg",{"large":559,"small":564,"medium":569,"thumbnail":574},{"ext":23,"url":560,"hash":561,"mime":26,"name":562,"path":18,"size":563,"width":29,"height":187},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_maatwerk_b13f4ae62e.jpg","large_maatwerk_b13f4ae62e","large_maatwerk.jpg",64.15,{"ext":23,"url":565,"hash":566,"mime":26,"name":567,"path":18,"size":568,"width":36,"height":193},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_maatwerk_b13f4ae62e.jpg","small_maatwerk_b13f4ae62e","small_maatwerk.jpg",19.69,{"ext":23,"url":570,"hash":571,"mime":26,"name":572,"path":18,"size":573,"width":43,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_maatwerk_b13f4ae62e.jpg","medium_maatwerk_b13f4ae62e","medium_maatwerk.jpg",39.51,{"ext":23,"url":575,"hash":576,"mime":26,"name":577,"path":18,"size":578,"width":205,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_maatwerk_b13f4ae62e.jpg","thumbnail_maatwerk_b13f4ae62e","thumbnail_maatwerk.jpg",5.55,"maatwerk_b13f4ae62e",96.54,"https://incredible-beef-2a6059b946.media.strapiapp.com/maatwerk_b13f4ae62e.jpg","2024-08-01T11:43:49.966Z","z85xixi08lol9621vn40pi13",{"id":585,"title":586,"subTitle":18,"content":587,"callToActionText":18,"callToActionLink":18,"colorStyle":174,"showAsides":175,"imageUrl":588,"__component":212},18,"Power Platform staat aan, wat nu?","Het Power Platform wordt al gebruikt in jouw organisatie. Een aantal enthousiaste collega's hebben al mooie apps gemaakt en je staat op het punt om het Power Platform in te zetten voor bedrijfskritische processen. Maar je weet niet precies hoe je dit het beste kunt aanpakken.\n\nWij begeleiden je in dit proces en samen bepalen we de \"next steps\". Onze architecten voeren een volledige omgevings- en securitycheck uit, wat resulteert in een omgevingsstrategie, governance, en een ontwikkel- en adoptieplan.",{"id":589,"name":590,"alternativeText":18,"caption":18,"width":179,"height":180,"formats":591,"hash":612,"ext":23,"mime":26,"size":613,"url":614,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":615,"updatedAt":616,"documentId":617,"publishedAt":58,"focalPoint":18},765,"power platform.jpg",{"large":592,"small":597,"medium":602,"thumbnail":607},{"ext":23,"url":593,"hash":594,"mime":26,"name":595,"path":18,"size":596,"width":29,"height":187},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_power_platform_39c53ca01e.jpg","large_power_platform_39c53ca01e","large_power platform.jpg",208.02,{"ext":23,"url":598,"hash":599,"mime":26,"name":600,"path":18,"size":601,"width":36,"height":193},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_power_platform_39c53ca01e.jpg","small_power_platform_39c53ca01e","small_power platform.jpg",66.01,{"ext":23,"url":603,"hash":604,"mime":26,"name":605,"path":18,"size":606,"width":43,"