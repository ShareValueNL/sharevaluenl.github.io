[{"data":1,"prerenderedAt":626},["ShallowReactive",2],{"collection-blogs-855812169":3,"_apollo:default":625},{"data":4,"meta":621},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":93,"blocks":482},89,"Machine Learning in begrijpelijke taal: kennis uit Microsoft Build","Tijdens Microsoft Build stond Microsoft stil bij een aantal onderwerpen. Een van de onderwerpen is Machine Learning. In dit blog leg ik uit wat het is en waarom jij dit moet weten.","machine-learning-in-begrijpelijke-taal-kennis-uit-microsoft-build","2023-10-13T10:26:38.072Z","2025-04-22T12:38:53.645Z","2023-10-13T10:26:37.979Z","2019-07-01","hbenwmq7hxutzjzllrtzw2pa",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},338,"machine-learning-in-begrijpelijke-taal-kennis-uit-microsoft-build.jpg",null,1600,1200,{"large":22,"small":31,"medium":38,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832.jpg","large_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832","image/jpg","large_machine-learning-in-begrijpelijke-taal-kennis-uit-microsoft-build.jpg",151.62,1000,750,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832.jpg","small_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832","small_machine-learning-in-begrijpelijke-taal-kennis-uit-microsoft-build.jpg",49.88,500,375,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":30,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832.jpg","medium_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832","medium_machine-learning-in-begrijpelijke-taal-kennis-uit-microsoft-build.jpg",96.19,563,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832.jpg","thumbnail_machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832","thumbnail_machine-learning-in-begrijpelijke-taal-kennis-uit-microsoft-build.jpg",11.22,208,156,"machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832",319.85,"https://incredible-beef-2a6059b946.media.strapiapp.com/machine_learning_in_begrijpelijke_taal_kennis_uit_microsoft_build_d7cae8d832.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:24:07.622Z","i7ivbk72t77z0fwf5vu0y2y6","2026-01-05T12:38:34.018Z",{"id":59,"metaTitle":60,"metaDescription":61,"structuredData":62,"metaImage":18,"metaSocial":92},177,"Machine Learning uitgelegd na Microsoft Build | ShareValue","Leer hoe je met ML.NET en Azure Machine Learning sentimentanalyse toepast in .NET-applicaties, gebaseerd op inzichten van Microsoft Build.​",[63,75],{"url":64,"@type":65,"author":66,"@context":67,"headline":60,"publisher":68,"description":74,"datePublished":13},"https://www.sharevalue.nl/blogs/machine-learning-in-begrijpelijke-taal-kennis-uit-microsoft-build","BlogPosting",{},"https://schema.org",{"logo":69,"name":72,"@type":73},{"url":70,"@type":71},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","ShareValue","Organization","Leer hoe je met ML.NET en Azure Machine Learning sentimentanalyse toepast in .NET-applicaties, gebaseerd op inzichten van Microsoft Build.",{"@type":76,"@context":67,"mainEntity":77},"FAQPage",[78,84,88],{"name":79,"@type":80,"acceptedAnswer":81},"Wat is Machine Learning volgens Microsoft Build?","Question",{"text":82,"@type":83},"Machine Learning wordt omschreven als 'programming the unprogrammable' en stelt ontwikkelaars in staat om patronen te herkennen en voorspellingen te doen op basis van data.","Answer",{"name":85,"@type":80,"acceptedAnswer":86},"Hoe werkt sentimentanalyse met ML.NET?",{"text":87,"@type":83},"Met ML.NET kun je een model trainen op basis van tekstdata en bijbehorende sentimentlabels. Het model leert patronen herkennen en kan vervolgens het sentiment van nieuwe teksten voorspellen.",{"name":89,"@type":80,"acceptedAnswer":90},"Welke tools zijn nodig voor het bouwen van een ML-model?",{"text":91,"@type":83},"Je kunt gebruikmaken van Visual Studio met de ML.NET Model Builder of Azure Machine Learning. Beide bieden wizards en AutoML-functionaliteit om modellen te trainen en evalueren zonder diepgaande ML-kennis.",[],[94,278],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105,"image":106,"seo":18,"blocks":126,"midPageBlocks":162},3,"Microsoft .NET","Maatwerkoplossingen voor ieder vraagstuk","Ons team van .NET-experts staat niet alleen klaar om onze klanten te ondersteunen bij diverse implementatie uitdagingen, maar we zijn ook gespecialiseerd in het testen van applicaties op verschillende niveaus, zoals unit tests, integratietests en acceptatietests. We streven naar uitmuntende testdekking om de stabiliteit en betrouwbaarheid van de applicaties te waarborgen.\n\nDaarnaast zijn we bedreven in het gebruik van verschillende Azure-services om schaalbare en veilige oplossingen te bieden aan onze klanten. Zo bieden we met Azure DevOps krachtige tools voor het beheren van de ontwikkeling, het automatiseren van tests en het geautomatiseerd uitrollen naar acceptatie- of productieomgevingen met CI/CD-pipelines.\n\nHet samenwerken met onze klanten staat centraal in ons werk, en we denken proactief mee om samen de meest optimale oplossingen te realiseren.","In de praktijk komen de .NET developers van ShareValue terecht in allerlei verschillende branches met uiteenlopende technische uitdagingen.","dotnet","2023-08-17T11:19:57.991Z","2024-12-13T12:16:04.480Z","2023-08-17T11:22:08.050Z",false,"v9pl553hsjk98esvs5gzoso3",{"id":107,"name":108,"alternativeText":18,"caption":18,"width":109,"height":110,"formats":111,"hash":121,"ext":113,"mime":116,"size":122,"url":123,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":124,"updatedAt":124,"documentId":125,"publishedAt":57,"focalPoint":18},17,"dotnet_logo.png",282,130,{"thumbnail":112},{"ext":113,"url":114,"hash":115,"mime":116,"name":117,"path":18,"size":118,"width":119,"height":120},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_dotnet_logo_d38dbc3865.png","thumbnail_dotnet_logo_d38dbc3865","image/png","thumbnail_dotnet_logo.png",7.14,245,113,"dotnet_logo_d38dbc3865",2.93,"https://incredible-beef-2a6059b946.media.strapiapp.com/dotnet_logo_d38dbc3865.png","2023-08-17T09:47:56.313Z","nnimzsossci29qmi8z0texlp",[127,134],{"id":128,"title":129,"aside":18,"postType":130,"limit":95,"expertise":131,"__component":133},167," Lees meer over .NET Development","alle",[132],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105},"strapi.related-kennisbank-list",{"id":135,"titleLeft":136,"callToActionTextLeft":137,"callToActionLinkUrlLeft":138,"titleRight":139,"callToActionTextRight":137,"callToActionLinkUrlRight":138,"iconUrlLeft":140,"iconUrlRight":153,"__component":161},212,"Heb je een .NET expert nodig?","Neem contact met ons op","/contact","Weten welke expert op dit moment beschikbaar is?",{"id":141,"name":142,"alternativeText":18,"caption":18,"width":143,"height":144,"formats":18,"hash":145,"ext":146,"mime":147,"size":148,"url":149,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":150,"updatedAt":151,"documentId":152,"publishedAt":57,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":154,"name":155,"alternativeText":18,"caption":18,"width":144,"height":144,"formats":18,"hash":156,"ext":146,"mime":147,"size":157,"url":158,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":159,"updatedAt":159,"documentId":160,"publishedAt":57,"focalPoint":18},250,"looking-glass.svg","looking_glass_cfa3801802",0.6,"https://incredible-beef-2a6059b946.media.strapiapp.com/looking_glass_cfa3801802.svg","2023-10-11T09:43:10.911Z","suv3p7h0kw7jdnuddk1l2rdu","call-to-action.double",[163,205,238,271],{"id":164,"title":165,"subTitle":18,"content":166,"callToActionText":167,"callToActionLink":138,"colorStyle":18,"showAsides":18,"imageUrl":168,"__component":204},36,"Bouwen en testen","Onze .NET-experts kunnen uiteraard goede en betrouwbare applicaties ontwikkelen met de laatste .NET-versies. Ook zijn onze collega’s ervaren in het onderhouden van oudere software. We kunnen je helpen met het upgraden en uitbreiden van je applicatie zodat deze aan de laatste wensen en eisen voldoet. Het uitvoeren van uitgebreide unit- en integratietests om de stabiliteit van applicaties te waarborgen, wordt meegenomen als standaard onderdeel van het werk. Met een focus op grondige testdekking streven we ernaar om eventuele bugs vroegtijdig op te sporen en op te lossen, waardoor de algehele kwaliteit van jouw product wordt verbeterd.  \n\nVan Blazor Front-End of REST API’s tot database communicatie, onze .NET-experts hebben er ruime ervaring mee.","Weten wat onze experts voo