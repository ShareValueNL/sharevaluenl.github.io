[{"data":1,"prerenderedAt":426},["ShallowReactive",2],{"collection-blogs-304503514":3,"_apollo:default":425},{"data":4,"meta":422},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":63,"author":285,"blocks":311,"seo":406},612,"Microsoft Entra Suite: de volgende stap in Zero Trust","Hybride werken, honderden SaaS-apps en een groeiend dreigingslandschap: het beheren van identiteiten en toegangsrechten is complexer dan ooit. Microsoft heeft daarom in 2024 de Entra Suite gelanceerd: een geïntegreerde oplossing om Zero Trust-principes in de praktijk te brengen.","microsoft-entra-suite-de-volgende-stap-in-zero-trust","2025-09-18T10:22:28.942Z","2026-01-23T13:27:36.614Z","2026-01-23T13:27:37.265Z","2025-10-02","iuymggf0fns0n9y89xi9rd4l",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":55,"ext":23,"mime":26,"size":56,"url":57,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":59,"updatedAt":60,"documentId":61,"publishedAt":62},1253,"Blog Gert Entra suite hoofdafb.png",null,1280,500,{"large":22,"small":32,"medium":39,"thumbnail":47},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30,"sizeInBytes":31},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0.png","large_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0","image/png","large_Blog Gert Entra suite hoofdafb.png",383.4,1000,391,383399,{"ext":23,"url":33,"hash":34,"mime":26,"name":35,"path":18,"size":36,"width":20,"height":37,"sizeInBytes":38},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0.png","small_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0","small_Blog Gert Entra suite hoofdafb.png",98.43,195,98425,{"ext":23,"url":40,"hash":41,"mime":26,"name":42,"path":18,"size":43,"width":44,"height":45,"sizeInBytes":46},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0.png","medium_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0","medium_Blog Gert Entra suite hoofdafb.png",215.63,750,293,215634,{"ext":23,"url":48,"hash":49,"mime":26,"name":50,"path":18,"size":51,"width":52,"height":53,"sizeInBytes":54},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0.png","thumbnail_Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0","thumbnail_Blog Gert Entra suite hoofdafb.png",28.85,245,96,28848,"Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0",122.68,"https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Gert_Entra_suite_hoofdafb_2bdd4f70f0.png","strapi-provider-upload-strapi-cloud","2025-09-18T11:34:48.857Z","2025-10-01T08:23:52.738Z","unt318acsmwuim3wqzjirw0f","2026-01-05T12:38:34.018Z",[64],{"id":65,"title":66,"subTitle":67,"description":68,"shortDescription":69,"slug":70,"createdAt":71,"updatedAt":72,"publishedAt":73,"isCoreExpertise":74,"documentId":75,"image":76,"blocks":93,"midPageBlocks":179,"seo":280},1,"Azure","Hét cloudcomputing platform van Microsoft","Azure is het cloudcomputing platform van Microsoft, dat zowel Infrastructure as a Service (IaaS) als Platform as a Service (PaaS) biedt. Met dit platform kun je applicaties ontwikkelen of een compleet netwerk hosten, en dit alles op een relatief eenvoudige manier beheren. Omdat Azure wordt gehost in managed datacenters over de hele wereld, kun je jouw netwerk of applicatie wereldwijd beschikbaar maken. Microsoft biedt daarnaast een breed scala aan services, zoals Internet of Things (IoT), Azure Kubernetes, Artificial Intelligence (AI) en oplossingen voor het gebruik van Big Data.\n\nOnze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt. Hierbij leveren wij iedere keer maatwerk, want het programma van eisen ziet er telkens anders uit. Of het nu gaat om de ondersteuning van een Azure team of het volledige beheer, onze Azure experts staan voor je klaar. Meer over ons werk lees je onder andere in onze Azure [klantcases](/kennisbank/klantcases/azure) en [blogs](/kennisbank/blogs/azure).\n\n","Onze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt.","azure","2023-08-17T09:47:20.996Z","2025-04-11T13:11:55.618Z","2023-08-17T09:50:22.095Z",true,"eubwn704tlyata6v2q819fn7",{"id":77,"name":78,"alternativeText":18,"caption":18,"width":79,"height":80,"formats":81,"hash":88,"ext":23,"mime":26,"size":89,"url":90,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":91,"updatedAt":91,"documentId":92,"publishedAt":62},657,"mircosoft azure web.png",282,130,{"thumbnail":82},{"ext":23,"url":83,"hash":84,"mime":26,"name":85,"path":18,"size":86,"width":52,"height":87},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_mircosoft_azure_web_031897ebac.png","thumbnail_mircosoft_azure_web_031897ebac","thumbnail_mircosoft azure web.png",5.54,113,"mircosoft_azure_web_031897ebac",1.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/mircosoft_azure_web_031897ebac.png","2024-04-05T12:52:48.184Z","z9c21qscgi7eh5jijkc40fzv",[94,156],{"__component":95,"id":96,"title":97,"aside":18,"postType":98,"limit":99,"expertise":100},"strapi.related-kennisbank-list",165,"Lees meer over Azure","alle",3,[101],{"id":65,"title":66,"subTitle":67,"description":68,"shortDescription":69,"slug":70,"createdAt":71,"updatedAt":72,"publishedAt":73,"isCoreExpertise":74,"documentId":75,"image":102,"blocks":105,"midPageBlocks":116,"seo":140},{"id":77,"name":78,"alternativeText":18,"caption":18,"width":79,"height":80,"formats":103,"hash":88,"ext":23,"mime":26,"size":89,"url":90,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":91,"updatedAt":91,"documentId":92,"publishedAt":62},{"thumbnail":104},{"ext":23,"url":83,"hash":84,"mime":26,"name":85,"path":18,"size":86,"width":52,"height":87},[106,107],{"__component":95,"id":96,"title":97,"aside":18,"postType":98,"limit":99},{"__component":108,"id":109,"titleLeft":110,"callToActionTextLeft":111,"callToActionLinkUrlLeft":112,"titleRight":113,"callToActionTextRight":114,"callToActionLinkUrlRight":115},"call-to-action.double",209,"Heb je een Azure expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[117,125,130,134],{"__component":118,"id":119,"title":120,"subTitle":18,"content":121,"callToActionText":122,"callToActionLink":112,"colorStyle":123,"showAsides":124},"global.alternating-page-section",25,"Azure Security: veiligheid in de cloud ","Voor organisaties is het belangrijk om de digitale infrastructuur te beveiligen in een steeds complexer wordend cyberlandschap. Onze experts helpen graag met behulp van Azure Security; een reeks beveiligingsdiensten en -functies die door Microsoft Azure wordt aangeboden om bedreigingen te detecteren, te voorkomen en erop te reageren. Enkele belangrijke componenten en functies van Azure Security waarmee wij werken zijn Azure Security Center, Microsoft Entra ID, Azure DDoS Protection en Azure Sentinel.","Neem contact op voor meer informatie","Sugar Glaze",false,{"__component":118,"id":126,"title":127,"subTitle":18,"content":128,"callToActionText":18,"callToActionLink":18,"colorStyle":129,"showAsides":124},26,"Azure Kubernetes Service (AKS)","Azure Kubernetes Service (AKS) helpt bij het beheren van applicaties die in containers draaien. Het vereenvoudigt en automatiseert de implementatie, het beheer en de operationele taken van Kubernetes-clusters. Door gebruik te maken van AKS kunnen organisaties zich richten op het ontwikkelen en beheren van hun applicaties, terwijl Microsoft de complexiteit van de Kubernetes-infrastructuur beheert. Hierdoor kunnen organisaties hun software efficiënt, betrouwbaar en kosteneffectief beheren. Doordat onze experts ruime kennis en ervaring hebben met AKS kunnen ze de klanten op een juiste manier helpen.","White",{"__component":118,"id":131,"title":132,"subTitle":18,"content":133,"callToActionText":18,"callToActionLink":18,"colorStyle":123,"showAsides":124},24,"Infrastructure as Code (IaC)","Infrastructure as Code (IaC) is het beheren van een Azure cloud-omgeving door middel van code en softwareontwikkelingstechnieken om infrastructuur te automatiseren, te configureren en te beheren. Het biedt versiebeheer voor configuraties, wat samenwerking en terugkeer naar eerdere versies vergemakkelijkt. Bovendien zorgt IaC voor consistentie in verschillende omgevingen en maakt het schaalvergroting eenvoudiger door configuraties te herhalen zonder handmatige ingrepen. \n\nAls je vragen hebt of ondersteuning nodig hebt, kunnen de Azure Experts je alles vertellen over Infrastructure as Code.",{"__component":135,"id":136,"title":137,"callToActionText":138,"callToActionLinkUrl":139,"body":18},"call-to-action.single",94,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Stichting Inlichtingenbureau","/klantcases/stichting-inlichtingenbureau-kiest-voor-migratie-naar-microsoft-azure",{"id":131,"metaTitle":141,"metaDescription":142,"structuredData":143},"Microsoft Azure-expertise – ShareValue helpt je vooruit","Van beheer tot DevOps: onze Azure-specialisten helpen je om cloudoplossingen slim en veilig in te richten en te optimaliseren.",{"url":144,"@type":145,"@context":146,"provider":147,"areaServed":151,"description":154,"serviceType":155},"https://www.sharevalue.nl/wat-we-doen/azure","Service","https://schema.org",{"url":148,"name":149,"@type":150},"https://www.sharevalue.nl","ShareValue","Organization",{"name":152,"@type":153},"Nederland","Country","ShareValue helpt organisaties om Microsoft Azure effectief in te zetten. Onze specialisten werken aan cloudmigraties, infrastructuur, security, automation en DevOps-oplossingen.","Microsoft Azure consultancy",{"__component":108,"id":109,"titleLeft":110,"callToActionTextLeft":111,"callToActionLinkUrlLeft":112,"titleRight":113,"callToActionTextRight":114,"callToActionLinkUrlRight":115,"iconUrlLeft":157,"iconUrlRight":170},{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":62},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":171,"name":172,"alternativeText":18,"caption":18,"width":161,"height":161,"formats":18,"hash":173,"ext":163,"mime":164,"size":174,"url":175,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":176,"updatedAt":177,"documentId":178,"publishedAt":62},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",[180,218,248,278],{"__component":118,"id":119,"title":120,"subTitle":18,"content":121,"callToActionText":122,"callToActionLink":112,"colorStyle":123,"showAsides":124,"imageUrl":181},{"id":182,"name":183,"alternativeText":18,"caption":18,"width":19,"height":184,"formats":185,"hash":213,"ext":187,"mime":190,"size":214,"url":215,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":216,"updatedAt":216,"documentId":217,"publishedAt":62},779,"security azure.jpg",850,{"large":186,"small":194,"medium":200,"thumbnail":206},{"ext":187,"url":188,"hash":189,"mime":190,"name":191,"path":18,"size":192,"width":29,"height":193},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_azure_b1610cf1cb.jpg","large_security_az