ovider":58,"provider_metadata":18,"createdAt":246,"updatedAt":246,"documentId":247,"publishedAt":62},{"large":388,"small":389,"medium":390,"thumbnail":391},{"ext":187,"url":224,"hash":225,"mime":190,"name":226,"path":18,"size":227,"width":29,"height":193},{"ext":187,"url":229,"hash":230,"mime":190,"name":231,"path":18,"size":232,"width":20,"height":199},{"ext":187,"url":234,"hash":235,"mime":190,"name":236,"path":18,"size":237,"width":44,"height":205},{"ext":187,"url":239,"hash":240,"mime":190,"name":241,"path":18,"size":242,"width":211,"height":212},{"__component":118,"id":131,"title":132,"subTitle":18,"content":133,"callToActionText":18,"callToActionLink":18,"colorStyle":123,"showAsides":124,"imageUrl":393},{"id":250,"name":251,"alternativeText":18,"caption":18,"width":19,"height":184,"formats":394,"hash":273,"ext":187,"mime":190,"size":274,"url":275,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":276,"updatedAt":276,"documentId":277,"publishedAt":62},{"large":395,"small":396,"medium":397,"thumbnail":398},{"ext":187,"url":254,"hash":255,"mime":190,"name":256,"path":18,"size":257,"width":29,"height":193},{"ext":187,"url":259,"hash":260,"mime":190,"name":261,"path":18,"size":262,"width":20,"height":199},{"ext":187,"url":264,"hash":265,"mime":190,"name":266,"path":18,"size":267,"width":44,"height":205},{"ext":187,"url":269,"hash":270,"mime":190,"name":271,"path":18,"size":272,"width":211,"height":212},{"__component":135,"id":136,"title":137,"callToActionText":138,"callToActionLinkUrl":139,"body":18,"imageUrl":400},{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":62},{"id":131,"metaTitle":141,"metaDescription":142,"structuredData":402,"metaImage":18,"metaSocial":405},{"url":144,"@type":145,"@context":146,"provider":403,"areaServed":404,"description":154,"serviceType":155},{"url":148,"name":149,"@type":150},{"name":152,"@type":153},[],{"id":407,"metaTitle":7,"metaDescription":408,"structuredData":409,"metaImage":18,"metaSocial":421},543,"In deze blog lees je waarom Entra Suite relevant is voor jouw organisatie.",{"url":410,"@type":411,"image":410,"author":412,"@context":146,"headline":413,"publisher":414,"articleBody":418,"description":419,"datePublished":420,"mainEntityOfPage":410},"https://www.sharevalue.nl/blogs/microsoft-entra-suite-de-volgende-stap-in-zero-trust","BlogPosting",{"name":149,"@type":150},"Microsoft Entra Suite: Volgende stap in Zero Trust",{"logo":415,"name":149,"@type":150},{"url":416,"@type":417},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","Microsoft Entra Suite is ontworpen om de Zero Trust-beveiligingsstrategie van organisaties te versterken. Het platform biedt oplossingen voor identiteits- en toegangsbeheer, apparaatbeheer en het beschermen van kritieke data binnen Microsoft 365 en Azure-omgevingen.","Microsoft Entra Suite helpt organisaties de volgende stap te zetten in Zero Trust-beveiliging. Leer hoe je toegang, identiteiten en apparaten beter beheert.","2025-09-15",[],{"pagination":423},{"page":65,"pageSize":424},100,{},1782136849432]