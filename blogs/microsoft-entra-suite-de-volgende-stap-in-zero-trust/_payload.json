ll_containers_2e766510ad","small_containers.jpg",49.69,{"ext":187,"url":234,"hash":235,"mime":190,"name":236,"path":18,"size":237,"width":44,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_containers_2e766510ad.jpg","medium_containers_2e766510ad","medium_containers.jpg",101.49,{"ext":187,"url":239,"hash":240,"mime":190,"name":241,"path":18,"size":242,"width":211,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_containers_2e766510ad.jpg","thumbnail_containers_2e766510ad","thumbnail_containers.jpg",12.65,"containers_2e766510ad",240.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/containers_2e766510ad.jpg","2024-08-08T08:54:58.426Z","idshbfmg66aak9yxdr9d22c7",{"__component":118,"id":131,"title":132,"subTitle":18,"content":133,"callToActionText":18,"callToActionLink":18,"colorStyle":123,"showAsides":124,"imageUrl":249},{"id":250,"name":251,"alternativeText":18,"caption":18,"width":19,"height":184,"formats":252,"hash":273,"ext":187,"mime":190,"size":274,"url":275,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":276,"updatedAt":276,"documentId":277,"publishedAt":62},781,"infrastructure.jpg",{"large":253,"small":258,"medium":263,"thumbnail":268},{"ext":187,"url":254,"hash":255,"mime":190,"name":256,"path":18,"size":257,"width":29,"height":193},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_infrastructure_bf66532759.jpg","large_infrastructure_bf66532759","large_infrastructure.jpg",246.61,{"ext":187,"url":259,"hash":260,"mime":190,"name":261,"path":18,"size":262,"width":20,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_infrastructure_bf66532759.jpg","small_infrastructure_bf66532759","small_infrastructure.jpg",69.57,{"ext":187,"url":264,"hash":265,"mime":190,"name":266,"path":18,"size":267,"width":44,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_infrastructure_bf66532759.jpg","medium_infrastructure_bf66532759","medium_infrastructure.jpg",149.51,{"ext":187,"url":269,"hash":270,"mime":190,"name":271,"path":18,"size":272,"width":211,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_infrastructure_bf66532759.jpg","thumbnail_infrastructure_bf66532759","thumbnail_infrastructure.jpg",15.74,"infrastructure_bf66532759",374.88,"https://incredible-beef-2a6059b946.media.strapiapp.com/infrastructure_bf66532759.jpg","2024-08-08T08:58:52.414Z","bmkl03ingwf6ms8pdk5jvmx5",{"__component":135,"id":136,"title":137,"callToActionText":138,"callToActionLinkUrl":139,"body":18,"imageUrl":279},{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":62},{"id":131,"metaTitle":141,"metaDescription":142,"structuredData":281,"metaImage":18,"metaSocial":284},{"url":144,"@type":145,"@context":146,"provider":282,"areaServed":283,"description":154,"serviceType":155},{"url":148,"name":149,"@type":150},{"name":152,"@type":153},[],{"id":286,"name":287,"jobTitle":288,"about":18,"createdAt":289,"updatedAt":290,"publishedAt":291,"documentId":292,"image":293,"contactOptions":310},36,"Gert","Engineer & Architect","2023-08-18T08:37:46.157Z","2024-03-18T14:39:44.060Z","2023-08-18T08:37:45.403Z","issofzsvhgrwftfjuizdg4ac",{"id":294,"name":295,"alternativeText":18,"caption":18,"width":296,"height":297,"formats":298,"hash":305,"ext":23,"mime":26,"size":306,"url":307,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":308,"updatedAt":308,"documentId":309,"publishedAt":62},604,"Gert websitefoto.png",278,326,{"thumbnail":299},{"ext":23,"url":300,"hash":301,"mime":26,"name":302,"path":18,"size":303,"width":304,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Gert_websitefoto_cab2bacf46.png","thumbnail_Gert_websitefoto_cab2bacf46","thumbnail_Gert websitefoto.png",20.16,133,"Gert_websitefoto_cab2bacf46",21.32,"https://incredible-beef-2a6059b946.media.strapiapp.com/Gert_websitefoto_cab2bacf46.png","2024-03-18T14:38:40.376Z","x8md4b4efqc3aih2mw7g0ro3",[],[312,316,319,322,326,329,332,335,338,341,344,362],{"__component":313,"id":314,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":18,"content":315,"introductionText":18},"global.pagesection",4304,"In de blogreeks over Zero Trust zijn we al dieper ingegaan op de kernprincipes van dit beveiligingsmodel: van identiteits- en apparaatbeveiliging tot least privilege access en het afdwingen van Conditional Access policies. We sloten de serie af met de bescherming en het beheer van gevoelige gegevens. Maar Microsoft heeft sindsdien niet stilgezeten. Met de lancering van de Microsoft Entra Suite in juli 2024 tilt Microsoft haar Zero Trust-aanpak naar een nieuw niveau.\nIn deze blog vertel ik je wat het is en waarom het relevant is voor jouw organisatie.\n",{"__component":313,"id":317,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":18,"content":318,"introductionText":18},4305,"## Wat is Microsoft Entra Suite?\n\n![Blog Gert Entra Suite Afb1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Gert_Entra_Suite_Afb1_16286ec83c.png)\n\nDe Microsoft Entra Suite is een verzameling van identiteits- en toegangsoplossingen die samen een solide fundament vormen voor een moderne Zero Trust-architectuur. De suite bestaat uit:\n- Microsoft Entra ID (voorheen Azure AD): identiteitsbeheer met Conditional Access, multifactor-authenticatie (MFA), en Identity Protection\n- Microsoft Entra ID Governance: automatisering en lifecyclebeheer van toegangsrechten op schaal\n- Microsoft Entra Verified ID: decentrale identiteitsverificatie met behulp van verifieerbare referenties\n- Microsoft Entra Internet Access: Secure Web Gateway (SWG) met identiteitsbewust beleid voor SaaS, Microsoft 365 en internetverkeer\n- Microsoft Entra Private Access: alternatief voor VPN, gericht op het bieden van veilige toegang bieden tot private apps op basis van identiteit, apparaatstatus en context",{"__component":313,"id":320,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":18,"content":321,"introductionText":18},4306,"## Wat doet het?\n\nWaar de traditionele Azure AD al een basis legde voor Zero Trust, breidt Entra Suite dit uit met concrete controle over netwerktoegang. \nDenk aan:\n- Het vervangen van VPN en traditionele proxy’s door identiteitsbewuste toegang tot interne applicaties\n- Het afdwingen van beleid op netwerkniveau, gebaseerd op dezelfde identiteiten en apparaten die je al beheert in Microsoft 365\n- Het combineren van identiteit + netwerkbeveiliging, waardoor Conditional Access verder reikt dan alleen authenticatie",{"__component":313,"id":323,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":324,"content":325,"introductionText":18},4307,"Afbeelding: Microsoft Security Zero trust access model","## Hoe past dit in mijn eerdere blogs?\n\n![Blog Gert Entra Suite Afb2.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Gert_Entra_Suite_Afb2_0222df716f.png)",{"__component":313,"id":327,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":18,"content":328,"introductionText":18},4308,"In mijn eerdere blogs behandelde ik onder andere:\n- Zero Trust principes en Microsoft’s -aanpak\n- Identiteits- en apparaatbeveiliging\n- Least privilege & Conditional Access\n- Tools & strategieën voor implementatie\n- Databescherming en governance\n\nDe Entra Suite integreert en operationaliseert exact die thema’s. Wat eerder bestond uit losse beleidskeuzes en technische configuraties, is nu in één suite bijeengebracht. Klaar voor grootschalige uitrol en geïntegreerd beheer.\n\nJe zou kunnen zeggen: Entra is niet alleen een uitbreiding van het Zero Trust-concept, het is de pragmatische vertaling ervan binnen het Microsoft-ecosysteem.",{"__component":313,"id":330,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":18,"content":331,"introductionText":18},4309,"## Waarom is dit relevant?\n\n![Blog Gert Entra Suite Afb3.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Gert_Entra_Suite_Afb3_4751f9d78c.png)\n\nVoor organisaties die worstelen met:\n- Gebruik van ongeautoriseerde apps en clouddiensten buiten IT\n- Moeilijk schaalbaar rechtenbeheer\n- Verouderde VPN-oplossingen die niet passen bij hybride werken\n- Gebrek aan zichtbaarheid en beleidsafdwinging op netwerkniveau\n\n... biedt Microsoft Entra Suite een geïntegreerd antwoord.\n\nBovendien sluit het aan op bestaande investeringen in Microsoft 365 en Defender, waardoor je beveiligings- en identiteitsbeheer naadloos in elkaar overvloeien.",{"__component":313,"id":333,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":18,"content":334,"introductionText":18},4310,"## Conclusie:\n\nZero Trust is géén eenmalig project, het is een strategie die meegroeit met je organisatie. Entra Suite is ontworpen om die groei te ondersteunen. Als je eerder al stappen hebt gezet met Conditional Access, MFA of informatiebeveiliging, dan is dit hét moment om door te schakelen.\n>Microsoft biedt niet langer alleen visie. Met Entra Suite levert het een compleet platform voor moderne toegang en beveiliging, klaar voor vandaag én morgen.\n",{"__component":313,"id":336,"title":18,"asideText":18,"underline":124,"centered":124,"blankAside":124,"aside":18,"content":337,"introductionText":18},4311,"Wil je sparren over hoe Entra Suite past in jouw beveiligingsstrategie? Neem gerust [contact](https://www.sharevalue.nl/contact) op, we denken graag mee over de volgende stap in jouw Zero Trust-reis.",{"__component":339,"id":340,"title":18,"showBlankAside":124},"global.social-sharing",494,{"__component":342,"id":343,"name":287,"jobTitle":288},"strapi.author-card",390,{"__component":108,"id":345,"titleLeft":346,"callToActionTextLeft":111,"callToActionLinkUrlLeft":112,"titleRight":347,"callToActionTextRight":348,"callToActionLinkUrlRight":349,"iconUrlLeft":350,"iconUrlRight":361},563,"Heb je een Azure-expert nodig?","Werken in ons Azure-team?","Klik hier","/word-onze-collega",{"id":351,"name":352,"alternativeText":18,"caption":18,"width":353,"height":354,"formats":18,"hash":355,"ext":163,"mime":164,"size":356,"url":357,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":358,"updatedAt":359,"documentId":360,"publishedAt":62},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":62},{"__component":95,"id":363,"title":97,"aside":18,"postType":364,"limit":99,"expertise":365},438,"blogs",[366],{"id":65,"title":66,"subTitle":67,"description":68,"shortDescription":69,"slug":70,"createdAt":71,"updatedAt":72,"publishedAt":73,"isCoreExpertise":74,"documentId":75,"image":367,"blocks":370,"midPageBlocks":377,"seo":401},{"id":77,"name":78,"alternativeText":18,"caption":18,"width":79,"height":80,"formats":368,"hash":88,"ext":23,"mime":26,"size":89,"url":90,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":91,"updatedAt":91,"documentId":92,"publishedAt":62},{"thumbnail":369},{"ext":23,"url":83,"hash":84,"mime":26,"name":85,"path":18,"size":86,"width":52,"height":87},[371,374],{"__component":95,"id":96,"title":97,"aside":18,"postType":98,"limit":99,"expertise":372},[373],{"id":65,"title":66,"subTitle":67,"description":68,"shortDescription":69,"slug":70,"createdAt":71,"updatedAt":72,"publishedAt":73,"isCoreExpertise