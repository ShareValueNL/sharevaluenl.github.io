":166,"height":167,"formats":18,"hash":168,"ext":169,"mime":170,"size":171,"url":172,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":173,"updatedAt":174,"documentId":175,"publishedAt":57,"focalPoint":18},{"id":371,"title":372,"subTitle":372,"description":373,"shortDescription":373,"slug":374,"createdAt":375,"updatedAt":376,"publishedAt":377,"isCoreExpertise":193,"documentId":378,"image":379,"seo":18,"blocks":408,"midPageBlocks":409},9,"Architect","\"","architect","2023-11-10T07:52:25.259Z","2023-11-10T07:53:22.170Z","2023-11-10T07:53:22.058Z","x9hq3mqhktltw90g0k4ina0y",{"id":380,"name":381,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":382,"hash":403,"ext":200,"mime":203,"size":404,"url":405,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":406,"updatedAt":406,"documentId":407,"publishedAt":57,"focalPoint":18},143,"pooltafel.jpg",{"large":383,"small":388,"medium":393,"thumbnail":398},{"ext":200,"url":384,"hash":385,"mime":203,"name":386,"path":18,"size":387,"width":29,"height":30},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_pooltafel_737db83b07.jpg","large_pooltafel_737db83b07","large_pooltafel.jpg",76.89,{"ext":200,"url":389,"hash":390,"mime":203,"name":391,"path":18,"size":392,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_pooltafel_737db83b07.jpg","small_pooltafel_737db83b07","small_pooltafel.jpg",26.21,{"ext":200,"url":394,"hash":395,"mime":203,"name":396,"path":18,"size":397,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_pooltafel_737db83b07.jpg","medium_pooltafel_737db83b07","medium_pooltafel.jpg",49.65,{"ext":200,"url":399,"hash":400,"mime":203,"name":401,"path":18,"size":402,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_pooltafel_737db83b07.jpg","thumbnail_pooltafel_737db83b07","thumbnail_pooltafel.jpg",7.77,"pooltafel_737db83b07",112.02,"https://incredible-beef-2a6059b946.media.strapiapp.com/pooltafel_737db83b07.jpg","2023-08-24T10:51:19.397Z","ffge4u003fjgklicm2rua4zz",[],[],[411,415,419,423,426,429,432,435,437,481],{"id":412,"title":18,"asideText":18,"underline":193,"centered":193,"blankAside":193,"aside":18,"content":413,"introductionText":18,"__component":414},1803,"- April 2024 blog: Implementering van identiteits- en apparaatbescherming, inclusief multifactor-authenticatie, privilege-toegang en voorwaardelijke toegangsbeleidsregels.\n- Juli 2024 blog: Implementeer een uitgebreide detectie- en responsoplossing om bedreigingen op verschillende eindpunten, identiteiten, cloud-apps en e-mails te detecteren, onderzoeken en erop te reageren.\n- Oktober 2024 blog: Bescherm en beheer gevoelige gegevens met oplossingen die inzicht bieden in alle gegevens en beleid ter voorkoming van gegevensverlies toepassen.\n\nIn deze blog wil ik het graag hebben over Microsoft Zero Trust Security. Ben je geïnteresseerd in bijvoorbeeld Azure-beveiliging of architectuurontwerp? Lees dan vooral verder. Dan neem ik je mee in de constant veranderende wereld van cybersecurity. ","global.pagesection",{"id":416,"title":18,"asideText":417,"underline":193,"centered":193,"blankAside":193,"aside":18,"content":418,"introductionText":18,"__component":414},1804,"Figuur 1: Microsoft Zero Trust Architectuur","![zero_trust_1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/zero_trust_1_421b096da9.png)\n\n\n## Het concept van Zero Trust\n\nWat is Zero Trust Security eigenlijk? Het is een verandering in hoe we cybersecurity benaderen. Traditioneel bouwden we digitale slotgrachten rondom onze bedrijfsnetwerken en vertrouwden alles van binnen, terwijl alles van buiten als een mogelijke bedreiging werd beschouwd. Zero Trust verandert dit concept. Het gaat ervan uit dat niemand, binnen of buiten het netwerk, standaard vertrouwd moet worden.",{"id":420,"title":18,"asideText":421,"underline":193,"centered":193,"blankAside":193,"aside":18,"content":422,"introductionText":18,"__component":414},1805,"Figuur 2: Het huidige model: Identiteitsperimeter vormt een aanvulling op de netwerkperimeter","![zero_trust_2.png](https://incredible-beef-2a6059b946.media.strapiapp.com/zero_trust_2_5d8efe3bcb.png)\n\n## Belangrijkste principes van Zero Trust\n\n- **Expliciet Verifiëren:** Elke gebruiker en elk apparaat wordt grondig geverifieerd voordat ze toegang krijgen. Geen impliciet vertrouwen meer.\n- **Minimale Toegangsrechten:** Gebruikers krijgen alleen toegang tot wat ze nodig hebben om hun werk te doen - niet meer, niet minder.\n- **Micro-Segmentatie:** Netwerken worden opgedeeld in kleine, geïsoleerde segmenten om het voor aanvallers moeilijk te maken zich lateraal te verplaatsen.\n- **Continue Monitoring:** Gebruikers en apparaten worden continu in de gaten gehouden, zelfs nadat ze toegang hebben gekregen, om afwijkingen snel te detecteren en erop te reageren.",{"id":424,"title":18,"asideText":18,"underline":193,"centered":193,"blankAside":193,"aside":18,"content":425,"introductionText":18,"__component":414},1806,"## Microsoft's Zero Trust aanpak\nMicrosoft omarmt de Zero Trust-aanpak en biedt een scala aan tools en services, vooral in Azure-omgevingen. In oktober 2023 publiceerde Microsoft een Inside Track-artikel waarin werd gesproken over de implementatie van een zero trust-beveiligingsmodel door Microsoft. Meer hierover leest u op [de website van Microsoft](https://www.microsoft.com/insidetrack/blog/implementing-a-zero-trust-security-model-at-microsoft/).\n\nMicrosoft Entra ID, Azure Sentinel en Azure Policy spelen hierbij een cruciale rol.\n- **Microsoft Entra ID:** De Identity and Access Management-oplossing van Microsoft biedt multi-factor authenticatie, voorwaardelijke toegangsbeleid en identity protection.\n- **Azure Sentinel:** Microsoft's cloud-native SIEM-oplossing verzamelt en analyseert beveiligingsgegevens in realtime.\n- **Azure Policy:** Het helpt om organisatorische normen en naleving af te dwingen.\n",{"id":427,"title":18,"asideText":18,"underline":193,"centered":193,"blankAside":193,"aside":18,"content":428,"introductionText":18,"__component":414},1807,"## Het belang van voortdurende aanpassing\n\nZero Trust is geen eenmalige gebeurtenis, maar een doorlopend proces. Aanvallers evolueren constant, dus je beveiligingsmaatregelen moeten zich ook blijven ontwikkelen. Het is cruciaal dat je regelmatig je Zero Trust-strategie herziet en aanpast.",{"id":430,"title":18,"asideText":18,"underline":193,"centered":193,"blankAside":193,"aside":18,"content":431,"introductionText":18,"__component":414},1808,"## Conclusie\nIn de steeds veranderende wereld van cybersecurity is de Zero Trust-beveiligingsaanpak van Microsoft een uitkomst. Het sluit goed aan bij het doel van Azure-beveiliging en architectuurontwerp, waarbij de nadruk wordt gelegd op de noodzaak om alles te verifiëren en standaard niets te vertrouwen. \n\nDe belangrijkste uitgangspunten van het Zero Trust-beleid zijn als volgt;\n\n- Grondige verificatie: Altijd authentiseren en autoriseren op basis van een volledige set gegevens.\n- Beperkte toegangsrechten: Beperk de toegang van gebruikers tot het strikt noodzakelijke met just-in-time toegang en toegangscontrole op basis van risico, en zorg voor gegevensbescherming om data te beveiligen en de efficiëntie te bevorderen.\n- Verwacht inbreuken: Zorg voor end-to-end-versleuteling en maak gebruik van analyses. om zichtbaarheid te verkrijgen, bedreigingen op te sporen en de beveiliging te verbeteren\n\nDus, houd Zero Trust in je gereedschapskist terwijl je de complexiteiten van Azure-beveiliging verder blijft ontdekken!\nBereid je voor op een interessante reis in 2024. Microsoft Zero Trust is meer dan een buzzword; het is een gamechanger, en we zijn er om je hierin te begeleiden. \n\nBlijf veilig, blijf nieuwsgierig, en houd die Azure-wolken zo veilig mogelijk!\n\nWil je meer weten over deze functionaliteit?[ Neem dan gerust contact met ons op](/contact), zodat we de mogelijkheden kunnen bespreken.",{"id":433,"title":18,"showBlankAside":193,"__component":434},186,"global.social-sharing",{"id":322,"name":86,"jobTitle":88,"__component":436},"strapi.author-card",{"id":438,"title":439,"aside":18,"postType":150,"limit":151,"expertise":440,"__component":154},5,"Lees ook onze andere berichten",[441],{"id":101,"title":102,"subTitle":103,"description":104,"shortDescription":105,"slug":106,"createdAt":107,"updatedAt":108,"publishedAt":109,"isCoreExpertise":110,"documentId":111,"image":442,"seo":445,"blocks":450,"midPageBlocks":457},{"id":113,"name":114,"alternativeText":18,"caption":18,"width":115,"height":116,"formats":443,"hash":126,"ext":119,"mime":122,"size":127,"url":128,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":129,"updatedAt":129,"documentId":130,"publishedAt":57,"focalPoint":18},{"thumbnail":444},{"ext":119,"url":120,"hash":121,"mime":122,"name":123,"path":18,"size":124,"width":49,"height":125},{"id":132,"metaTitle":133,"metaDescription":134,"structuredData":446,"metaImage":18,"metaSocial":449},{"url":136,"@type":137,"@context":89,"provider":447,"areaServed":448,"description":143,"serviceType":144},{"url":139,"name":94,"@type":95},{"name":141,"@type":142},[],[451,454],{"id":148,"title":149,"aside":18,"postType":150,"limit":151,"expertise":452,"__component":154},[453],{"id":101,"title":102,"subTitle":103,"description":104,"shortDescription":105,"slug":106,"createdAt":107,"updatedAt":108,"publishedAt":109,"isCoreExpertise":110,"documentId":111},{"id":156,"titleLeft":157,"callToActionTextLeft":158,"callToActionLinkUrlLeft":159,"titleRight":160,"callToActionTextRight":161,"callToActionLinkUrlRight":162,"iconUrlLeft":455,"iconUrlRight":456,"__component":185},{"id":164,"name":165,"alternativeText":18,"caption":18,"width":166,"height":167,"formats":18,"hash":168,"ext":169,"mime":170,"size":171,"url":172,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":173,"updatedAt":174,"documentId":175,"publishedAt":57,"foca