[{"data":1,"prerenderedAt":616},["ShallowReactive",2],{"collection-blogs--192901086":3,"_apollo:default":615},{"data":4,"meta":611},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":93,"blocks":475},66,"Met Microsoft 365 in control van je dagelijkse portie werk","De vakantie is voorbij, maar volledig terug naar kantoor is nog lang niet iedereen. Hoe gingen de afgelopen weken met het thuiswerken? Voelde je je in control van hetgeen je moet doen of ben je misschien toch nog zoekende naar meer structuur?","met-microsoft-365-in-control-van-je-dagelijkse-portie-werk","2023-10-13T10:26:34.934Z","2025-04-17T13:45:40.619Z","2023-10-13T10:26:34.838Z","2020-08-27","x4cu7vnt3ben735vhguy3ldc",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},315,"met-microsoft-365-in-control-van-je-dagelijkse-portie-werk.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c.jpg","large_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c","image/jpg","large_met-microsoft-365-in-control-van-je-dagelijkse-portie-werk.jpg",41.56,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c.jpg","small_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c","small_met-microsoft-365-in-control-van-je-dagelijkse-portie-werk.jpg",14.4,195,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c.jpg","medium_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c","medium_met-microsoft-365-in-control-van-je-dagelijkse-portie-werk.jpg",26.52,750,293,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c.jpg","thumbnail_met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c","thumbnail_met-microsoft-365-in-control-van-je-dagelijkse-portie-werk.jpg",4.95,245,96,"met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c",60.16,"https://incredible-beef-2a6059b946.media.strapiapp.com/met_microsoft_365_in_control_van_je_dagelijkse_portie_werk_52190dc18c.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:23:06.009Z","nutcsz8m9hdpjexwu5cfgn33","2026-01-05T12:38:34.018Z",{"id":59,"metaTitle":60,"metaDescription":61,"structuredData":62,"metaImage":18,"metaSocial":92},154,"Microsoft 365: grip op je werkdag | ShareValue","Ontdek hoe je met Microsoft To Do, Planner en Teams je taken centraliseert en structuur aanbrengt in je werkdag.",[63,75],{"url":64,"@type":65,"author":66,"@context":67,"headline":68,"publisher":69,"description":61,"datePublished":13},"https://www.sharevalue.nl/blogs/met-microsoft-365-in-control-van-je-dagelijkse-portie-werk","BlogPosting",{},"https://schema.org","Microsoft 365: grip op je werkdag met To Do & Teams",{"logo":70,"name":73,"@type":74},{"url":71,"@type":72},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","ShareValue","Organization",{"@type":76,"@context":67,"mainEntity":77},"FAQPage",[78,84,88],{"name":79,"@type":80,"acceptedAnswer":81},"Hoe helpt Microsoft To Do bij het beheren van taken?","Question",{"text":82,"@type":83},"Microsoft To Do stelt je in staat om persoonlijke taken bij te houden en een overzicht van je taken in Planner op te halen, waardoor je een gecentraliseerd overzicht van je werk hebt.","Answer",{"name":85,"@type":80,"acceptedAnswer":86},"Wat verandert er met de integratie van Planner in Teams?",{"text":87,"@type":83},"Planner in Teams wordt hernoemd naar Tasks, wat een integratie biedt met zowel Planner-taken als To Do-taken, waardoor je een persoonlijk en teamoverzicht van taken binnen Teams krijgt.",{"name":89,"@type":80,"acceptedAnswer":90},"Hoe kan ik e-mails omzetten in taken met Outlook Online?",{"text":91,"@type":83},"In Outlook Online kun je e-mails naar het To Do-venster slepen om er een taak of afspraak van te maken, wat helpt bij het opvolgen van belangrijke e-mails.",[],[94],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105,"image":106,"seo":125,"blocks":140,"midPageBlocks":180},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":107,"name":108,"alternativeText":18,"caption":18,"width":109,"height":110,"formats":111,"hash":120,"ext":113,"mime":116,"size":121,"url":122,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":123,"updatedAt":123,"documentId":124,"publishedAt":57,"focalPoint":18},16,"microsoft-365.png",282,130,{"thumbnail":112},{"ext":113,"url":114,"hash":115,"mime":116,"name":117,"path":18,"size":118,"width":49,"height":119},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":126,"metaTitle":127,"metaDescription":128,"structuredData":129,"metaImage":18,"metaSocial":139},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":130,"@type":131,"@context":67,"provider":132,"areaServed":134,"description":137,"serviceType":138},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":133,"name":73,"@type":74},"https://www.sharevalue.nl",{"name":135,"@type":136},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[141,149],{"id":142,"title":143,"aside":18,"postType":144,"limit":145,"expertise":146,"__component":148},166,"Lees meer over Microsoft 365","alle",3,[147],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105},"strapi.related-kennisbank-list",{"id":150,"titleLeft":151,"callToActionTextLeft":152,"callToActionLinkUrlLeft":153,"titleRight":154,"callToActionTextRight":155,"callToActionLinkUrlRight":156,"iconUrlLeft":157,"iconUrlRight":170,"__component":179},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":57,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":171,"name":172,"alternativeText":18,"caption":18,"width":161,"height":161,"formats":18,"hash":173,"ext":163,"mime":164,"size":174,"url":175,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":176,"updatedAt":177,"documentId":178,"publishedAt":57,"focalPoint":18},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[181,225,261,295,329,364,398,434,468],{"id":182,"title":183,"subTitle":184,"content":185,"callToActionText":18,"callToActionLink":18,"colorStyle":186,"showAsides":187,"imageUrl":188,"__component":224},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"id":189,"name":190,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":192,"hash":219,"ext":23,"mime":196,"size":220,"url":221,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":222,"updatedAt":222,"documentId":223,"publishedAt":57,"focalPoint":18},782,"Teams.jpg",850,{"large":193,"small":200,"medium":206,"thumbnail":212},{"ext":23,"url":194,"hash":195,"mime":196,"name":197,"path":18,"size":198,"width":29,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Teams_43eca91eed.jpg","large_Teams_43eca91eed","image/jpeg","large_Teams.jpg",75.76,664,{"ext":23,"url":201,"hash":202,"mime":196,"name":203,"path":18,"size":204,"width":20,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Teams_43eca91eed.jpg","small_Teams_43eca91eed","small_Teams.jpg",24.28,332,{"ext":23,"url":207,"hash":208,"mime":196,"name":209,"path":18,"size":210,"width":42,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Teams_43eca91eed.jpg","medium_Teams_43eca91eed","medium_Teams.jpg",45.38,498,{"ext":23,"url":213,"hash":214,"mime":196,"name":215,"path":18,"size":216,"width":217,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Teams_43eca91eed.jpg","thumbnail_Teams_43eca91eed","thumbnail_Teams.jpg",8.28,235,156,"Teams_43eca91eed",119.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Teams_43eca91eed.jpg","2024-08-08T09:42:56.910Z","ht6rctym4qbbspr1vnahyrg1","global.alternating-page-section",{"id":226,"title":227,"subTitle":228,"content":229,"callToActionText":230,"callToActionLink":153,"colorStyle":231,"showAsides":187,"imageUrl":232,"__component":224},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"id":233,"name":234,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":235,"hash":256,"ext":23,"mime":196,"size":257,"url":258,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":259,"updatedAt":259,"documentId":260,"publishedAt":57,"focalPoint":18},783,"adoptie.jpg",{"large":236,"small":241,"medium":246,"thumbnail":251},{"ext":23,"url":237,"hash":238,"mime":196,"name":239,"path":18,"size":240,"width":29,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_adoptie_dc3bbcacaa.jpg","large_adoptie_dc3bbcacaa","large_adoptie.jpg",140.54,{"ext":23,"url":242,"hash":243,"mime":196,"name":244,"path":18,"size":245,"width":20,"height":205},"https://