"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":23,"url":315,"hash":316,"mime":196,"name":317,"path":18,"size":318,"width":42,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":320,"hash":321,"mime":196,"name":322,"path":18,"size":323,"width":217,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":330,"title":331,"subTitle":332,"content":333,"callToActionText":334,"callToActionLink":153,"colorStyle":186,"showAsides":187,"imageUrl":335,"__component":224},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":336,"name":337,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":338,"hash":359,"ext":23,"mime":196,"size":360,"url":361,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":362,"updatedAt":362,"documentId":363,"publishedAt":57,"focalPoint":18},786,"migratie.jpg",{"large":339,"small":344,"medium":349,"thumbnail":354},{"ext":23,"url":340,"hash":341,"mime":196,"name":342,"path":18,"size":343,"width":29,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":345,"hash":346,"mime":196,"name":347,"path":18,"size":348,"width":20,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":350,"hash":351,"mime":196,"name":352,"path":18,"size":353,"width":42,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":355,"hash":356,"mime":196,"name":357,"path":18,"size":358,"width":217,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":365,"title":366,"subTitle":367,"content":368,"callToActionText":18,"callToActionLink":18,"colorStyle":231,"showAsides":187,"imageUrl":369,"__component":224},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":370,"name":371,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":372,"hash":393,"ext":23,"mime":196,"size":394,"url":395,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":396,"updatedAt":396,"documentId":397,"publishedAt":57,"focalPoint":18},787,"microsoft security.jpg",{"large":373,"small":378,"medium":383,"thumbnail":388},{"ext":23,"url":374,"hash":375,"mime":196,"name":376,"path":18,"size":377,"width":29,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":379,"hash":380,"mime":196,"name":381,"path":18,"size":382,"width":20,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":384,"hash":385,"mime":196,"name":386,"path":18,"size":387,"width":42,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":389,"hash":390,"mime":196,"name":391,"path":18,"size":392,"width":217,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":399,"title":400,"subTitle":401,"content":402,"callToActionText":403,"callToActionLink":404,"colorStyle":186,"showAsides":187,"imageUrl":405,"__component":224},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":406,"name":407,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":408,"hash":429,"ext":23,"mime":196,"size":430,"url":431,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":432,"updatedAt":432,"documentId":433,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":409,"small":414,"medium":419,"thumbnail":424},{"ext":23,"url":410,"hash":411,"mime":196,"name":412,"path":18,"size":413,"width":29,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":415,"hash":416,"mime":196,"name":417,"path":18,"size":418,"width":20,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":420,"hash":421,"mime":196,"name":422,"path":18,"size":423,"width":42,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":425,"hash":426,"mime":196,"name":427,"path":18,"size":428,"width":217,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":435,"title":436,"subTitle":437,"content":438,"callToActionText":18,"callToActionLink":18,"colorStyle":231,"showAsides":187,"imageUrl":439,"__component":224},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":440,"name":441,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":442,"hash":463,"ext":23,"mime":196,"size":464,"url":465,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":466,"updatedAt":466,"documentId":467,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":443,"small":448,"medium":453,"thumbnail":458},{"ext":23,"url":444,"hash":445,"mime":196,"name":446,"path":18,"size":447,"width":29,"height":199},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":449,"hash":450,"mime":196,"name":451,"path":18,"size":452,"width":20,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":454,"hash":455,"mime":196,"name":456,"path":18,"size":457,"width":42,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":459,"hash":460,"mime":196,"name":461,"path":18,"size":462,"width":217,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":469,"title":470,"callToActionText":471,"callToActionLinkUrl":472,"body":18,"imageUrl":473,"__component":474},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":57,"focalPoint":18},"call-to-action.single",[476,481,485,488,491,494,497,501,504,507,510,513,517,520,523,526,605],{"id":477,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":479,"introductionText":18,"__component":480},947,"","Ik merk bij mijzelf dat ik overal wat heb staan, de backlog in Planner, een takenlijst in SharePoint, mijn op te volgen e-mail in To Do en er zwerft ook nog een papiertje op mijn bureau.","global.pagesection",{"id":482,"title":18,"asideText":483,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":484,"introductionText":18,"__component":480},948,"Microsoft To Do","## To Do\n\nMet To Do kun je je persoonlijke taken bijhouden en een overzicht van jouw taken in Planner ophalen. Het is een van de redenen dat ik veelvuldig gebruik maak van Outlook Online omdat ik daar de integratie met To Do als erg prettig ervaar. Als je namelijk in Outlook Online klikt op het icoontje met vinkje in de balk bovenin, vouwt aan de rechterkant To Do open.",{"id":486,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":487,"introductionText":18,"__component":480},949,"![](https://www.sharevalue.nl/images/sharevalue/blogs/in_control_1.png)",{"id":489,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":490,"introductionText":18,"__component":480},950,"Door de e-mail te slepen naar dit venster kun je er een afspraak of een taak van maken.",{"id":492,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":493,"introductionText":18,"__component":480},951,"![](https://www.sharevalue.nl/images/sharevalue/blogs/in_control_2.gif)",{"id":495,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":496,"introductionText":18,"__component":480},954,"Zo kan ik snel e-mail die ik wil opvolgen in mijn takenlijst zetten of eventueel zelfs snel een vervolgafspraak plannen.",{"id":498,"title":18,"asideText":499,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":500,"introductionText":18,"__component":480},953,"Overzicht!","## Alle taken op één plek\n\nAllereerst is het vele malen prettiger als alles op één plek staat, maar nu ik het grootste gedeelte van mijn werk vanuit Teams doe, zou het toch fijn zijn als ik daar alles kan bekijken.\n\nEr is goed nieuws! Binnenkort gaat Microsoft de Planner optie in Teams aanpassen naar Tasks. Misschien heb je onderstaande balk al gezien toen je Planner in Teams opstartte:",{"id":502,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":503,"introductionText":18,"__component":480},952,"![](https://www.sharevalue.nl/images/sharevalue/blogs/in_control_3.png)",{"id":505,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":506,"introductionText":18,"__component":480},955,"Nu vind je er nog een overzicht van de Planborden waar je gebruikt van maakt en je toegewezen taken. Straks komt er ook een integratie met de taken die je in To Do hebt staan. Hierin kan dan een persoonlijk overzicht worden opgeroepen, maar ook een teamoverzicht. Het gaat er dan ongeveer zo uit zien:",{"id":508,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":509,"introductionText":18,"__component":480},956,"![](https://www.sharevalue.nl/images/sharevalue/blogs/in_control_4.png)",{"id":511,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":512,"introductionText":18,"__component":480},957,"De volgende stap die Microsoft aangeeft om te integreren, zijn de taken die je eventueel vanuit Outlook hebt aangemaakt en zelfs de opmerkingen in Office-documenten die aan jou zijn gericht komen in het overzicht erbij.\n\nZo’n taakoverzicht kun je oproepen vanuit het linkermenu in Teams waarin je een totaaloverzicht krijgt, maar je kunt ook een tab in een Team toevoegen die dan puur de taken voor dat team overzichtelijk toont.",{"id":514,"title":18,"asideText":515,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":516,"introductionText":18,"__component":480},958,"Hoe snel komt het?","## Wijzigen routine\n\nNu de belangrijkste vraag, hoe snel komt het? Er wordt gesproken over uitrollen in 2020, dat is helaas nog een ruim begrip. In Teams zie je nu nog Planner staan, deze knop wordt eerst hernoemd naar Tasks by Planner and To Do en daarna wordt deze Tasks genoemd. Een exacte maand of periode is nog niet genoemd voor deze uitrol, maar de eerste tekenen worden zichtbaar.\n\nIk kan je aanraden om alvast routine op te bouwen met het gebruiken van To Do, als straks de integratie helemaal is doorgevoerd, kun je er meteen alles uithalen. To Do is mobiel beschikbaar met een fijne app, zodat je snelle toegang hebt tot je taken. Geen last meer van losse blaadjes met aantekeningen, een duidelijk overzicht met wat er die dag gedaan moet worden en dus meer in control. Dat wil jij toch ook?!",{"id":518,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":519,"introductionText":18,"__component":480},959,"Aan de slag met Microsoft 365 of hulp nodig bij de implementatie van Teams? Mijn collega-consultants bij ShareValue en ik helpen je graag. [Neem contact met ons op](/contact) om te kijken wat wij voor je kunnen betekenen!",{"id":521,"title":18,"showBlankAside":104,"__component":522},105,"global.social-sharing",{"id":524,"name":18,"jobTitle":18,"__component":525},63,"strapi.author-card",{"id":527,"title":528,"aside":18,"postType":144,"limit":145,"expertise":529,"__component":148},74,"Lees ook onze andere berichten",[530],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105,"image":531,"seo":534,"blocks":539,"midPageBlocks":546},{"id":107,"name":108,"alternativeText":18,"caption":18,"width":109,"height":110,"formats":532,"hash":120,"ext":113,"mime":116,"size":121,"url":122,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":123,"updatedAt":123,"documentId":124,"publishedAt":57,"focalPoint":18},{"thumbnail":533},{"ext":113,"url":114,"hash":115,"mime":116,"name":117,"path":18,"size":118,"width":49,"height":119},{"id":126,"metaTitle":127,"metaDescription":128,"structuredData":535,"metaImage":18,"metaSocial":538},{"url":130,"@type":131,"@context":67,"provider":536,"areaServed":537,"description":137,"serviceType":138},{"url":133,"name":73,"@type":74},{"name":135,"@type":136},[],[540,543],{"id":142,"title":143,"aside":18,"postType":144,"limit":145,"expertise":541,"__component":148},[542],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105},{"id":150,"titleLeft":151,"callToActionTextLeft":152,"callToActionLinkUrlLeft":153,"titleRight":154,"callToActionTextRight":155,"callToActionLinkUrlRight":156,"iconUrlLeft":544,"iconUrlRight":545,"__component":179},{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":1