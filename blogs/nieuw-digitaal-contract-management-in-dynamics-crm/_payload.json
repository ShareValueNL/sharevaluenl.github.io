},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":452,"hash":453,"mime":229,"name":454,"path":18,"size":455,"width":30,"height":244},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":457,"hash":458,"mime":229,"name":459,"path":18,"size":460,"width":250,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":174,"id":175,"title":176,"callToActionText":177,"callToActionLinkUrl":178,"body":18,"imageUrl":467},{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":57},{"id":180,"metaTitle":181,"metaDescription":182,"structuredData":469,"metaImage":18,"metaSocial":472},{"url":184,"@type":185,"@context":186,"provider":470,"areaServed":471,"description":194,"serviceType":195},{"url":188,"name":189,"@type":190},{"name":192,"@type":193},[],{"id":162,"name":474,"jobTitle":475,"about":18,"createdAt":476,"updatedAt":477,"publishedAt":478,"documentId":479,"image":480,"contactOptions":497},"Jaap","Consultant & Architect","2023-08-18T08:37:46.142Z","2024-04-18T14:14:47.615Z","2023-08-18T08:37:45.364Z","ylun9zjxpvjd4rq1teczcwna",{"id":481,"name":482,"alternativeText":18,"caption":18,"width":483,"height":484,"formats":485,"hash":492,"ext":89,"mime":92,"size":493,"url":494,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":495,"updatedAt":495,"documentId":496,"publishedAt":57},685,"Jaap websitefoto.png",278,326,{"thumbnail":486},{"ext":89,"url":487,"hash":488,"mime":92,"name":489,"path":18,"size":490,"width":491,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Jaap_websitefoto_b7bbefc0bd.png","thumbnail_Jaap_websitefoto_b7bbefc0bd","thumbnail_Jaap websitefoto.png",19.14,133,"Jaap_websitefoto_b7bbefc0bd",19.61,"https://incredible-beef-2a6059b946.media.strapiapp.com/Jaap_websitefoto_b7bbefc0bd.png","2024-04-18T14:13:38.415Z","cvbav3qa5a84m18w8fmg5l5c",[],[499,504,507,511,514,517,520,523,530],{"__component":500,"id":501,"title":18,"asideText":502,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":503,"introductionText":18},"global.pagesection",885,"Stap 1: DocumentsCorePack","## DocumentsCorePack\n\nTen eerste heb je DocumentsCorePack van MSCRM-addons voor het opmaken van het contract-document.\n\nDeze oplossing heeft een uitgebreide sjablonen-functie. Behalve dat het data uit CRM haalt (zelfs via een zelfgebouwde fetch als je dat wilt), kan het sjabloon ook berekeningen doen, streepjescodes en QR codes genereren en ga zo maar door. Én de reden waarom ik het in deze blog noem: DocumentsCorePack heeft de mogelijkheid om vakjes te plaatsen voor de digitale ondertekening van Adobe of DocuSign.\n\nHet aanmaken van het document kan aangeroepen worden met een workflow\\*, bijvoorbeeld als je order van de fase “registreren” naar de fase “reviewen” gaat. Je kunt ervoor kiezen om het document als een attachment in de notities te bewaren, of in SharePoint.",{"__component":500,"id":505,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":506,"introductionText":18},887,"![](https://www.sharevalue.nl/images/sharevalue/blogs/contract_management.png)\n\n​",{"__component":500,"id":508,"title":18,"asideText":509,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":510,"introductionText":18},886,"Stap 2: DocuSign","## DocuSign for Dynamics 365 CRM\n\nVoor de tweede stap heb ik gebruik gemaakt van “DocuSign for Dynamics 365 CRM”. Deze oplossing herkent de placeholders van DocumentsCorePack en stuurt het document achtereenvolgens naar de verschillende ondertekenaars, die één voor één tekenen in het juiste vakje.\n\nHet versturen van het document naar de ondertekenaars gebeurt natuurlijk ook in een workflow\\*. Deze workflow wordt bijvoorbeeld aangeroepen wanneer de gebruiker de order van de fase “review” naar de fase “contract signing” promoveert.\n\nWanneer het contract door alle partijen is ondertekend, plaatst “DocuSign for Dynamics 365 CRM” het document automatisch als pdf in de juiste SharePoint folder. Dat is natuurlijk ook gelijk de trigger om de order gereed te melden!",{"__component":500,"id":512,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":513,"introductionText":18},888,"Indien je veel werkt met Dynamics 365 en SharePoint, en je voor het ondertekenen van digitale bestanden het liefst binnen Microsoft 365 blijft werken: dat kan dus! Hopelijk komt Dynamics CRM binnenkort met een eigen functionaliteit, maar met de hierboven besproken optie werkt het ook prima. Als mijn collega’s en ik kunnen helpen bij het inrichten hiervan, horen we dat natuurlijk graag.",{"__component":500,"id":515,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":516,"introductionText":18},889,"_\\* Alle functionaliteiten van DocumentsCorePack en “DocuSign for Dynamics 365 CRM” kunnen met custom workflow activities worden aangeroepen._",{"__component":518,"id":519,"title":18,"showBlankAside":80},"global.social-sharing",99,{"__component":521,"id":522,"name":18,"jobTitle":18},"strapi.author-card",57,{"__component":104,"id":524,"title":525,"aside":18,"postType":107,"limit":108,"expertise":526},68,"Lees ook onze andere berichten",[527],{"id":60,"title":61,"subTitle":62,"description":62,"shortDescription":62,"slug":63,"createdAt":64,"updatedAt":64,"publishedAt":65,"isCoreExpertise":66,"documentId":67,"image":18,"blocks":528,"midPageBlocks":529,"seo":18},[],[],{"__component":117,"id":531,"titleLeft":532,"callToActionTextLeft":120,"callToActionLinkUrlLeft":533,"titleRight":534,"callToActionTextRight":535,"callToActionLinkUrlRight":536,"iconUrlLeft":537,"iconUrlRight":538},126,"Heb je en Dynamics 365 expert nodig?","https://www.sharevalue.nl/contact","Wil je weten waar wij goed in zijn?","Ontdek wat we doen","https://www.sharevalue.nl/wat-we-doen",{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":57},{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":57},{"id":540,"metaTitle":541,"metaDescription":542,"structuredData":543,"metaImage":18,"metaSocial":571},148,"Digitaal contractbeheer in Dynamics CRM | ShareValue","Jaap toont hoe je met DocumentsCorePack en DocuSign digitale contracten beheert en ondertekent binnen Dynamics 365 CRM en SharePoint.",[544,554],{"url":545,"@type":546,"author":547,"@context":186,"headline":541,"publisher":550,"description":542,"datePublished":13},"https://www.sharevalue.nl/blogs/nieuw-digitaal-contract-management-in-dynamics-crm","BlogPosting",{"name":474,"@type":548,"jobTitle":475,"worksFor":549},"Person",{"name":189,"@type":190},{"logo":551,"name":189,"@type":190},{"url":552,"@type":553},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject",{"@type":555,"@context":186,"mainEntity":556},"FAQPage",[557,563,567],{"name":558,"@type":559,"acceptedAnswer":560},"Wat is DocumentsCorePack?","Question",{"text":561,"@type":562},"DocumentsCorePack is een tool van MSCRM-addons waarmee je sjablonen kunt maken voor documenten in Dynamics CRM, inclusief digitale ondertekeningsvelden.","Answer",{"name":564,"@type":559,"acceptedAnswer":565},"Hoe integreer je DocuSign met Dynamics 365 CRM?",{"text":566,"@type":562},"Met 'DocuSign for Dynamics 365 CRM' kun je documenten automatisch laten ondertekenen door meerdere partijen en de ondertekende documenten opslaan in SharePoint.",{"name":568,"@type":559,"acceptedAnswer":569},"Is het mogelijk om contracten volledig digitaal te beheren binnen Microsoft 365?",{"text":570,"@type":562},"Ja, door gebruik te maken van DocumentsCorePack en DocuSign binnen Dynamics 365 CRM en SharePoint kun je het volledige contractbeheer digitaal uitvoeren.",[],{"pagination":573},{"page":574,"pageSize":575},1,100,{},1780406658756]