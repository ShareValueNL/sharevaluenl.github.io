[{"data":1,"prerenderedAt":519},["ShallowReactive",2],{"collection-blogs-545104963":3,"_apollo:default":518},{"data":4,"meta":514},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":62,"author":327,"blocks":353,"seo":457},650,"Power Apps Canvas vs Model-driven: wanneer kies je welke app?","Je wilt een Power App bouwen. Maar kies je voor Canvas of Model-driven app? Deze keuze heeft invloed op de ontwerpvrijheid (en daarmee UX), databronnen en licenties. In deze blog leg ik de belangrijkste verschillen uit en wanneer je welke optie kiest.","power-apps-canvas-vs-model-driven-wanneer-kies-je-welke-app","2026-03-05T15:05:25.522Z","2026-03-06T15:30:36.941Z","2026-03-06T15:30:39.070Z","2026-03-06","trk32z2py06ot8w6snpycrkc",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":55,"ext":23,"mime":26,"size":56,"url":57,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":59,"updatedAt":59,"documentId":60,"publishedAt":61},1419,"Header blog website Power Apps Canvas vs Model-driven.jpg",null,1280,500,{"large":22,"small":32,"medium":39,"thumbnail":47},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30,"sizeInBytes":31},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102.jpg","large_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102","image/jpeg","large_Header blog website Power Apps Canvas vs Model-driven.jpg",25.5,1000,391,25499,{"ext":23,"url":33,"hash":34,"mime":26,"name":35,"path":18,"size":36,"width":20,"height":37,"sizeInBytes":38},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102.jpg","small_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102","small_Header blog website Power Apps Canvas vs Model-driven.jpg",9.57,195,9572,{"ext":23,"url":40,"hash":41,"mime":26,"name":42,"path":18,"size":43,"width":44,"height":45,"sizeInBytes":46},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102.jpg","medium_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102","medium_Header blog website Power Apps Canvas vs Model-driven.jpg",16.78,750,293,16778,{"ext":23,"url":48,"hash":49,"mime":26,"name":50,"path":18,"size":51,"width":52,"height":53,"sizeInBytes":54},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102.jpg","thumbnail_Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102","thumbnail_Header blog website Power Apps Canvas vs Model-driven.jpg",3.44,245,96,3436,"Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102",35.18,"https://incredible-beef-2a6059b946.media.strapiapp.com/Header_blog_website_Power_Apps_Canvas_vs_Model_driven_9750bba102.jpg","strapi-provider-upload-strapi-cloud","2026-03-06T12:30:07.202Z","cduw08tg0t7sj9dujpjojax8","2026-03-06T12:30:07.203Z",[63],{"id":64,"title":65,"subTitle":66,"description":67,"shortDescription":68,"slug":69,"createdAt":70,"updatedAt":71,"publishedAt":72,"isCoreExpertise":73,"documentId":74,"image":75,"blocks":95,"midPageBlocks":187,"seo":322},7,"Power Platform","Optimaliseer je bedrijfsprocessen met Microsoft Power Platform","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.\n\nBij ShareValue leveren we oplossingen die precies aansluiten op de behoeften van jouw organisatie. Of het nu gaat om het opzetten van een uitgebreide governance- en omgevingsstrategie, het ontwikkelen van een app met bijbehorende automatiseringen of het bevorderen van gebruikersadoptie; wij hebben de juiste expertise in huis.\n\nOnze Power Platform-specialisten, bestaande uit ervaren consultants en developers, hebben een bewezen staat van dienst in diverse sectoren. Zij delen continu hun kennis en passen deze toe op de unieke vraagstukken van onze klanten, waardoor we steeds de meest effectieve en innovatieve oplossingen kunnen bieden.\n","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.","power-platform","2023-10-12T11:27:43.792Z","2025-04-11T13:13:15.099Z","2023-10-12T11:27:43.781Z",true,"prbaerw7gypadu8gfdyg53sy",{"id":76,"name":77,"alternativeText":18,"caption":18,"width":78,"height":79,"formats":80,"hash":89,"ext":82,"mime":85,"size":90,"url":91,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":92,"updatedAt":92,"documentId":93,"publishedAt":94},927,"Logo PowerPlatform 2025 web png.png",282,130,{"thumbnail":81},{"ext":82,"url":83,"hash":84,"mime":85,"name":86,"path":18,"size":87,"width":52,"height":88},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Power_Platform_2025_web_png_4268556f17.png","thumbnail_Logo_Power_Platform_2025_web_png_4268556f17","image/png","thumbnail_Logo PowerPlatform 2025 web png.png",8.26,113,"Logo_Power_Platform_2025_web_png_4268556f17",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Power_Platform_2025_web_png_4268556f17.png","2024-12-16T11:07:06.507Z","a12tjlb3ssr20rrzj9rulb58","2026-01-05T12:38:34.018Z",[96,164],{"__component":97,"id":98,"title":99,"aside":18,"postType":100,"limit":101,"expertise":102},"strapi.related-kennisbank-list",164,"Lees meer over het Power Platform","alle",3,[103],{"id":64,"title":65,"subTitle":66,"description":67,"shortDescription":68,"slug":69,"createdAt":70,"updatedAt":71,"publishedAt":72,"isCoreExpertise":73,"documentId":74,"image":104,"blocks":107,"midPageBlocks":118,"seo":147},{"id":76,"name":77,"alternativeText":18,"caption":18,"width":78,"height":79,"formats":105,"hash":89,"ext":82,"mime":85,"size":90,"url":91,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":92,"updatedAt":92,"documentId":93,"publishedAt":94},{"thumbnail":106},{"ext":82,"url":83,"hash":84,"mime":85,"name":86,"path":18,"size":87,"width":52,"height":88},[108,109],{"__component":97,"id":98,"title":99,"aside":18,"postType":100,"limit":101},{"__component":110,"id":111,"titleLeft":112,"callToActionTextLeft":113,"callToActionLinkUrlLeft":114,"titleRight":115,"callToActionTextRight":116,"callToActionLinkUrlRight":117},"call-to-action.double",235,"Heb je een Power Platform expert nodig?","Neem contact op voor de mogelijkheden","/contact","Zoek je een nieuwe uitdaging?","Bekijk onze vacatures","/word-onze-collega/vacatures",[119,127,132,136,141],{"__component":120,"id":121,"title":122,"subTitle":18,"content":123,"callToActionText":124,"callToActionLink":114,"colorStyle":125,"showAsides":126},"global.alternating-page-section",16,"Power Platform governance: de balans tussen beveiliging en innovatie","Het is belangrijk om een balans te vinden tussen beveiliging en innovatie binnen jouw organisatie. Hoewel governance noodzakelijk is, moeten je medewerkers en teams de ruimte krijgen om waarde te creëren voor zowel henzelf als de onderneming.\n\nOnze Power Platform-specialisten staan klaar om je te adviseren over de diverse mogelijkheden. We begeleiden je tijdens het ontwikkelen en implementeren van een effectieve governance- en omgevingsstrategie, zodat je het beste uit het Microsoft Power Platform kunt halen.","Wil je meer weten? Neem contact met ons op.","Sugar Glaze",false,{"__component":120,"id":128,"title":129,"subTitle":18,"content":130,"callToActionText":18,"callToActionLink":18,"colorStyle":131,"showAsides":126},17,"Snel maatwerktoepassingen creëren met het Power Platform","Het Power Platform is de ideale oplossing om je verouderde processen en applicaties te stroomlijnen met slimme apps, efficiënte werkstromen en geavanceerde, op maat gemaakte formulieren.\n\nOnze specialisten staan klaar om je te adviseren over de vele mogelijkheden. Heb je meer ondersteuning nodig bij het ontwikkelen van je toepassing? Onze ervaren developers ontwikkelen de toepassing volledig voor je.","White",{"__component":120,"id":133,"title":134,"subTitle":18,"content":135,"callToActionText":18,"callToActionLink":18,"colorStyle":125,"showAsides":126},18,"Power Platform staat aan, wat nu?","Het Power Platform wordt al gebruikt in jouw organisatie. Een aantal enthousiaste collega's hebben al mooie apps gemaakt en je staat op het punt om het Power Platform in te zetten voor bedrijfskritische processen. Maar je weet niet precies hoe je dit het beste kunt aanpakken.\n\nWij begeleiden je in dit proces en samen bepalen we de \"next steps\". Onze architecten voeren een volledige omgevings- en securitycheck uit, wat resulteert in een omgevingsstrategie, governance, en een ontwikkel- en adoptieplan.",{"__component":120,"id":137,"title":138,"subTitle":18,"content":139,"callToActionText":140,"callToActionLink":114,"colorStyle":131,"showAsides":126},19,"Is jouw omgeving veilig en secure?","Onze omgevings- en securitycheck geeft je een helder beeld van de huidige status van je omgeving en laat zien wat je nog kunt doen om toepassingen nog veiliger en consistenter te ontwikkelen.","Wil je de check laten doen?",{"__component":142,"id":143,"title":144,"callToActionText":145,"callToActionLinkUrl":146,"body":18},"call-to-action.single",99,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Stork","/klantcases/stork-focust-op-citizen-development-met-het-microsoft-power-platform",{"id":148,"metaTitle":149,"metaDescription":150,"structuredData":151},26,"Power Platform specialisten – ShareValue helpt vooruit","Haal meer uit Power Apps, Automate en Power BI. Wij helpen bij strategie, ontwikkeling en beheer van jouw Power Platform-omgeving.",{"url":152,"@type":153,"@context":154,"provider":155,"areaServed":159,"description":162,"serviceType":163},"https://www.sharevalue.nl/wat-we-doen/power-platform","Service","https://schema.org",{"url":156,"name":157,"@type":158},"https://www.sharevalue.nl","ShareValue","Organization",{"name":160,"@type":161},"Nederland","Country","ShareValue helpt organisaties om Power Platform optimaal in te zetten. Denk aan Power Apps, Power Automate en Power BI. We bieden begeleiding bij strategie, governance, ontwikkeling en beheer.","Power Platform consultancy",{"__component":110,"id":111,"titleLeft":112,"callToActionTextLeft":113,"callToActionLinkUrlLeft":114,"titleRight":115,"callToActionTextRight":116,"callToActionLinkUrlRight":117,"iconUrlLeft":165,"iconUrlRight":178},{"id":166,"name":167,"alternativeText":18,"caption":18,"width":168,"height":169,"formats":18,"hash":170,"ext":171,"mime":172,"size":173,"url":174,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":175,"updatedAt":176,"documentId":177,"publishedAt":94},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":179,"name":180,"alternativeText":18,"caption":18,"width":169,"height":169,"formats":18,"hash":181,"ext":171,"mime":172,"size":182,"url":183,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":184,"updatedAt":185,"documentId":186,"publishedAt":94},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",[188,225,259,290,320],{"__component":120,"id":121,"title":122,"subTitle":18,"content":123,"callToActionText":124,"callToActionLink":114,"colorStyle":125,"showAsides":126,"imageUrl":189},{"id":190,"name":191,"alternativeText":18,"caption":18,"width":192,"height":193,"formats":194,"hash":220,