3bc3","small_security check.jpg",29.41,{"ext":23,"url":306,"hash":307,"mime":26,"name":308,"path":18,"size":309,"width":44,"height":248},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":311,"hash":312,"mime":26,"name":313,"path":18,"size":314,"width":111,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":142,"id":143,"title":144,"callToActionText":145,"callToActionLinkUrl":146,"body":18,"imageUrl":321},{"id":166,"name":167,"alternativeText":18,"caption":18,"width":168,"height":169,"formats":18,"hash":170,"ext":171,"mime":172,"size":173,"url":174,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":175,"updatedAt":176,"documentId":177,"publishedAt":94},{"id":148,"metaTitle":149,"metaDescription":150,"structuredData":323,"metaImage":18,"metaSocial":326},{"url":152,"@type":153,"@context":154,"provider":324,"areaServed":325,"description":162,"serviceType":163},{"url":156,"name":157,"@type":158},{"name":160,"@type":161},[],{"id":328,"name":329,"jobTitle":330,"about":18,"createdAt":331,"updatedAt":332,"publishedAt":333,"documentId":334,"image":335,"contactOptions":352},10,"Daan","Consultant","2023-08-18T08:37:46.063Z","2024-03-04T15:16:58.040Z","2023-08-18T08:37:44.938Z","rxdxqagbl0aor3g5ixct15eu",{"id":336,"name":337,"alternativeText":18,"caption":18,"width":338,"height":339,"formats":340,"hash":347,"ext":82,"mime":85,"size":348,"url":349,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":350,"updatedAt":350,"documentId":351,"publishedAt":94},543,"Daan websitefoto.png",278,326,{"thumbnail":341},{"ext":82,"url":342,"hash":343,"mime":85,"name":344,"path":18,"size":345,"width":346,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Daan_websitefoto_531915d0a7.png","thumbnail_Daan_websitefoto_531915d0a7","thumbnail_Daan websitefoto.png",21.05,133,"Daan_websitefoto_531915d0a7",24.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/Daan_websitefoto_531915d0a7.png","2024-03-04T15:16:26.930Z","e5jw9x1ytw0dff2euouwxelr",[],[354,358,361,364,367,370,373,376,379,382,385,405],{"__component":355,"id":356,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":357,"introductionText":18},"global.pagesection",4647,"## Het verschil in ontwerpvrijheid\nWanneer je een nieuwe app aan wilt maken in het Power Platform zie je eigenlijk al 2 verschillende opties om met een lege app te beginnen:\n- Start with data\n- Start with a page design\nHierbij wordt het grote verschil eigenlijk al beschreven, waar Model-driven apps voornamelijk data-gedreven zijn en minder ontwerpvrijheid bieden kan je binnen een Canvas app met een pagina-design starten en vanuit daar de app vrij opmaken.",{"__component":355,"id":359,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":360,"introductionText":18},4648,"## Model-driven app\nAls je een nieuwe Model-driven app aanmaakt en een nieuwe pagina wil aanmaken krijg je de volgende opties:\n![Afbeelding1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding1_25b6102798.png)\n\nZoals in de afbeelding links te zien is heb je 5 verschillende opties om pagina’s toe te voegen aan de app. Om data aan te maken, lezen, bewerken of verwijderen maak je een pagina op basis van een Dataverse-tabel. Deze pagina maakt gebruik van Views en Forms die zijn aangemaakt voor de gekozen tabel. Om dit aan te passen zul je binnen de tabel de Views en Forms moeten bewerken, waarna de verschillen zichtbaar zullen worden in de Dataverse-pagina. Na het toevoegen van de Dataverse-pagina staat er meteen een pagina die werkt op basis van de configuraties in de tabel. Voor het ontwerp hoef je verder niks toe te voegen. Je kan bijvoorbeeld kleuren, zoals te zien bij functie, instellen in de View van de tabel.\n\n![Afbeelding2.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding2_20f02b6310.png)",{"__component":355,"id":362,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":363,"introductionText":18},4649,"## Canvas app\nIn een Canvas app begin je met een lege pagina, waarbij je wel kan kiezen hoe het paginadesign gestructureerd is:\nVanuit een pagina kan je zelf knoppen, lijsten en formulieren toevoegen en deze koppelen met data. Hierbij is het wel noodzakelijk dit zelf te configureren vanuit de app. Hieronder zijn enkele opties zichtbaar die gekozen kunnen worden om toe te voegen.\n\n![Afbeelding3.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding3_5e0c68b649.png)\n![Afbeelding4.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding4_5d36c2d753.png)\n",{"__component":355,"id":365,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":366,"introductionText":18},4650,"## Het verschil in databrongebruik\nBinnen een Canvas app is het mogelijk om veel verschillende databronnen toe te voegen om mee te werken. Denk hierbij bijvoorbeeld aan SharePoint, Teams, Outlook, Entra ID, maar ook Dataverse kan toegevoegd worden aan een Canvas app. Dit maakt het binnen een Canvas app dus mogelijk om met meerdere databronnen tegelijk te werken.\n![Afbeelding5.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding5_247b27dc6d.png)\n\nBinnen een Model-driven app is de databron altijd Dataverse. Op het moment dat je toch met andere data zou willen werken, zal dit binnen een Dataverse-tabel (Virtual Table) met een Power Automate flow (Data syncen van/naar Dataverse) opgelost moeten worden. \nEen andere optie om met meerdere databronnen te werken in een Model-driven app is om een custom page toe te voegen: \nEen custom page is eigenlijk een Canvas app, die aangemaakt en toegevoegd wordt aan de Model-driven app. Op die manier kunnen dus beide opties samen geïmplementeerd worden.\n![Afbeelding6.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding6_022dddfcc0.png)\n",{"__component":355,"id":368,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":369,"introductionText":18},4651,"## De licentieverschillen uitgelegd\nDe benodigde licentie hangt af van de gebruikte databronnen. Omdat Model-driven apps altijd gebruik maken van Dataverse, is voor een Model-driven app altijd een Power Apps Premium licentie nodig.\nBij een Canvas app is het afhankelijk van welke databronnen gebruikt gemaakt wordt. Op het moment dat er gebruik gemaakt wordt van een standaard connector is een E3 of E5 licentie voldoende, maar wanneer er gebruikt wordt gemaakt van een Premium Connector heeft de gebruiker een Power Apps Premium Licentie nodig.\n![Afbeelding7.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding7_a88dca6a1d.png)",{"__component":355,"id":371,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":372,"introductionText":18},4652,"## Wat betekent dit in de praktijk?\nNu de theorie is uitgelegd zal hieronder visueel worden weergegeven wat de verschillen zijn tussen de Model-driven en Canvas app in design. Ik heb voor deze blog een app gemaakt voor het beheren van medewerkers. Ik heb voor de Model-driven app en de Canvas app dezelfde bronnen gebruikt.\n\n### Model-driven app\nMedewerker overzicht:\n![Afbeelding8.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding8_194bf23fe3.png)\n\nMedewerker formulier:\n![Afbeelding9.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding9_43d382b37c.png)\n\nZoals in de afbeeldingen hierboven te zien is, zijn de opmaak en de knoppen praktisch hetzelfde in alle schermen en staat de data centraal.\n\n### Canvas app\nMedewerker overzicht:\n![Afbeelding10.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding10_8477916fde.png)\n\nMedewerker formulier:\n![Afbeelding11.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding11_10e2a8adeb.png)",{"__component":355,"id":374,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":375,"introductionText":18},4653,"## Wanneer kies je welke optie?\nEigenlijk is er dus geen eenduidig antwoord welk type app het beste gekozen kan worden. Dit is namelijk volledig afhankelijk van het gebruik van databronnen, de mate van ontwerpvrijheid die nodig is en de licentiekosten. Daarnaast kan er altijd gekozen worden voor een combinatie van beide apps, door een Custom Page toe te voegen aan de Model-driven app.\n",{"__component":355,"id":377,"title":18,"asideText":18,"underline":126,"centered":126,"blankAside":126,"aside":18,"content":378,"introductionText":18},4654,"## Aan de slag met Power Apps?\nOf het nu gaat om een kleine interne app of een complexe oplossing met meerdere databronnen en integraties: de juiste architectuurkeuze aan het begin maakt een groot verschil.\nOnze Power Platform consultants helpen organisaties met het ontwerpen en bouwen van Power Apps – van eerste idee tot volwassen applicatie.\n\nOverweeg je Power Apps in te zetten en wil je sparren over de beste aanpak?\nNeem gerust [contact](https://sharevalue.nl/contact) met ons op. We denken graag met je mee. \n",{"__component":380,"id":381,"title":18,"showBlankAside":126},"global.social-sharing",533,{"__component":383,"id":384,"name":329,"jobTitle":330},"strapi.author-card",417,{"__component":110,"id":386,"titleLeft":387,"callToActionTextLeft":388,"callToActionLinkUrlLeft":389,"titleRight":390,"callToActionTextRight":391,"callToActionLinkUrlRight":392,"iconUrlLeft":393,"iconUrlRight":404},629,"Heb je een Power Platform-expert nodig?","Neem contact met ons op","https://sharevalue.nl/contact","Werken in ons Power Platform-team?","Klik hier","https://sharevalue.nl/word-onze-collega/vacatures/expertise/power-platform",{"id":394,"name":395,"alternativeText":18,"caption":18,"width":396,"height":397,"formats":18,"hash":398,"ext":171,"mime":172,"size":399,"url":400,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":401,"updatedAt":402,"documentId":403,"publishedAt":94},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",{"id":166,"name":167,"alternativeText":18,"caption":18,"width":168,"height":169,"formats":18,"hash":170,"ext":171,"mime":172,"size":173,"url":174,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":175,"updatedAt":176,"documentId":177,"publishedAt":94},{"__component":97,"id":406,"title":407,"aside":18,"postType":408,"limit":101,"expertise":409},465,"Lees meer over Power Platform","blogs",[410],{"id":64,"title":65,"subTitle":66,"description":67,"shortDescription":68,"slug":69,"createdAt":70,"updatedAt":71,"publishedAt":72,"isCoreExpertise":73,"documentId":74,"image":411,"blocks":414,"midPageBlocks":421,"seo":452},{"id":76,"name":77,"alternativeText":18,"caption":18,"width":78,"height":79,"formats":412,"hash":89,"ext":82,"mime":85,"size":90,"url":91,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":92,"updatedAt":92,"documentId":93,"publishedAt":94},{"thumbnail":413},{"ext":82,"url":83,"hash":84,"mime":85,"name":86,"path":18,"size":87,"width":52,"height":88},[415,418],{"__component":97,"id":98,"title":99,"aside":18,"postType":100,"limit":101,"expertise":416},[417],{"id":64,"title":65,"subTitle":66,"description":67,"shortDescription":68,"slug":69,"createdAt":70,"updatedAt":71,"publishedAt":72,"isCoreExpertise":73,"documentId":74},{"__component":