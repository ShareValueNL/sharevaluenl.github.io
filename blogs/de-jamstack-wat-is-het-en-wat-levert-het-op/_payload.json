,"small":289,"medium":294,"thumbnail":299},{"ext":23,"url":285,"hash":286,"mime":182,"name":287,"path":18,"size":288,"width":29,"height":185},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_stack_fec3a2bfae.jpg","large_stack_fec3a2bfae","large_stack.jpg",95.19,{"ext":23,"url":290,"hash":291,"mime":182,"name":292,"path":18,"size":293,"width":36,"height":191},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_stack_fec3a2bfae.jpg","small_stack_fec3a2bfae","small_stack.jpg",29.21,{"ext":23,"url":295,"hash":296,"mime":182,"name":297,"path":18,"size":298,"width":30,"height":197},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_stack_fec3a2bfae.jpg","medium_stack_fec3a2bfae","medium_stack.jpg",58.57,{"ext":23,"url":300,"hash":301,"mime":182,"name":302,"path":18,"size":303,"width":203,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_stack_fec3a2bfae.jpg","thumbnail_stack_fec3a2bfae","thumbnail_stack.jpg",8.24,"stack_fec3a2bfae",143.32,"https://incredible-beef-2a6059b946.media.strapiapp.com/stack_fec3a2bfae.jpg","2024-08-08T08:26:50.506Z","2024-12-09T10:18:46.269Z","kpz9iiz9dr551k3umhmtwy3k",{"id":311,"title":312,"callToActionText":313,"callToActionLinkUrl":314,"body":18,"imageUrl":315,"__component":316},100,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Rovict","/klantcases/rovict-vernieuwt-leerlingadministratie-en-leerlingvolgsysteem-esis",{"id":145,"name":146,"alternativeText":18,"caption":18,"width":147,"height":148,"formats":18,"hash":149,"ext":150,"mime":151,"size":152,"url":153,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":154,"updatedAt":155,"documentId":156,"publishedAt":57,"focalPoint":18},"call-to-action.single",{"id":318,"title":319,"subTitle":320,"description":321,"shortDescription":322,"slug":323,"createdAt":324,"updatedAt":325,"publishedAt":326,"isCoreExpertise":327,"documentId":328,"image":329,"seo":343,"blocks":358,"midPageBlocks":398},10,"Development","Maatwerkoplossingen voor ieder vraagstuk","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. Van gebruiksvriendelijke interfaces tot krachtige Back-End-architecturen: wij hebben de kennis en ervaring om jouw project tot een succes te maken.","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. ","development","2024-12-13T12:15:40.484Z","2025-04-11T13:13:55.384Z","2024-12-13T12:15:42.976Z",true,"lpzfadokpxn5sdnx9czcdg47",{"id":330,"name":331,"alternativeText":18,"caption":18,"width":109,"height":110,"formats":332,"hash":338,"ext":113,"mime":116,"size":95,"url":339,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":340,"updatedAt":341,"documentId":342,"publishedAt":57,"focalPoint":18},950,"Logo Development 2025 web.png",{"thumbnail":333},{"ext":113,"url":334,"hash":335,"mime":116,"name":336,"path":18,"size":337,"width":119,"height":120},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Development_2025_web_d7711df072.png","thumbnail_Logo_Development_2025_web_d7711df072","thumbnail_Logo Development 2025 web.png",8.58,"Logo_Development_2025_web_d7711df072","https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Development_2025_web_d7711df072.png","2024-12-17T15:02:47.479Z","2024-12-19T08:35:22.054Z","okwfs117fps338v5fj5dnrpb",{"id":344,"metaTitle":345,"metaDescription":346,"structuredData":347,"metaImage":18,"metaSocial":357},27,"Maatwerk software & integraties – ShareValue Development","Van webapps tot koppelingen: onze developers bouwen slimme oplossingen die passen bij jouw Microsoft-omgeving.",{"url":348,"@type":349,"@context":67,"provider":350,"areaServed":352,"description":355,"serviceType":356},"https://www.sharevalue.nl/wat-we-doen/development","Service",{"url":351,"name":73,"@type":74},"https://www.sharevalue.nl",{"name":353,"@type":354},"Nederland","Country","Onze developers realiseren maatwerkoplossingen binnen Microsoft-omgevingen. Denk aan webapplicaties, API-integraties, extensies voor Microsoft 365 en koppelingen met externe systemen. Technisch sterk én begrijpelijk ingericht.","Maatwerk softwareontwikkeling en integraties",[],[359,374],{"id":360,"title":361,"aside":18,"postType":131,"limit":132,"expertise":362,"__component":135},179,"Lees meer over Development",[363,364,365],{"id":318,"title":319,"subTitle":320,"description":321,"shortDescription":322,"slug":323,"createdAt":324,"updatedAt":325,"publishedAt":326,"isCoreExpertise":327,"documentId":328},{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105},{"id":132,"title":366,"subTitle":320,"description":367,"shortDescription":368,"slug":369,"createdAt":370,"updatedAt":371,"publishedAt":372,"isCoreExpertise":104,"documentId":373},"Microsoft .NET","Ons team van .NET-experts staat niet alleen klaar om onze klanten te ondersteunen bij diverse implementatie uitdagingen, maar we zijn ook gespecialiseerd in het testen van applicaties op verschillende niveaus, zoals unit tests, integratietests en acceptatietests. We streven naar uitmuntende testdekking om de stabiliteit en betrouwbaarheid van de applicaties te waarborgen.\n\nDaarnaast zijn we bedreven in het gebruik van verschillende Azure-services om schaalbare en veilige oplossingen te bieden aan onze klanten. Zo bieden we met Azure DevOps krachtige tools voor het beheren van de ontwikkeling, het automatiseren van tests en het geautomatiseerd uitrollen naar acceptatie- of productieomgevingen met CI/CD-pipelines.\n\nHet samenwerken met onze klanten staat centraal in ons werk, en we denken proactief mee om samen de meest optimale oplossingen te realiseren.","In de praktijk komen de .NET developers van ShareValue terecht in allerlei verschillende branches met uiteenlopende technische uitdagingen.","dotnet","2023-08-17T11:19:57.991Z","2024-12-13T12:16:04.480Z","2023-08-17T11:22:08.050Z","v9pl553hsjk98esvs5gzoso3",{"id":375,"titleLeft":376,"callToActionTextLeft":139,"callToActionLinkUrlLeft":140,"titleRight":141,"callToActionTextRight":142,"callToActionLinkUrlRight":143,"iconUrlLeft":377,"iconUrlRight":388,"__component":166},251,"Heb je een Developer nodig?",{"id":378,"name":379,"alternativeText":18,"caption":18,"width":380,"height":381,"formats":18,"hash":382,"ext":150,"mime":151,"size":383,"url":384,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":385,"updatedAt":386,"documentId":387,"publishedAt":57,"focalPoint":18},7,"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":389,"name":390,"alternativeText":18,"caption":18,"width":391,"height":381,"formats":18,"hash":392,"ext":150,"mime":151,"size":393,"url":394,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":395,"updatedAt":396,"documentId":397,"publishedAt":57,"focalPoint":18},372,"magnifier.svg",49,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",[399,423,456,466,500],{"id":400,"title":401,"subTitle":18,"content":402,"callToActionText":18,"callToActionLink":18,"colorStyle":403,"showAsides":104,"imageUrl":404,"__component":209},47,"Optimale gebruikerservaring","Een goede Front-End is meer dan alleen een aantrekkelijke interface; het vormt de schakel tussen technologie en eindgebruiker. Onze Developers combineren hun kennis van frameworks zoals React, Angular en Vue met ervaring in geavanceerde technologieën zoals GraphQL en CI/CD pipelines. Dit stelt ons in staat om interactieve, intuïtieve en betrouwbare applicaties te ontwikkelen die voldoen aan de hoogste standaarden.\n\nWij werken nauw samen met UX-designers om via design patterns en design tokens een naadloze integratie van ontwerp naar functionaliteit te realiseren. Dankzij regelmatige LevelUp-sessies, interne projecten en kennisdeling blijven onze Front-End specialisten altijd up-to-date.","Sugar Glaze",{"id":405,"name":175,"alternativeText":18,"caption":18,"width":176,"height":177,"formats":406,"hash":419,"ext":23,"mime":182,"size":205,"url":420,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":421,"updatedAt":421,"documentId":422,"publishedAt":57,"focalPoint":18},904,{"large":407,"small":410,"medium":413,"thumbnail":416},{"ext":23,"url":408,"hash":409,"mime":182,"name":183,"path":18,"size":184,"width":29,"height":185},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_development_6e5abdca44.jpg","large_development_6e5abdca44",{"ext":23,"url":411,"hash":412,"mime":182,"name":189,"path":18,"size":190,"width":36,"height":191},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_development_6e5abdca44.jpg","small_development_6e5abdca44",{"ext":23,"url":414,"hash":415,"mime":182,"name":195,"path":18,"size":196,"width":30,"height":197},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_development_6e5abdca44.jpg","medium_development_6e5abdca44",{"ext":23,"url":417,"hash":418,"mime":182,"name":201,"path":18,"size":202,"width":203,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_development_6e5abdca44.jpg","thumbnail_development_6e5abdca44","development_6e5abdca44","https://incredible-beef-2a6059b946.media.strapiapp.com/development_6e5abdca44.jpg","2024-12-13T12:36:11.969Z","qqi9wubjpzs8w6daj98mtc7a",{"id":391,"title":424,"subTitle":18,"content":425,"callToActionText":18,"callToActionLink":18,"colorStyle":426,"showAsides":104,"imageUrl":427,"__component":209},"Betrouwbaarheid en schaalbaarheid","Voor robuuste Back-End-oplossingen vertrouwen we op onze kennis van .NET. Of het nu gaat om het bouwen van nieuwe applicaties, het onderhouden van bestaande software of het implementeren van geavanceerde authenticatie- en autorisatiesystemen: ons team levert maatwerk dat aansluit bij de specifieke wensen en behoeften van jouw organisatie.\n\nHierbij maken we onder andere gebruik van onze kennis van Azure-services zoals Function Apps, Service Bus en App Services, maar ook tools als Docker en Kubernetes om veilige, schaalbare oplossingen te realiseren.\n\nOnze focus op grondige tests – van unit tests tot integratietests – garandeert stabiliteit en betrouwbaarheid.","White",{"id":428,"name":429,"alternativeText":18,"caption":18,"width":176,"height":177,"formats":430,"hash":451,"ext":23,"mime":182,"size":452,"url":453,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":454,"updatedAt":454,"documentId":455,"publishedAt":57,"focalPoint":18},791,"service bus.jpg",{"large":431,"small":436,"medium":441,"thumbnail":446},{"ext":23,"url":432,"hash":433,"mime":182,"name":434,"path":18,"size":435,"width":29,"height":185},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_service_bus_2b48e3a7cc.jpg","large_service_bus_2b48e3a7cc","large_service bus.jpg",82.82,{"ext":23,"url":437,"hash":438,"mime":182,"name":439,"path":18,"size":440,"width":36,"height":191},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_service_bus_2b48e3a7cc.jpg","small_service_bus_2b48e3a7cc","small_service bus.jpg",29.35,{"ext":23,"url":442,"hash":443,"mime":182,"name":444,"path":18,"size":445,"width":30,"height":197},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_service_bus_2b48e3a7cc.jpg","medium_service_bus_2b48e3a7cc","medium_service bus.jpg",54.72,{"ext":23,"url":447,"hash":448,"mime":182,"name":449,"path":18,"size":450,"width":203,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_service_bus_2b48e3a7cc.jpg","thumbnail_service_bus_2b48e3a7cc","thumbnail_service bus.jpg",8.71,"service_bus_2b48e3a7cc",117.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/service_bus_2b48e3a7cc.jpg","2024-08-09T08:35:35.231Z","rbpawsulv6vrsistrk2yupwg",{"id":457,"title":458,"subTitle":18,"content":459,"callToActionText":18,"callToActionLink":18,"colorStyle":403,"showAsides":104,"imageUrl":460,"__component":209},50,"Full-Stack mogelijkheden","Wat ons uniek maakt, is onze combinatie van Front-End en .NET-expertise. Onze Developers zijn niet alleen gespecialiseerd in het creëren van intuïtieve interfaces, maar beheersen ook de complexiteit van Back-End-architectuur en Azure-integraties. Dit maakt hen volwaardige Full-Stack Developers die moeiteloos schakelen tussen de verschillende onderdelen van jouw project.",{"id":281,"name":282,"alternativeText":18,"caption":18,"width":176,"height":177,"formats":461,"hash":304,"ext":23,"mime":182,"size":305,"url":306,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":307,"updatedAt":308,"documentId":309,"publishedAt":57,"focalPoint":18},{"large":462,"small":463,"medium":464,"thumbnail":465},{"ext":23,"url":285,"hash":286,"mime":182,"name":287,"path":18,"size":288,"width":29,"height":185},{"ext":23,"url":290,"hash":291,"mime":182,"name":292,"path":18,"size":293,"width":36,"height":191},{"ext":23,"url":295,"hash":296,"mime":182,"name":297,"path":18,"size":298,"width":30,"height":197},{"ext":23,"url":300,"hash":301,"mime":182,"name":302,"path":18,"size":303,"width":203,"height":50},{"id":467,"title":468,"subTitle":18,"content":469,"callToActionText":470,"callToActionLink":140,"colorStyle":426,"showAsides":104,"imageUrl":471,"__component":209},48,"Samen naar succes","Onze aanpak is erop gericht om samen met jou het optimale resultaat te behalen. Door proactief mee te denken en onze kennis te delen, zorgen we ervoor dat jouw project voldoet aan de hoogste standaarden van gebruiksvriendelijkheid, betrouwbaarheid en veiligheid. Of het nu gaat om een tijdelijke versterking van je team of volledige projectondersteuning: ons Development-team staat voor je klaar.\n\nOntdek wat wij voor jouw project kunnen betekenen."," Neem contact met ons op voor meer informatie!",{"id":472,"name":473,"alternativeText":18,"caption":18,"width":176,"height":177,"formats":474,"hash":495,"ext":23,"mime":182,"size":496,"url":497,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":498,"updatedAt":498,"documentId":499,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":475,"small":480,"medium":485,"thumbnail":490},{"ext":23,"url":476,"hash":477,"mime":182,"name":478,"path":18,"size":479,"width":29,"height":185},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":481,"hash":482,"mime":182,"name":483,"path":18,"size":484,"width":36,"height":191},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":486,"hash":487,"mime":182,"name":488,"path":18,"size":489,"width":30,"height":197},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":491,"hash":492,"mime":182,"name":493,"path":18,"size":494,"width":203,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":501,"title":502,"callToActionText":313,"callToActionLinkUrl":503,"body":18,"imageUrl":504,"__component":316},103,"Wil je weten wat onze collega’s allemaal kunnen?","https://www.sharevalue.nl/klantcases/rovict-vernieuwt-leerlingadministratie-en-leerlingvolgsysteem-esis",{"id":145,"name":146,"alternativeText":18,"caption":18,"width":147,"height":148,"formats":18,"hash":149,"ext":150,"mime":151,"size":152,"url":153,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":154,"updatedAt":155,"documentId":156,"publishedAt":57,"focalPoint":18},[506,511,515,518,522,526,530,534,538,542,545,548,551,597],{"id":507,"title":18,"asideText":508,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":509,"introductionText":18,"__component":510},1149,"","## Wat is een JAMstack?\n\nDe JAM in JAMstack is een afkorting die staat voor:\n\n*   JavaScript – dit gedeelte draagt zorg voor het interactieve gedeelte van een site of applicatie: eigenlijk alles wat met een modern JavaScript framework kan valt binnen deze categorie\n*   API’s - oftewel een “Application Programming Interface”. API’s maken het mogelijk om te communiceren met externe systemen of services\n*   Markup – de markup (bekend van de M uit HTML) staat op de opmaak van een pagina. Binnen JAMstack worden hier meestal de templates mee bedoeld die via JavaScript gevuld worden met content\n\nDit stelt Front-End Developers in staat om in betrekkelijk korte tijd een project op te zetten, zonder dat hij of zij hoeft te wachten op een Back-End om te communiceren.\n\nIk leg het uit aan de hand van een aantal schema’s:","global.pagesection",{"id":512,"title":18,"asideText":513,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":514,"introductionText":18,"__component":510},1150,"Schema: hoe werkt JAMstack?","![](https://www.sharevalue.nl/images/sharevalue/blogs/schema_JAMstack.png)",{"id":516,"title":18,"asideText":508,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":517,"introductionText":18,"__component":510},1151,"Zoals te zien is in de modellen, is de JAMstack veel platter dan een traditionele stack. Dit komt doordat de meeste lagen geabstraheerd zijn in losse calls, waardoor er niet met één Back-End wordt gecommuniceerd, maar middels meerdere software-as-a-service-oplossingen.\n\n### Wacht, meerdere connecties is sneller dan één ouderwetse architectuur?\n\nJa, er is een verschil tussen de laadtijden bij rendering en bij de laadtijden bij compiling:\n\nDoordat alle verschillende onderdelen gegenereerd worden én worden geserveerd van een CDN, komen alle onderdelen veel sneller binnen.",{"id":519,"title":18,"asideText":520,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":521,"introductionText":18,"__component":510},1152,"Demo!","## Voorbeeld: JAMdemo\n\nIk heb een demo gebouwd in GatsbyJS en React met Sanity als Content Management System en Netlify als CDN (Content Delivery Network). Dit geeft het volgende schema:\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/jamstack_onderdelen.png)",{"id":523,"title":18,"asideText":524,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":525,"introductionText":18,"__component":510},1153,"JavaScript","### De J van JavaScript\n\nMijn startpunt is [GatsbyJS](https://www.gatsbyjs.org/); een Static site generator die gebouwd is op ReactJS. Met Gatsby kun je websites en applicaties bouwen waarbij de content overal vandaan kan komen: dit kunnen markdown-files zijn in een map binnen je project, maar ook content die via API’s kunnen worden ontsloten. Dat laatste is waar ik voor gekozen heb voor mijn demo.",{"id":527,"title":18,"asideText":528,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":529,"introductionText":18,"__component":510},1155,"API’s","### De A van API’s\n\nDe content schrijf ik in [Sanity](https://www.sanity.io/), een Headless CMS (oftewel een CMS zonder voorkant). Bij Sanity kun je een account aanmaken en vervolgens je eigen data-model opzetten via een interface. Uiteraard zijn er ook tal van start-templates beschikbaar. Zodra je je content geschreven hebt, kunnen we Gatsby en Sanity aan elkaar knopen.",{"id":531,"title":18,"asideText":532,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":533,"introductionText":18,"__component":510},1154,"Markup","### De M van Markup\n\nDe markup in mijn demo komt uit Gatsby; Hierin bouw je de templates die gevuld worden met de content uit Sanity.\n\nOp deze manier was ik in staat om in korte tijd een site te bouwen.",{"id":535,"title":18,"asideText":536,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":537,"introductionText":18,"__component":510},1156,"Versiebeheer","## Versiebeheer en Continuous Deployment\n\nUiteraard is er versiebeheer toegepast voor dit project. [Het staat op GitHub](https://github.com/johanbijlsma/JAMdemo) en elke keer als er nieuwe code wordt weggeschreven naar de Github repo, wordt het project gebouwd en gedeployed door Netlify (de CDN en Host van dit project).\n\nDe demo site staat live op deze locatie: [https://jams-jams-jams.netlify.com/](https://jams-jams-jams.netlify.com/)",{"id":539,"title":18,"asideText":540,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":541,"introductionText":18,"__component":510},1157,"Demo-website","![](https://www.sharevalue.nl/images/sharevalue/blogs/demo_JAMstack.jpg)",{"id":543,"title":18,"asideText":508,"underline":104,"centered":104,"blankAside":104,"aside":18,"content":544,"introductionText":18,"__component":510},1158,"## Conclusie\n\nDe JAMstack biedt veel nieuwe mogelijkheden. Door een kortere time-to-market en het combineren van diverse services, biedt dit veel kansen voor bijvoorbeeld ontwikkelteams met minder of geen Back-End capaciteit.\n\nDe Front-Enders bij ShareValue vinden de JAMstack een mooie nieuwe ontwikkeling die we graag verder onderzoeken. Zo gaan meerdere Developers het aankomende JAMstack\\_conf 2019 in London bijwonen, om zo nog meer te weten te komen over deze nieuwe manier van bouwen. Kan Johan of een van zijn Front-End-collega’s jou helpen bij het opzetten van jouw JAMstack-oplossing? [Laat het ons weten](/contact), we helpen graag!",{"id":546,"title":18,"showBlankAside":327,"__component":547},127,"global.social-sharing",{"id":549,"name":18,"jobTitle":18,"__component":550},85,"strapi.author-card",{"id":552,"title":553,"aside":18,"postType":131,"limit":132,"expertise":554,"__component":135},96,"Lees ook onze andere berichten",[555],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105,"image":556,"seo":18,"blocks":559,"midPageBlocks":566},{"id":107,"name":108,"alternativeText":18,"caption":18,"width":109,"height":110,"formats":557,"hash":121,"ext":113,"mime":116,"size":122,"url":123,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":124,"updatedAt":124,"documentId":125,"publishedAt":57,"focalPoint":18},{"thumbnail":558},{"ext":113,"url":114,"hash":115,"mime":116,"name":117,"path":18,"size":118,"width":119,"height":120},[560,563],{"id":128,"title":129,"aside":130,"postType":131,"limit":132,"expertise":561,"__component":135},[562],{"id":95,"title":96,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105},{"id":137,"titleLeft":138,"callToActionTextLeft":139,"callToActionLinkUrlLeft":140,"titleRight":141,"callToActionTextRight":142,"callToActionLinkUrlRight":143,"iconUrlLeft":564,"iconUrlRight":565,"__component":166},{"id":145,"name":146,"alternativeText":18,"caption":18,"width":147,"height":148,"formats":18,"hash":149,"ext":150,"mime":151,"size":152,"url":153,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":154,"updatedAt":155,"documentId":156,"publishedAt":57,"focalPoint":18},{"id":158,"name":159,"alternativeText":18,"caption":18,"width":148,"height":148,"formats":18,"hash":160,"ext":150,"mime":151,"size":161,"url":162,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":163,"updatedAt":164,"documentId":