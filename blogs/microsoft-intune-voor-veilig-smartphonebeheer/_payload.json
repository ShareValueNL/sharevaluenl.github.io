[{"data":1,"prerenderedAt":487},["ShallowReactive",2],{"collection-blogs-1118471987":3,"_apollo:default":486},{"data":4,"meta":483},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"seo":61,"expertises":121,"author":324,"blocks":389},727,"Microsoft Intune voor veilig smartphonebeheer","Microsoft Intune wordt steeds vaker gebruikt binnen organisaties om mobiele apparaten zoals smartphones en tablets te beheren. Dit geldt zowel voor zakelijke toestellen als voor privételefoons die gebruikt worden voor werk (BYOD: Bring Your Own Device). In de praktijk zorgt dit vaak voor uitdagingen op het gebied van beveiliging, controle en gebruiksgemak. Microsoft Intune biedt hiervoor een centrale beheeroplossing.\nIn deze blog leg ik uit wat Microsoft Intune is, waarom het belangrijk is en hoe het in de praktijk gebruikt kan worden binnen een organisatie.","microsoft-intune-voor-veilig-smartphonebeheer","2026-07-13T12:02:13.776Z","2026-07-13T12:24:19.603Z","2026-07-13T12:24:19.816Z","2026-07-13","f75727xrah4rb6wwym2cnrb5",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":55,"ext":23,"mime":26,"size":56,"url":57,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":59,"updatedAt":59,"documentId":60,"publishedAt":59,"focalPoint":18},1485,"Blog hero Intune voor beheer smartphones.jpg",null,1280,500,{"large":22,"small":32,"medium":39,"thumbnail":47},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30,"sizeInBytes":31},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Blog_hero_Intune_voor_beheer_smartphones_33dec036d6.jpg","large_Blog_hero_Intune_voor_beheer_smartphones_33dec036d6","image/jpeg","large_Blog hero Intune voor beheer smartphones.jpg",31.74,1000,391,31742,{"ext":23,"url":33,"hash":34,"mime":26,"name":35,"path":18,"size":36,"width":20,"height":37,"sizeInBytes":38},"https://inc