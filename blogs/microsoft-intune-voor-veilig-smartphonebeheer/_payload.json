t":18},{"id":199,"name":200,"alternativeText":18,"caption":18,"width":189,"height":189,"formats":18,"hash":201,"ext":191,"mime":192,"size":202,"url":203,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":204,"updatedAt":205,"documentId":206,"publishedAt":153,"focalPoint":18},[366,373,380,387],{"id":210,"title":211,"subTitle":18,"content":212,"callToActionText":213,"callToActionLink":182,"colorStyle":214,"showAsides":215,"imageUrl":367,"__component":250},{"id":217,"name":218,"alternativeText":18,"caption":18,"width":19,"height":219,"formats":368,"hash":245,"ext":23,"mime":26,"size":246,"url":247,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":248,"updatedAt":248,"documentId":249,"publishedAt":153,"focalPoint":18},{"large":369,"small":370,"medium":371,"thumbnail":372},{"ext":23,"url":222,"hash":223,"mime":26,"name":224,"path":18,"size":225,"width":29,"height":62},{"ext":23,"url":227,"hash":228,"mime":26,"name":229,"path":18,"size":230,"width":20,"height":231},{"ext":23,"url":233,"hash":234,"mime":26,"name":235,"path":18,"size":236,"width":44,"height":237},{"ext":23,"url":239,"hash":240,"mime":26,"name":241,"path":18,"size":242,"width":243,"height":244},{"id":252,"title":253,"subTitle":18,"content":254,"callToActionText":18,"callToActionLink":18,"colorStyle":255,"showAsides":215,"imageUrl":374,"__component":250},{"id":257,"name":258,"alternativeText":18,"caption":18,"width":19,"height":219,"formats":375,"hash":280,"ext":23,"mime":26,"size":281,"url":282,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":283,"updatedAt":283,"documentId":284,"publishedAt":153,"focalPoint":18},{"large":376,"small":377,"medium":378,"thumbnail":379},{"ext":23,"url":261,"hash":262,"mime":26,"name":263,"path":18,"size":264,"width":29,"height":62},{"ext":23,"url":266,"hash":267,"mime":26,"name":268,"path":18,"size":269,"width":20,"height":231},{"ext":23,"url":271,"hash":272,"mime":26,"name":273,"path":18,"size":274,"width":44,"height":237},{"ext":23,"url":276,"hash":277,"mime":26,"name":278,"path":18,"size":279,"width":243,"height":244},{"id":155,"title":286,"subTitle":18,"content":287,"callToActionText":18,"callToActionLink":18,"colorStyle":214,"showAsides":215,"imageUrl":381,"__component":250},{"id":289,"name":290,"alternativeText":18,"caption":18,"width":19,"height":219,"formats":382,"hash":312,"ext":23,"mime":26,"size":313,"url":314,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":315,"updatedAt":315,"documentId":316,"publishedAt":153,"focalPoint":18},{"large":383,"small":384,"medium":385,"thumbnail":386},{"ext":23,"url":293,"hash":294,"mime":26,"name":295,"path":18,"size":296,"width":29,"height":62},{"ext":23,"url":298,"hash":299,"mime":26,"name":300,"path":18,"size":301,"width":20,"height":231},{"ext":23,"url":303,"hash":304,"mime":26,"name":305,"path":18,"size":306,"width":44,"height":237},{"ext":23,"url":308,"hash":309,"mime":26,"name":310,"path":18,"size":311,"width":243,"height":244},{"id":318,"title":319,"callToActionText":320,"callToActionLinkUrl":321,"body":18,"imageUrl":388,"__component":323},{"id":111,"name":187,"alternativeText":18,"caption":18,"width":188,"height":189,"formats":18,"hash":190,"ext":191,"mime":192,"size":193,"url":194,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":195,"updatedAt":196,"documentId":197,"publishedAt":153,"focalPoint":18},[390,394,397,400,403,406,409,412,415,418,421,439],{"id":391,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":392,"introductionText":18,"__component":393},5253,"## Voorbeeldsituatie\nBinnen veel bedrijven worden smartphones gebruikt om te communiceren via e-mail, Teams en andere werkapplicaties. Vaak ontstaat er een mix van zakelijke toestellen en privétoestellen van medewerkers.\n\nEen voorbeeldsituatie:\nEen organisatie met 50 medewerkers laat iedereen werken met mobiele toegang tot bedrijfsdata. Een deel heeft een zakelijke telefoon, maar een groot deel gebruikt ook hun eigen toestel. \nZonder goed beheer ontstaat al snel onoverzichtelijkheid:\n- Bedrijfsdata staat verspreid over verschillende apparaten\n- Er is geen controle over beveiligingsinstellingen\n- Bij verlies van een toestel is er risico op datalekken\n- IT heeft weinig inzicht in gebruik en compliance\n\nIn deze situatie wordt Microsoft Intune ingezet om structuur en beveiliging aan te brengen.","global.pagesection",{"id":395,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":396,"introductionText":18,"__component":393},5254,"## Wat is Microsoft Intune?\n\nMicrosoft Intune is een cloud-based [Mv1.1]oplossing van Microsoft waarmee organisaties apparaten en applicaties kunnen beheren. Het is onderdeel van het Microsoft-beheerplatform en maakt het mogelijk om instellingen, beveiliging en toegang centraal te regelen.\nEen groot voordeel is dat dit allemaal op afstand gebeurt. IT-beheerders hoeven dus geen fysieke toegang tot een toestel te hebben om instellingen aan te passen of beleid toe te passen.\n",{"id":398,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":399,"introductionText":18,"__component":393},5255,"## Beheer van zakelijke smartphones\n\nBij zakelijke smartphones heeft een organisatie volledige controle over het toestel. Dit maakt het mogelijk om standaard beveiligingsregels en instellingen toe te passen.\n\nVoorbeelden hiervan zijn:\n- Verplichte pincode of biometrische beveiliging\n- Automatische schermvergrendeling\n- Installatie van bedrijfsapps zoals Outlook en Teams\n- Op afstand wissen van gegevens bij verlies of diefstal\n\nHierdoor blijft bedrijfsinformatie beter beschermd, zelfs wanneer een toestel niet meer in bezit is van de gebruiker.",{"id":401,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":402,"introductionText":18,"__component":393},5256,"## Bring Your Own Device (BYOD)\n\nBij BYOD gebruiken medewerkers hun eigen smartphone voor werkdoeleinden. Dat is flexibel en vaak kostenbesparend, maar brengt ook risico’s met zich mee.\nMicrosoft Intune lost dit op door werk en privé gescheiden te houden. Dit gebeurt via app-beveiligingsbeleid (App Protection Policies).\n\nVoorbeelden hiervan zijn:\n- Werkdata kan niet worden gekopieerd naar privé-apps\n- Extra beveiliging binnen werkapps (zoals een pincode)\n- Selectief wissen van bedrijfsdata zonder privégegevens te verwijderen\n\nHierdoor behoudt de medewerker privacy, terwijl de organisatie toch controle houdt over bedrijfsinformatie.",{"id":404,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":405,"introductionText":18,"__component":393},5257,"## Microsoft Intune stap voor stap implementeren\n\nDe implementatie van Microsoft Intune bestaat uit een aantal stappen. In de praktijk is dit vaak een proces dat stap voor stap wordt uitgevoerd.\n\n**Stap 1: Voorbereiding**\n\nEerst wordt gekeken naar de Microsoft 365-omgeving, licenties en welke apparaten beheerd moeten worden.\n\n**Stap 2: Enrollment (apparaten toevoegen)**\n\nToestellen worden gekoppeld aan Intune via inschrijving. Dit kan handmatig of automatisch gebeuren.\nBij BYOD gebeurt dit vaak via de Company Portal-app, waarin gebruikers inloggen met hun werkaccount.\n\n**Stap 3: Beleid en configuratieprofielen**\n\nHier worden regels ingesteld zoals:\n- Pincodeverplichting\n- Wifi- en e-mailinstellingen\n- Beveiligingsinstellingen per type apparaat\n\n**Stap 4: App-beheer**\n\nHier wordt bepaald welke apps gebruikt mogen worden en hoe bedrijfsdata binnen apps beschermd wordt.\n\n**Stap 5: Compliance en controle**\n\nApparaten worden gecontroleerd op veiligheid en instellingen. Niet-compliant apparaten kunnen toegang verliezen tot bedrijfsdata.\n",{"id":407,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":408,"introductionText":18,"__component":393},5258,"## Wat verandert er na de inrichting van Intune? Een praktijkvoorbeeld\n\nIn een organisatie zonder goed beheer ontstonden problemen doordat medewerkers hun eigen smartphones gebruikten voor werk. Er was geen duidelijk beleid en weinig controle.\nNa de implementatie van Microsoft Intune veranderde dit:\n- Alle zakelijke toestellen werden centraal beheerd\n- BYOD werd veilig ingericht met app-beveiliging\n- IT kreeg beter overzicht over apparaten\n- Datalekrisico’s werden verkleind\n\nIn het begin moesten gebruikers wennen aan extra beveiligingsstappen, maar dit werd na verloop van tijd normaal.",{"id":410,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":411,"introductionText":18,"__component":393},5259,"## Wat levert Microsoft Intune op?\n\nMicrosoft Intune biedt verschillende voordelen:\n- Centrale controle over alle mobiele apparaten\n- Ondersteuning voor zowel Android als iOS\n- Geschikt voor zakelijke en privétoestellen\n- Betere beveiliging van bedrijfsdata\n- Minder handmatig werk voor IT-beheer",{"id":413,"title":18,"asideText":18,"underline":215,"centered":215,"blankAside":215,"aside":18,"content":414,"introductionText":18,"__component":393},5260,"## Conclusie\nMicrosoft Intune is een krachtige oplossing voor het beheren van smartphones binnen organisaties. Vooral in situaties waar zowel zakelijke toestellen als BYOD worden gebruikt, biedt het een goede balans tussen beveiliging en gebruiksgemak.\nHoewel de implementatie tijd kost en goed ingericht moet worden, levert het op de lange termijn overzicht, controle en betere beveiliging op.\nSteeds meer organisaties maken gebruik van dit soort oplossingen, omdat mobiel werken steeds belangrijker wordt in de moderne werkomgeving.\n\nWil je aan de slag binnen jouw organisatie met smartphonebeheer? Neem gerust [contact](https://sharevalue.nl/contact) met ons op. We helpen je graag met een veilige en passende inrichting van Microsoft Intune.",{"id":416,"title":18,"showBlankAside":215,"__component":417},589,"global.social-sharing",{"id":419,"name":69,"jobTitle":71,"__component":420},466,"strapi.author-card",{"id":422,"titleLeft":423,"callToActionTextLeft":181,"callToActionLinkUrlLeft":182,"titleRight":424,"callToActionTextRight":425,"callToActionLinkUrlRight":426,"iconUrlLeft":427,"iconUrlRight":438,"__component":207},736,"Heb je een Azure Engineer nodig?","Kom je werken in ons Azure-team?","Klik hier","/word-onze-collega",{"id":428,"name":429,"alternativeText":18,"caption":18,"width":430,"height":431,"formats":18,"hash":432,"ext":191,"mime":192,"size":433,"url":434,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":435,"updatedAt":436,"documentId":437,"publishedAt":153,"focalPoint":18},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",{"id":199,"name":200,"alternativeText":18,"caption":18,"width":189,"height":189,"formats":18,"hash":201,"ext":191,"mime":192,"size":202,"url":203,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":204,"updatedAt":205,"documentId":206,"publishedAt":153,"focalPoint":18},{"id":440,"title":172,"aside":18,"postType":441,"limit":174,"expertise":442,"__component":177},516,"blogs",[443],{"id":123,"title":124,"subTitle":125,"description":126,"shortDescription":127,"slug":128,"createdAt":129,"updatedAt":130,"publishedAt":131,"isCoreExpertise":132,"documentId":133,"image":444,"seo":447,"blocks":452,"midPageBlocks":459},{"id":135,"name":136,"alternativeText":18,"caption":18,"width":137,"height":138,"formats":445,"hash":148,"ext":141,"mime":144,"size":149,"url":150,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":151,"updatedAt":151,"documentId":152,"publishedAt":153,"focalPoint":18},{"thumbnail":446},{"ext":141,"url":142,"hash":143,"mime":144,"name":145,"path":18,"size":146,"width":52,"height":147},{"id":155,"metaTitle":156,"metaDescrip