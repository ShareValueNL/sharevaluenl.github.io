nLink":178,"colorStyle":211,"showAsides":212,"imageUrl":367,"__component":248},{"id":214,"name":215,"alternativeText":18,"caption":18,"width":19,"height":216,"formats":368,"hash":243,"ext":23,"mime":26,"size":244,"url":245,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":246,"updatedAt":246,"documentId":247,"publishedAt":149,"focalPoint":18},{"large":369,"small":370,"medium":371,"thumbnail":372},{"ext":23,"url":219,"hash":220,"mime":26,"name":221,"path":18,"size":222,"width":29,"height":223},{"ext":23,"url":225,"hash":226,"mime":26,"name":227,"path":18,"size":228,"width":20,"height":229},{"ext":23,"url":231,"hash":232,"mime":26,"name":233,"path":18,"size":234,"width":44,"height":235},{"ext":23,"url":237,"hash":238,"mime":26,"name":239,"path":18,"size":240,"width":241,"height":242},{"id":250,"title":251,"subTitle":18,"content":252,"callToActionText":18,"callToActionLink":18,"colorStyle":253,"showAsides":212,"imageUrl":374,"__component":248},{"id":255,"name":256,"alternativeText":18,"caption":18,"width":19,"height":216,"formats":375,"hash":278,"ext":23,"mime":26,"size":279,"url":280,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":281,"updatedAt":281,"documentId":282,"publishedAt":149,"focalPoint":18},{"large":376,"small":377,"medium":378,"thumbnail":379},{"ext":23,"url":259,"hash":260,"mime":26,"name":261,"path":18,"size":262,"width":29,"height":223},{"ext":23,"url":264,"hash":265,"mime":26,"name":266,"path":18,"size":267,"width":20,"height":229},{"ext":23,"url":269,"hash":270,"mime":26,"name":271,"path":18,"size":272,"width":44,"height":235},{"ext":23,"url":274,"hash":275,"mime":26,"name":276,"path":18,"size":277,"width":241,"height":242},{"id":151,"title":284,"subTitle":18,"content":285,"callToActionText":18,"callToActionLink":18,"colorStyle":211,"showAsides":212,"imageUrl":381,"__component":248},{"id":287,"name":288,"alternativeText":18,"caption":18,"width":19,"height":216,"formats":382,"hash":310,"ext":23,"mime":26,"size":311,"url":312,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":313,"updatedAt":313,"documentId":314,"publishedAt":149,"focalPoint":18},{"large":383,"small":384,"medium":385,"thumbnail":386},{"ext":23,"url":291,"hash":292,"mime":26,"name":293,"path":18,"size":294,"width":29,"height":223},{"ext":23,"url":296,"hash":297,"mime":26,"name":298,"path":18,"size":299,"width":20,"height":229},{"ext":23,"url":301,"hash":302,"mime":26,"name":303,"path":18,"size":304,"width":44,"height":235},{"ext":23,"url":306,"hash":307,"mime":26,"name":308,"path":18,"size":309,"width":241,"height":242},{"id":316,"title":317,"callToActionText":318,"callToActionLinkUrl":319,"body":18,"imageUrl":388,"__component":321},{"id":183,"name":184,"alternativeText":18,"caption":18,"width":185,"height":186,"formats":18,"hash":187,"ext":188,"mime":189,"size":190,"url":191,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":192,"updatedAt":193,"documentId":194,"publishedAt":149,"focalPoint":18},[390,394,397,400,403,406,409,412,415,420],{"id":391,"title":18,"asideText":18,"underline":212,"centered":212,"blankAside":212,"aside":18,"content":392,"introductionText":18,"__component":393},4740,"## Passkeys: varianten en verschillen\n\nPasskeys zijn op FIDO2 gebaseerde aanmeldmethoden die phishing-resistent zijn. In plaats van een wachtwoord gebruik je bijvoorbeeld:\n- Microsoft Authenticator\n- Windows Hello\n- Een fysieke security key\n\n\nMicrosoft maakt nu onderscheid tussen:\n\n**Apparaatgebonden passkeys**  \nDeze zijn gekoppeld aan één specifiek apparaat.\n\n\n**Gesynchroniseerde passkeys**  \nDeze worden opgeslagen in een passkey-provider en gesynchroniseerd tussen apparaten, bijvoorbeeld via iCloud of een password manager.\n\n\n| **Apparaatgebonden** | **Gesynchroniseerd** |\n| --- | --- |\n| Microsoft Authenticator | Apple iCloud Keychain |\n| Security Key | Google Password Manager |\n| Windows Hello | 1Password |\n| | Bitwarden| \n\n\nBij apparaatgebonden passkeys is de sleutel gekoppeld aan één specifiek apparaat of een fysieke security key. Gaat dat apparaat verloren of defect, dan moet je een nieuwe passkey uitgeven. Dat kost tijd en beheerinspanning.\nGesynchroniseerde passkeys werken anders. Ze worden opgeslagen in een passkey-provider die al op het apparaat aanwezig is en synchroniseren automatisch tussen apparaten van dezelfde gebruiker.\nHierdoor wordt herstel eenvoudiger en dalen de kosten voor heruitgifte. Voor veel omgevingen is dit daarom de meest praktische keuze, mits het gewenste beveiligingsniveau past bij deze vorm van opslag.","global.pagesection",{"id":395,"title":18,"asideText":18,"underline":212,"centered":212,"blankAside":212,"aside":18,"content":396,"introductionText":18,"__component":393},4741,"## Wat verandert er in Microsoft Entra?\nMicrosoft introduceert een nieuwe instelling: **passkeyType**.\nHiermee kun je onderscheid maken tussen:\n- Apparaatgebonden passkeys\n- Gesynchroniseerde passkeys\n\nAls je niets aanpast, migreert  Microsoft je huidige FIDO2-instellingen automatisch.\n- Heb je attestation uitgeschakeld? Dan worden gesynchroniseerde passkeys automatisch toegestaan.\n- Heb je een registratiecampagne op “Microsoft Managed” staan? Dan verschuift de campagne van Microsoft Authenticator naar Passkeys.\n\nOnderstaand schema laat zien hoe Microsoft je bestaande FIDO2- en registratie-instellingen automatisch migreert naar het nieuwe passkey-profiel.\n\n![Afbeelding1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Afbeelding1_086a58f918.png)\n\nControleer daarom vóór de automatische uitrol of je huidige instellingen aansluiten bij je gewenste security-niveau.",{"id":398,"title":18,"asideText":18,"underline":212,"centered":212,"blankAside":212,"aside":18,"content":399,"introductionText":18,"__component":393},4742,"## Welke invloed heeft dit op jouw omgeving?\nDe wijziging lijkt klein, maar heeft direct invloed op je securityniveau en beheer.\nAfhankelijke van je huidige configuratie kunnen gebruikers straks automatisch andere authenticatiemethoden gebruiken dan je verwacht. Denk aan gesynchroniseerde passkeys via externe providers, zonder dat je dit expliciet hebt toegestaan. \n\nDat kan gevolgen hebben voor:\n- je controle op authenticators\n- compliance-eisen\n- en het beheerproces rondom uitgifte en herstel\n\nJuist in omgevingen met hogere zekerheidseisen wil je hier vooraf een bewuste keuze in maken.",{"id":401,"title":18,"asideText":18,"underline":212,"centered":212,"blankAside":212,"aside":18,"content":402,"introductionText":18,"__component":393},4743,"## Wanneer wordt dit automatisch ingeschakeld?\nMicrosoft heeft de functionaliteit van Public Preview naar General Availability omgezet in maart. De verwachting is dat de werkelijke automatische inschakeling zal plaatsvinden vanaf begin april, en klaar is eind mei 2026.\n",{"id":404,"title":18,"asideText":18,"underline":212,"centered":212,"blankAside":212,"aside":18,"content":405,"introductionText":18,"__component":393},4744,"## Zo voorkom je ongewenste wijzigingen\nControleer eerst of FIDO2 is ingeschakeld in je tenant. Kijk daarna of je registratiecampagne op “Microsoft Managed” staat. In dat geval kan de doelgroep automatisch verschuiven naar passkeys. Wil je dat voorkomen? Zet de campagne dan expliciet op “Enabled”.\n\nWerk je in een omgeving met hoge zekerheidseisen? Dan is het verstandig om attestation af te dwingen, zodat alleen goedgekeurde apparaatgebonden authenticators worden toegestaan.\n\nAttestation controleert of een authenticator afkomstig is van een goedgekeurde leverancier. Dit is relevant in omgevingen met hoge zekerheidseisen.\n",{"id":407,"title":18,"asideText":18,"underline":212,"centered":212,"blankAside":212,"aside":18,"content":408,"introductionText":18,"__component":393},4745,"## Wat moet je nu doen?\nGesynchroniseerde passkeys maken passwordless werken toegankelijker, maar veranderen ook je beheermodel. Controleer daarom vóór mei 2026 je huidige configuratie en bepaal bewust of je gesynchroniseerde passkeys wilt toestaan.\n\nDeze wijziging in Microsoft Entra rond gesynchroniseerde passkeys lijkt klein, maar kan grote impact hebben op je identity- en securitybeleid.\n\nWil je sparren over de juiste inrichting voor jouw omgeving? Neem [contact](https://sharevalue.nl/contact) met ons op!\n",{"id":410,"title":18,"showBlankAside":212,"__component":411},541,"global.social-sharing",{"id":413,"name":324,"jobTitle":325,"__component":414},423,"strapi.author-card",{"id":416,"titleLeft":176,"callToActionTextLeft":177,"callToActionLinkUrlLeft":178,"titleRight":417,"callToActionTextRight":180,"callToActionLinkUrlRight":181,"iconUrlLeft":418,"iconUrlRight":419,"__component":204},648,"Wil je onze collega worden?",{"id":183,"name":184,"alternativeText":18,"caption":18,"width":185,"height":186,"formats":18,"hash":187,"ext":188,"mime":189,"size":190,"url":191,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":192,"updatedAt":193,"documentId":194,"publishedAt":149,"focalPoint":18},{"id":196,"name":197,"alternativeText":18,"caption":18,"width":186,"height":186,"formats":18,"hash":198,"ext":188,"mime":189,"size":199,"url":200,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":201,"updatedAt":202,"documentId":203,"publishedAt":149,"focalPoint":18},{"id":421,"title":168,"aside":18,"postType":422,"limit":170,"expertise":423,"__component":173},471,"blogs",[424],{"id":119,"title":120,"subTitle":121,"description":122,"shortDescription":123,"slug":124,"createdAt":125,"updatedAt":126,"publishedAt":127,"isCoreExpertise":128,"documentId":129,"image":425,"seo":428,"blocks":433,"midPageBlocks":440},{"id":131,"name":132,"alternativeText":18,"caption":18,"width":133,"height":134,"formats":426,"hash":144,"ext":137,"mime":140,"size":145,"url":146,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":147,"updatedAt":147,"documentId":148,"publishedAt":149,"focalPoint":18},{"thumbnail":427},{"ext":137,"url":138,"hash":139,"mime":140,"name":141,"pa