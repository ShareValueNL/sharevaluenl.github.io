ork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":447,"hash":448,"mime":218,"name":449,"path":18,"size":450,"width":239,"height":240},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":163,"id":164,"title":165,"callToActionText":166,"callToActionLinkUrl":167,"body":18,"imageUrl":457},{"id":187,"name":188,"alternativeText":18,"caption":18,"width":189,"height":190,"formats":18,"hash":191,"ext":192,"mime":193,"size":194,"url":195,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":196,"updatedAt":197,"documentId":198,"publishedAt":57},{"id":169,"metaTitle":170,"metaDescription":171,"structuredData":459,"metaImage":18,"metaSocial":462},{"url":173,"@type":174,"@context":175,"provider":460,"areaServed":461,"description":183,"serviceType":184},{"url":177,"name":178,"@type":179},{"name":181,"@type":182},[],{"id":464,"name":465,"jobTitle":466,"about":18,"createdAt":467,"updatedAt":468,"publishedAt":469,"documentId":470,"image":471,"contactOptions":488},46,"Gerard","Consultant","2023-08-18T08:37:46.169Z","2024-09-30T14:34:40.504Z","2023-08-18T08:37:45.582Z","rln093elur7zel0sre3bheq5",{"id":472,"name":473,"alternativeText":18,"caption":18,"width":474,"height":475,"formats":476,"hash":483,"ext":78,"mime":81,"size":484,"url":485,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":486,"updatedAt":486,"documentId":487,"publishedAt":57},836,"Gerard websitefoto.png",278,326,{"thumbnail":477},{"ext":78,"url":478,"hash":479,"mime":81,"name":480,"path":18,"size":481,"width":482,"height":240},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Gerard_websitefoto_e8b2a30611.png","thumbnail_Gerard_websitefoto_e8b2a30611","thumbnail_Gerard websitefoto.png",21.88,133,"Gerard_websitefoto_e8b2a30611",24.59,"https://incredible-beef-2a6059b946.media.strapiapp.com/Gerard_websitefoto_e8b2a30611.png","2024-09-30T14:33:55.264Z","nfzgua290ztx7qmzp8gt117a",[],[490,495,498,502,506,509,512,515,518,521,524,527,606],{"__component":491,"id":492,"title":18,"asideText":493,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":494,"introductionText":18},"global.pagesection",847,"","Sinds de uitbraak van corona werken wij voor een groot deel thuis of op afstand, en voor de toekomst is de verwachting dat deze manier van werken wordt voortgezet. We zullen op een andere manier gaan kijken naar werken op kantoor, zijn eigenlijk al gewend aan thuiswerken, en kijken ook heel anders naar zaken als reistijd.\n\nEen belangrijke bijdrage aan het goed kunnen werken en vooral samenwerken in allerlei situaties is geleverd door Microsoft Teams. In het afgelopen jaar is het gebruik van Teams enorm gegroeid, van 32 miljoen actieve gebruikers in maart 2020 naar 115 miljoen in oktober 2020.\n\nOm al die gebruikers te kunnen ondersteunen is een enorme inzet gedaan door Microsoft, niet alleen om de bestaande Teams-omgevingen in de lucht te houden, maar vooral ook in honderden nieuwe mogelijkheden en verbeteringen in het afgelopen jaar. Denk aan iets ingrijpends zoals breakout-rooms, maar ook aan een simpele mogelijkheid om je hand op te steken.\n\nVoor de komende periode staat ons ook weer veel nieuws te wachten. Hieronder een aantal van de meest interessante vernieuwingen die er binnenkort aan komen. Wil je alle nieuwe ontwikkelingen zien? Onderaan het artikel staat een link naar een overzichtspagina van Microsoft.",{"__component":491,"id":496,"title":18,"asideText":493,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":497,"introductionText":18},845,"## Dynamische weergave\n\nDynamische weergave zorgt er op een slimme manier voor dat je een zo prettig mogelijke kijkervaring hebt. Wanneer mensen inloggen, hun video in- of uitschakelen, beginnen te spreken of beginnen te presenteren in een vergadering, past Teams de lay-out automatisch aan en personaliseert deze.",{"__component":491,"id":499,"title":18,"asideText":500,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":501,"introductionText":18},846,"Dynamische weergave in Teams","![](https://www.sharevalue.nl/images/sharevalue/blogs/Ignite_1.gif)",{"__component":491,"id":503,"title":18,"asideText":504,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":505,"introductionText":18},843,"Weergave-wisselaar","## Weergave-wisselaar\n\nMet de nieuwe weergave wisselaar in de bovenste balk van de Teams-vergadering kun je bepalen hoe je de inhoud van de vergadering ziet. De inmiddels bekende Modus Samen, of de nieuw ‘Galerie bovenaan’ (Gallery on Top) worden de video beeldjes van collega’s boven aan het vergadervenster weergegeven. Focus verbergt alle video’s en legt de aandacht volledig op de gedeelde inhoud. Volledig scherm helpt om afleidingen op het bureaublad te verminderen.",{"__component":491,"id":507,"title":18,"asideText":493,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":508,"introductionText":18},844,"![](https://www.sharevalue.nl/images/sharevalue/blogs/Ignite_2.png)",{"__component":491,"id":213,"title":18,"asideText":510,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":511,"introductionText":18},"Presentatormodus in Teams","## Presentatormodus\n\nAltijd al jezelf willen tonen vóór je dia’s tijdens een presentatie? Gebruik dan de presentator modus. Met de optie ‘Stand-out’ word je vóór de gedeelde inhoud geprojecteerd. ‘Reporter’ toont de inhoud als een nieuwsbericht boven je schouder. ‘Naast elkaar’ plaatst je naast de inhoud.",{"__component":491,"id":513,"title":18,"asideText":493,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":514,"introductionText":18},851,"![](https://www.sharevalue.nl/images/sharevalue/blogs/Ignite_3.gif)",{"__component":491,"id":516,"title":18,"asideText":493,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":517,"introductionText":18},848,"Naast deze opvallende wijzigingen komt er nog meer aan. Kijk voor een volledig overzicht hier:\n\n[What’s New in Microsoft Teams | Microsoft Ignite 2021 - Microsoft Tech Community](https://techcommunity.microsoft.com/t5/microsoft-teams-blog/what-s-new-in-microsoft-teams-microsoft-ignite-2021/ba-p/2118226)\n\n[](https://techcommunity.microsoft.com/t5/microsoft-teams-blog/what-s-new-in-microsoft-teams-december-2020/ba-p/2030942)",{"__component":491,"id":519,"title":18,"asideText":493,"underline":121,"centered":121,"blankAside":121,"aside":18,"content":520,"introductionText":18},849,"Ben jij met Microsoft Teams bezig en ben je benieuwd naar deze wijzigingen? [We vertellen je er graag meer over](/contact)!",{"__component":522,"id":523,"title":18,"showBlankAside":69},"global.social-sharing",95,{"__component":525,"id":526,"name":18,"jobTitle":18},"strapi.author-card",53,{"__component":92,"id":528,"title":529,"aside":18,"postType":95,"limit":96,"expertise":530},64,"Lees ook onze andere berichten",[531],{"id":60,"title":61,"subTitle":62,"description":63,"shortDescription":64,"slug":65,"createdAt":66,"updatedAt":67,"publishedAt":68,"isCoreExpertise":69,"documentId":70,"image":532,"blocks":535,"midPageBlocks":542,"seo":601},{"id":72,"name":73,"alternativeText":18,"caption":18,"width":74,"height":75,"formats":533,"hash":85,"ext":78,"mime":81,"size":86,"url":87,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":88,"updatedAt":88,"documentId":89,"publishedAt":57},{"thumbnail":534},{"ext":78,"url":79,"hash":80,"mime":81,"name":82,"path":18,"size":83,"width":49,"height":84},[536,539],{"__component":92,"id":93,"title":94,"aside":18,"postType":95,"limit":96,"expertise":537},[538],{"id":60,"title":61,"subTitle":62,"description":63,"shortDescription":64,"slug":65,"createdAt":66,"updatedAt":67,"publish