ratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":340,"name":341,"alternativeText":18,"caption":18,"width":19,"height":195,"formats":342,"hash":363,"ext":23,"mime":200,"size":364,"url":365,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":366,"updatedAt":366,"documentId":367,"publishedAt":57,"focalPoint":18},786,"migratie.jpg",{"large":343,"small":348,"medium":353,"thumbnail":358},{"ext":23,"url":344,"hash":345,"mime":200,"name":346,"path":18,"size":347,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":349,"hash":350,"mime":200,"name":351,"path":18,"size":352,"width":20,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":354,"hash":355,"mime":200,"name":356,"path":18,"size":357,"width":42,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":359,"hash":360,"mime":200,"name":361,"path":18,"size":362,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":369,"title":370,"subTitle":371,"content":372,"callToActionText":18,"callToActionLink":18,"colorStyle":235,"showAsides":191,"imageUrl":373,"__component":228},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":374,"name":375,"alternativeText":18,"caption":18,"width":19,"height":195,"formats":376,"hash":397,"ext":23,"mime":200,"size":398,"url":399,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":400,"updatedAt":400,"documentId":401,"publishedAt":57,"focalPoint":18},787,"microsoft security.jpg",{"large":377,"small":382,"medium":387,"thumbnail":392},{"ext":23,"url":378,"hash":379,"mime":200,"name":380,"path":18,"size":381,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":383,"hash":384,"mime":200,"name":385,"path":18,"size":386,"width":20,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":388,"hash":389,"mime":200,"name":390,"path":18,"size":391,"width":42,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":393,"hash":394,"mime":200,"name":395,"path":18,"size":396,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":403,"title":404,"subTitle":405,"content":406,"callToActionText":407,"callToActionLink":408,"colorStyle":190,"showAsides":191,"imageUrl":409,"__component":228},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":410,"name":411,"alternativeText":18,"caption":18,"width":19,"height":195,"formats":412,"hash":433,"ext":23,"mime":200,"size":434,"url":435,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":436,"updatedAt":436,"documentId":437,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":413,"small":418,"medium":423,"thumbnail":428},{"ext":23,"url":414,"hash":415,"mime":200,"name":416,"path":18,"size":417,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":419,"hash":420,"mime":200,"name":421,"path":18,"size":422,"width":20,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":424,"hash":425,"mime":200,"name":426,"path":18,"size":427,"width":42,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":429,"hash":430,"mime":200,"name":431,"path":18,"size":432,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":439,"title":440,"subTitle":441,"content":442,"callToActionText":18,"callToActionLink":18,"colorStyle":235,"showAsides":191,"imageUrl":443,"__component":228},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":444,"name":445,"alternativeText":18,"caption":18,"width":19,"height":195,"formats":446,"hash":467,"ext":23,"mime":200,"size":468,"url":469,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":470,"updatedAt":470,"documentId":471,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":447,"small":452,"medium":457,"thumbnail":462},{"ext":23,"url":448,"hash":449,"mime":200,"name":450,"path":18,"size":451,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":453,"hash":454,"mime":200,"name":455,"path":18,"size":456,"width":20,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":458,"hash":459,"mime":200,"name":460,"path":18,"size":461,"width":42,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":463,"hash":464,"mime":200,"name":465,"path":18,"size":466,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":473,"title":474,"callToActionText":475,"callToActionLinkUrl":476,"body":18,"imageUrl":477,"__component":478},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":57,"focalPoint":18},"call-to-action.single",[480,485,489,492,495,498,577],{"id":481,"title":18,"asideText":482,"underline":191,"centered":191,"blankAside":191,"aside":18,"content":483,"introductionText":18,"__component":484},1524,"","Met “SharePoint on Premise” was dat altijd zeer duidelijk, maar met [Office 365](/expertises/microsoft-365) is het niet altijd even helder omdat de ontwikkelingen continu zijn. We verwachten dit jaar tijdens de SharePoint Conference in Las Vegas echter informatie te ontvangen die veel functionaliteiten (en dus ook de visie) verder gaat verduidelijken. Dit jaar gaan er namens ShareValue een aantal collega’s naar Las Vegas, maar ook naar de conferentie in Mainz. (En waarschijnlijk kom je ons ook tegen bij DIWUG-avonden, SharePoint Saturday of de European SharePoint conference). We willen namelijk altijd bijblijven op ons vakgebied en als Developer, applicatiebeheerder of als functioneel consultant heb je andere focusgebieden.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/SharePoint-conference-las-vegas.png)","global.pagesection",{"id":486,"title":18,"asideText":487,"underline":191,"centered":191,"blankAside":191,"aside":18,"content":488,"introductionText":18,"__component":484},1523,"Focuspunten","## Op welke onderwerpen ga ik me focussen?\n\nMijn aandachtsgebieden voor Office 365 liggen voornamelijk bij het veranderen en verbeteren van organisaties op basis van Office 365/SharePoint. Dat kan variëren van de adoptie van Office 365 tot het inrichten van een intranet. Wat er gebeurt in Las Vegas is natuurlijk lastig te voorspellen, maar ik stel mij als doel om meer informatie te achterhalen over minimaal de volgende onderwerpen:\n\n1.  Communication en Hub Sites: het intranet is altijd een zeer arbeidsintensieve ontwikkeling geweest op SharePoint. De Communication Sites en aangekondigde Hub Sites kunnen hier een zeer groot verschil in maken. De communication sites zoals ze nu zijn, zijn voor kleine organisaties al goed genoeg, maar ik ben erg benieuwd in hoeverre we straks hier Enterprise oplossingen mee kunnen maken.\n2.  Dan is dé klapper van Office 365 de applicatie [Teams](/blogs/vijf-aandachtspunten-bij-het-inrichten-en-gebruiken-van-microsoft-teams). Teams is een van de jongste apps binnen de Office 365 familie, maar de adoptie bij klanten en eindgebruikers is zeer hoog. Zo hoog dat de ontwikkelingen voor Teams niet snel genoeg kunnen gaan. Ik ben dan ook benieuwd welke ontwikkelingen er nog aan gaan komen, maar vooral ook hoe we Teams kunnen gaan gebruiken om de data beter en efficiënter te beheren. Ben je als organisatie nu al bezig met het inrichten en gebruiken van Teams? Dan kan de blog van mijn collega Pieter van der Poort interessant zijn. In zijn blog beschrijft hij [vijf aandachtspunten bij het inrichten en gebruiken van Microsoft Teams.](/blogs/vijf-aandachtspunten-bij-het-inrichten-en-gebruiken-van-microsoft-teams)  \n    \n3.  Voor je überhaupt aan de slag gaat met Office 365 en SharePoint, moet je als organisatie nadenken over de informatie-architectuur. Met het oude SharePoint was die structuur zeer helder, maar Office 365 biedt zeer veel cross-datamogelijkheden dat een logische architectuur steeds lastiger wordt om op te sturen. Ik wil dan ook onderzoeken wat daarin de beste mogelijkheden zijn. Is een informatie-architectuur überhaupt nog wel nodig?",{"id":490,"title":18,"asideText":482,"underline":191,"centered":191,"blankAside":191,"aside":18,"content":491,"introductionText":18,"__component":484},1525,"Het laatste punt is eigenlijk een zeer praktisch punt: veel IT-organisaties hebben al moeite om de ontwikkelingen van Office 365 bij te benen. Laat staan een goede implementatie te bieden die echt een meerwaarde biedt voor eindgebruikers. Welke stappen kun je als IT-afdeling nemen om gebruikers te overtuigen en misschien zelfs wel te enthousiasmeren?\n\nDit zijn mijn focuspunten voor de conferentie in Las Vegas. Ons plan is om te breken met het aloude gezegde: “What happens in Vegas, stays in Vegas”. Op 5 juni zullen we namelijk onze kennis, en nieuws delen tijdens een informatieavond. Volg ShareValue op de diverse Social Media of ondergetekende via [@r\\_acker](https://twitter.com/r_acker). Dan wordt je vanzelf op de hoogte gehouden wanneer je je hier voor kunt aanmelden.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/P1030166b.png)\n\nWe houden deze informatieavond nu voor de derde keer en mijn idee is dat bezoekers dat ervaren als een avond waar je veel kennis kunt opdoen. Kennis óver Office 365, kennis ván mijn collega’s die u graag op weg helpen, maar vooral ook bíj andere organisaties. Ook dit jaar zal een van onze klanten hun ervaring met SharePoint/Office 365 komen delen.\n\nTot 5 juni!",{"id":493,"title":18,"showBlankAside":108,"__component":494},153,"global.social-sharing",{"id":496,"name":18,"jobTitle":18,"__component":497},111,"strapi.author-card",{"id":499,"title":500,"aside":18,"postType":148,"limit":149,"expertise":501,"__component":152},122,"Lees ook onze andere berichten",[502],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109,"image":503,"seo":506,"blocks":511,"midPageBlocks":518},{"id":111,"name":112,"alternativeText":18,"caption":18,"width":113,"height":114,"formats":504,"hash":124,"ext":117,"mime":120,"size":125,"url":126,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":127,"updatedAt":127,"documentId":128,"publishedAt":57,"focalPoint":18},{"thumbnail":505},{"ext":117,"url":118,"hash":119,"mime":120,"name":121,"path":18,"size":122,"width":49,"height":123},{"id":130,"metaTitle":131,"metaDescription":132,"structuredData":507,"metaImage":18,"metaSocial":510},{"url":134,"@type":135,"@context":67,"provider":508,"areaServed":509,"description":141,"serviceType":142},{"url":137,"name":73,"@type":74},{"name":139,"@type":140},[],[512,515],{"id":146,"title":147,"aside":18,"postType":148,"limit":149,"expertise":513,"__component":152},[514],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109},{"id":154,"titleLeft":155,"callToActionTextLeft":156,"callToActionLinkUrlLeft":157,"titleRight":158,"callToActionTextRight":159,"callToActionLinkUrlRight":160,"iconUrlLeft":516,"iconUrlRight":517,"__component":183},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url