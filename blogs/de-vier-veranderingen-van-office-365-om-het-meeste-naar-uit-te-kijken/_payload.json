[{"data":1,"prerenderedAt":591},["ShallowReactive",2],{"collection-blogs-182011681":3,"_apollo:default":590},{"data":4,"meta":586},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":97,"blocks":479},114,"De vier veranderingen van Office 365 om het meeste naar uit te kijken","De ontwikkeling van Office 365 stopt niet. Maar ééns per jaar worden er grote mededelingen door Microsoft gedaan en lichten ze een tipje van de sluier op voor het komende jaar. Met die teasers gaan wij aan de slag om de visie, oplossingen en tooling aan elkaar te knopen tot toekomst vaste oplossingen.","de-vier-veranderingen-van-office-365-om-het-meeste-naar-uit-te-kijken","2023-10-13T10:26:42.831Z","2025-04-22T13:11:06.393Z","2023-10-13T10:26:42.781Z","2018-04-16","fylyqxy3qez0807xmebwq1yr",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},363,"de-vier-veranderingen-van-office-365-om-het-meeste-naar-uit-te-kijken.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_de_vier_veranderingen_van_office_365_om_het_meeste_naar_uit_te_kijken_9840507d4f.jpg","large_de_vier_veranderingen_van_office_365_om_het_meeste_naar_uit_te_kijken_9840507d4f","image/jpg","large_de-vier-veranderingen-van-office-365-om-het-meeste-naar-uit-te-kijken.jpg",89.65,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_de_vier_veranderingen_van_office_365_om_het_meeste_naar_uit_te_kijken_9840507d4f.jpg","small_d