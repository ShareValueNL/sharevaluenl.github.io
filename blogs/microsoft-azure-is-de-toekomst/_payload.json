h":258,"mime":188,"name":259,"path":18,"size":260,"width":36,"height":197},{"ext":23,"url":262,"hash":263,"mime":188,"name":264,"path":18,"size":265,"width":43,"height":203},{"ext":23,"url":267,"hash":268,"mime":188,"name":269,"path":18,"size":270,"width":209,"height":210},{"__component":133,"id":134,"title":135,"callToActionText":136,"callToActionLinkUrl":137,"body":18,"imageUrl":381},{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":129,"metaTitle":139,"metaDescription":140,"structuredData":383,"metaImage":18,"metaSocial":386},{"url":142,"@type":143,"@context":144,"provider":384,"areaServed":385,"description":152,"serviceType":153},{"url":146,"name":147,"@type":148},{"name":150,"@type":151},[],{"__component":106,"id":388,"titleLeft":111,"callToActionTextLeft":112,"callToActionLinkUrlLeft":389,"titleRight":390,"callToActionTextRight":391,"callToActionLinkUrlRight":392,"iconUrlLeft":393,"iconUrlRight":394},166,"https://www.sharevalue.nl/word-onze-collega/vacatures","Wil je weten waar wij goed in zijn?","Ontdek wat we doen","https://www.sharevalue.nl/wat-we-doen",{"id":169,"name":170,"alternativeText":18,"caption":18,"width":159,"height":159,"formats":18,"hash":171,"ext":161,"mime":162,"size":172,"url":173,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":174,"updatedAt":175,"documentId":176,"publishedAt":58},{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":396,"metaTitle":397,"metaDescription":398,"structuredData":399,"metaImage":18,"metaSocial":429},187,"Waarom Microsoft Azure de toekomst is | ShareValue","Ontdek waarom Microsoft Azure essentieel is voor moderne IT-strategieën, met focus op schaalbaarheid, beveiliging en innovatie.",[400,412],{"url":401,"@type":402,"author":403,"@context":144,"headline":397,"publisher":407,"description":398,"datePublished":411},"https://www.sharevalue.nl/blogs/microsoft-azure-is-de-toekomst","BlogPosting",{"name":285,"@type":404,"jobTitle":405,"worksFor":406},"Person","Engineer",{"name":147,"@type":148},{"logo":408,"name":147,"@type":148},{"url":409,"@type":410},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","2019-01-31",{"@type":413,"@context":144,"mainEntity":414},"FAQPage",[415,421,425],{"name":416,"@type":417,"acceptedAnswer":418},"Waarom is Microsoft Azure belangrijk voor de toekomst?","Question",{"text":419,"@type":420},"Microsoft Azure biedt schaalbare cloudoplossingen die bedrijven helpen bij digitale transformatie, met sterke beveiliging en integratie met andere Microsoft-diensten.","Answer",{"name":422,"@type":417,"acceptedAnswer":423},"Hoe ondersteunt Azure innovatie binnen organisaties?",{"text":424,"@type":420},"Azure biedt een breed scala aan tools en services, zoals AI, machine learning en IoT, die organisaties in staat stellen innovatieve oplossingen te ontwikkelen en te implementeren.",{"name":426,"@type":417,"acceptedAnswer":427},"Wat zijn de voordelen van Azure ten opzichte van andere cloudplatforms?",{"text":428,"@type":420},"Azure onderscheidt zich door naadloze integratie met Microsoft-producten, een uitgebreid wereldwijd datacenternetwerk en een sterke focus op beveiliging en compliance.",[],{"pagination":431},{"page":61,"pageSize":6},{},1781259264869]