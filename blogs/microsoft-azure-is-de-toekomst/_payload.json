structure_bf66532759","medium_infrastructure.jpg",149.51,{"ext":23,"url":267,"hash":268,"mime":188,"name":269,"path":18,"size":270,"width":209,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_infrastructure_bf66532759.jpg","thumbnail_infrastructure_bf66532759","thumbnail_infrastructure.jpg",15.74,"infrastructure_bf66532759",374.88,"https://incredible-beef-2a6059b946.media.strapiapp.com/infrastructure_bf66532759.jpg","2024-08-08T08:58:52.414Z","bmkl03ingwf6ms8pdk5jvmx5",{"__component":133,"id":134,"title":135,"callToActionText":136,"callToActionLinkUrl":137,"body":18,"imageUrl":277},{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":129,"metaTitle":139,"metaDescription":140,"structuredData":279,"metaImage":18,"metaSocial":282},{"url":142,"@type":143,"@context":144,"provider":280,"areaServed":281,"description":152,"serviceType":153},{"url":146,"name":147,"@type":148},{"name":150,"@type":151},[],{"id":284,"name":285,"jobTitle":286,"about":18,"createdAt":287,"updatedAt":288,"publishedAt":289,"documentId":290,"image":291,"contactOptions":308},61,"Makele","Engineer & Architect","2023-08-18T08:37:46.187Z","2024-03-18T14:40:45.737Z","2023-08-18T08:37:45.771Z","k7324xqqufdayy6t4669cykm",{"id":292,"name":293,"alternativeText":18,"caption":18,"width":294,"height":295,"formats":296,"hash":303,"ext":79,"mime":82,"size":304,"url":305,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":306,"updatedAt":306,"documentId":307,"publishedAt":58},606,"Makele websitefoto.png",278,326,{"thumbnail":297},{"ext":79,"url":298,"hash":299,"mime":82,"name":300,"path":18,"size":301,"width":302,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Makele_websitefoto_f6bc761239.png","thumbnail_Makele_websitefoto_f6bc761239","thumbnail_Makele websitefoto.png",19.57,133,"Makele_websitefoto_f6bc761239",18.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/Makele_websitefoto_f6bc761239.png","2024-03-18T14:38:40.552Z","u3h6yt6hpddxen0ycly1we2t",[],[310,315,318,321,326,331,334,337,340,343,387],{"__component":311,"id":312,"title":18,"asideText":313,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":314,"introductionText":18},"global.pagesection",1269,"","Onze experts bij ShareValue hebben ervaring met de ontwikkeling, implementatie en hosting van applicaties en infrastructuur op Microsoft Azure. Zo heeft ShareValue voor Microsoft Azure de juiste experts in huis. Deze kennis wordt onderling continu gedeeld en ingezet op de vraagstukken van onze klanten.",{"__component":311,"id":316,"title":18,"asideText":313,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":317,"introductionText":18},1270,"## Waarom is Azure de toekomst?\n\nHet is een product van Microsoft wat alleen maar groter wordt en alles voorbij zal gaan streven. Alle diensten die wij bij ShareValue leveren kunnen op Azure. Je kan er eigenlijk gewoon niet meer omheen.\n\nDe verwachting van onze teammanager Robert is dat er over 5 jaar nog maar weinig bedrijven zijn met een eigen datacenter. Het uitbesteden van een datacenter is goedkoper en het beheer ligt bij Microsoft. Het geld wat Microsoft uitgeeft aan hun beveiliging is echt enorm, daar kan geen enkel bedrijf tegenop. De kans om gehackt te worden is daardoor heel erg klein en het misgaan ook. Microsoft is bezig om een hele stabiele omgeving neer te zetten voor een redelijk lage prijs. Voor veel bedrijven is dit een reden om over te stappen naar Azure.",{"__component":311,"id":319,"title":18,"asideText":313,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":320,"introductionText":18},1271,"## Azure expertise groeit bij ShareValue\n\nBij ShareValue wordt de Azure expertise ook alleen maar groter en groter. Robert stelt daarom graag zijn team aan jullie voor.",{"__component":311,"id":322,"title":18,"asideText":323,"underline":122,"centered":122,"blankAside":122,"aside":324,"content":325,"introductionText":18},1272,"Sandino\n\n​","![sandino.jpg](https://incredible-beef-2a6059b946.media.strapiapp.com/sandino_041b374230.jpg)","### Sandino\nSandino is een rustige en collegiale jongen die zich graag blijft ontwikkelen. Hij is zeer leergierig en pakt hierdoor snel dingen op. Sandino kan zich als geen ander verplaatsen in de klant/gebruiker door zijn grote inlevingsvermogen. Op dit moment is hij werkzaam als SQL-database beheerder met daarnaast SharePoint werkzaamheden. Dit is voornamelijk on-premises werk. Het gaat om een groot project waarin beveiligingscertificaten toegevoegd moeten worden. Naast deze werkzaamheden geeft hij ook advies op het gebied van Office 365.\n\nBuiten zijn opdracht is Sandino veel met andere Azure experts aan het sparren over nieuwe dingen binnen Azure.",{"__component":311,"id":327,"title":18,"asideText":328,"underline":122,"centered":122,"blankAside":122,"aside":329,"content":330,"introductionText":18},1273,"Makele\n\n​","![makele.jpg](https://incredible-beef-2a6059b946.media.strapiapp.com/makele_3eadd09ea1.jpg)","### Makele\n\nMakele is een ervaren Office 365 en Microsoft Azure consultant. Hij heeft ruime ervaring in het implementeren van SharePoint omgevingen, technisch applicatie beheer in SharePoint, migratie projecten en Technisch beheer Microsoft Azure omgevingen.\n\nMakele is iemand die zich constant wil blijven ontwikkelen. Het is zijn ambitie om door te groeien tot SharePoint/Cloud architect met gedegen kennis van Office 365 en Azure, zowel technisch als functioneel. Flexibiliteit en teamsprit kenmerken Makele en hij beschikt over de capaciteit om zich gemakkelijk aan te passen aan nieuwe omgevingen en situaties.\n\nIn zijn huidige opdracht is Makele volledig bezig met Azure. Van omgevingen bouwen tot een nieuwe service neerzetten en weer weghalen. Verder is hij verantwoordelijk voor het regelen de infrastructuur. Eigenlijk alles wat je met Azure kan doen, daar is Makele in thuis.",{"__component":311,"id":332,"title":18,"asideText":313,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":333,"introductionText":18},1274,"### Robert\n\nRobert is gecertificeerd infrastructuur engineer. Hij heeft ervaring met client- en met serveromgevingen. Daardoor heeft hij veel kennis en ervaring met het uitvoeren van engineering- en beheerwerkzaamheden. Robert is sociaal, proactief en een echte teamplayer. Hij werkt gestructureerd en kent geen stress. Zijn uitstekende communicatieve vaardigheden en goede teamspirit maken hem tot een prettige collega om mee samen te werken. Robert neemt snel kennis tot zich. Dat maakt hem tot een infrastructuur engineer die graag de uitdaging aangaat, tevens is hij Teammanager van het Infrastructuur team binnen ShareValue.\n\nOp dit moment heeft Robert bij zijn opdrachtgever een volledige SharePoint omgeving gebouwd on-premises. Verder geeft hij organisaties veel advies op het gebied van Office 365 en Azure. ‘Het gaafste wat ikzelf met Azure heb gedaan, is de boel plat leggen.’, aldus Robert. Tijdens een hacking training was hij aan het kijken wat wij met Azure konden doen. Ze hebben toen gekeken of ze de boel plat konden leggen, uiteraard wel eigen services.",{"__component":311,"id":335,"title":18,"asideText":313,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":336,"introductionText":18},1275,"Staat jouw organisatie voor een vraagstuk op het gebied van Azure? Onze experts gaan graag aan de slag samen met jouw team. Neem contact met ons op voor meer informatie.",{"__component":338,"id":339,"title":18,"showBlankAside":70},"global.social-sharing",139,{"__component":341,"id":342,"name":18,"jobTitle":18},"strapi.author-card",97,{"__component":93,"id":344,"title":345,"aside":18,"postType":96,"limit":97,"expertise":346},107,"Lees ook onze andere berichten",[347],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":348,"blocks":351,"midPageBlocks":358,"seo":382},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":349,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":350},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[352,355],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":353},[354],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71},{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":113,"iconUrlLeft":356,"iconUrlRight":357},{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":169,"name":170,"alternativeText":18,"caption":18,"width":159,"height":159,"formats":18,"hash":171,"ext":161,"mime":162,"size":172,"url":173,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":174,"updatedAt":175,"documentId":176,"publishedAt":58},[359,366,373,380],{"__component":116,"id":117,"title":118,"subTitle":18,"content":119,"callToActionText":120,"callToActionLink":110,"colorStyle":121,"showAsides":122,"imageUrl":360},{"id":180,"name":181,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":361,"hash":211,"ext":23,"mime":188,"size":212,"url":213,"previewUrl":18,"provider":55,"provider_metadata":18,"crea