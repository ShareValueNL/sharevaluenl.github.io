At":57,"focalPoint":18},787,"microsoft security.jpg",{"large":378,"small":383,"medium":388,"thumbnail":393},{"ext":23,"url":379,"hash":380,"mime":202,"name":381,"path":18,"size":382,"width":29,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":384,"hash":385,"mime":202,"name":386,"path":18,"size":387,"width":36,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":389,"hash":390,"mime":202,"name":391,"path":18,"size":392,"width":43,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":394,"hash":395,"mime":202,"name":396,"path":18,"size":397,"width":223,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":404,"title":405,"subTitle":406,"content":407,"callToActionText":408,"callToActionLink":409,"colorStyle":191,"showAsides":192,"imageUrl":410,"__component":229},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":411,"name":412,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":413,"hash":434,"ext":23,"mime":202,"size":435,"url":436,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":437,"updatedAt":437,"documentId":438,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":414,"small":419,"medium":424,"thumbnail":429},{"ext":23,"url":415,"hash":416,"mime":202,"name":417,"path":18,"size":418,"width":29,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":420,"hash":421,"mime":202,"name":422,"path":18,"size":423,"width":36,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":425,"hash":426,"mime":202,"name":427,"path":18,"size":428,"width":43,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":430,"hash":431,"mime":202,"name":432,"path":18,"size":433,"width":223,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":440,"title":441,"subTitle":442,"content":443,"callToActionText":18,"callToActionLink":18,"colorStyle":236,"showAsides":192,"imageUrl":444,"__component":229},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":445,"name":446,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":447,"hash":468,"ext":23,"mime":202,"size":469,"url":470,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":471,"updatedAt":471,"documentId":472,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":448,"small":453,"medium":458,"thumbnail":463},{"ext":23,"url":449,"hash":450,"mime":202,"name":451,"path":18,"size":452,"width":29,"height":205},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":454,"hash":455,"mime":202,"name":456,"path":18,"size":457,"width":36,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":459,"hash":460,"mime":202,"name":461,"path":18,"size":462,"width":43,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":464,"hash":465,"mime":202,"name":466,"path":18,"size":467,"width":223,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":474,"title":475,"callToActionText":476,"callToActionLinkUrl":477,"body":18,"imageUrl":478,"__component":479},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":163,"name":164,"alternativeText":18,"caption":18,"width":165,"height":166,"formats":18,"hash":167,"ext":168,"mime":169,"size":170,"url":171,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":172,"updatedAt":173,"documentId":174,"publishedAt":57,"focalPoint":18},"call-to-action.single",[481,486,490,494,498,502,506,510,513,516,523],{"id":482,"title":18,"asideText":483,"underline":192,"centered":192,"blankAside":192,"aside":18,"content":484,"introductionText":18,"__component":485},1558,"Sessie van Ben Howard (MVP)","Op de ESPC17 in Dublin (13 november t/m 16 november 2017) heb ik de sessie bezocht van Ben Howard (MVP). De integratie van MS Project met MS Planner is nieuw en optimaal voor een goede adoptie! Naar mijn idee heeft hij hieraan te kort aandacht besteed. Immers, deze integratie is een erg goede stap richting de gebruiker. Hiermee worden de geplande werkzaamheden (vanuit MS Project naar MS Planner) sneller inzichtelijk voor de gebruiker. Dus meer ‘power-to-the-people’.\n\nDe volgende vijf updates wil ik graag met jullie delen:","global.pagesection",{"id":487,"title":18,"asideText":488,"underline":192,"centered":192,"blankAside":192,"aside":18,"content":489,"introductionText":18,"__component":485},1559,"Taken koppelen aan Planner","## 1\\. Een taak in Project koppelen aan Planner\n\nIn Planner kun je eenvoudig de werkzaamheden opsplitsen, een team samenstellen, taken toewijzen en de status bijwerken in een handig takenbord weergave. Onderstaand de stappen om dit voor elkaar te krijgen:\n\nSelecteer een taak in Project en klik op de knop ‘Planner’ op het ‘Taak-lint’.\n\n![Figuur 1: taak-lint](https://www.sharevalue.nl/images/sharevalue/blogs/fig1_taak-lint.png)\n\nFiguur 1: taak-lint\n\n  \n\nStap 1: zoek in het deelvenster ‘Taak koppelen aan abonnement’ naar de groep waarvan je abonnement deel uitmaakt en kies vervolgens in de lijst het abonnement waarnaar je een koppeling wilt maken.\n\nStap 2: selecteer ‘Koppeling maken’.\n\nDe projecttaak wordt nu gekoppeld aan dat abonnement en de eigenaar van de taak in Project wordt eigenaar van dit abonnement in Planner.",{"id":491,"title":18,"asideText":492,"underline":192,"centered":192,"blankAside":192,"aside":18,"content":493,"introductionText":18,"__component":485},1560,"​Taken koppelen met een vervolgkeuzelijst","## 2.Taken koppelen met behulp van een vervolgkeuzelijst\n\nJe hoeft niet meer de ID te onthouden van de taak die je wilt koppelen. Als je nu een cel selecteert in de kolom ‘Voorafgaande taken’ en vervolgens de pijl omlaag selecteert, zie je een lijst met alle taken in je project. De taakhiërarchie en de volgorde komen hiermee precies overeen, zodat je eenvoudig naar de juiste taak kunt schuiven en vervolgens het bijbehorende selectievakje kunt inschakelen.\n\nN.B. Je kunt hetzelfde type vervolgkeuzelijst ook gebruiken om taken te selecteren in de kolom ‘Opvolgende taken’.\n\n![Figuur 2: Taken koppelen](https://www.sharevalue.nl/images/sharevalue/blogs/fig2_taken_koppelen.png)\n\nFiguur 2: Taken koppelen",{"id":495,"title":18,"asideText":496,"underline":192,"centered":192,"blankAside":192,"aside":18,"content":497,"introductionText":18,"__component":485},1561,"Ondersteuning van Agile","## 3\\. Ondersteuning Agile\n\nOm een flexibele projectplanning te vergemakkelijken, levert Microsoft nu een Agile template in Project Online! Deze is voorzien van nieuwe interfaces waarin gebruikers zogenoemde ‘product back log items’ kunnen maken. Deze kunnen dan in sprints worden verplaatst via ‘drag and drop’.\n\nGebruikers kunnen met programma’s zoals Jira en Team Foundation Server (TFS) een verbinding maken. Dat stelt ze in staat om de taakplanning via Jira (of TFS) te verbinden met een taak in Project Online.\n\n![Figuur 3: Agile template](https://www.sharevalue.nl/images/sharevalue/blogs/fig3_Agile.png)\n\nFiguur 3: Agile template",{"id":499,"title":18,"asideText":500,"underline":192,"centered":192,"blankAside":192,"aside":18,"content":501,"introductionText":18,"__component":485},1562,"Programmamanegement","## 4\\. Programmanagement\n\nProgrammamanagement wordt vereenvoudigd door de nieuwe portefeuilleweergave. Projecten die bij elkaar horen kunnen worden toegewezen aan een portfolio (of programma) in een hiërarchische structuur. Programma elementen kunnen een MS Project projectplan, een TFS-project en een Planner taaklijst bevatten.\n\n![Figuur 4: Programmamanagement](https://www.sharevalue.nl/images/sharevalue/blogs/fig4_programmamanagement.png)\n\nFiguur 4: Programmamanagement",{"id":503,"title":18,"asideText":504,"underline":192,"centered":192,"blankAside":192,"aside":18,"content":505,"introductionText":18,"__component":485},1563,"Power BI-rapporten","## 5\\. Portfolio rapporten (out-of-the-box)\n\nEr zijn gedefinieerde rapporten voor de Power BI-gebruiker. Dit maakt het mogelijk om op een eenvoudige manier diverse interactieve- en grafische portefeuille verslagen te produceren en deze te demonstreren op elk type toestel (van tablet, iPad tot en met je Windows bureaublad).\n\n![Figuur 5: Office 365 Project Portfolio Dashboard](https://www.sharevalue.nl/images/sharevalue/blogs/fig5_Project_Portfolio_Dashboard.png)\n\nFiguur 5: Office 365 Project Portfolio Dashboard",{"id":507,"title":18,"asideText":508,"underline":192,"centered":192,"blankAside":192,"aside":18,"content":509,"introductionText":18,"__component":485},1564,"","## Tenslotte\n\nMet de nieuwe functionaliteiten en met name de integratie van MS Planner meen ik dat Microsoft wederom een goede stap heeft gemaakt om MS Project (en Project Online) dichter bij de gebruikers te krijgen. Heb je vragen naar aanleiding van deze blog? Neem gerust contact met ons op. Op de informatieavond ‘Welke richting kies jij?’ op maandag 27 november aanstaande kun je mij ook persoonlijk vragen stellen tijdens het onderdeel ‘Ask the Expert’.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/fig6_Dublingroep.jpg)",{"id":511,"title":18,"showBlankAside":108,"__component":512},158,"global.social-sharing",{"id":514,"name":18,"jobTitle":18,"__component":515},116,"strapi.author-card",{"id":517,"titleLeft":518,"callToActionTextLeft":157,"callToActionLinkUrlLeft":519,"titleRight":159,"callToActionTextRight":160,"callToActionLinkUrlRight":520,"iconUrlLeft":521,"iconUrlRight":522,"__component":184},184,"Heb je een Microsoft Expert nodig?","https://www.sharevalue.nl/contact","https://www.sharevalue.nl/word-onze-collega/vacatures",{"id":163,"name":164,"alternativeText":18,"caption":18,"width":165,"height":166,"formats":18,"hash":167,"ext":168,"mime":169,"size":170,"url":171,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":172,"updatedAt":173,"documentId":174,"publishedAt":57,"focalPoint":18},{"id":176,"name":177,"alternativeText":18,"caption":18,"width":166,"height":166,"formats":18,"hash":178,"ext":168,"mime":169,"size":179,"url":180,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":181,"updatedAt":182,"documentId":183,"publishedAt":57,"focalPoint":18},{"id":524,"title":525,"aside":18,"postType":149,"limit":150,"expertise":526,"__component":153},127,"Lees ook onze andere berichten",[527],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"published