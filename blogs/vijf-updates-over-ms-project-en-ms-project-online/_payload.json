[{"data":1,"prerenderedAt":607},["ShallowReactive",2],{"collection-blogs-1414737297":3,"_apollo:default":606},{"data":4,"meta":602},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":97,"blocks":480},119,"Vijf updates over MS Project en MS Project Online","Deze update is gebaseerd op mijn bezoek aan de European SharePoint Conference (ESPC17) in Dublin en de PPM-roadmap van Microsoft. De afkorting PPM staat voor Project & Portfolio Management. Al 15 jaar werkt Microsoft aan de ontwikkeling hiervan. Niet alleen voor Project Server (on-premises) maar nu ook voor Project Online.","vijf-updates-over-ms-project-en-ms-project-online","2023-10-13T10:26:43.363Z","2025-04-22T15:20:46.819Z","2023-10-13T10:26:43.307Z","2017-11-24","xarqak7rf2mgmmb1angfi2gq",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},368,"vijf-updates-over-ms-project-en-ms-project-online.jpg",null,1014,676,{"large":22,"small":31,"medium":38,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_vijf_updates_over_ms_project_en_ms_project_online_9b611335f9.jpg","large_vijf_updates_over_ms_project_en_ms_project_online_9b611335f9","image/jpg","large_vijf-updates-over-ms-project-en-ms-project-online.jpg",225.46,1000,667,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vijf_updates_over_ms_project_en_ms_project_online_9b611335f9.jpg","small_vijf_updates_over_ms_project_en_ms_project_online_9b611335f9","small_vijf-updates-over-ms-project-en-ms-project-onlin