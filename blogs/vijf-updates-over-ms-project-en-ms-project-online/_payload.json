elopment_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":23,"url":315,"hash":316,"mime":202,"name":317,"path":18,"size":318,"width":36,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":23,"url":320,"hash":321,"mime":202,"name":322,"path":18,"size":323,"width":43,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":325,"hash":326,"mime":202,"name":327,"path":18,"size":328,"width":223,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":335,"title":336,"subTitle":337,"content":338,"callToActionText":339,"callToActionLink":158,"colorStyle":191,"showAsides":192,"imageUrl":340,"__component":229},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":341,"name":342,"alternativeText":18,"caption":18,"width":196,"height":197,"formats":343,"hash":364,"ext":23,"mime":202,"size":365,"url":366,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":367,"updatedAt":367,"documentId":368,"publishedAt":57,"foca