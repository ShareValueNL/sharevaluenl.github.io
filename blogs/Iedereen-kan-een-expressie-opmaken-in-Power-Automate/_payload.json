ight":239},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_check_94d0553bc3.jpg","small_security_check_94d0553bc3","small_security check.jpg",29.41,{"ext":23,"url":303,"hash":304,"mime":230,"name":305,"path":18,"size":306,"width":43,"height":245},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":308,"hash":309,"mime":230,"name":310,"path":18,"size":311,"width":107,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":138,"id":139,"title":140,"callToActionText":141,"callToActionLinkUrl":142,"body":18,"imageUrl":318},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":144,"metaTitle":145,"metaDescription":146,"structuredData":320,"metaImage":18,"metaSocial":323},{"url":148,"@type":149,"@context":150,"provider":321,"areaServed":322,"description":158,"serviceType":159},{"url":152,"name":153,"@type":154},{"name":156,"@type":157},[],{"id":325,"name":326,"jobTitle":327,"about":18,"createdAt":328,"updatedAt":329,"publishedAt":330,"documentId":331,"image":332,"contactOptions":349},35,"Joost","Consultant","2023-08-18T08:37:46.155Z","2024-03-08T12:46:28.737Z","2023-08-18T08:37:45.395Z","njwfi2eesf691vtpewkga0s1",{"id":333,"name":334,"alternativeText":18,"caption":18,"width":335,"height":336,"formats":337,"hash":344,"ext":79,"mime":82,"size":345,"url":346,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":347,"updatedAt":347,"documentId":348,"publishedAt":58},578,"Joost websitefoto.png",278,326,{"thumbnail":338},{"ext":79,"url":339,"hash":340,"mime":82,"name":341,"path":18,"size":342,"width":343,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Joost_websitefoto_af5f8633d8.png","thumbnail_Joost_websitefoto_af5f8633d8","thumbnail_Joost websitefoto.png",18.83,133,"Joost_websitefoto_af5f8633d8",23.92,"https://incredible-beef-2a6059b946.media.strapiapp.com/Joost_websitefoto_af5f8633d8.png","2024-03-08T12:44:24.321Z","ja3uxwy59jyctja6btxtsrja",[],[351,356,359,362,365,368,371,374,377,380,431],{"__component":352,"id":353,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":355,"introductionText":18},"global.pagesection",270,"","### Hoe ziet dit eruit?\n\nExpressies in Power Automate is een krachtige manier om bewerkingen uit te voeren op gegevens. Nu kan het opmaken van expressies best ingewikkeld zijn, vooral als het gaat om complexe varianten. Het is nu mogelijk om op basis van voorbeelden een expressie op te bouwen. Waardoor je zonder de verschillende functies en bijbehorende syntaxis te kennen die nodig zijn om de gewenste expressies te maken, toch die complexe variant kunt opmaken. Dit is voor elke maker, ervaren of niet, een perfecte toevoeging.  \n  \nAls je tekst, data of getallen wilt opmaken, kan dit vrij gemakkelijk door alleen voorbeelden te geven van de uitvoerindeling die je door de stroom wilt produceren. Power Automate genereert automatisch de expressieformule die je dan direct kan gebruiken in je flow.",{"__component":352,"id":357,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":358,"introductionText":18},271,"### Datum opmaken op basis van voorbeelden.\n\nHoe gebruik je deze functionaliteit? Stel je voor: je gebruikt een SharePoint-lijst met reserveringen op producten die je uitleent voor twee weken. Als de twee weken verlopen zijn, wil je een e-mail verzenden naar de persoon die het product heeft geleend met de vraag deze in te leveren. Standaard noteert de SharePoint-indeling data als volgt: 2023-05-14. Maar dit wil je in het e-mailmeldingsbericht weergeven als 14 mei.  \nLaten we eens kijken hoe we de notatie van de datum met opmaakgegevens kunnen wijzigen aan de hand van voorbeelden.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_1_Blog_Joost_Iedereen_kan_een.png)",{"__component":352,"id":360,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":361,"introductionText":18},272,"Wanneer je de Flow bewerkt in de Power Automate-ontwerper, selecteer je de actie waarin je de opgemaakte datum wilt invoegen en ga je vervolgens naar een tekstveld op de kaart.  \nSelecteer in het venster dat opent de optie **Expressie > Gegevens opmaken op basis van voorbeelden**.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_2_Blog_Joost_Iedereen_kan_een.png)",{"__component":352,"id":363,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":364,"introductionText":18},273,"In de lijst die geopend wordt, vind je alle items die in de stroom weergegeven kunnen worden. Selecteer het item dat je wilt omzetten en geef een voorbeeld van de oorspronkelijke gegevens voor het item dat je in de vorige stap hebt geselecteerd.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_3_Blog_Joost_Iedereen_kan_een.png)",{"__component":352,"id":366,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":367,"introductionText":18},274,"Power Automate geeft de expressie weer waarmee je de gewenste uitvoer te zien krijgt. Dit kan je testen met een andere waarde om te bevestigen dat de expressie doet wat je verwacht.",{"__component":352,"id":369,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":370,"introductionText":18},275,"### Conclusie\n\nMet deze verbetering ben je in staat om makkelijk en snel je expressies vorm te geven, zonder dat je de verschillende functies en bijbehorende syntaxis kent die nodig zijn om de gewenste expressies te maken.  \nDeze functionaliteit is voor iedere maker een verbetering, eenvoudig in gebruik en krachtig in uitvoer. Probeer het eens uit en je zal zien dat het ook jouw Flow beter maakt.",{"__component":352,"id":372,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":373,"introductionText":18},276,"Wil je meer weten over deze functionaliteit of over het Power Platform in het algemeen? Neem dan gerust contact op met ons zodat we de mogelijkheden kunnen bespreken.",{"__component":375,"id":376,"title":18,"showBlankAside":70},"global.social-sharing",51,{"__component":378,"id":379,"name":18,"jobTitle":18},"strapi.author-card",9,{"__component":93,"id":381,"title":382,"aside":18,"postType":96,"limit":97,"expertise":383},20,"Lees ook onze andere berichten",[384],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":385,"blocks":388,"midPageBlocks":395,"seo":426},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":386,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":387},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[389,392],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":390},[391],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71},{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionL