dth":20,"height":241},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_power_platform_39c53ca01e.jpg","small_power_platform_39c53ca01e","small_power platform.jpg",66.01,{"ext":23,"url":274,"hash":275,"mime":26,"name":276,"path":18,"size":277,"width":44,"height":247},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_power_platform_39c53ca01e.jpg","medium_power_platform_39c53ca01e","medium_power platform.jpg",131.84,{"ext":23,"url":279,"hash":280,"mime":26,"name":281,"path":18,"size":282,"width":110,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_power_platform_39c53ca01e.jpg","thumbnail_power_platform_39c53ca01e","thumbnail_power platform.jpg",17.35,"power_platform_39c53ca01e",304.58,"https://incredible-beef-2a6059b946.media.strapiapp.com/power_platform_39c53ca01e.jpg","2024-08-01T11:43:50.458Z","2024-08-01T11:43:59.138Z","gic37kkycc1gz3zx65l4himw",{"__component":119,"id":136,"title":137,"subTitle":18,"content":138,"callToActionText":139,"callToActionLink":113,"colorStyle":130,"showAsides":125,"imageUrl":290},{"id":291,"name":292,"alternativeText":18,"caption":18,"width":19,"height":228,"formats":293,"hash":314,"ext":23,"mime":26,"size":315,"url":316,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":317,"updatedAt":317,"documentId":318,"publishedAt":93},763,"security check.jpg",{"large":294,"small":299,"medium":304,"thumbnail":309},{"ext":23,"url":295,"hash":296,"mime":26,"name":297,"path":18,"size":298,"width":29,"height":235},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_check_94d0553bc3.jpg","large_security_check_94d0553bc3","large_security check.jpg",137.47,{"ext":23,"url":300,"hash":301,"mime":26,"name":302,"path":18,"size":303,"width":20,"height":241},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_check_94d0553bc3.jpg","small_security_check_94d0553bc3","small_security check.jpg",29.41,{"ext":23,"url":305,"hash":306,"mime":26,"name":307,"path":18,"size":308,"width":44,"height":247},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":310,"hash":311,"mime":26,"name":312,"path":18,"size":313,"width":110,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":141,"id":142,"title":143,"callToActionText":144,"callToActionLinkUrl":145,"body":18,"imageUrl":320},{"id":165,"name":166,"alternativeText":18,"caption":18,"width":167,"height":168,"formats":18,"hash":169,"ext":170,"mime":171,"size":172,"url":173,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":174,"updatedAt":175,"documentId":176,"publishedAt":93},{"id":147,"metaTitle":148,"metaDescription":149,"structuredData":322,"metaImage":18,"metaSocial":325},{"url":151,"@type":152,"@context":153,"provider":323,"areaServed":324,"description":161,"serviceType":162},{"url":155,"name":156,"@type":157},{"name":159,"@type":160},[],{"id":327,"name":328,"jobTitle":329,"about":18,"createdAt":330,"updatedAt":331,"publishedAt":332,"documentId":333,"image":334,"contactOptions":351},35,"Joost","Consultant","2023-08-18T08:37:46.155Z","2024-03-08T12:46:28.737Z","2023-08-18T08:37:45.395Z","njwfi2eesf691vtpewkga0s1",{"id":335,"name":336,"alternativeText":18,"caption":18,"width":337,"height":338,"formats":339,"hash":346,"ext":81,"mime":84,"size":347,"url":348,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":349,"updatedAt":349,"documentId":350,"publishedAt":93},578,"Joost websitefoto.png",278,326,{"thumbnail":340},{"ext":81,"url":341,"hash":342,"mime":84,"name":343,"path":18,"size":344,"width":345,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Joost_websitefoto_af5f8633d8.png","thumbnail_Joost_websitefoto_af5f8633d8","thumbnail_Joost websitefoto.png",18.83,133,"Joost_websitefoto_af5f8633d8",23.92,"https://incredible-beef-2a6059b946.media.strapiapp.com/Joost_websitefoto_af5f8633d8.png","2024-03-08T12:44:24.321Z","ja3uxwy59jyctja6btxtsrja",[],[353,357,360,363,366,369,372,375,378],{"__component":354,"id":355,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":356,"introductionText":18},"global.pagesection",5187,"## Wat is het CoE Starter Kit eigenlijk?\nHet Power Platform CoE Starter Kit is een door Microsoft beschikbaar gestelde referentieoplossing met voorbeeldcomponenten om governance rondom Power Platform op te zetten. Het was daarbij geen officieel door Microsoft ondersteund product, maar wel een veelgebruikte starterkit om inzicht te krijgen in apps, flows, eigenaarschap en adoptie. Inmiddels heeft Microsoft bevestigd dat het kit niet langer actief wordt onderhouden en dat de belangrijkste mogelijkheden verschuiven naar het Power Platform Admin Center.\n\n![image1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/image1_2bc0185a4e.png)\n\u003Csmall>Overzicht van het CoE Starter Kit‑dashboard in Power Platform met monitor-, governance‑ en adoptie‑inzichten.\u003C/small>",{"__component":354,"id":358,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":359,"introductionText":18},5188,"## Wat verandert er concreet?\nMicrosoft verschuift de focus naar het Power Platform Admin Center als centrale plek voor governance. Daar komen steeds meer native mogelijkheden beschikbaar voor inzicht, gebruik, monitoring en beheer van apps, flows en omgevingen. Daarmee wordt governance minder afhankelijk van losse toolkit-oplossingen en meer onderdeel van het platform zelf.\nTegelijkertijd betekent het stoppen van het CoE Starter Kit dat organisaties een belangrijk hulpmiddel verliezen. Niet omdat het meteen stopt met werken, maar omdat het langzaam achter gaat lopen.",{"__component":354,"id":361,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":362,"introductionText":18},5189,"## Waar ontstaan de grootste risico’s?\nDe grootste risico’s ontstaan vooral wanneer overzicht, eigenaarschap en governance-afspraken niet meer actueel zijn. Daardoor wordt het lastiger om groei van het platform beheersbaar te houden en nemen beheer- en compliancerisico’s toe.\nJuist daarom kiezen veel organisaties voor een oplossing die snel waarde oplevert en past bij hun governance-behoefte. Met de juiste aanpak is het goed mogelijk om grip te houden op het platform.",{"__component":354,"id":364,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":365,"introductionText":18},5190,"## Zo pak je het pragmatische aan\nEen combinatie van het Power Platform Admin Center en een aanvullende governance-laag blijkt in de praktijk het meest effectief voor Power Platform governance.\nDenk aan een helder dashboard, slim gebruik van data uit het Power Platform Admin Center en gerichte aanvullingen voor rapportage of signalering waar dat echt nodig is. Zo ontstaat stap voor stap meer grip, zonder meteen een groot nieuw traject te starten.\nGeen groot project, maar een beheersbare stap naar meer controle.",{"__component":354,"id":367,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":368,"introductionText":18},5191,"## Conclusie\nHet stoppen van het CoE Starter Kit dwingt organisaties om opnieuw na te denken over hoe ze de beste ondersteuning kunnen geven aan hun Power Platform governance. Niet door het één-op-één te vervangen, maar door slimmer gebruik te maken van wat er al is.\nDe oplossing zit dus niet in een één-op-één vervanging van CoE, maar in een pragmatische aanpak die meebeweegt met het platform. Juist nu is er een kans om governance eenvoudiger, slimmer en toekomstbestendiger in te richten.",{"__component":354,"id":370,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":371,"introductionText":18},5192,"## Wat wij hierin kunnen betekenen\nBij ShareValue helpen we organisaties om Power Platform governance praktisch en beheersbaar in te richten. Daarbij kijken we niet alleen naar wat Microsoft standaard biedt, maar ook naar wat er aanvullend nodig is om echt grip te krijgen op apps, flows, omgevingen, eigenaarschap en risico’s.\nDat kan een slim dashboard zijn, een aanvullende governance-tool of een oplossing op maat die precies aansluit op jouw organisatie. Geen overbodige complexiteit, maar een praktische oplossing die snel inzicht geeft en meegroeit met het platform.\nWil je verkennen wat in jouw situatie de slimste stap is? Dan denken we graag met je mee en laten we zien hoe een passende oplossing of tool eruit kan zien voor jouw organisatie. Neem [hier](https://sharevalue.nl/contact) contact met ons op.",{"__component":373,"id":374,"title":18,"showBlankAside":125},"global.social-sharing",581,{"__component":376,"id":377,"name":328,"jobTitle":329},"strapi.author-card",458,{"__component":109,"id":379,"titleLeft":380,"callToActionTextLeft":381,"callToActionLinkUrlLeft":382,"titleRight":383,"callToActionTextRight":384,"callToActionLinkUrlRight":385,"iconUrlLeft":386,"iconUrlRight":397},725,"Heb je een Power Platform-expert nodig?","Neem contact met ons op","https://sharevalue.nl/contact","Werken in ons Power Platform-team?","Klik hier","https://sharevalue.nl/word-onze-collega/vacatures/expertise/power-platform",{"id":387,"name":388,"alternativeText":18,"caption":18,"width":389,"height":390,"formats":18,"hash":391,"ext":170,"mime":171,"size":392,"url":393,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":394,"updatedAt":395,"documentId":396,"publishedAt":93},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-b