[{"data":1,"prerenderedAt":612},["ShallowReactive",2],{"collection-blogs-1208550866":3,"_apollo:default":611},{"data":4,"meta":607},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":59,"expertises":96,"blocks":485},117,"Dotnét wat sneller naar de eindstreep","Waarom de keuze voor .NET in plaats van Java? Het blijft de eeuwige discussie onder developers, maar ik vind de discussie an sich niet zo heel interessant eigenlijk. Bottom line zijn het uiteindelijk gelijkwaardige alternatieven, sterker nog: .NET en Java hebben op allerlei vlakken veel overeenkomsten.","dotnet-wat-sneller-naar-de-eindstreep","2023-10-13T10:26:43.125Z","2025-04-22T15:16:46.128Z","2023-10-13T10:26:43.096Z","2018-03-13","ve85ae4w6lqpm8g1nhcm9pur",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":18},366,"dotnet-wat-sneller-naar-de-eindstreep.jpg",null,2992,2000,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_dotnet_wat_sneller_naar_de_eindstreep_048bc181c6.jpg","large_dotnet_wat_sneller_naar_de_eindstreep_048bc181c6","image/jpg","large_dotnet-wat-sneller-naar-de-eindstreep.jpg",158.28,1000,668,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_dotnet_wat_sneller_naar_de_eindstreep_048bc181c6.jpg","small_dotnet_wat_sneller_naar_de_eindstreep_048bc181c6","small_dotnet-wat-sneller-naar-de-eindstreep.jpg",40.8,500,334,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incred