[{"data":1,"prerenderedAt":601},["ShallowReactive",2],{"collection-blogs-977438348":3,"_apollo:default":600},{"data":4,"meta":596},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":92,"blocks":475},74,"Taggen in Microsoft Teams; bereik eenvoudig de juiste mensen","Twee weken gelden hebben we deze nieuwe functionaliteit voor het eerst gespot binnen Teams voor Office 365. Het was al mogelijk om documenten in Teams te voorzien van metadata (advies: probeer dit zo min mogelijk te doen!). Met deze nieuwe manier van taggen, kunnen we nu ook onderscheid maken tussen de verschillende teamleden. En dát werkt wel goed!","taggen-in-microsoft-teams-bereik-eenvoudig-de-juiste-mensen","2023-10-13T10:26:35.808Z","2025-04-17T13:53:51.182Z","2023-10-13T10:26:35.753Z","2020-03-18","tosl1kvntxp6lgrra65b5fun",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},323,"taggen-in-microsoft-teams-bereik-eenvoudig-de-juiste-mensen.jpg",null,1600,1200,{"large":22,"small":31,"medium":38,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6.jpg","large_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6","image/jpg","large_taggen-in-microsoft-teams-bereik-eenvoudig-de-juiste-mensen.jpg",170.13,1000,750,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6.jpg","small_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6","small_taggen-in-microsoft-teams-bereik-eenvoudig-de-juiste-mensen.jpg",31.11,500,375,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":30,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6.jpg","medium_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6","medium_taggen-in-microsoft-teams-bereik-eenvoudig-de-juiste-mensen.jpg",84.1,563,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6.jpg","thumbnail_taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6","thumbnail_taggen-in-microsoft-teams-bereik-eenvoudig-de-juiste-mensen.jpg",4.53,208,156,"taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6",467.95,"https://incredible-beef-2a6059b946.media.strapiapp.com/taggen_in_microsoft_teams_bereik_eenvoudig_de_juiste_mensen_8ddbd487b6.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:23:26.824Z","j7dbwvz5buhm4gsq243nxffr","2026-01-05T12:38:34.018Z",{"id":59,"metaTitle":60,"metaDescription":61,"structuredData":62,"metaImage":18,"metaSocial":91},162,"Taggen in Teams: bereik de juiste mensen | ShareValue","Met tags in Microsoft Teams spreek je eenvoudig specifieke groepen aan, zoals ontwikkelaars of beheerders, voor gerichte communicatie.",[63,74],{"url":64,"@type":65,"author":66,"@context":67,"headline":60,"publisher":68,"description":61,"datePublished":13},"https://www.sharevalue.nl/blogs/taggen-in-microsoft-teams-bereik-eenvoudig-de-juiste-mensen","BlogPosting",{},"https://schema.org",{"logo":69,"name":72,"@type":73},{"url":70,"@type":71},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","ShareValue","Organization",{"@type":75,"@context":67,"mainEntity":76},"FAQPage",[77,83,87],{"name":78,"@type":79,"acceptedAnswer":80},"Wat zijn tags in Microsoft Teams?","Question",{"text":81,"@type":82},"Tags in Microsoft Teams zijn labels die je aan teamleden kunt toekennen, zoals 'ontwikkelaar' of 'beheerder'. Hiermee kun je specifieke groepen binnen een team gemakkelijk aanspreken door hun tag te gebruiken in berichten.","Answer",{"name":84,"@type":79,"acceptedAnswer":85},"Hoe voeg ik een tag toe aan een teamlid?",{"text":86,"@type":82},"Ga naar het overzicht van teamleden in Microsoft Teams. In de kolom 'Tags' kun je per lid een of meerdere tags toekennen door op het tag-icoon te klikken en een tagnaam in te voeren.",{"name":88,"@type":79,"acceptedAnswer":89},"Wat zijn de voordelen van het gebruik van tags in Teams?",{"text":90,"@type":82},"Met tags kun je gerichter communiceren binnen grote teams. In plaats van iedereen te taggen, kun je berichten richten aan specifieke groepen, zoals alleen ontwikkelaars of beheerders, wat de efficiëntie en relevantie van communicatie verhoogt.",[],[93],{"id":94,"title":95,"subTitle":96,"description":97,"shortDescription":98,"slug":99,"createdAt":100,"updatedAt":101,"publishedAt":102,"isCoreExpertise":103,"documentId":104,"image":105,"seo":125,"blocks":140,"midPageBlocks":180},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":106,"name":107,"alternativeText":18,"caption":18,"width":108,"height":109,"formats":110,"hash":120,"ext":112,"mime":115,"size":121,"url":122,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":123,"updatedAt":123,"documentId":124,"publishedAt":57,"focalPoint":18},16,"microsoft-365.png",282,130,{"thumbnail":111},{"ext":112,"url":113,"hash":114,"mime":115,"name":116,"path":18,"size":117,"width":118,"height":119},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,245,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":126,"metaTitle":127,"metaDescription":128,"structuredData":129,"metaImage":18,"metaSocial":139},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":130,"@type":131,"@context":67,"provider":132,"areaServed":134,"description":137,"serviceType":138},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":133,"name":72,"@type":73},"https://www.sharevalue.nl",{"name":135,"@type":136},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[141,149],{"id":142,"title":143,"aside":18,"postType":144,"limit":145,"expertise":146,"__component":148},166,"Lees meer over Microsoft 365","alle",3,[147],{"id":94,"title":95,"subTitle":96,"description":97,"shortDescription":98,"slug":99,"createdAt":100,"updatedAt":101,"publishedAt":102,"isCoreExpertise":103,"documentId":104},"strapi.related-kennisbank-list",{"id":150,"titleLeft":151,"callToActionTextLeft":152,"callToActionLinkUrlLeft":153,"titleRight":154,"callToActionTextRight":155,"callToActionLinkUrlRight":156,"iconUrlLeft":157,"iconUrlRight":170,"__component":179},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":57,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":171,"name":172,"alternativeText":18,"caption":18,"width":161,"height":161,"formats":18,"hash":1