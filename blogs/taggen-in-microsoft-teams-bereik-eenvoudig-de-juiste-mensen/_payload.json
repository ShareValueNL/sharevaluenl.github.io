s://incredible-beef-2a6059b946.media.strapiapp.com/small_Teams_43eca91eed.jpg","small_Teams_43eca91eed","small_Teams.jpg",24.28,332,{"ext":23,"url":208,"hash":209,"mime":197,"name":210,"path":18,"size":211,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Teams_43eca91eed.jpg","medium_Teams_43eca91eed","medium_Teams.jpg",45.38,498,{"ext":23,"url":214,"hash":215,"mime":197,"name":216,"path":18,"size":217,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Teams_43eca91eed.jpg","thumbnail_Teams_43eca91eed","thumbnail_Teams.jpg",8.28,235,"Teams_43eca91eed",119.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Teams_43eca91eed.jpg","2024-08-08T09:42:56.910Z","ht6rctym4qbbspr1vnahyrg1","global.alternating-page-section",{"id":226,"title":227,"subTitle":228,"content":229,"callToActionText":230,"callToActionLink":153,"colorStyle":231,"showAsides":187,"imageUrl":232,"__component":224},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"id":233,"name":234,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":235,"hash":256,"ext":23,"mime":197,"size":257,"url":258,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":259,"updatedAt":259,"documentId":260,"publishedAt":57,"focalPoint":18},783,"adoptie.jpg",{"large":236,"small":241,"medium":246,"thumbnail":251},{"ext":23,"url":237,"hash":238,"mime":197,"name":239,"path":18,"size":240,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_adoptie_dc3bbcacaa.jpg","large_adoptie_dc3bbcacaa","large_adoptie.jpg",140.54,{"ext":23,"url":242,"hash":243,"mime":197,"name":244,"path":18,"size":245,"width":36,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_adoptie_dc3bbcacaa.jpg","small_adoptie_dc3bbcacaa","small_adoptie.jpg",46.09,{"ext":23,"url":247,"hash":248,"mime":197,"name":249,"path":18,"size":250,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_adoptie_dc3bbcacaa.jpg","medium_adoptie_dc3bbcacaa","medium_adoptie.jpg",90.06,{"ext":23,"url":252,"hash":253,"mime":197,"name":254,"path":18,"size":255,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_adoptie_dc3bbcacaa.jpg","thumbnail_adoptie_dc3bbcacaa","thumbnail_adoptie.jpg",13.08,"adoptie_dc3bbcacaa",204.86,"https://incredible-beef-2a6059b946.media.strapiapp.com/adoptie_dc3bbcacaa.jpg","2024-08-08T09:47:03.256Z","kqdvjnnutm27pjz49n0b8l8r",{"id":262,"title":263,"subTitle":264,"content":265,"callToActionText":18,"callToActionLink":18,"colorStyle":186,"showAsides":187,"imageUrl":266,"__component":224},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"id":267,"name":268,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":269,"hash":290,"ext":23,"mime":197,"size":291,"url":292,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":293,"updatedAt":293,"documentId":294,"publishedAt":57,"focalPoint":18},784,"trends.jpg",{"large":270,"small":275,"medium":280,"thumbnail":285},{"ext":23,"url":271,"hash":272,"mime":197,"name":273,"path":18,"size":274,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_trends_e84a321990.jpg","large_trends_e84a321990","large_trends.jpg",198.92,{"ext":23,"url":276,"hash":277,"mime":197,"name":278,"path":18,"size":279,"width":36,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_trends_e84a321990.jpg","small_trends_e84a321990","small_trends.jpg",59.76,{"ext":23,"url":281,"hash":282,"mime":197,"name":283,"path":18,"size":284,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":23,"url":286,"hash":287,"mime":197,"name":288,"path":18,"size":289,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"id":296,"title":297,"subTitle":298,"content":299,"callToActionText":18,"callToActionLink":18,"colorStyle":231,"showAsides":187,"imageUrl":300,"__component":224},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":301,"name":302,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":303,"hash":324,"ext":23,"mime":197,"size":325,"url":326,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":327,"updatedAt":327,"documentId":328,"publishedAt":57,"focalPoint":18},785,"microsoft development.jpg",{"large":304,"small":309,"medium":314,"thumbnail":319},{"ext":23,"url":305,"hash":306,"mime":197,"name":307,"path":18,"size":308,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":23,"url":310,"hash":311,"mime":197,"name":312,"path":18,"size":313,"width":36,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":23,"url":315,"hash":316,"mime":197,"name":317,"path":18,"size":318,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":320,"hash":321,"mime":197,"name":322,"path":18,"size":323,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":330,"title":331,"subTitle":332,"content":333,"callToActionText":334,"callToActionLink":153,"colorStyle":186,"showAsides":187,"imageUrl":335,"__component":224},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":336,"name":337,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":338,"hash":359,"ext":23,"mime":197,"size":360,"url":361,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":362,"updatedAt":362,"documentId":363,"publishedAt":57,"focalPoint":18},786,"migratie.jpg",{"large":339,"small":344,"medium":349,"thumbnail":354},{"ext":23,"url":340,"hash":341,"mime":197,"name":342,"path":18,"size":343,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":345,"hash":346,"mime":197,"name":347,"path":18,"size":348,"width":36,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":350,"hash":351,"mime":197,"name":352,"path":18,"size":353,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":355,"hash":356,"mime":197,"name":357,"path":18,"size":358,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":365,"title":366,"subTitle":367,"content":368,"callToActionText":18,"callToActionLink":18,"colorStyle":231,"showAsides":187,"imageUrl":369,"__component":224},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":370,"name":371,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":372,"hash":393,"ext":23,"mime":197,"size":394,"url":395,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":396,"updatedAt":396,"documentId":397,"publishedAt":57,"focalPoint":18},787,"microsoft security.jpg",{"large":373,"small":378,"medium":383,"thumbnail":388},{"ext":23,"url":374,"hash":375,"mime":197,"name":376,"path":18,"size":377,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":379,"hash":380,"mime":197,"name":381,"path":18,"size":382,"width":36,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":384,"hash":385,"mime":197,"name":386,"path":18,"size":387,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":389,"hash":390,"mime":197,"name":391,"path":18,"size":392,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":399,"title":400,"subTitle":401,"content":402,"callToActionText":403,"callToActionLink":404,"colorStyle":186,"showAsides":187,"imageUrl":405,"__component":224},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":406,"name":407,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":408,"hash":429,"ext":23,"mime":197,"size":430,"url":431,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":432,"updatedAt":432,"documentId":433,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":409,"small":414,"medium":419,"thumbnail":424},{"ext":23,"url":410,"hash":411,"mime":197,"name":412,"path":18,"size":413,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":415,"hash":416,"mime":197,"name":417,"path":18,"size":418,"width":36,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":420,"hash":421,"mime":197,"name":422,"path":18,"size":423,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":425,"hash":426,"mime":197,"name":427,"path":18,"size":428,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":435,"title":436,"subTitle":437,"content":438,"callToActionText":18,"callToActionLink":18,"colorStyle":231,"showAsides":187,"imageUrl":439,"__component":224},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":440,"name":441,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":442,"hash":463,"ext":23,"mime":197,"size":464,"url":465,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":466,"updatedAt":466,"documentId":467,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":443,"small":448,"medium":453,"thumbnail":458},{"ext":23,"url":444,"hash":445,"mime":197,"name":446,"path":18,"size":447,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":449,"hash":450,"mime":197,"name":451,"path":18,"size":452,"width":36,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":454,"hash":455,"mime":197,"name":456,"path":18,"size":457,"width":30,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":459,"hash":460,"mime":197,"name":461,"path":18,"size":462,"width":218,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":469,"title":470,"callToActionText":471,"callToActionLinkUrl":472,"body":18,"imageUrl":473,"__component":474},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":57,"focalPoint":18},"call-to-action.single",[476,481,485,489,493,497,501,504,507,509,511,590],{"id":477,"title":18,"asideText":478,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":479,"introductionText":18,"__component":480},1012,"​Samenwerken","## Waarom is dit nodig?\n\nHet toverwoord van Teams is “samenwerken”. Samenwerken aan documenten, notulen en afspraken vastleggen in OneNote, en het belangrijkste: discussies, vragen en beslissingen zijn voor het hele team inzichtelijk. Dat scheelt tijd. Heel veel tijd.\n\nMaar laten we nu één enkel voorbeeld nemen. Een projectteam wordt volgens een standaard methodiek ingedeeld in een aantal kanalen. Bijvoorbeeld:","global.pagesection",{"id":482,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":483,"content":484,"introductionText":18,"__component":480},1013,"![kanalen_van_projectteam.png](https://incredible-beef-2a6059b946.media.strapiapp.com/kanalen_van_projectteam_e1063a5370.png)","In de praktijk bestaat zo’n project uit een diversiteit van medewerkers van verschillende afdelingen. Dit gaat van een ontwikkelaar tot een communicatie-medewerker. En van een manager tot een financieel expert.\n\nHet is met Teams mogelijk om zowel een Team aan te roepen als een Kanaal. In dit geval zou ik dus “@PRJ005498” kunnen gebruiken in mijn gesprekken, maar ik zou ook “@06 Beheer” kunnen aanroepen.\n\nIn beide gevallen krijgen alle gebruikers van dat Team een notificatie. De reden is dat standaard alle gebruikers toegang hebben tot alle data in Teams. En dus heeft iedereen toegang tot “06 Beheer” en krijgt ook iedereen die notificatie. Als we het hebben over een team met 50 personen, is dat niet handig. Dan wil je gewoon die doelgroep aanspreken die nodig is. Maar hoe spreek je dan Functioneel Beheerders of Applicatiebeheerders aan in dit team?",{"id":486,"title":18,"asideText":487,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":488,"introductionText":18,"__component":480},1014,"Taggen","## Tags in Teams\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/taggen_in_teams.png)\n\nBij het overzicht van alle gebruikers in een Team is er nu een extra kolom zichtbaar: “Tags”. Hiermee kun je per team, en per medewerker een of meerdere tags toekennen. Door op het icoontje te klikken kun je een tagnaam bepalen en vervolgens wordt deze bij alle gebruikers zichtbaar om te selecteren.",{"id":490,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":491,"content":492,"introductionText":18,"__component":480},1015,"![tag_toevoegen.png](https://incredible-beef-2a6059b946.media.strapiapp.com/tag_toevoegen_d84fd557eb.png)","Aan de linkerzijde is zo’n kolom ingevuld te zien. Je ziet ook dat er meerdere tags aan meerdere personen toegekend kunnen worden. De lijst met te kiezen tags wordt direct bijgewerkt met alle trefwoorden.\n\n## Waarom moet ik hier nu blij van worden?\n\nDe reden waarom ik zo enthousiast ben over deze functionaliteit heeft vooral te maken met het feit dat we op een natuurlijke wijze een extra dwarsdoorsnede hebben door de informatie- én communicatiestructuur van teams.\n\nTeams heeft immers een zeer hiërarchische opzet. Een team bestaat uit kanalen, een kanaal bestaat uit gesprekken en bestanden en daarin slaan we onze documenten op. Al dan niet in een mappenstructuur.\n\nDe kracht van metadata was altijd dat we die hiërarchische structuur los kunnen laten, maar dat gaat eigenlijk ten koste van het gebruik van Teams. Gebruikers willen immers zo min mogelijk metadata invullen (ik ga hier even kort door de bocht, maar anders zou ik hier een tweede artikel aan kunnen wijden).\n\nBovendien is zo’n tag helemaal geen metadata voor je document. Het is een stukje metadata voor de mens. En dat is vrij nieuw. Voorheen konden we met SharePoint wel met “doelgroepen” werken om informatie te beperken, maar het was niet heel natuurlijk.\n\nMet deze taggingmogelijkheid hebben we met een minimale inspanning de ruimte om een kruisverband te maken over thema’s, documenten en gebruikers.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/tagging_in_berichten.png)\n\nEn zo kan ik dus in een willekeurig kanaal, alleen die ontwikkelaars aanspreken die deze tag ook gebruiken. In deze test-omgeving was er slechts een ontwikkelaar, dus ik had hem ook rechtstreeks kunnen aanspreken.",{"id":494,"title":18,"asideText":495,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":496,"introductionText":18,"__component":480},1016,"Waar kan je het voor gebruiken?","## Toepasbaarheid\n\nMet tagging kan elke teameigenaar trefwoorden toekennen. Het meest gebruikt is om dit op basis van verschillende functies te doen. Zo kunnen we in bovenstaand voorbeeld bij een gesprek dit richten aan “@ontwikkelaar” waardoor alleen de teamleden met dit trefwoord een melding krijgen. En dat staat dus los van het kanaal waar dit gesprek plaatsvindt.\n\nJe kunt ook denken aan onderwerpen als “tag”. Daarmee zou je in een themakanaal met veel gebruikers onderscheid kunnen maken tussen de verschillende subthema’s of actualiteiten.",{"id":498,"title":18,"asideText":499,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":500,"introductionText":18,"__component":480},1017,"","## Admin\n\nHet gebruik van tags kunnen door de Teams Admin in- en uitgeschakeld worden. Hierbij zijn de volgende opties zichtbaar:\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/tags_aanzetten_als_admin.png)\n\nEen van de meest gevraagde opties is waarschijnlijk dat de medewerker zélf zijn tags kan toevoegen aan zijn profiel. In bovenstaand screenshot staat deze optie centraal uitgesteld. Dit is de standaardinstelling en dient dus éénmaal te worden geactiveerd door de Teams Admin.\n\nHet gebruik van standaard tags is af te raden omdat Teams juist veelal kleine eilanden zijn waar medewerkers verschillende rollen kunnen hebben. Je wilt die flexibiliteit echt aan het team zelf overlaten.\n\nDe Teameigenaar heeft overigens alleen de volgende optie tot zijn beschikking:\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/teameigenaar.png)",{"id":502,"title":18,"asideText":499,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":503,"introductionText":18,"__component":480},1018,"## Ontwikkelaar\n\nVanuit een ontwikkelaarsoogpunt is mij helaas nog niet bekend waar deze tags worden vastgelegd. Ik had verwacht dat dit in de Termstore zou worden opgeslagen, maar daar kon ik het niet terugvinden. Mijn vermoeden is nu dat dit op dezelfde plek wordt opgeslagen als de gesprekken in Teams (dus ergens in Azure). Zodra dit definitief bekend is, zal ik dit artikel bijwerken met een juiste bronverwijzing.",{"id":505,"title":18,"asideText":499,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":506,"introductionText":18,"__component":480},1019,"## Toekomst\n\nDe tag-mogelijkheden zijn nu al erg fijn, maar het beperkt ons nu wel tot gesprekken in Chats. Het zou ideaal zijn wanneer we deze tags ook standaard bij documenten kunnen toekennen. Dan hoeven ze maar op één plek te worden gemaakt en kunnen ze door een heel team zorgen voor nieuwe verbanden. Het is echter niet de verwachting dat dit er op korte termijn aan komt, gezien gesprekken en bestanden op gescheiden plekken worden bewaard. Dat betekent helaas dat er straks op Teamniveau tags aangemaakt worden voor medewerkers en op SharePoint niveau metadata wordt gemaakt voor Bestanden.\n\nEen ander, potentieel nadeel is dat deze trefwoorden per Team in te stellen zijn en niet over meerdere teams heen. Nu is het tegenwoordig eenvoudig om een Team te baseren op een bestaand Team, maar daarbij worden de trefwoorden niet meegenomen. Er zijn naar mijn weten ook geen plannen om dit centraal te gaan beheren. Maar eerlijk gezegd, wil ik deze functie voorlopig ook nog helemaal niet zien omdat het een averechts effect kan hebben.\n\nMocht je nog vragen hebben, [neem dan vrijblijvend contact met ons op](/contact). Wellicht dat ik of een van mijn collega’s dan al je vragen kunnen beantwoorden.",{"id":119,"title":18,"showBlankAside":103,"__component":508},"global.social-sharing",{"id":160,"name":18,"jobTitle":18,"__component":510},"strapi.author-card",{"id":512,"title":513,"aside":18,"postType":144,"limit":145,"expertise":514,"__component":148},82,"Lees ook onze andere berichten",[515],{"id":94,"title":95,"subTitle":96,"description":97,"shortDescription":98,"slug":99,"createdAt":100,"updatedAt":101,"publishedAt":102,"isCoreExpertise":103,"documentId":104,"image":516,"seo":519,"blocks":524,"midPageBlocks":531},{"id":106,"name":107,"alternativeText":18,"caption":18,"width":108,"height":109,"formats":517,"hash":120,"ext":112,"mime":115,"size":121,"url":122,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":123,"updatedAt":123,"documentId":124,"publishedAt":57,"focalPoint":18},{"thumbnail":518},{"ext":112,"url":113,"hash":114,"mime":115,"name":116,"path":18,"size":117,"width":118,"height":119},{"id":12