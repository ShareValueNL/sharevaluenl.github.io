ible-beef-2a6059b946.media.strapiapp.com/medium_virtuele_werelden_ervaren_met_sharepoint_spaces_c35c2485b1.jpg","medium_virtuele_werelden_ervaren_met_sharepoint_spaces_c35c2485b1","medium_virtuele-werelden-ervaren-met-sharepoint-spaces.jpg",50.93,750,293,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_virtuele_werelden_ervaren_met_sharepoint_spaces_c35c2485b1.jpg","thumbnail_virtuele_werelden_ervaren_met_sharepoint_spaces_c35c2485b1","thumbnail_virtuele-werelden-ervaren-met-sharepoint-spaces.jpg",5.76,245,96,"virtuele_werelden_ervaren_met_sharepoint_spaces_c35c2485b1",152.13,"https://incredible-beef-2a6059b946.media.strapiapp.com/virtuele_werelden_ervaren_met_sharepoint_spaces_c35c2485b1.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:22:40.308Z","psitspqy61akq6zpk5eldlhn","2026-01-05T12:38:34.018Z",{"id":59,"metaTitle":60,"metaDescription":61,"structuredData":62,"metaImage":18,"metaSocial":93},141,"Ervaar virtuele werelden met SharePoint Spaces | ShareValue​","Ontdek hoe SharePoint Spaces virtuele 3D-omgevingen creëert voor intranet, onboarding en productpresentaties binnen Microsoft 365.",[63,76],{"url":64,"@type":65,"author":66,"@context":67,"headline":68,"publisher":69,"description":61,"datePublished":75},"https://www.sharevalue.nl/blogs/virtuele-werelden-ervaren-met-sharepoint-spaces","BlogPosting",{},"https://schema.org","Ervaar virtuele werelden met SharePoint Spaces | ShareValue",{"logo":70,"name":73,"@type":74},{"url":71,"@type":72},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","ShareValue","Organization","2020-11-01",{"@type":77,"@context":67,"mainEntity":78},"FAQPage",[79,85,89],{"name":80,"@type":81,"acceptedAnswer":82},"Wat is SharePoint Spaces?","Question",{"text":83,"@type":84},"SharePoint Spaces is een webgebaseerd platform waarmee je interactieve 3D-omgevingen kunt creëren binnen SharePoint, zoals virtuele tours en productpresentaties.","Answer",{"name":86,"@type":81,"acceptedAnswer":87},"Welke toepassingen biedt SharePoint Spaces?",{"text":88,"@type":84},"Toepassingen omvatten virtuele onboarding, 3D-productcatalogi, interactieve trainingsomgevingen en virtuele bedrijfsevenementen.",{"name":90,"@type":81,"acceptedAnswer":91},"Is SharePoint Spaces nog beschikbaar?",{"text":92,"@type":84},"Microsoft heeft aangekondigd dat SharePoint Spaces vanaf maart 2025 wordt uitgefaseerd. Voor nieuwe 3D-ervaringen wordt Microsoft Mesh aanbevolen.",[],[95],{"id":96,"title":97,"subTitle":98,"description":99,"shortDescription":100,"slug":101,"createdAt":102,"updatedAt":103,"publishedAt":104,"isCoreExpertise":105,"documentId":106,"image":107,"seo":126,"blocks":141,"midPageBlocks":181},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":108,"name":109,"alternativeText":18,"caption":18,"width":110,"height":111,"formats":112,"hash":121,"ext":114,"mime":117,"size":122,"url":123,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":124,"updatedAt":124,"documentId":125,"publishedAt":57,"focalPoint":18},16,"microsoft-365.png",282,130,{"thumbnail":113},{"ext":114,"url":115,"hash":116,"mime":117,"name":118,"path":18,"size":119,"width":49,"height":120},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":127,"metaTitle":128,"metaDescription":129,"structuredData":130,"metaImage":18,"metaSocial":140},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":131,"@type":132,"@context":67,"provider":133,"areaServed":135,"description":138,"serviceType":139},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":134,"name":73,"@type":74},"https://www.sharevalue.nl",{"name":136,"@type":137},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementa