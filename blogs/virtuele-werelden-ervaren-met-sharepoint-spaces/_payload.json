b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":321,"hash":322,"mime":197,"name":323,"path":18,"size":324,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":331,"title":332,"subTitle":333,"content":334,"callToActionText":335,"callToActionLink":154,"colorStyle":187,"showAsides":188,"imageUrl":336,"__component":225},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":337,"name":338,"alternativeText":18,"caption":18,"width":19,"height":192,"formats":339,"hash":360,"ext":23,"mime":197,"size":361,"url":362,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":363,"updatedAt":363,"documentId":364,"publishedAt":57,"focalPoint":18},786,"migratie.jpg",{"large":340,"small":345,"medium":350,"thumbnail":355},{"ext":23,"url":341,"hash":342,"mime":197,"name":343,"path":18,"size":344,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":346,"hash":347,"mime":197,"name":348,"path":18,"size":349,"width":20,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":351,"hash":352,"mime":197,"name":353,"path":18,"size":354,"width":42,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":356,"hash":357,"mime":197,"name":358,"path":18,"size":359,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":366,"title":367,"subTitle":368,"content":369,"callToActionText":18,"callToActionLink":18,"colorStyle":232,"showAsides":188,"imageUrl":370,"__component":225},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":371,"name":372,"alternativeText":18,"caption":18,"width":19,"height":192,"formats":373,"hash":394,"ext":23,"mime":197,"size":395,"url":396,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":397,"updatedAt":397,"documentId":398,"publishedAt":57,"focalPoint":18},787,"microsoft security.jpg",{"large":374,"small":379,"medium":384,"thumbnail":389},{"ext":23,"url":375,"hash":376,"mime":197,"name":377,"path":18,"size":378,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":380,"hash":381,"mime":197,"name":382,"path":18,"size":383,"width":20,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":385,"hash":386,"mime":197,"name":387,"path":18,"size":388,"width":42,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":390,"hash":391,"mime":197,"name":392,"path":18,"size":393,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":400,"title":401,"subTitle":402,"content":403,"callToActionText":404,"callToActionLink":405,"colorStyle":187,"showAsides":188,"imageUrl":406,"__component":225},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":407,"name":408,"alternativeText":18,"caption":18,"width":19,"height":192,"formats":409,"hash":430,"ext":23,"mime":197,"size":431,"url":432,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":433,"updatedAt":433,"documentId":434,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":410,"small":415,"medium":420,"thumbnail":425},{"ext":23,"url":411,"hash":412,"mime":197,"name":413,"path":18,"size":414,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":416,"hash":417,"mime":197,"name":418,"path":18,"size":419,"width":20,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":421,"hash":422,"mime":197,"name":423,"path":18,"size":424,"width":42,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":426,"hash":427,"mime":197,"name":428,"path":18,"size":429,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":436,"title":437,"subTitle":438,"content":439,"callToActionText":18,"callToActionLink":18,"colorStyle":232,"showAsides":188,"imageUrl":440,"__component":225},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":441,"name":442,"alternativeText":18,"caption":18,"width":19,"height":192,"formats":443,"hash":464,"ext":23,"mime":197,"size":465,"url":466,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":467,"updatedAt":467,"documentId":468,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":444,"small":449,"medium":454,"thumbnail":459},{"ext":23,"url":445,"hash":446,"mime":197,"name":447,"path":18,"size":448,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":450,"hash":451,"mime":197,"name":452,"path":18,"size":453,"width":20,"height":206},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":455,"hash":456,"mime":197,"name":457,"path":18,"size":458,"width":42,"height":212},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":460,"hash":461,"mime":197,"name":462,"path":18,"size":463,"width":218,"height":219},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":470,"title":471,"callToActionText":472,"callToActionLinkUrl":473,"body":18,"imageUrl":474,"__component":475},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":159,"name":160,"alternativeText":18,"caption":18,"width":161,"height":162,"formats":18,"hash":163,"ext":164,"mime":165,"size":166,"url":167,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":168,"updatedAt":169,"documentId":170,"publishedAt":57,"focalPoint":18},"call-to-action.single",[477,482,485,489,492,496,499,502,506,509,512,515,518,597],{"id":478,"title":18,"asideText":479,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":480,"introductionText":18,"__component":481},815,"","Waar voor VR eerder een ontwikkelaar nodig was met uitgebreide kennis van game-development, kunnen nu eindgebruikers zelf een virtual reality ervaring in elkaar klikken. Deze SharePoint Space kan vervolgens bekeken worden vanuit de browser. Het is echter vooral gemaakt om beleefd te worden met een virtual reality bril.","global.pagesection",{"id":483,"title":18,"asideText":479,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":484,"introductionText":18,"__component":481},819,"## Hoe maak je een Space?\n\nOm SharePoint Spaces aan te kunnen maken, moet de feature wel geactiveerd zijn. Dit zet je in SharePoint Online aan via site settings > manage site features > Spaces. Wanneer dit zo is, heb je de optie om een Space aan te maken op dezelfde plek waar pagina’s worden aangemaakt. Zie de screenshot hieronder.",{"id":486,"title":18,"asideText":487,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":488,"introductionText":18,"__component":481},818,"Zet de optie voor Spaces aan","![](https://www.sharevalue.nl/images/sharevalue/blogs/SharePoint_Spaces_1.png)",{"id":490,"title":18,"asideText":479,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":491,"introductionText":18,"__component":481},817,"De aangemaakte Space kan het beste gezien worden als een bol (een zogeheten sphere), waarbij de gebruiker in het midden op een structuur staat. De gebruiker kan 360 graden om zich heen kijken en boven en onder zich. De structuur waar de gebruiker op staat, wordt gekozen door de ontwerper van de Space. Hierbij is er keuze uit zes structures.\n\nBuiten de structuur wordt een 360 graden sferische panoramafoto gebruikt als achtergrond. Je kunt hier kiezen voor één van de standaard aanwezige achtergronden, maar ook Een eigen sferische panorama uploaden.",{"id":493,"title":18,"asideText":494,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":495,"introductionText":18,"__component":481},816,"Een sferische panorama als achtergrond","![](https://www.sharevalue.nl/images/sharevalue/blogs/SharePoint_Spaces_2.png)",{"id":497,"title":18,"asideText":479,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":498,"introductionText":18,"__component":481},820,"Een ander belangrijk onderdeel van een Space design is geluid. Met geluid zorg je ervoor dat een gebruiker, die de Space met een VR-bril ervaart, écht het idee heeft op een andere plek te zijn. Deze ervaring wordt dan versterkt door ondersteunende achtergrondgeluiden zoals fabrieksgeluiden of vogels in een bos.",{"id":500,"title":18,"asideText":479,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":501,"introductionText":18,"__component":481},821,"## Wat zet je in je Space?\n\nJe kunt je virtuele ruimte verder inrichten door webparts toe te voegen. Deze webparts plaats je in de ruimte, om zo de Space verder aan te kleden.\n\nDoor het ‘3D models’-webpart te combineren met het ‘tekst en documenten’-webpart kan bijvoorbeeld een display worden gemaakt. In het voorbeeld hieronder zie je een model van een raketmotor met de naam erbij en een factsheet.",{"id":503,"title":18,"asideText":504,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":505,"introductionText":18,"__component":481},822,"3D model met titel en factsheet","![](https://www.sharevalue.nl/images/sharevalue/blogs/SharePoint_Spaces_3.png)",{"id":507,"title":18,"asideText":479,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":508,"introductionText":18,"__component":481},823,"Voor het ‘3D models’-webpart zijn veel modellen standaard beschikbaar, maar ook hier kan je eigen modellen uploaden.\n\nNaast de eerder genoemde webparts, is ook het ‘360 graden tours’-webpart erg interessant. Hiermee kan een 360 graden rondleiding worden gebouwd met behulp van de ingebouwde hulp. Met deze 360 graden tours bouw je bijvoorbeeld onboarding-omgevingen of veiligheidstrainingen.",{"id":510,"title":18,"asideText":479,"underline":188,"centered":188,"blankAside":188,"aside":18,"content":511,"introductionText":18,"__component":481},824,"Wil je meer weten over SharePoint Spaces of wellicht een demo om ons kantoor en SharePoint Spaces in virtual reality te ervaren? [Laat het ons weten](/contact), we vertellen je er graag meer over.",{"id":513,"title":18,"showBlankAside":105,"__component":514},92,"global.social-sharing",{"id":516,"name":18,"jobTitle":18,"__component":517},50,"strapi.author-card",{"id":519,"title":520,"aside":18,"postType":145,"limit":146,"expertise":521,"__component":149},61,"Lees ook onze andere berichten",[522],{"id":96,"title":97,"subTitle":98,"description":99,"shortDescription":100,"slug":101,"createdAt":102,"updatedAt":103,"publishedAt":104,"isCoreExpertise":105,"documentId":106,"image":523,"seo":526,"blocks":531,"midPageBlocks":538},{"id":108,"name":109,"alternativeText":18,"caption":18,"width":110,"height":111,"formats":524,"hash":121,"ext":114,"mime":117,"size":122,"url":123,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":124,"updatedAt":124,"documentId":125,"publishedAt":57,"focalPoint":18},{"thumbnail":525},{"ext":114,"url":115,"hash":116,"mime":117,"name":118,"path":18,"size":119,"width":49,"height":120},{"id":127,"metaTitle":128,"metaDescription":