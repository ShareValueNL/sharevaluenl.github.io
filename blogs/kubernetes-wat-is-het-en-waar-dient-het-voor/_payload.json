updatedAt":165,"documentId":166,"publishedAt":57},{"id":128,"metaTitle":138,"metaDescription":139,"structuredData":354,"metaImage":18,"metaSocial":357},{"url":141,"@type":142,"@context":143,"provider":355,"areaServed":356,"description":151,"serviceType":152},{"url":145,"name":146,"@type":147},{"name":149,"@type":150},[],{"__component":105,"id":359,"titleLeft":107,"callToActionTextLeft":108,"callToActionLinkUrlLeft":360,"titleRight":361,"callToActionTextRight":362,"callToActionLinkUrlRight":363,"iconUrlLeft":364,"iconUrlRight":365},105,"https://www.sharevalue.nl/contact","Hoor van onze experts hoe leuk ShareValue is","Lees de verhalen van onze collega's","https://www.sharevalue.nl/word-onze-collega/collegas-aan-het-woord",{"id":155,"name":156,"alternativeText":18,"caption":18,"width":157,"height":158,"formats":18,"hash":159,"ext":160,"mime":161,"size":162,"url":163,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":164,"updatedAt":165,"documentId":166,"publishedAt":57},{"id":366,"name":367,"alternativeText":18,"caption":18,"width":368,"height":369,"formats":18,"hash":370,"ext":160,"mime":161,"size":371,"url":372,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":373,"updatedAt":374,"documentId":375,"publishedAt":57},7,"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":377,"metaTitle":378,"metaDescription":379,"structuredData":380,"metaImage":18,"metaSocial":407},127,"Wat is Kubernetes en waarom gebruik je het? | ShareValue","Kubernetes helpt bij het beheren van containers. In deze blog lees je wat het is, hoe het werkt en waarom organisaties het inzetten.",[381,390],{"url":382,"@type":383,"author":384,"@context":143,"headline":378,"publisher":385,"description":379,"datePublished":389},"https://www.sharevalue.nl/blogs/kubernetes-wat-is-het-en-waar-dient-het-voor","BlogPosting",{},{"logo":386,"name":146,"@type":147},{"url":387,"@type":388},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","2023-07-06",{"@type":391,"@context":143,"mainEntity":392},"FAQPage",[393,399,403],{"name":394,"@type":395,"acceptedAnswer":396},"Wat is Kubernetes?","Question",{"text":397,"@type":398},"Kubernetes is een open-source platform voor het automatiseren van de uitrol, het beheer en de schaalbaarheid van containerapplicaties.","Answer",{"name":400,"@type":395,"acceptedAnswer":401},"Waarom gebruiken organisaties Kubernetes?",{"text":402,"@type":398},"Omdat het zorgt voor flexibiliteit, schaalbaarheid en betrouwbaarheid bij het beheren van moderne applicaties in containers.",{"name":404,"@type":395,"acceptedAnswer":405},"Is Kubernetes moeilijk om mee te starten?",{"text":406,"@type":398},"Het heeft een leercurve, maar tools zoals Azure Kubernetes Service maken het eenvoudiger om ermee aan de slag te gaan.",[],{"pagination":409},{"page":60,"pageSize":410},100,{},1782136880248]