[{"data":1,"prerenderedAt":529},["ShallowReactive",2],{"collection-blogs-1119510909":3,"_apollo:default":528},{"data":4,"meta":525},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"seo":58,"expertises":97,"author":302,"blocks":367},27,"De Cloud van Microsoft verkennen? Dat kan met een Azure free account","Heb je weleens de behoefte gehad om iets uit te proberen in Microsoft Azure? Of ben je simpelweg nieuw in de Cloud oplossing van Microsoft en wil je een kijkje nemen achter de schermen? Dan is dat goed mogelijk met een Azure free account waarvoor jij, zoals de term free al weggeeft, je gratis kunt aanmelden voor het gebruik van Azure.","de-cloud-van-microsoft-verkennen-dat-kan-met-een-azure-free-account","2023-10-13T10:26:26.955Z","2025-04-15T12:38:17.621Z","2023-10-13T10:26:26.630Z","2022-12-08","ho0zg7tndku5y0nntgpovv51",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},276,"de-cloud-van-microsoft-verkennen-dat-kan-met-een-azure-free-account.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_de_cloud_van_microsoft_verkennen_dat_kan_met_een_azure_free_account_17b3a145cb.jpg","large_de_cloud_van_microsoft_verkennen_dat_kan_met_een_azure_free_account_17b3a145cb","image/jpg","large_de-cloud-van-microsoft-verkennen-dat-kan-met-een-azure-free-account.jpg",39.79,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_de_cloud_van_microsoft_verkennen_dat_kan_met_een_azure_free_account_17