all_security_check_94d0553bc3","small_security check.jpg",29.41,{"ext":23,"url":303,"hash":304,"mime":230,"name":305,"path":18,"size":306,"width":43,"height":245},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":308,"hash":309,"mime":230,"name":310,"path":18,"size":311,"width":107,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":138,"id":139,"title":140,"callToActionText":141,"callToActionLinkUrl":142,"body":18,"imageUrl":318},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":144,"metaTitle":145,"metaDescription":146,"structuredData":320,"metaImage":18,"metaSocial":323},{"url":148,"@type":149,"@context":150,"provider":321,"areaServed":322,"description":158,"serviceType":159},{"url":152,"name":153,"@type":154},{"name":156,"@type":157},[],{"id":325,"name":326,"jobTitle":327,"about":18,"createdAt":328,"updatedAt":329,"publishedAt":330,"documentId":331,"image":332,"contactOptions":349},35,"Joost","Consultant","2023-08-18T08:37:46.155Z","2024-03-08T12:46:28.737Z","2023-08-18T08:37:45.395Z","njwfi2eesf691vtpewkga0s1",{"id":333,"name":334,"alternativeText":18,"caption":18,"width":335,"height":336,"formats":337,"hash":344,"ext":79,"mime":82,"size":345,"url":346,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":347,"updatedAt":347,"documentId":348,"publishedAt":58},578,"Joost websitefoto.png",278,326,{"thumbnail":338},{"ext":79,"url":339,"hash":340,"mime":82,"name":341,"path":18,"size":342,"width":343,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Joost_websitefoto_af5f8633d8.png","thumbnail_Joost_websitefoto_af5f8633d8","thumbnail_Joost websitefoto.png",18.83,133,"Joost_websitefoto_af5f8633d8",23.92,"https://incredible-beef-2a6059b946.media.strapiapp.com/Joost_websitefoto_af5f8633d8.png","2024-03-08T12:44:24.321Z","ja3uxwy59jyctja6btxtsrja",[],[351,356,359,362,365,367,370,373,376,427],{"__component":352,"id":353,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":355,"introductionText":18},"global.pagesection",288,"","## Hoe ziet deze moderne, vernieuwende uiterlijk eruit?\n\n### Opdrachtbalk\n\nDe opdrachtbalk is in een aparte ‘zwevende’ sectie boven aan de pagina terug te vinden.   \nDit uiterlijk is afgestemd op de Microsoft 365-ervaring met afgeronde hoeken en hoogte.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_1.png)",{"__component":352,"id":357,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":358,"introductionText":18},291,"### Weergavepagina’s\n\nDe grootste verandering op weergavepagina's is de overschakeling van het alleen-lezen raster naar het Power Apps-rasterbesturingselement. Dit biedt de mogelijkheid voor oneindig scrollen door pagina’s. Het Power Apps-rasterbesturingselement ondersteunt ook online bewerken, waarmee gebruikers records kunnen bekijken, openen en bewerken vanuit weergaven en subrasters. \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_2.png)",{"__component":352,"id":360,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":361,"introductionText":18},289,"### Formulieren\n\nHet onderdeel formulieren gebruikt ook de nieuwe opdrachtbalk. Maar hier zijn meer aanpassingen gedaan zoals vernieuwde kopteksten, tabbladen en secties. De snelle weergaven, kaartformulieren, kopteksten, sitemaps en de tijdlijn besturingselementen hebben een verandering in uiterlijk doorgemaakt.  \nHieronder zie je een formulierpagina met een modern, vernieuwd uiterlijk.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_3.png)",{"__component":352,"id":363,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":364,"introductionText":18},290,"### Veldbesturingselementen\n\nOok de veldbesturingselementen zoals tekst invoer, actie-invoer, opzoeken zijn gebouwd en ontworpen met Fluent-componenten. Deze hebben nu een meer gestroomlijnd ontwerp. De pictogrammen zijn verplaatst naar de rechterkant van het veld labels. Sommige overbodige pictogrammen zijn verwijderd, als voorbeeld: het slotpictogram wordt niet weergegeven voor alleen-lezen velden.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_4.png)",{"__component":352,"id":44,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":366,"introductionText":18},"## Conclusie\n\nHet Microsoft Fluent uiterlijk wordt de nieuwe moderne, snelle en efficiënte standaard voor veel Microsoft producten. Niet alleen de modelgestuurde apps maar ook andere Power Platform onderdelen worden langzaam getransformeerd in dit uiterlijk. Voor de modelgestuurde app is dit een begin van een modern, en een meer efficiënte manier van werken met je data in een gebruiksvriendelijke en herkenbaar uiterlijk.",{"__component":352,"id":368,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":369,"introductionText":18},293,"Wil je meer weten over deze functionaliteit of over het Power Platform in het algemeen? Neem dan gerust contact op met ons zodat we de mogelijkheden kunnen bespreken.",{"__component":371,"id":372,"title":18,"showBlankAside":70},"global.social-sharing",53,{"__component":374,"id":375,"name":18,"jobTitle":18},"strapi.author-card",11,{"__component":93,"id":377,"title":378,"aside":18,"postType":96,"limit":97,"expertise":379},22,"Lees ook onze andere berichten",[380],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":381,"blocks":384,"midPageBlocks":391,"seo":422},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":382,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":383},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[385,388],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":386},[387],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71},{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":113,"iconUrlLeft":389,"iconUrlRight":390},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":175,"name":176,"alternativeText":18,"caption":18,"width":165,"height":165,"formats":18,"hash":177,"ext":167,"mime":168,"size":178,"url":179,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":180,"updatedAt":181,"documentId":182,"publishedAt":58},[392,399,406,413,420],{"__component":116,"id":117,"title":118,"subTitle":18,"content":119,"callToActionText":120,"callToActionLink":110,"colorStyle":121,"showAsides":122,"imageUrl":393},{"id":186,"name":187,"alternativeText":18,"caption":18,"width":1