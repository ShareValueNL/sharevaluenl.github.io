":188,"name":229,"path":18,"size":230,"width":36,"height":197},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_containers_2e766510ad.jpg","small_containers_2e766510ad","small_containers.jpg",49.69,{"ext":23,"url":232,"hash":233,"mime":188,"name":234,"path":18,"size":235,"width":43,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_containers_2e766510ad.jpg","medium_containers_2e766510ad","medium_containers.jpg",101.49,{"ext":23,"url":237,"hash":238,"mime":188,"name":239,"path":18,"size":240,"width":209,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_containers_2e766510ad.jpg","thumbnail_containers_2e766510ad","thumbnail_containers.jpg",12.65,"containers_2e766510ad",240.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/containers_2e766510ad.jpg","2024-08-08T08:54:58.426Z","idshbfmg66aak9yxdr9d22c7",{"__component":116,"id":129,"title":130,"subTitle":18,"content":131,"callToActionText":18,"callToActionLink":18,"colorStyle":121,"showAsides":122,"imageUrl":247},{"id":248,"name":249,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":250,"hash":271,"ext":23,"mime":188,"size":272,"url":273,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":274,"updatedAt":274,"documentId":275,"publishedAt":58},781,"infrastructure.jpg",{"large":251,"small":256,"medium":261,"thumbnail":266},{"ext":23,"url":252,"hash":253,"mime":188,"name":254,"path":18,"size":255,"width":29,"height":191},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_infrastructure_bf66532759.jpg","large_infrastructure_bf66532759","large_infrastructure.jpg",246.61,{"ext":23,"url":257,"hash":258,"mime":188,"name":259,"path":18,"size":260,"width":36,"height":197},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_infrastructure_bf66532759.jpg","small_infrastructure_bf66532759","small_infrastructure.jpg",69.57,{"ext":23,"url":262,"hash":263,"mime":188,"name":264,"path":18,"size":265,"width":43,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_infrastructure_bf66532759.jpg","medium_infrastructure_bf66532759","medium_infrastructure.jpg",149.51,{"ext":23,"url":267,"hash":268,"mime":188,"name":269,"path":18,"size":270,"width":209,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_infrastructure_bf66532759.jpg","thumbnail_infrastructure_bf66532759","thumbnail_infrastructure.jpg",15.74,"infrastructure_bf66532759",374.88,"https://incredible-beef-2a6059b946.media.strapiapp.com/infrastructure_bf66532759.jpg","2024-08-08T08:58:52.414Z","bmkl03ingwf6ms8pdk5jvmx5",{"__component":133,"id":134,"title":135,"callToActionText":136,"callToActionLinkUrl":137,"body":18,"imageUrl":277},{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":129,"metaTitle":139,"metaDescription":140,"structuredData":279,"metaImage":18,"metaSocial":282},{"url":142,"@type":143,"@context":144,"provider":280,"areaServed":281,"description":152,"serviceType":153},{"url":146,"name":147,"@type":148},{"name":150,"@type":151},[],[284,289,293,297,301,304,307,310,313,357],{"__component":285,"id":286,"title":18,"asideText":287,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":288,"introductionText":18},"global.pagesection",1237,"​Het valt mee, gelukkig","Gelukkig kwam er op 15 oktober 2018 [een nieuw bericht](https://azure.microsoft.com/en-us/blog/azure-powershell-cross-platform-az-module-replacing-azurerm/): de PowerShell module AzureRM stopt en wordt vervangen door de PowerShell Az Module. In [dit artikel van Microsoft](https://docs.microsoft.com/en-us/powershell/azure/migrate-from-azurerm-to-az?view=azps-1.4.0) wordt nog duidelijker dat het alleen gaat om het vervangen van AzureRM door de PowerShell Az Module.\n\nDe eerste release van deze module is uitgekomen op 15 januari en wordt elke 2 weken geüpdatet. De update moet je wel handmatig doorvoeren met het commando Update-Module.",{"__component":285,"id":290,"title":18,"asideText":291,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":292,"introductionText":18},1236,"Hoe stap je over?","## Overstappen naar de Az Module\n\nOp dit ogenblik kan ik nog nergens een einddatum vinden van de AzureRM Module. Toch raad ik iedereen aan om alvast te kijken naar de nieuwe Az Module. Het omzetten van de PowerShell scripts is redelijk eenvoudig.\n\nIk heb zelf nu 20 scripts omgezet. Dit hield voor mij in dat ik in de scripts AzureRM moest vervangen door Az. Een voorbeeld:\n\n*   Restart-AzureRmWebApp => Restart-AzWebApp\n*   Restart-AzureRmWebAppSlot => Restart-AzWebAppSlot\n\nHelaas is het niet altijd zo eenvoudig als hierboven. De PowerShell Az Module is namelijk uitgebreider dan de PowerShell AzureRM Module. Ook hiervan een voorbeeld:\n\n*   New-AzureRmVM => New-AZVM\n\nHierbij zijn alle opties hetzelfde, behalve dat \\[-EnableUltraSSD\\] erbij is gekomen.\n\nDit geldt voor veel cmdlet, dus overzetten kan redelijk snel. Houd echter rekening met de extra opties. En uiteraard: test de scripts na overzetten!\n\nIn de Az Module zit een compatibility-optie die je kunt aanzetten met commando Enable-AzureRmAlias.\n\nAls je dit doet, kun je alvast de nieuwe module gebruiken met je oude PowerShell scripts. Als je echter met sessions werkt, kan dit helaas niet. Dan moet je het script wel omzetten.",{"__component":285,"id":294,"title":18,"asideText":295,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":296,"introductionText":18},1238,"Wat zijn de pluspunten?","## Mijn favoriete onderdelen van PowerShell Az\n\nEr is veel positiefs te melden over de nieuwe module. Twee onderdelen springen voor mij echter boven de andere onderdelen uit. Dit zijn de volgende twee:",{"__component":285,"id":298,"title":18,"asideText":299,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":300,"introductionText":18},1239,"","### 1\\. Completers\n\nWat ik zelf het mooiste vind aan de nieuwe module zijn de Completers. Ik krijg regelmatig de vraag wat het Resource ID is van een bepaalde VM. Dit was altijd lastig te achterhalen doordat PowerShell het afkapte. Nu is dit niet meer het geval!\n\nDit geldt ook voor de locatie; die is nu ook volledig te zien en wordt niet meer afgekapt. Lees hier meer over in [dit artikel van Microsoft](https://azure.microsoft.com/en-us/blog/completers-in-azure-powershell/).",{"__component":285,"id":302,"title":18,"asideText":299,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":303,"introductionText":18},1240,"### 2\\. Cross-platform\n\nDe PowerShell Az Module werkt ook met PowerShell core en is hiermee dus [Cross-platform](https://azure.microsoft.com/nl-nl/blog/azure-powershell-az-module-version-1/).\n\nMijn advies aan alle Azure-engineers is dus om alvast over te stappen naar de nieuwe PowerShell Az Module. Het is wellicht nog niet noodzakelijk, het heeft zeker voordelen. En je kan het maar alvast geregeld hebben, mocht AzureRM toch eens ophouden te bestaan.",{"__component":285,"id":305,"title":18,"asideText":299,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":306,"introductionText":18},1241,"Wil je overstappen naar de nieuwe module, maar kan je daar hulp bij gebruiken van een van onze experts? [Neem contact op om een afspraak te maken](/contact)!",{"__component":308,"id":309,"title":18,"showBlankAside":70},"global.social-sharing",135,{"__component":311,"id":312,"name":18,"jobTitle":18},"strapi.author-card",93,{"__component":93,"id":314,"title":315,"aside":18,"postType":96,"limit":97,"expertise":316},104,"Lees ook onze andere berichten",[317],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":318,"blocks":321,"midPageBlocks":328,"seo":352},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":319,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":320},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[322,325],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":323},[324],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71},{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":113,"iconUrlLeft":326,"iconUrlRight":327},{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":169,"name":170,"alternativeText":18,"caption":18,"width":159,"height":159,"formats":18,"hash":171,"ext":161,"mime":162,"size":172,"url":173,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":174,"updatedAt":175,"documentId":176,"publishedAt":58},[329,336,343,350],{"__component":116,"id":117,"title":118,"subTitle":18,"content":119,"callToActionText":120,"callToActionLink":110,"colorStyle":121,"showAsides":122,"imageUrl":330},{"id":180,"name":181,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":331,"hash":211,"ext":23,"mime":188,"size":212,"url":213,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":214,"updatedAt":214,"documentId":215,"publishedAt":58},{"large":332,"small":333,"medium":334,"thumbnail":335},{"ext":23,"url":186,"hash":187,"mime":188,"name":189,"path":18,"size":190,"width":29,"height":191},{"ext":23,"url":193,"hash":194,"mime":188,"name":195,"path":18,"size":196,"width":36,"height":197},{"ext":23,"url":199,"hash":200,"mime":188,"name":201,"path":18,"size":202,"width":43,"height":203},{"ext":23,"url":205,"hash":206,"mime":188,"name":207,"path":18,"size":208,"width":209,"height":210},{"__component":116,"id":124,"title":125,"subTitle":18,"content":126,"callToActionText":18,"callToActionLink":18,"colorStyle":127,"showAsides":122,"imageUrl":337},{"id":218,"name":219,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":338,"hash":241,"ext":23,"mime":188,"size":242,"url":243,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":244,"updatedAt":244,"documentId":245,"publishedAt":58},{"large":339,"small":340,"medium":341,"thumbnail":342},{"ext":23,"url":222,"hash":223,"mime":188,"name":224,"path":18,"size":225,"width":29,"height":191},{"ext":23,"url":227,"hash":228,"mime":188,"name":229,"path":18,"size":230,"width":36,"height":197},{"ext":23,"url":232,"hash":233,"mime":188,"name":234,"path":18,"size":235,"width":43,"height":203},{"ext":23,"url":237,"hash":238,"mime":188,"name":239,"path":18,"size":240,"width":209,"height":210},{"__component":116,"id":129,"title":130,"subTitle":18,"content":131,"callToActionText":18,"callToActionLink":18,"colorStyle":121,"showAsides":122,"imageUrl":344},{"id":248,"name":249,"alternativeText":18,"caption":18,"width":182,"height":183,"formats":345,"hash":271,"ext":23,"mime":188,"size":272,"url":273,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":274,"updatedAt":274,"documentId":275,"publishedAt":58},{"large":346,"small":347,"medium":348,"thumbnail":349},{"ext":23,"url":252,"hash":253,"mime":188,"name":254,"path":18,"size":255,"width":29,"height":191},{"ext":23,"url":257,"hash":258,"mime":188,"name":259,"path":18,"size":260,"width":36,"height":197},{"ext":23,"url":262,"hash":263,"mime":188,"name":264,"path":18,"size":265,"width":43,"height":203},{"ext":23,"url":267,"hash":268,"mime":188,"name":269,"path":18,"size":270,"width":209,"height":210},{"__component":133,"id":134,"title":135,"callToActionText":136,"callToActionLinkUrl":137,"body":18,"imageUrl":351},{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":129,"metaTitle":139,"metaDescription":140,"structuredData":353,"metaImage":18,"metaSocial":356},{"url":142,"@type":143,"@context":144,"provider":354,"areaServed":355,"description":152,"serviceType":153},{"url":146,"name":147,"@type":148},{"name":150,"@type":151},[],{"__component":106,"id":358,"titleLeft":359,"callToActionTextLeft":109,"callToActionLinkUrlLeft":360,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":361,"iconUrlLeft":362,"iconUrlRight":363},162,"Heb je een Microsoft Expert nodig?","https://www.sharevalue.nl/contact","https://www.sharevalue.nl/word-onze-collega/vacatures",{"id":156,"name":157,"alternativeText":18,"caption":18,"width":158,"height":159,"formats":18,"hash":160,"ext":161,"mime":162,"size":163,"url":164,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":165,"updatedAt":166,"documentId":167,"publishedAt":58},{"id":169,"name":170,"alternativeText":18,"caption":18,"width":159,"height":159,"formats":18,"hash":171,"ext":161,"mime":162,"size":172,"url":173,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":174,"updatedAt":175,"documentId":176,"publishedAt":58},{"id":365,"metaTitle":366,"metaDescription":367,"structuredData":368,"metaImage":18,"metaSocial":394},184,"Overstappen naar PowerShell Az Module | ShareValue","Leer hoe je eenvoudig migreert van AzureRM naar de PowerShell Az Module, inclusief tips voor cmdlet-aanpassingen en compatibiliteit.",[369,377],{"url":370,"@type":371,"author":372,"@context":144,"headline":366,"publisher":373,"description":367,"datePublished":13},"https://www.sharevalue.nl/blogs/hoe-stap-je-over-naar-de-nieuwe-powershell-az-module","BlogPosting",{},{"logo":374,"name":147,"@type":148},{"url":375,"@type":376},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject",{"@type":378,"@context":144,"mainEntity":379},"FAQPage",[380,386,390],{"name":381,"@type":382,"acceptedAnswer":383},"Waarom overstappen naar de PowerShell Az Module?","Question",{"text":384,"@type":385},"De Az Module is de opvolger van AzureRM, biedt cross-platform ondersteuning en wordt regelmatig bijgewerkt met nieuwe functies en verbeteringen.","Answer",{"name":387,"@type":382,"acceptedAnswer":388},"Hoe migreer ik mijn scripts van AzureRM naar Az?",{"text":389,"@type":385},"Vervang 'AzureRM' door 'Az' in je cmdlets, bijvoorbeeld 'Restart-AzureRmWebApp' wordt 'Restart-AzWebApp'. Let op eventuele extra parameters in de nieuwe module.",{"name":391,"@type":382,"acceptedAnswer":392},"Wat is de functie van 'Enable-AzureRmAlias'?",{"text":393,"@type":385},"Met 'Enable-AzureRmAlias' kun je oude AzureRM-cmdlets blijven gebruiken als aliassen voor de nieuwe Az-cmdlets, wat de migratie vergemakkelijkt.",[],{"pagination":396},{"page":61,"pageSize":397},100,{},1780405237530]