0,"url":281,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":282,"updatedAt":282,"documentId":283,"publishedAt":118,"focalPoint":18},{"large":350,"small":351,"medium":352,"thumbnail":353},{"ext":23,"url":260,"hash":261,"mime":26,"name":262,"path":18,"size":263,"width":29,"height":192},{"ext":23,"url":265,"hash":266,"mime":26,"name":267,"path":18,"size":268,"width":20,"height":198},{"ext":23,"url":270,"hash":271,"mime":26,"name":272,"path":18,"size":273,"width":44,"height":204},{"ext":23,"url":275,"hash":276,"mime":26,"name":277,"path":18,"size":278,"width":210,"height":211},{"id":285,"title":286,"callToActionText":287,"callToActionLinkUrl":288,"body":18,"imageUrl":355,"__component":290},{"id":152,"name":153,"alternativeText":18,"caption":18,"width":154,"height":155,"formats":18,"hash":156,"ext":157,"mime":158,"size":159,"url":160,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":161,"updatedAt":162,"documentId":163,"publishedAt":118,"focalPoint":18},{"id":357,"title":358,"subTitle":358,"description":359,"shortDescription":359,"slug":360,"createdAt":361,"updatedAt":362,"publishedAt":363,"isCoreExpertise":181,"documentId":364,"image":365,"seo":18,"blocks":394,"midPageBlocks":395},9,"Architect","\"","architect","2023-11-10T07:52:25.259Z","2023-11-10T07:53:22.170Z","2023-11-10T07:53:22.058Z","x9hq3mqhktltw90g0k4ina0y",{"id":366,"name":367,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":368,"hash":389,"ext":23,"mime":26,"size":390,"url":391,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":392,"updatedAt":392,"documentId":393,"publishedAt":118,"focalPoint":18},143,"pooltafel.jpg",{"large":369,"small":374,"medium":379,"thumbnail":384},{"ext":23,"url":370,"hash":371,"mime":26,"name":372,"path":18,"size":373,"width":29,"height":30},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_pooltafel_737db83b07.jpg","large_pooltafel_737db83b07","large_pooltafel.jpg",76.89,{"ext":23,"url":375,"hash":376,"mime":26,"name":377,"path":18,"size":378,"width":20,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_pooltafel_737db83b07.jpg","small_pooltafel_737db83b07","small_pooltafel.jpg",26.21,{"ext":23,"url":380,"hash":381,"mime":26,"name":382,"path":18,"size":383,"width":44,"height":45},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_pooltafel_737db83b07.jpg","medium_pooltafel_737db83b07","medium_pooltafel.jpg",49.65,{"ext":23,"url":385,"hash":386,"mime":26,"name":387,"path":18,"size":388,"width":52,"height":53},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_pooltafel_737db83b07.jpg","thumbnail_pooltafel_737db83b07","thumbnail_pooltafel.jpg",7.77,"pooltafel_737db83b07",112.02,"https://incredible-beef-2a6059b946.media.strapiapp.com/pooltafel_737db83b07.jpg","2023-08-24T10:51:19.397Z","ffge4u003fjgklicm2rua4zz",[],[],[397,401,404,407,410,413,416,419,423,428],{"id":398,"title":18,"asideText":18,"underline":181,"centered":181,"blankAside":181,"aside":18,"content":399,"introductionText":18,"__component":400},4594,"## Waarom de oude aanpak niet werkt\n\nHet klassieke perimetermodel, één grote firewall die het kasteel beschermt, is verleden tijd. Dreigingen verschuiven steeds meer naar identiteit en AI-gedreven aanvallen. Werken in de cloud en hybride omgevingen maken grenzen poreus.\nHet gaat vandaag niet meer om een harde buitengrens, maar om inzicht in wie toegang heeft, hoe apparaten zich gedragen en wat er in je netwerk gebeurt.","global.pagesection",{"id":402,"title":18,"asideText":18,"underline":181,"centered":181,"blankAside":181,"aside":18,"content":403,"introductionText":18,"__component":400},4595,"## Identity-first security: zo werkt het\n\nMicrosoft speelt in op die verschuiving met innovaties die het netwerk veranderen van een “doorvoerlaag” naar een intelligent controle- en analyseplatform:\n- AI in Defender XDR → automatische phishing-triage en incidentanalyse.\n- Agent-identiteiten in Entra → ook AI-bots krijgen gecontroleerde toegang.\n- Sentinel Data Lake → schaalbare opslag en analyse van logdata met AI.\n- Conditional Access evolution → What-If simulaties en per-policy reporting.\n\n![Identity-first security in beeld.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Identity_first_security_in_beeld_fae88d78a3.png)\n_Afbeelding: Identity-first security in beeld_\n\nHet netwerk is niet langer alleen een verbindende laag, maar een controle- en analyseplatform. Beveiliging verschuift naar:\n- \u003Cu>Wie\u003C/u> logt er in?\n- \u003Cu>Wat\u003C/u> mag iemand doen?\n- \u003Cu>Hoe\u003C/u> gedraagt een identiteit, device of AI-agent zich?",{"id":405,"title":18,"asideText":18,"underline":181,"centered":181,"blankAside":181,"aside":18,"content":406,"introductionText":18,"__component":400},4596,"## Strategische waarde voor management\n\nHet gesprek over netwerkbeveiliging gaat vaak nog te veel over technische details, terwijl de echte impact op strategisch niveau ligt. Voor bestuurders en managers draait het om continuïteit, reputatie en vertrouwen. Een cyberincident is allang geen IT-probleem meer, maar een direct bedrijfsrisico. Denk aan organisaties die dagenlang stillagen door ransomware of klanten die massaal hun contract opzegden na een datalek.\n\n![Zero Trust als fundament.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Zero_Trust_als_fundament_74158d07b0.png)\n_Afbeelding: Zero Trust als fundament_\n\nDaarom zien we dat investeren in moderne beveiliging steeds vaker wordt neergezet als een businessbeslissing. De voordelen zijn duidelijk:\n- Strategische voorsprong: organisaties die AI-gedreven beveiliging inzetten, reageren sneller en beperken de schade bij incidenten.\n- Business differentiator: klanten en partners werken liever samen met leveranciers die aantoonbaar investeren in moderne beveiliging.\n- Kosten & ROI: AI-ondersteunde security schaalt beter dan handmatige operaties. Minder druk op teams betekent snellere incidentafhandeling.\n- Risicobeheersing: door legacy authenticatie, zwakke tokenflows en onvoldoende monitoring uit te schakelen, verklein je je aanvalsvlak drastisch.",{"id":408,"title":18,"asideText":18,"underline":181,"centered":181,"blankAside":181,"aside":18,"content":409,"introductionText":18,"__component":400},4597,"## Praktische stappen voor technische teams\n\nVoor IT- en securityteams komt vaak de vraag terug: “Wat kunnen we morgen al concreet doen?” Microsoft biedt hiervoor praktische handvatten, zowel voor grote organisaties met een SOC als voor kleinere bedrijven zonder specialistisch team. Hieronder vind je acties die in de praktijk bewezen effectief zijn.\n\n![Microsoft_Defender_Cloud_Sentinel_architecture.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Microsoft_Defender_Cloud_Sentinel_architecture_0d6ea9e371.png)\n_Afbeelding: Hybride monitoring met Sentinel en Defender XDR_\n\nAfhankelijk van de omvang van je organisatie kun je morgen al de eerste stappen zetten. Voor grotere organisaties zijn dit vaak de quick wins, terwijl kleinere bedrijven vooral baat hebben bij deze aanpak.\n\nVoor grotere organisaties (met SOC/SIEM):\n- Start een pilot met de phishing triage-agent in Defender XDR om werklast te verlagen.\n- Gebruik What-If simulaties voor Conditional Access voordat beleid live gaat.\n- Test Sentinel Data Lake voor historische correlaties en forensisch onderzoek.\n- Plan de uitfasering van legacy flows en device code authenticatie.\n- Activeer linkable token identifiers voor beter onderzoek bij incidenten.\n- Richt agent-identiteiten in Entra in zodra AI-toepassingen in gebruik komen.\n\nVoor kleinere organisaties (zonder SOC/SIEM):\n- Activeer MFA en Conditional Access via Microsoft 365 Business Premium.\n- Gebruik de Security & Compliance-portals voor logging en rapportages.\n- Zet Defender for Office 365 en Defender for Endpoint (P1) aan voor bescherming zonder extra tooling.\n- Schakel legacy authentication uit om 90% van brute-force aanvallen te voorkomen.\n- Automatiseer meldingen via Power Automate (bijv. alerts naar Teams of e-mail).",{"id":411,"title":18,"asideText":18,"underline":181,"centered":181,"blankAside":181,"aside":18,"content":412,"introductionText":18,"__component":400},4598,"## Uitdagingen & valkuilen\n\nGeen enkele technologie is een silver bullet. Bij de invoering van moderne netwerkbeveiliging komen altijd obstakels kijken: van licentiekosten tot draagvlak binnen de organisatie.\n\n![Geïntegreerde security-architectuur.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Geintegreerde_security_architectuur_b1ee1c58cc.png)\n_Afbeelding: Geïntegreerde security-architectuur: balans tussen technologie, processen en governance_\n\nOp basis van onze ervaring zijn dit de meest voorkomende struikelblokken die organisaties tegenkomen:\n- Licenties en kosten: veel geavanceerde functies vragen om Entra P1/P2 of E5. Kleine organisaties moeten slim kijken wat al in hun huidige licenties zit.\n- Gefaseerde uitrol: zet nieuwe beleidsregels eerst in report-only mode en voer ze daarna stap voor stap door.\n- Mens en proces: technologie alleen is niet genoeg: training, governance en duidelijke processen zijn net zo belangrijk.\n- Stakeholdermanagement: betrek vroegtijdig compliance, directie en architectuurteams om draagvlak te creëren.",{"id":414,"title":18,"asideText":18,"underline":181,"centered":181,"blankAside":181,"aside":18,"content":415,"introductionText":18,"__component":400},4599,"## Van inzicht naar actie\n\nNetwerkbeveiliging staat niet stil. Wat vijf jaar geleden vooruitstrevend was, is vandaag de basis. Het goede nieuws: veel van de nieuwe innovaties van Microsoft zijn nu al beschikbaar en relatief eenvoudig in te zetten. De vraag is niet óf je ermee aan de slag gaat, maar wanneer.\nWacht niet tot de volgende aanval je raakt. Met een Security Roadmap weet je waar je organisatie vandaag staat en welke stappen het meeste resultaat opleveren.\n\nOnze Security Roadmap bestaat uit:\n- Een eerste analyse van de omgeving (technische check, licenties, instellingen).\n- Interviews met sleutelpersonen uit IT, security en management.\n- Een eindrapport en presentatie met concrete verbeterpunten en een roadmap, afgestemd op groot én klein.\n\nNeem [contact](https://www.sharevalue.nl/contact) met ons op voor een Security Roadmap en ontdek welke stappen vandaag al verschil maken.",{"id":417,"title":18,"showBlankAside":181,"__component":418},528,"global.social-sharing",{"id":420,"name":69,"jobTitle":421,"__component":422},412,"Azure Architect","strapi.author-card",{"id":424,"titleLeft":145,"callToActionTextLeft":146,"callToActionLinkUrlLeft":147,"titleRight":425,"callToActionTextRight":149,"callToActionLinkUrlRight":150,"iconUrlLeft":426,"iconUrlRight":427,"__component":173},617,"Wil je onze collega worden?",{"id":152,"name":153,"alternativeText":18,"caption":18,"width":154,"height":155,"formats":18,"hash":156,"ext":157,"mime":158,"size":159,"url":160,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":161,"updatedAt":162,"documentId":163,"publishedAt":118,"focalPoint":18},{"id":165,"name":166,"alternativeText":18,"caption":18,"width":155,"height":155,"formats":18,"hash":167,"ext":157,"mime":158,"size":168,"url":169,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":170,"updatedAt":171,"documentId":172,"publishedAt":118,"focalPoint":18},{"id":429,"title":137,"aside":18,"postType":430,"limit":139,"expertise":431,"__component":142},460,"blogs",[432],{"id":88,"title":89,"subTitle":90,"description":91,"shortDescription":92,"slug":93,"createdAt":94,"updatedAt":95,"publishedAt":96,"isCoreExpertise":97,"documentId":98,"image":433,"seo":436,"blocks":441,"midPageBlocks":448},{"id":100,"name":101,"alternativeText":18,"caption":18,"width":102,"height":103,"formats":434,"hash":113,"ext":106,"mime":109,"size":114,"url":115,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":116,"updatedAt":116,"documentId":117,"publishedAt":118,"focalP