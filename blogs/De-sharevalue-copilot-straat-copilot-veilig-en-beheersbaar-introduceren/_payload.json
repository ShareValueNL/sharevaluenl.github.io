[{"data":1,"prerenderedAt":655},["ShallowReactive",2],{"collection-blogs--1348015783":3,"_apollo:default":654},{"data":4,"meta":650},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":58,"author":462,"blocks":488,"seo":620},153,"De ShareValue Copilot-straat: Copilot veilig en beheersbaar introduceren","Heb je ooit gewenst dat je een persoonlijke assistent had die je kon helpen met het schrijven van je documenten, presentaties, e-mails en andere teksten? Een assistent die je suggesties geeft, je spelling en grammatica controleert, je stijl verbetert en je creatiever maakt? Dat is precies wat Copilot voor Microsoft 365 doet: het is een generatieve AI-oplossing die je ondersteunt bij al je schrijftaken.","De-sharevalue-copilot-straat-copilot-veilig-en-beheersbaar-introduceren","2024-06-20T08:03:12.803Z","2025-05-08T12:39:27.742Z","2024-06-20T08:03:19.363Z","2024-06-20","t8h0jr9vbcpg26cat1hwb1ur",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57},733,"header copilot.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_header_copilot_b894e96f46.jpg","large_header_copilot_b894e96f46","image/jpeg","large_header copilot.jpg",44.64,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_header_copilot_b894e96f46.jpg","small_header_copilot_b894e96f46","small_header copilot.jpg",15.94,195,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_header_copilot_b894e96f46.jpg","medium_header_copilot_b894e96f46","medium_header copilot.jpg",28.9,750,293,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_header_copilot_b894e96f46.jpg","thumbnail_header_copilot_b894e96f46","thumbnail_header copilot.jpg",5.18,245,96,"header_copilot_b894e96f46",64.29,"https://incredible-beef-2a6059b946.media.strapiapp.com/header_copilot_b894e96f46.jpg","strapi-provider-upload-strapi-cloud","2024-06-20T07:54:37.242Z","q1go857avfjmqc3bsr4kr92h","2026-01-05T12:38:34.018Z",[59],{"id":60,"title":61,"subTitle":62,"description":63,"shortDescription":64,"slug":65,"createdAt":66,"updatedAt":67,"publishedAt":68,"isCoreExpertise":69,"documentId":70,"image":71,"blocks":90,"midPageBlocks":208,"seo":457},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":72,"name":73,"alternativeText":18,"caption":18,"width":74,"height":75,"formats":76,"hash":85,"ext":78,"mime":81,"size":86,"url":87,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":88,"updatedAt":88,"documentId":89,"publishedAt":57},16,"microsoft-365.png",282,130,{"thumbnail":77},{"ext":78,"url":79,"hash":80,"mime":81,"name":82,"path":18,"size":83,"width":49,"height":84},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",[91,185],{"__component":92,"id":93,"title":94,"aside":18,"postType":95,"limit":96,"expertise":97},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",3,[98],{"id":60,"title":61,"subTitle":62,"description":63,"shortDescription":64,"slug":65,"createdAt":66,"updatedAt":67,"publishedAt":68,"isCoreExpertise":69,"documentId":70,"image":99,"blocks":102,"midPageBlocks":113,"seo":168},{"id":72,"name":73,"alternativeText":18,"caption":18,"width":74,"height":75,"formats":100,"hash":85,"ext":78,"mime":81,"size":86,"url":87,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":88,"updatedAt":88,"documentId":89,"publishedAt":57},{"thumbnail":101},{"ext":78,"url":79,"hash":80,"mime":81,"name":82,"path":18,"size":83,"width":49,"height":84},[103,104],{"__component":92,"id":93,"title":94,"aside":18,"postType":95,"limit":96},{"__component":105,"id":106,"titleLeft":107,"callToActionTextLeft":108,"callToActionLinkUrlLeft":109,"titleRight":110,"callToActionTextRight":111,"callToActionLinkUrlRight":112},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[114,122,129,134,139,145,150,157,162],{"__component":115,"id":116,"title":117,"subTitle":118,"content":119,"callToActionText":18,"callToActionLink":18,"colorStyle":120,"showAsides":121},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"__component":115,"id":123,"title":124,"subTitle":125,"content":126,"callToActionText":127,"callToActionLink":109,"colorStyle":128,"showAsides":121},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":115,"id":130,"title":131,"subTitle":132,"content":133,"callToActionText":18,"callToActionLink":18,"colorStyle":120,"showAsides":121},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":115,"id":135,"title":136,"subTitle":137,"content":138,"callToActionText":18,"callToActionLink":18,"colorStyle":128,"showAsides":121},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":115,"id":140,"title":141,"subTitle":142,"content":143,"callToActionText":144,"callToActionLink":109,"colorStyle":120,"showAsides":121},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":115,"id":146,"title":147,"subTitle":148,"content":149,"callToActionText":18,"callToActionLink":18,"colorStyle":128,"showAsides":121},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":115,"id":151,"title":152,"subTitle":153,"content":154,"callToActionText":155,"callToActionLink":156,"colorStyle":120,"showAsides":121},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":115,"id":158,"title":159,"subTitle":160,"content":161,"callToActionText":18,"callToActionLink":18,"colorStyle":128,"showAsides":121},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":163,"id":164,"title":165,"callToActionText":166,"callToActionLinkUrl":167,"body":18},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":169,"metaTitle":170,"metaDescription":171,"structuredData":172},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":173,"@type":174,"@context":175,"provider":176,"areaServed":180,"description":183,"serviceType":184},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":177,"name":178,"@type":179},"https://www.sharevalue.nl","ShareValue","Organization",{"name":181,"@type":182},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":105,"id":106,"titleLeft":107,"callToActionTextLeft":108,"callToActionLinkUrlLeft":109,"titleRight":110,"callToActionTextRight":111,"callToActionLinkUrlRight":112,"iconUrlLeft":186,"iconUrlRight":199},{"id":187,"name":188,"alternativeText":18,"caption":18,"width":189,"height":190,"formats":18,"hash":191,"ext":192,"mime":193,"size":194,"url":195,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":196,"updatedAt":197,"documentId":198,"publishedAt":57},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":200,"name":201,"alternativeText