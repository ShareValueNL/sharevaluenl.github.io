,"name":263,"path":18,"size":264,"width":29,"height":232},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_power_platform_39c53ca01e.jpg","large_power_platform_39c53ca01e","large_power platform.jpg",208.02,{"ext":23,"url":266,"hash":267,"mime":229,"name":268,"path":18,"size":269,"width":36,"height":238},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_power_platform_39c53ca01e.jpg","small_power_platform_39c53ca01e","small_power platform.jpg",66.01,{"ext":23,"url":271,"hash":272,"mime":229,"name":273,"path":18,"size":274,"width":43,"height":244},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_power_platform_39c53ca01e.jpg","medium_power_platform_39c53ca01e","medium_power platform.jpg",131.84,{"ext":23,"url":276,"hash":277,"mime":229,"name":278,"path":18,"size":279,"width":107,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_power_platform_39c53ca01e.jpg","thumbnail_power_platform_39c53ca01e","thumbnail_power platform.jpg",17.35,"power_platform_39c53ca01e",304.58,"https://incredible-beef-2a6059b946.media.strapiapp.com/power_platform_39c53ca01e.jpg","2024-08-01T11:43:50.458Z","2024-08-01T11:43:59.138Z","gic37kkycc1gz3zx65l4himw",{"__component":116,"id":132,"title":133,"subTitle":18,"content":134,"callToActionText":135,"callToActionLink":110,"colorStyle":126,"showAsides":122,"imageUrl":287},{"id":288,"name":289,"alternativeText":18,"caption":18,"width":19,"height":224,"formats":290,"hash":311,"ext":23,"mime":229,"size":312,"url":313,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":314,"updatedAt":314,"documentId":315,"publishedAt":58},763,"security check.jpg",{"large":291,"small":296,"medium":301,"thumbnail":306},{"ext":23,"url":292,"hash":293,"mime":229,"name":294,"path":18,"size":295,"width":29,"height":232},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_check_94d0553bc3.jpg","large_security_check_94d0553bc3","large_security check.jpg",137.47,{"ext":23,"url"