mime":82,"size":344,"url":345,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":346,"updatedAt":346,"documentId":347,"publishedAt":58},578,"Joost websitefoto.png",278,326,{"thumbnail":337},{"ext":79,"url":338,"hash":339,"mime":82,"name":340,"path":18,"size":341,"width":342,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Joost_websitefoto_af5f8633d8.png","thumbnail_Joost_websitefoto_af5f8633d8","thumbnail_Joost websitefoto.png",18.83,133,"Joost_websitefoto_af5f8633d8",23.92,"https://incredible-beef-2a6059b946.media.strapiapp.com/Joost_websitefoto_af5f8633d8.png","2024-03-08T12:44:24.321Z","ja3uxwy59jyctja6btxtsrja",[],[350,355,358,361,364,367,418],{"__component":351,"id":352,"title":18,"asideText":353,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":354,"introductionText":18},"global.pagesection",307,"","Met Power Automate kan je veel uitgebreide acties uitvoeren, maar soms wil je alleen gebruik maken van basisbewerkingen, zoals de huidige tijd ophalen, getallen bij elkaar optellen of een deel van een tekstreeks vervangen.  \n\nDeze basisfunctionaliteit was al aanwezig in Power Automate, waarbij je kon kiezen voor twee verschillende opties: de Dynamic content tab en de Expression tab. Deze twee opties kon je combineren in één actie, hiervoor moest je schakelen tussen de Dynamic content tab en de Expression tab om je actie samen te voegen.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Before-1_Groot_(1).gif)",{"__component":351,"id":356,"title":18,"asideText":353,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":357,"introductionText":18},308,"In de updates van deze maand zit o.a. een wijziging in het uiterlijk van deze functionaliteit. De manier van navigeren binnen de verschillende tabbladen Dynamic content en Expression is ook veranderd. Je kan nu vanuit 1 scherm je complete code opbouwen zonder te navigeren tussen de verschillende tabbladen.  \n\nHiermee zie je direct welke mogelijke velden en opties je kan gebruiken in deze expressie.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/After-2_Groot_(1).gif)",{"__component":351,"id":359,"title":18,"asideText":353,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":360,"introductionText":18},309,"Met deze updates ben je in staat om makkelijk en snel je expressies vorm te geven. Je krijgt tijdens het maken van een expressie een goed beeld van de mogelijkheden. Daarnaast kan je de volledige code van de expressie terugvinden in een duidelijke weergave. Op deze manier maak je met het gebruikersvriendelijk en intuïtief uiterlijk van Power Automate krachtige expressies voor zowel de IT-specialist als voor de Citizen Developer binnen de organisatie.\n\nWil je meer weten over deze functionaliteit of over het Power Platform in het algemeen? Neem dan gerust contact met ons op zodat we de mogelijkheden kunnen bespreken.",{"__component":362,"id":363,"title":18,"showBlankAside":70},"global.social-sharing",56,{"__component":365,"id":366,"name":18,"jobTitle":18},"strapi.author-card",14,{"__component":93,"id":368,"title":369,"aside":18,"postType":96,"limit":97,"expertise":370},25,"Lees ook onze andere berichten",[371],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":372,"blocks":375,"midPageBlocks":382,"seo":413},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":373,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":374},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[376,379],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":377},[378],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"s