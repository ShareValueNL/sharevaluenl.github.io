[{"data":1,"prerenderedAt":451},["ShallowReactive",2],{"collection-blogs--1357840747":3,"_apollo:default":450},{"data":4,"meta":447},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"seo":58,"expertises":98,"author":302,"blocks":369},180,"PIM of PAM? Zo maak je de juiste keuze voor databeveiliging","In een tijd waarin cyberaanvallen steeds geavanceerder worden, is het essentieel dat organisaties hun meest gevoelige systemen en data beschermen. Twee sleuteltechnologieën die hierbij helpen zijn Privileged Identity Management (PIM) en Privileged Access Management (PAM).","pim-of-pam-zo-maak-je-de-juiste-keuze-voor-databeveiliging","2025-06-19T08:22:27.420Z","2025-06-19T10:21:55.961Z","2025-06-19T08:47:27.891Z","2025-06-20","dwg0q998vp8lzc8ogcvtr5rl",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},1151,"header blog faris.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_header_blog_faris_6b4bf440d6.jpg","large_header_blog_faris_6b4bf440d6","image/jpeg","large_header blog faris.jpg",83.4,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_header_blog_faris_6b4bf440d6.jpg","small_header_blog_faris_6b4bf440d6","small_header blog faris.jpg",25.27,195,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_header_blog_faris_6b4bf440d6.jpg","medium_header_blog_faris_6b4bf440d6","medium_header blog faris.jpg",50.81,750,293,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_header_blog_faris_6b4bf440d6.jpg","thumbnail_header_blog_faris_6b4bf440d6","thumbnail_header blog faris.jpg",7.18,245,96,"header_blog_faris_6b4bf440d6",125.26,"https://incredible-beef-2a6059b946.media.strapiapp.com/header_blog_faris_6b4bf440d6.jpg","strapi-provider-upload-strapi-cloud","2025-06-19T08:21:36.402Z","u2stnxtjzgz99uc9kw6k6qlt","2026-01-05T12:38:34.018Z",{"id":59,"metaTitle":60,"metaDescription":61,"structuredData":62,"metaImage":18,"metaSocial":97},236,"PIM of PAM? | ShareValue","Vergelijk PIM en PAM en kies wat het beste past om je gevoelige data en systemen goed te beveiligen.",{"@graph":63,"@context":96},[64,79],{"@type":65,"author":66,"headline":69,"publisher":70,"description":61,"datePublished":75,"mainEntityOfPage":76},"BlogPosting",{"name":67,"@type":68},"ShareValue","Person","PIM of PAM? Zo maak je de juiste keuze voor beveiliging",{"logo":71,"name":67,"@type":74},{"url":72,"@type":73},"https://www.sharevalue.nl/logo.png","ImageObject","Organization","2025-06-19",{"@id":77,"@type":78},"https://www.sharevalue.nl/blogs/pim-of-pam","WebPage",{"@type":80,"mainEntity":81},"FAQPage",[82,88,92],{"name":83,"@type":84,"acceptedAnswer":85},"Wat is het verschil tussen PIM en PAM?","Question",{"text":86,"@type":87},"PIM regelt wie tijdelijk toegang krijgt tot bevoorrechte rollen, PAM beheert hoe die toegang wordt verleend en gemonitord.","Answer",{"name":89,"@type":84,"acceptedAnswer":90},"Wat doet PIM in Microsoft Entra ID?",{"text":91,"@type":87},"PIM in Microsoft Entra ID biedt just-in-time toegang, MFA-verplichting en controle op wie toegang heeft tot kritieke rollen.",{"name":93,"@type":84,"acceptedAnswer":94},"Heb ik PIM of PAM nodig voor mijn organisatie?",{"text":95,"@type":87},"De meeste organisaties hebben baat bij beide: PIM voor tijdelijk rolbeheer en PAM voor bredere toegangscontrole.","https://schema.org",[],[99],{"id":100,"title":101,"subTitle":102,"description":103,"shortDescription":104,"slug":105,"createdAt":106,"updatedAt":107,"publishedAt":108,"isCoreExpertise":109,"documentId":110,"image":111,"seo":130,"blocks":145,"midPageBlocks":185},1,"Azure","Hét cloudcomputing platform van Microsoft","Azure is het cloudcomputing platform van Microsoft, dat zowel Infrastructure as a Service (IaaS) als Platform as a Service (PaaS) biedt. Met dit platform kun je applicaties ontwikkelen of een compleet netwerk hosten, en dit alles op een relatief eenvoudige manier beheren. Omdat Azure wordt gehost in managed datacenters over de hele wereld, kun je jouw netwerk of applicatie wereldwijd beschikbaar maken. Microsoft biedt daarnaast een breed scala aan services, zoals Internet of Things (IoT), Azure Kubernetes, Artificial Intelligence (AI) en oplossingen voor het gebruik van Big Data.\n\nOnze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt. Hierbij leveren wij iedere keer maatwerk, want het programma van eisen ziet er telkens anders uit. Of het nu gaat om de ondersteuning van een Azure team of het volledige beheer, onze Azure experts staan voor je klaar. Meer over ons werk lees je onder andere in onze Azure [klantcases](/kennisbank/klantcases/azure) en [blogs](/kennisbank/blogs/azure).\n\n","Onze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt.","azure","2023-08-17T09:47:20.996Z","2025-04-11T13:11:55.618Z","2023-08-17T09:50:22.095Z",true,"eubwn704tlyata6v2q819fn7",{"id":112,"name":113,"alternativeText":18,"caption":18,"width":114,"height":115,"formats":116,"hash":125,"ext":118,"mime":121,"size":126,"url":127,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":128,"updatedAt":128,"documentId":129,"publishedAt":57,"focalPoint":18},657,"mircosoft azure web.png",282,130,{"thumbnail":117},{"ext":118,"url":119,"hash":120,"mime":121,"name":122,"path":18,"size":123,"width":49,"height":124},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_mircosoft_azure_web_031897ebac.png","thumbnail_mircosoft_azure_web_031897ebac","image/png","thumbnail_mircosoft azure web.png",5.54,113,"mircosoft_azure_web_031897ebac",1.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/mircosoft_azure_web_031897ebac.png","2024-04-05T12:52:48.184Z","z9c21qscgi7eh5jijkc40fzv",{"id":131,"metaTitle":132,"metaDescription":133,"structuredData":134,"metaImage":18,"metaSocial":144},24,"Microsoft Azure-expertise – ShareValue helpt je vooruit","Van beheer tot DevOps: onze Azure-specialisten helpen je om cloudoplossingen slim en veilig in te richten en te optimaliseren.",{"url":135,"@type":136,"@context":96,"provider":137,"areaServed":139,"description":142,"serviceType":143},"https://www.sharevalue.nl/wat-we-doen/azure","Service",{"url":138,"name":67,"@type":74},"https://www.sharevalue.nl",{"name":140,"@type":141},"Nederland","Country","ShareValue helpt organisaties om Microsoft Azure effectief in te zetten. Onze specialisten werken aan cloudmigraties, infrastructuur, security, automation en DevOps-oplossingen.","Microsoft Azure consultancy",[],[146,154],{"id":147,"title":148,"aside":18,"postType":149,"limit":150,"expertise":151,"__component":153},165,"Lees meer over Azure","alle",3,[152],{"id":100,"title":101,"subTitle":102,"description":103,"shortDescription":104,"slug":105,"createdAt":106,"updatedAt":107,"publishedAt":108,"isCoreExpertise":109,"documentId":110},"strapi.related-kennisbank-list",{"id":155,"titleLeft":156,"callToActionTextLeft":157,"callToActionLinkUrlLeft":158,"titleRight":159,"callToActionTextRight":160,"callToActionLinkUrlRight":161,"iconUrlLeft":162,"iconUrlRight":175,"__component":184},209,"Heb je een Azure expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":163,"name":164,"alternativeText":18,"caption":18,"width":165,"height":166,"formats":18,"hash":167,"ext":168,"mime":169,"size":170,"url":171,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":172,"updatedAt":173,"documentId":174,"publishedAt":57,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":176,"name":177,"alternativeText":18,"caption":18,"width":166,"height":166,"formats":18,"hash":178,"ext":168,"mime":169,"size":179,"url":180,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":181,"updatedAt":182,"documentId":183,"publishedAt":57,"focalPoint":18},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[186,229,263,295],{"id":187,"title":188,"subTitle":18,"content":189,"callToActionText":190,"callToActionLink":158,"colorStyle":191,"showAsides":192,"imageUrl":193,"__component":228},25,"Azure Security: veiligheid in de cloud ","Voor organisaties is het belangrijk om de digitale infrastructuur te beveiligen in een steeds complexer wordend cyberlandschap. Onze experts helpen graag met behulp van Azure Security; een reeks beveiligingsdiensten en -functies die door Microsoft Azure wordt aangeboden om bedreigingen te detecteren, te voorkomen en erop te reageren. Enkele belangrijke componenten en functies van Azure Security waarmee wij werken zijn Azure Security Center, Microsoft Entra ID, Azure DDoS Protection en Azure Sentinel.","Neem contact op voor meer informatie","Sugar Glaze",false,{"id":194,"name":195,"alternativeText":18,"caption":18,"width":19,"height":196,"formats":197,"hash":223,"ext":23,"mime":26,"size":224,"url":225,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":226,"updatedAt":226,"documentId":227,"publishedAt":57,"focalPoint":18},779,"security azure.jpg",850,{"large":198,"small":204,"medium":210,"thumbnail":216},{"ext":23,"url":199,"hash":200,"mime":26,"name":201,"path":18,"size":202,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_azure_b1610cf1cb.jpg","large_security_azure_b1610cf1cb","large_security azure.jpg",107.3,664,{"ext":23,"url":205,"hash":206,"mime":26,"name":207,"path":18,"size":208,"width":20,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_azure_b1610cf1cb.jpg","small_security_azure_b1610cf1cb","small_security azure.jpg",39.16,332,{"ext":23,"url":211,"hash":212,"mime":26,"name":213,"path":18,"size":214,"width":42,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_azure_b1610cf1cb.jpg","medium_security_azure_b1610cf1cb","medium_security azure.jpg",71.35,498,{"ext":23,"url":217,"hash":218,"mime":26,"name":219,"path":18,"size":220,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_azure_b1610cf1cb.jpg","thumbnail_security_azure_b1610cf1cb","thumbnail_security azure.jpg",12.37,235,156,"security_azure_b1610cf1cb",150.42,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_azure_b1610cf1cb.jpg","2024-08-08T08:50:26.921Z","z3xlbivuior2upad6adbxjgz","global.alternating-page-section",{"id":230,"title":231,"subTitle":18,"content":232,"callToActionText":18,"callToActionLink":18,"colorStyle":233,"showAsides":192,"imageUrl":234,"__component":228},26,"Azure Kubernetes Service (AKS)","Azure Kubernetes Service (AKS) helpt bij het beheren van applicaties die in containers draaien. Het vereenvoudigt en automatiseert de implementatie, het beheer en de operationele taken van Kubernetes-clusters. Door gebruik te maken van AKS kunnen organisaties zich richten op het ontwikkelen en beheren van hun applicaties, terwijl Microsoft de complexiteit van de Kubernetes-infrastructuur beheert. Hierdoor kunnen organisaties hun software efficiënt, betrouwbaar en kosteneffectief beheren. Doordat onze experts ruime kennis en ervaring hebben met AKS kunnen ze de klanten op een juiste manier helpen.","White",{"id":235,"name":236,"alternativeText":18,"caption":18,"width":19,"height":196,"formats":237,"hash":258,"ext":23,"mime":26,"size":259,"url":260,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":261,"updatedAt":261,"documentId":262,"publishedAt":57,"focalPoint":18},780,"containers.jpg",{"large":238,"small":243,"medium":248,"thumbnail":253},{"ext":23,"url":239,"hash":240,"mime":26,"name":241,"path":18,"size":242,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_containers_2e766510ad.jpg","large_containers_2e766510ad","large_containers.jpg",163.19,{"ext":23,"url":244,"hash":245,"mime":26,"name":246,"path":18,"size":247,"width":20,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_containers_2e766510ad.jpg","small_containers_2e766510ad","small_containers.jpg",49.69,{"ext":23,"url":249,"hash":250,"mime":26,"name":251,"path":18,"size":252,"width":42,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_containers_2e766510ad.jpg","medium_containers_2e766510ad","medium_containers.jpg",101.49,{"ext":23,"url":254,"hash":255,"mime":26,"name":256,"path":18,"size":257,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_containers_2e766510ad.jpg","thumbnail_containers_2e766510ad","thumbnail_containers.jpg",12.65,"containers_2e766510ad",240.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/containers_2e766510ad.jpg","2024-08-08T08:54:58.426Z","idshbfmg66aak9yxdr9d22c7",{"id":131,"title":264,"subTitle":18,"content":265,"callToActionText":18,"callToActionLink":18,"colorStyle":191,"showAsides":192,"imageUrl":266,"__component":228},"Infrastructure as Code (IaC)","Infrastructure as Code (IaC) is het beheren van een Azure cloud-omgeving door middel van code en softwareontwikkelingstechnieken om infrastructuur te automatiseren, te configureren en te beheren. Het biedt versiebeheer voor configuraties, wat samenwerking en terugkeer naar eerdere versies vergemakkelijkt. Bovendien zorgt IaC voor consistentie in verschillende omgevingen en maakt het schaalvergroting eenvoudiger door configuraties te herhalen zonder handmatige ingrepen. \n\nAls je vragen hebt of ondersteuning nodig hebt, kunnen de Azure Experts je alles vertellen over Infrastructure as Code.",{"id":267,"name":268,"alternativeText":18,"caption":18,"width":19,"height":196,"formats":269,"hash":290,"ext":23,"mime":26,"size":291,"url":292,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":293,"updatedAt":293,"documentId":294,"publishedAt":57,"focalPoint":18},781,"infrastructure.jpg",{"large":270,"small":275,"medium":280,"thumbnail":285},{"ext":23,"url":271,"hash":272,"mime":26,"name":273,"path":18,"size":274,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_infrastructure_bf66532759.jpg","large_infrastructure_bf66532759","large_infrastructure.jpg",246.61,{"ext":23,"url":276,"hash":277,"mime":26,"name":278,"path":18,"size":279,"width":20,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_infrastructure_bf66532759.jpg","small_infrastructure_bf66532759","small_infrastructure.jpg",69.57,{"ext":23,"url":281,"hash":282,"mime":26,"name":283,"path":18,"size":284,"width":42,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_infrastructure_bf66532759.jpg","medium_infrastructure_bf66532759","medium_infrastructure.jpg",149.51,{"ext":23,"url":286,"hash":287,"mime":26,"name":288,"path":18,"size":289,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.stra