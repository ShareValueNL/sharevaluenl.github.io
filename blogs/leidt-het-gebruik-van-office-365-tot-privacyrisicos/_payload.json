[{"data":1,"prerenderedAt":618},["ShallowReactive",2],{"collection-blogs--333254683":3,"_apollo:default":617},{"data":4,"meta":613},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":92,"blocks":474},83,"Leidt het gebruik van Office 365 tot privacyrisico’s?","Minister Grapperhaus van Justitie en Veiligheid heeft de Tweede Kamer 1 juli 2019 in een brief laten weten dat het Strategisch Leveranciersmanagement Microsoft Rijk (SLM Microsoft Rijk) er vanuit AVG-perspectief geen bezwaar tegen heeft dat bij SLM Microsoft Rijk aangesloten overheidsorganisaties Microsoft Office ProPlus, Windows 10 Enterprise en Azure gebruiken.","leidt-het-gebruik-van-office-365-tot-privacyrisicos","2023-10-13T10:26:37.429Z","2025-04-22T12:13:28.801Z","2023-10-13T10:26:37.359Z","2019-09-17","z4la3afvke0ph23ikm51tqgt",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},332,"leidt-het-gebruik-van-office-365-tot-privacyrisicos.jpg",null,1600,1200,{"large":22,"small":31,"medium":38,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_leidt_het_gebruik_van_office_365_tot_privacyrisicos_b3e7642c81.jpg","large_leidt_het_gebruik_van_office_365_tot_privacyrisicos_b3e7642c81","image/jpg","large_leidt-het-gebruik-van-office-365-tot-privacyrisicos.jpg",74.48,1000,750,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_leidt_het_gebruik_van_office_365_tot_privacyrisicos_b3e7642c81.jpg","small_leidt_het_gebruik_van_office_365_tot_privacyrisicos_b3e7642c8