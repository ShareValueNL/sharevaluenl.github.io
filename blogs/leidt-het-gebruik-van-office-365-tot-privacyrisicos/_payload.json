36,{"ext":23,"url":314,"hash":315,"mime":197,"name":316,"path":18,"size":317,"width":30,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":319,"hash":320,"mime":197,"name":321,"path":18,"size":322,"width":217,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":329,"title":330,"subTitle":331,"content":332,"callToActionText":333,"callToActionLink":153,"colorStyle":186,"showAsides":187,"imageUrl":334,"__component":223},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":335,"name":336,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":337,"hash":358,"ext":23,"mime":197,"size":359,"url":360,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":361,"updatedAt":361,"documentId":362,"publishedAt":57,"focalPoint":18},786,"migratie.jpg",{"large":338,"small":343,"medium":348,"thumbnail":353},{"ext":23,"url":339,"hash":340,"mime":197,"name":341,"path":18,"size":342,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":344,"hash":345,"mime":197,"name":346,"path":18,"size":347,"width":36,"height":16},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":349,"hash":350,"mime":197,"name":351,"path":18,"size":352,"width":30,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":354,"hash":355,"mime":197,"name":356,"path":18,"size":357,"width":217,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":364,"title":365,"subTitle":366,"content":367,"callToActionText":18,"callToActionLink":18,"colorStyle":230,"showAsides":187,"imageUrl":368,"__component":223},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":369,"name":370,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":371,"hash":392,"ext":23,"mime":197,"size":393,"url":394,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":395,"updatedAt":395,"documentId":396,"publishedAt":57,"focalPoint":18},787,"microsoft security.jpg",{"large":372,"small":377,"medium":382,"thumbnail":387},{"ext":23,"url":373,"hash":374,"mime":197,"name":375,"path":18,"size":376,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":378,"hash":379,"mime":197,"name":380,"path":18,"size":381,"width":36,"height":16},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":383,"hash":384,"mime":197,"name":385,"path":18,"size":386,"width":30,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":388,"hash":389,"mime":197,"name":390,"path":18,"size":391,"width":217,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":398,"title":399,"subTitle":400,"content":401,"callToActionText":402,"callToActionLink":403,"colorStyle":186,"showAsides":187,"imageUrl":404,"__component":223},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":405,"name":406,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":407,"hash":428,"ext":23,"mime":197,"size":429,"url":430,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":431,"updatedAt":431,"documentId":432,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":408,"small":413,"medium":418,"thumbnail":423},{"ext":23,"url":409,"hash":410,"mime":197,"name":411,"path":18,"size":412,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":414,"hash":415,"mime":197,"name":416,"path":18,"size":417,"width":36,"height":16},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":419,"hash":420,"mime":197,"name":421,"path":18,"size":422,"width":30,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":424,"hash":425,"mime":197,"name":426,"path":18,"size":427,"width":217,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":434,"title":435,"subTitle":436,"content":437,"callToActionText":18,"callToActionLink":18,"colorStyle":230,"showAsides":187,"imageUrl":438,"__component":223},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":439,"name":440,"alternativeText":18,"caption":18,"width":191,"height":192,"formats":441,"hash":462,"ext":23,"mime":197,"size":463,"url":464,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":465,"updatedAt":465,"documentId":466,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":442,"small":447,"medium":452,"thumbnail":457},{"ext":23,"url":443,"hash":444,"mime":197,"name":445,"path":18,"size":446,"width":29,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":448,"hash":449,"mime":197,"name":450,"path":18,"size":451,"width":36,"height":16},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":453,"hash":454,"mime":197,"name":455,"path":18,"size":456,"width":30,"height":211},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":458,"hash":459,"mime":197,"name":460,"path":18,"size":461,"width":217,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":468,"title":469,"callToActionText":470,"callToActionLinkUrl":471,"body":18,"imageUrl":472,"__component":473},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":57,"focalPoint":18},"call-to-action.single",[475,480,483,486,489,492,495,498,502,505,508,512,515,519,522,525,528,607],{"id":476,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":478,"introductionText":18,"__component":479},1114,"","Op verzoek van [SLM Microsoft Rijk](https://slmmicrosoftrijk.nl/) heeft Microsoft namelijk een aantal productwijzigingen doorgevoerd die voor alle Enterprise klanten in Europa beschikbaar zijn gekomen. Daarnaast heeft SLM Microsoft Rijk aanvullende afspraken met Microsoft gemaakt over de verplichtingen van de verwerkingsverantwoordelijke en de verwerker.","global.pagesection",{"id":481,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":482,"introductionText":18,"__component":479},1111,"## Geen bekende hoge privacyrisico’s meer voor overheidsinstellingen\n\nSLM Microsoft Rijk adviseert overheidsinstellingen volgens het onderzoeks- en adviesbureau [Privacy Company](https://www.privacycompany.eu/nieuwe-dpias-zakelijke-microsoft-office-en-windows-software-nog-steeds-privacyrisicos-kort/) wel om\n\n*   voorlopig af te zien van het gebruik van Office Online en de mobiele Office apps en\n*   het laagst mogelijke niveau van gegevensverzameling in Windows 10, Security (Beveiliging), te kiezen.\n\nAls systeembeheerders van overheidsinstellingen daarnaast de andere adviezen uit [de DPIA-rapporten](https://www.rijksoverheid.nl/documenten/rapporten/2019/06/11/data-protection-impact-assessment-windows-10-enterprise) opvolgen, zijn er volgens Privacy Company geen bekende hoge privacyrisico’s meer voor overheidsinstellingen.",{"id":484,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":485,"introductionText":18,"__component":479},1112,"## Wat was de aanleiding voor deze brief?\n\nIn 2018 heeft SLM Microsoft Rijk Privacy Company een data protection impact assessment (DPIA) laten uitvoeren op diagnostische dataverzamelingen in nieuwe versies van Microsoft Office. Daaruit is gebleken dat Microsoft Office ProPlus diagnostische gegevens van en over gebruikers verzamelde en opsloeg in een database in de VS. Dat was niet conform de Algemene Verordening Gegevensbescherming (AVG).",{"id":487,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":488,"introductionText":18,"__component":479},1113,"## Hoge privacyrisico’s voor niet-overheidsorganisaties\n\n[De brief van Grapperhaus](https://www.rijksoverheid.nl/binaries/rijksoverheid/documenten/kamerstukken/2019/07/01/tk-verificatie-op-de-uitvoering-van-het-overeengekomen-verbeterplan-met-microsoft/tk-verificatie-op-de-uitvoering-van-het-overeengekomen-verbeterplan-met-microsoft.pdf) en de data protection impact assessments zijn om twee redenen ook relevant voor niet-overheidsorganisaties die overwegen om Microsoft 365 of Office 365 in te voeren of al ingevoerd hebben:\n\n*   De invoering en het gebruik van Microsoft 365 of Office 365 bij een organisatie leidt vrijwel automatisch tot het gebruik van de [Microsoft Office ProPlus](https://www.microsoft.com/nl-nl/p/office-365-proplus/cfq7ttc0k8r0?activetab=pivot:techspecstab) applicaties, Office Online en de mobiele Office apps. Daarnaast leidt de invoering van Microsoft 365 automatisch tot het gebruik van Windows 10. Dit omdat Microsoft 365 uit Microsoft Office, Office 365 apps, Windows 10 en een aantal beveiligingsopties bestaat.\n*   Niet-overheidsorganisaties moeten volgens Privacy Company bij het gebruik van Office ProPlus, Office Online, de mobiele Office apps en Windows 10 Enterprise rekening houden met hoge privacyrisico’s. Dit omdat de aanvullende afspraken van SLM Microsoft Rijk met Microsoft alleen gelden voor onderdelen van de rijksoverheid die zijn aangesloten bij SLM Microsoft Rijk.",{"id":490,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":491,"introductionText":18,"__component":479},1115,"## Drie aanbevelingen\n\nPrivacy Company doet [drie aanbevelingen](https://www.privacycompany.eu/nieuwe-dpias-zakelijke-microsoft-office-en-windows-software-nog-steeds-privacyrisicos-kort/) aan niet-overheidsorganisaties om deze privacyrisico’s beheersbaar te maken:\n\n*   Niet-overheidsorganisaties moeten zich bij voorkeur via een vakorganisatie tot Microsoft wenden om vergelijkbare privacygaranties te bedingen als het Rijk. Deze [factsheet van SLM Microsoft Rijk](https://slmmicrosoftrijk.nl/wp-content/uploads/2019/08/Factsheet-AVG-compliant-gebruik-Windows10-en-Office-ProPlus-20190815.pdf) bevat een samenvatting van de contractaanpassingen die SLM Microsoft Rijk en Microsoft zijn overeen gekomen.\n*   Niet-overheidsorganisaties kunnen net als de bij SLM Microsoft Rijk aangesloten overheidsorganisaties zelf [twaalf maatregelen](https://www.privacycompany.eu/nieuwe-dpias-zakelijke-microsoft-office-en-windows-software-nog-steeds-privacyrisicos-kort/) nemen om de privacyrisico’s in te dammen. Een van de maatregelen is voorlopig afzien van het gebruik van Office Online en de mobiele Office apps. Een andere maatregel is het laagst mogelijke niveau van gegevensverzameling in Windows 10 kiezen. Zie ook de [factsheet](https://slmmicrosoftrijk.nl/wp-content/uploads/2019/08/Factsheet-AVG-compliant-gebruik-Windows10-en-Office-ProPlus-20190815.pdf) van SLM Microsoft Rijk voor een overzicht van de maatregelen.\n*   Niet-overheidsorganisaties kunnen een eigen DPIA uitvoeren en de restrisico’s voorleggen aan de Autoriteit Persoonsgegevens.",{"id":493,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":494,"introductionText":18,"__component":479},1116,"## Wat betekent dit voor niet-overheidsorganisaties?\n\nVoor niet-overheidsorganisaties die overwegen om Microsoft 365 of Office 365 in te voeren, is het raadzaam om 1) privacyrisico’s vanaf de start mee te nemen in het implementatieproject en 2) in een vroeg stadium te onderzoeken of het voor hen haalbaar en acceptabel is om bovenstaande aanbevelingen uit te voeren.\n\nEen voorbeeld hiervan is de Technische Universiteit Eindhoven (TUE). Die berichtte 2 juli 2019 [op haar website](https://www.cursor.tue.nl/nieuws/2019/juli/week-1/id-als-eerste-faculteit-geheel-over-op-office-365/) dat de faculteit Industrial Design in de eerste week van juli 2019 geheel is over gegaan op Office 365. De TUE laat daarbij eventuele kwetsbare groepen met privacygevoelige data in kaart brengen. Ook verkent de TUE mogelijke oplossingen.\n\nTot slot enkele tips die kunnen helpen om privacyrisico’s rond Microsoft/Office 365 in kaart te brengen en te beperken.",{"id":496,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":497,"introductionText":18,"__component":479},1117,"## O&O ShutUp10\n\nEen handige gratis tool voor individueel gebruik is O&O ShutUp10. Deze tool toont een praktisch overzicht van alle Windows 10 instellingen op je pc/laptop die betrekking hebben op je privacy en op dataoverdracht naar Microsoft. Per instelling vind je een toelichting, een aanbeveling (yes, limited en of no) en een schakelaar waarmee je de instelling afhankelijk van je rechten eenvoudig kan aanpassen. Bij grote bedrijven beheert de IT-afdeling meestal de PC’s. In dat geval kan je dit programma waarschijnlijk niet aanroepen en/of gebruiken.",{"id":499,"title":18,"asideText":500,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":501,"introductionText":18,"__component":479},1118,"Figuur 1: de tool O&O ShutUp10 toont een overzicht van al je Windows 10-instellingen die betrekking hebben op privacy en data-overdracht.","![](https://www.sharevalue.nl/images/sharevalue/blogs/instellingen_privacy_windows_10.png)",{"id":503,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":504,"introductionText":18,"__component":479},1119,"## Privacy riskmapper\n\nBij het in kaart brengen van privacyrisico’s kunnen organisaties gebruik maken van de privacy riskmapper. Dit is een online vragenlijst op de [privacydesigner website](https://www.privacydesigner.nl/riskmapper). Deze site is ontwikkeld om informatie over privacy by design te bundelen en te ontsluiten.",{"id":506,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":507,"introductionText":18,"__component":479},1120,"## Privacy ontwerpstrategieën\n\nDaarnaast kunnen organisaties een of meer privacy ontwerpstrategieën toepassen bij het ontwerpen en inrichten van Office 365. Universitair hoofddocent Computerwetenschappen Jaap-Henk Hoekman beschrijft in zijn ‘[blauwe boekje](https://www.cs.ru.nl/~jhh/publications/pds-boekje.pdf)’ vier datageoriënteerde en vier procesgeoriënteerde privacy ontwerpstrategieën (zie onderstaande tabel en figuur).",{"id":509,"title":18,"asideText":510,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":511,"introductionText":18,"__component":479},1121,"Tabel 1: datageoriënteerde en procesgeoriënteerde privacy-ontwerpstrategieën","![](https://www.sharevalue.nl/images/sharevalue/blogs/ontwerpstrategie%C3%ABn.jpg)",{"id":513,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":514,"introductionText":18,"__component":479},1122,"De datageoriënteerde ontwerpstrategieën richten zich op de privacyvriendelijke verwerking van data (en staan binnen het kader in onderstaande afbeelding). De procesgeoriënteerde ontwerpstrategieën richten zich op de verwerkingsprocessen van persoonsgegevens. Ze gaan over de organisatorische aspecten en de noodzakelijke procedures (en staan buiten het kader in onderstaande afbeelding).",{"id":516,"title":18,"asideText":517,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":518,"introductionText":18,"__component":479},1124,"Figuur 2: datageoriënteerde en procesgeoriënteerde privacy ontwerpstrtegieën (afkomstig uit het ‘blauwe boekje’)","![](https://www.sharevalue.nl/images/sharevalue/blogs/privacy_ontwerpstrategieen.png)",{"id":520,"title":18,"asideText":477,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":521,"introductionText":18,"__component":479},1123,"## Hulp nodig?\n\nShareValue kan ook jouw organisatie helpen bij de (voorbereiding van de) invoering van Office 365. Meer weten? [Neem dan contact met ons op](/contact).",{"id":523,"title":18,"showBlankAside":103,"__component":524},122,"global.social-sharing",{"id":526,"name":18,"jobTitle":18,"__component":527},80,"strapi.author-card",{"id":529,"title":530,"aside":18,"postType":144,"limit":145,"expertise":531,"__component":148},91,"Lees ook onze andere berichten",[532],{"id":94,"title":95,"subTitle":96,"description":97,"shortDescription":98,"slug":99,"createdAt":100,"updatedAt":101,"publishedAt":102,"isCoreExpertise":103,"documentId":104,"image":533,"seo":536,"blocks":541,"midPageBlocks":548},{"id":106,"name":107,"alternativeText":18,"caption":18,"width":108,"height":109,"formats":534,"hash":120,"ext":112,"mime":115,"size":121,"url":122,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":123,"updatedAt":123,"documentId":124,"publishedAt":57,"focalPoint":18},{"thumbnail":535},{"ext":112,"url":113,"hash":114,"mime":115,"name":116,"path":18,"size":117,"width":118,"height":119},{"id":126,"metaTitle":127,"metaDescription":128,"structuredData":537,"metaImage":18,