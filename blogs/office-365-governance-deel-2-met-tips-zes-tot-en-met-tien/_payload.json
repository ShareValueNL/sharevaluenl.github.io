[{"data":1,"prerenderedAt":625},["ShallowReactive",2],{"collection-blogs--695577701":3,"_apollo:default":624},{"data":4,"meta":620},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":59,"author":18,"blocks":464,"seo":588},102,"Office 365 governance: deel 2 met tips zes tot en met tien","In deel 1 van deze blog is uitgelegd waarom Office 365 governance belangrijk is en wat het inhoudt. Op grond van literatuur en ervaring met governanceprojecten zijn er in deel 1 vijf kritieke succesfactoren voor Office 365 governance benoemd, waaronder de Goudlokje benadering. Deel 2 van deze blog beschrijft de kritieke succesfactoren zes tot en met tien.","office-365-governance-deel-2-met-tips-zes-tot-en-met-tien","2023-10-13T10:26:40.241Z","2025-04-22T12:57:00.802Z","2023-10-13T10:26:40.137Z","2018-08-28","ear8ffd4pexki4rsnj5by04t",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58},351,"office-365-governance-deel-2-met-tips-zes-tot-en-met-tien.jpg",null,1280,579,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d.jpg","large_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d","image/jpg","large_office-365-governance-deel-2-met-tips-zes-tot-en-met-tien.jpg",156.81,1000,452,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d.jpg","small_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d","small_office-365-governance-deel-2-met-tips-zes-tot-en-met-tien.jpg",36.41,500,226,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d.jpg","medium_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d","medium_office-365-governance-deel-2-met-tips-zes-tot-en-met-tien.jpg",83.52,750,339,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d.jpg","thumbnail_office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d","thumbnail_office-365-governance-deel-2-met-tips-zes-tot-en-met-tien.jpg",9.11,245,110,"office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d",276.96,"https://incredible-beef-2a6059b946.media.strapiapp.com/office_365_governance_deel_2_met_tips_zes_tot_en_met_tien_445aa7ec7d.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:24:35.046Z","xqnidzjzyqqnlt70x10gcv74","2026-01-05T12:38:34.018Z",[60],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":72,"blocks":91,"midPageBlocks":209,"seo":459},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":77,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},16,"microsoft-365.png",282,130,{"thumbnail":78},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",[92,186],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":98},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",3,[99],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":100,"blocks":103,"midPageBlocks":114,"seo":169},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":101,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":102},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[104,105],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97},{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":113},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[115,123,130,135,140,146,151,158,163],{"__component":116,"id":117,"title":118,"subTitle":119,"content":120,"callToActionText":18,"callToActionLink":18,"colorStyle":121,"showAsides":122},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"__component":116,"id":124,"title":125,"subTitle":126,"content":127,"callToActionText":128,"callToActionLink":110,"colorStyle":129,"showAsides":122},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":116,"id":131,"title":132,"subTitle":133,"content":134,"callToActionText":18,"callToActionLink":18,"colorStyle":121,"showAsides":122},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":116,"id":136,"title":137,"subTitle":138,"content":139,"callToActionText":18,"callToActionLink":18,"colorStyle":129,"showAsides":122},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":116,"id":141,"title":142,"subTitle":143,"content":144,"callToActionText":145,"callToActionLink":110,"colorStyle":121,"showAsides":122},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":116,"id":147,"title":148,"subTitle":149,"content":150,"callToActionText":18,"callToActionLink":18,"colorStyle":129,"showAsides":122},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":116,"id":152,"title":153,"subTitle":154,"content":155,"callToActionText":156,"callToActionLink":157,"colorStyle":121,"showAsides":122},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":116,"id":159,"title":160,"subTitle":161,"content":162,"callToActionText":18,"callToActionLink":18,"colorStyle":129,"showAsides":122},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":164,"id":165,"title":166,"callToActionText":167,"callToActionLinkUrl":168,"body":18},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":170,"metaTitle":171,"metaDescription":172,"structuredData":173},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":174,"@type":175,"@context":176,"provider":177,"areaServed":181,"description":184,"serviceType":185},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":178,"name":179,"@type":180},"https://www.sharevalue.nl","ShareValue","Organization",{"name":182,"@type":183},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrl