width":36,"height":240},{"ext":23,"url":273,"hash":274,"mime":231,"name":275,"path":18,"size":276,"width":43,"height":246},{"ext":23,"url":278,"hash":279,"mime":231,"name":280,"path":18,"size":281,"width":107,"height":215},{"__component":116,"id":133,"title":134,"subTitle":18,"content":135,"callToActionText":136,"callToActionLink":110,"colorStyle":127,"showAsides":122,"imageUrl":433},{"id":290,"name":291,"alternativeText":18,"caption":18,"width":225,"height":226,"formats":434,"hash":313,"ext":23,"mime":231,"size":314,"url":315,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":316,"updatedAt":316,"documentId":317,"publishedAt":58},{"large":435,"small":436,"medium":437,"thumbnail":438},{"ext":23,"url":294,"hash":295,"mime":231,"name":296,"path":18,"size":297,"width":29,"height":234},{"ext":23,"url":299,"hash":300,"mime":231,"name":301,"path":18,"size":302,"width":36,"height":240},{"ext":23,"url":304,"hash":305,"mime":231,"name":306,"path":18,"size":307,"width":43,"height":246},{"ext":23,"url":309,"hash":310,"mime":231,"name":311,"path":18,"size":312,"width":107,"height":215},{"__component":138,"id":139,"title":140,"callToActionText":141,"callToActionLinkUrl":142,"body":18,"imageUrl":440},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":144,"metaTitle":145,"metaDescription":146,"structuredData":442,"metaImage":18,"metaSocial":445},{"url":148,"@type":149,"@context":150,"provider":443,"areaServed":444,"description":158,"serviceType":159},{"url":152,"name":153,"@type":154},{"name":156,"@type":157},[],{"__component":106,"id":447,"titleLeft":108,"callToActionTextLeft":448,"callToActionLinkUrlLeft":449,"titleRight":450,"callToActionTextRight":451,"callToActionLinkUrlRight":452,"iconUrlLeft":453,"iconUrlRight":454},77,"Neem contact met ons op","https://www.sharevalue.nl/contact","Hoor van onze experts hoe leuk ShareValue is","Lees de verhalen van onze collega's","https://www.sharevalue.nl/word-onze-collega/collegas-aan-het-woord",{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":61,"name":455,"alternativeText":18,"caption":18,"width":456,"height":457,"formats":18,"hash":458,"ext":167,"mime":168,"size":459,"url":460,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":461,"updatedAt":462,"documentId":463,"publishedAt":58},"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":465,"metaTitle":466,"metaDescription":467,"structuredData":468,"metaImage":18,"metaSocial":497},105,"Nieuwe look van Power Apps met modern controls | ShareValue","Wat kun je met de nieuwe modern controls in Power Apps? Wendy laat zien hoe je apps een frisse, consistente en toegankelijke look geeft.",[469,480],{"url":470,"@type":471,"author":472,"@context":150,"headline":466,"publisher":475,"description":467,"datePublished":479},"https://www.sharevalue.nl/blogs/de-nieuwe-look-feel-van-power-apps-met-de-modern-controls-wat-kan-je-ermee","BlogPosting",{"name":327,"@type":473,"jobTitle":328,"worksFor":474},"Person",{"name":153,"@type":154},{"logo":476,"name":153,"@type":154},{"url":477,"@type":478},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","2023-12-07",{"@type":481,"@context":150,"mainEntity":482},"FAQPage",[483,489,493],{"name":484,"@type":485,"acceptedAnswer":486},"Wat zijn modern controls in Power Apps?","Question",{"text":487,"@type":488},"Modern controls zijn vernieuwde componenten in Power Apps die zorgen voor een consistente, toegankelijke en moderne gebruikerservaring.","Answer",{"name":490,"@type":485,"acceptedAnswer":491},"Waarom zou je modern controls gebruiken?",{"text":492,"@type":488},"Omdat ze beter aansluiten bij hedendaagse designstandaarden, eenvoudiger aan te passen zijn en beter werken met theming en responsiviteit.",{"name":494,"@type":485,"acceptedAnswer":495},"Wat is een praktische tip van Wendy bij gebruik van modern controls?",{"text":496,"@type":488},"Experimenteer met de nieuwe galerijen en knoppen, en let goed op de instellingen voor toegankelijkheid en themagebruik.",[],{"pagination":499},{"page":500,"pageSize":501},1,100,{},1779188846089]