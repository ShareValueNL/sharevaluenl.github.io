ible-beef-2a6059b946.media.strapiapp.com/large_security_check_94d0553bc3.jpg","large_security_check_94d0553bc3","large_security check.jpg",137.47,{"ext":23,"url":299,"hash":300,"mime":231,"name":301,"path":18,"size":302,"width":36,"height":240},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_check_94d0553bc3.jpg","small_security_check_94d0553bc3","small_security check.jpg",29.41,{"ext":23,"url":304,"hash":305,"mime":231,"name":306,"path":18,"size":307,"width":43,"height":246},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":309,"hash":310,"mime":231,"name":311,"path":18,"size":312,"width":107,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":138,"id":139,"title":140,"callToActionText":141,"callToActionLinkUrl":142,"body":18,"imageUrl":319},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":144,"metaTitle":145,"metaDescription":146,"structuredData":321,"metaImage":18,"metaSocial":324},{"url":148,"@type":149,"@context":150,"provider":322,"areaServed":323,"description":158,"serviceType":159},{"url":152,"name":153,"@type":154},{"name":156,"@type":157},[],{"id":326,"name":327,"jobTitle":328,"about":18,"createdAt":329,"updatedAt":330,"publishedAt":331,"documentId":332,"image":333,"contactOptions":350},92,"Wendy","Consultant","2024-01-17T11:12:26.548Z","2024-09-30T14:08:19.679Z","2024-01-17T11:12:28.261Z","hchiwq47auyclgz42lperq5o",{"id":334,"name":335,"alternativeText":18,"caption":18,"width":336,"height":337,"formats":338,"hash":345,"ext":79,"mime":82,"size":346,"url":347,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":348,"updatedAt":348,"documentId":349,"publishedAt":58},835,"Wendy websitefoto.png",278,326,{"thumbnail":339},{"ext":79,"url":340,"hash":341,"mime":82,"name":342,"path":18,"size":343,"width":344,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Wendy_websitefoto_ae754ca068.png","thumbnail_Wendy_websitefoto_ae754ca068","thumbnail_Wendy websitefoto.png",20.75,133,"Wendy_websitefoto_ae754ca068",22.02,"https://incredible-beef-2a6059b946.media.strapiapp.com/Wendy_websitefoto_ae754ca068.png","2024-09-30T14:07:38.741Z","sp0nkgxmnxzzlojwk5clwemm",[],[352,357,360,363,365,368,370,373,376,379,382,385,388,391,394,396,446],{"__component":353,"id":354,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":356,"introductionText":18},"global.pagesection",257,"","## De originele controls, Teams controls en nu ook de modern controls!\n\nHet standaard uiterlijk van de canvas apps kennen we al een tijdje. Naar mijn mening verdient dit geen schoonheidsprijs en kan het mooier. Want het oog wilt ook wat. De gebruikerservaring nemen we gelijk mee in deze verbetering. \n\nDe controls uit Teams kun je al gebruiken in Power Apps, met een kleine omweg. Hoe je dit doet kom ik verderop in deze blog op terug. \n\nNu is er een nieuwe functie beschikbaar, de modern controls. Dit is gebaseerd op het [Microsoft Fluent Design System](https://www.microsoft.com/design/fluent/). Hiermee ontwerp je sneller en gemakkelijker een app die er overzichtelijker en ruimtelijker uitziet. Én bovenal een betere gebruikerservaring oplevert. Dit alleen al door een paar mooie onderdelen toe te voegen!",{"__component":353,"id":358,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":359,"introductionText":18},258,"## Hoe schakel je deze functie in? \n\nOm de modern controls te kunnen gebruiken, controleer je eerst de instellingen. Open de app vanuit de Power app studio (https://make.powerapps.com) en navigeer onderaan naar de instellingen.\n\n1: Onder de tab 'Upcoming features' klik je op 'Preview', onderaan schakel je de optie 'Try out the modern controls' in.  \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_1.png)",{"__component":353,"id":361,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":362,"introductionText":18},259,"2: Controleer in de tab 'Support' welke versie je momenteel hebt. Deze dient minstens 3.23034.5 of hoger te zijn. Welke versie je hebt, wordt bepaald door de locatie waar je omgeving zich bevindt en de verversingscadans. Wanneer er een update wordt uitgebracht voor jouw omgeving, verandert de standaardversie van de Power Apps Studio. Pas dit alleen aan indien nodig. Je kunt de versie aanpassen via ‘Edit’. Zodra je beide stappen hebt gedaan en het instellingenmenu afsluit, kun je aan de slag. \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_2.png)",{"__component":353,"id":16,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":364,"introductionText":18},"3: In de app staat nu onder 'Insert' een nieuw onderdeel genaamd 'modern controls'. Het is een lijst met behoorlijk wat nieuw functies die je naast de gebruikelijke controls nu ook kunt toevoegen aan de App.  \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_3.png)",{"__component":353,"id":366,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":367,"introductionText":18},261,"## Welke modern controls zijn er? \n\nHierbij een overzicht van alle modern controls met hun bijbehorende functie. \n\n| Control | Toepassing | Eigenschap set |\n|----|----|----|\n| Badge  | Snelle manier om belangrijke, korte informatie te tonen, zoals een statusindicator of initialen | Content |\n| Button        | Door erop te klikken acties starten en door een interface te navigeren | Text |\n| Checkbox      | Eén of meerdere opties selecteren uit een keuzelijst | Label |\n| Datepicker    | Gebruiksvriendelijke manier om datum in te voeren/te selecteren dankzij maandoverzicht | Value |\n| Dropdown      | Opties selecteren uit compacte, voorgedefinieerde lijst | Items |\n| Info Button   | Aanvullende informatie over een functie of veld om gebruikers te helpen | Content |\n| Link          | Vanuit de app doornavigeren naar een webpagina | URL |\n| Progress Bar  | Voortgang van taak of proces visueel weergeven | Value |\n| Radio Group   | Uit een lijst van opties één optie selecteren | Items |\n| Spinner       | Informatieve feedback dat de inhoud wordt geladen | Label |\n| Tab list      | Reeks tabbladen om te navigeren tussen andere secties of pagina's | Items |\n| Tekst         | Tekst voor het tonen van een beschrijving of informatie | Text |\n| Text Input    | Veld voor het invoeren van gegevens | Default |",{"__component":353,"id":37,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":369,"introductionText":18},"1: Voorbeeld van de app met de **originele controls**:\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_4.png)",{"__component":353,"id":371,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":372,"introductionText":18},264,"2: Voorbeeld van de App met **modern controls**:\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_5.png)",{"__component":353,"id":374,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":375,"introductionText":18},263,"Door vanuit Power Apps in Teams te bouwen, maak je snel een App met het bijbehorende Teams-uiterlijk. Dit geeft de gebruiker herkenbaarheid en de App draait soepel in de gewenste kanalen.   \nDe controls uit Teams kun je met een kleine omweg gebruiken in de Power Apps Studio.",{"__component":353,"id":377,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":378,"introductionText":18},265,"## Hoe kun je de elementen uit Teams aan je Canvas App toevoegen? \n\nOpen Teams en ga in de linker navigatiebalk naar de App genaamd 'Apps'. Hier kun je zoeken op Power Apps en voeg deze toe door ‘Add’ te selecteren. \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_6.png)",{"__component":353,"id":380,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":381,"introductionText":18},266,"Om hier gemakkelijk bij te kunnen vanuit je navigatiebalk in Teams, kun je de App vastpinnen. Door onderaan de linker navigatiebalk de 3 bolletjes te selecteren, kun je de Power App opzoeken. Om het vast te pinnen druk je met de rechtermuisknop op de app en 'Pin'.  \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_7.png)",{"__component":353,"id":383,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":384,"introductionText":18},267,"Nu kun je vanuit Teams een Power App creëren en hierin enkele controls toevoegen. Deze controls kun je d.m.v. kopiëren toevoegen aan je Canvas App in een andere omgeving, zoals de Power Apps Studio van de browser. Door dit te doen heb je meer functionaliteiten dan in de Power Apps in Teams. Voorbeeld hoe het er uit komt te zien: \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Modern_controls_afbeelding_8.png)",{"__component":353,"id":386,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":387,"introductionText":18},268,"Op dit moment zijn de modern controls helaas nog een preview functie, met bijbehorende beperkingen. Enkele nadelen zijn: De eigenschap sets (properties) zijn anders dan van de originele controls. De standaard kleuren die je gebruikt in de app zijn niet aanpasbaar. De App checker regels, zoals toegankelijkheid en formules werken momenteel nog niet. En de datepicker is niet op dezelfde manier in te stellen qua standaarden.  \n\nMijn advies: probeer voor nu de modern controls vooral uit en raak ermee bekend. Om het gebruiksvriendelijk en overzichtelijk te houden voor jezelf, bouw een app met of alleen modern controls, of alleen met de originele of Teams controls. Een combi van beide doet de App nu nog geen goed.\n\nConclusie: ondanks de nu nog aanwezige beperkingen die bij een Preview functie horen, zijn de modern controls echt veelbelovend en voegen absoluut wat toe aan de gebruikerservaring. De App loopt soepeler, is sneller, duidelijker en visueel aantrekkelijker. Voor de makers is het ook gemakkelijker te configureren.  \nHopelijk is het snel voor iedereen Generally Available, met nog meer toffe functies eraan toegevoegd!\n\nIn mijn volgende blog ga ik meer in op de UI van Canvas Apps. En geef ik meerdere tips & tricks die ik graag had geweten toe ik begon met Power Apps. Dus houdt de ShareValue website in de gaten!",{"__component":353,"id":389,"title":18,"asideText":355,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":390,"introductionText":18},269,"## Meer weten?\n\nWil je meer weten over deze functionaliteit of over het Power Platform in het algemeen? Neem dan gerust [contact op](https://www.sharevalue.nl/contact) met ons zodat we de mogelijkheden kunnen bespreken.",{"__component":392,"id":393,"title":18,"showBlankAside":70},"global.social-sharing",50,{"__component":395,"id":175,"name":18,"jobTitle":18},"strapi.author-card",{"__component":93,"id":133,"title":397,"aside":18,"postType":96,"limit":97,"expertise":398},"Lees ook onze andere berichten",[399],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":400,"blocks":403,"midPageBlocks":410,"seo":441},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":401,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":402},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[404,407],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":405},[406],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71},{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":113,"iconUrlLeft":408,"iconUrlRight":409},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":175,"name":176,"alternativeText":18,"caption":18,"width":165,"height":165,"formats":18,"hash":177,"ext":167,"mime":168,"size":178,"url":179,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":180,"updatedAt":181,"documentId":182,"publishedAt":58},[411,418,425,432,439],{"__component":116,"id":117,"title":118,"subTitle":18,"content":119,"callToActionText":120,"callToActionLink":110,"colorStyle":121,"showAsides":122,"imageUrl":412},{"id":186,"name":187,"alternativeText":18,"caption":18,"width":188,"height":189,"formats":413,"hash":216,"ext":79,"mime":82,"size":217,"url":218,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":219,"updatedAt":219,"documentId":220,"pu