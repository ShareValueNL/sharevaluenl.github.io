arge":441,"small":446,"medium":451,"thumbnail":456},{"ext":23,"url":442,"hash":443,"mime":229,"name":444,"path":18,"size":445,"width":29,"height":232},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":447,"hash":448,"mime":229,"name":449,"path":18,"size":450,"width":36,"height":238},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":452,"hash":453,"mime":229,"name":454,"path":18,"size":455,"width":30,"height":244},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":457,"hash":458,"mime":229,"name":459,"path":18,"size":460,"width":250,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":174,"id":175,"title":176,"callToActionText":177,"callToActionLinkUrl":178,"body":18,"imageUrl":467},{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":57},{"id":180,"metaTitle":181,"metaDescription":182,"structuredData":469,"metaImage":18,"metaSocial":472},{"url":184,"@type":185,"@context":186,"provider":470,"areaServed":471,"description":194,"serviceType":195},{"url":188,"name":189,"@type":190},{"name":192,"@type":193},[],{"id":162,"name":474,"jobTitle":475,"about":18,"createdAt":476,"updatedAt":477,"publishedAt":478,"documentId":479,"image":480,"contactOptions":497},"Jaap","Consultant & Architect","2023-08-18T08:37:46.142Z","2024-04-18T14:14:47.615Z","2023-08-18T08:37:45.364Z","ylun9zjxpvjd4rq1teczcwna",{"id":481,"name":482,"alternativeText":18,"caption":18,"width":483,"height":484,"formats":485,"hash":492,"ext":89,"mime":92,"size":493,"url":494,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":495,"updatedAt":495,"documentId":496,"publishedAt":57},685,"Jaap websitefoto.png",278,326,{"thumbnail":486},{"ext":89,"url":487,"hash":488,"mime":92,"name":489,"path":18,"size":490,"width":491,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Jaap_websitefoto_b7bbefc0bd.png","thumbnail_Jaap_websitefoto_b7bbefc0bd","thumbnail_Jaap websitefoto.png",19.14,133,"Jaap_websitefoto_b7bbefc0bd",19.61,"https://incredible-beef-2a6059b946.media.strapiapp.com/Jaap_websitefoto_b7bbefc0bd.png","2024-04-18T14:13:38.415Z","cvbav3qa5a84m18w8fmg5l5c",[],[499,503,507,511,514,517,520,523,526,529,532,535,538,541,548],{"__component":500,"id":501,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":502,"introductionText":18},"global.pagesection",1100,"In deze blog ga ik eerst in op de achtergrond van de virtuele entiteit. Wat je ermee kunt en wat de beperkingen zijn.\n\nDaarna beschrijf ik hoe het werkt, door een eenvoudige proef-entiteit op te zetten. Dit onderdeel is voornamelijk interessant als je bekend bent met het bouwen van entiteiten in CRM.\n\nTot slot sluit ik af met mijn conclusie, waarin ik beschrijf _wat de verdere mogelijkheden zijn_.",{"__component":500,"id":504,"title":18,"asideText":505,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":506,"introductionText":18},1101,"Wat is een virtuele entiteit?","## Wat is een Virtuele Entiteit?\n\nMet een Virtuele Entiteit is het mogelijk om externe data te ontsluiten binnen CRM alsof het een normale entiteit is, compleet met weergaves en formulieren, zonder dat de data in CRM wordt opgeslagen.\n\nDe huidige beperkingen zijn:\n\n*   Je kunt de data alleen lezen, niet bijwerken.\n*   De data van de virtuele entiteit is organization owned, dat wil zeggen dat je (afhankelijk van je beveiligingsrol) ofwel alle records kunt lezen ofwel geen enkel. Je kunt geen onderscheid maken op basis van het eigendom van records.\n*   De externe databron moet een GUID veld gebruiken als primaire sleutel.\n*   Een aantal standaard functies zijn niet beschikbaar zoals wachtrijen, bedrijfsprocesstromen en auditing.",{"__component":500,"id":508,"title":18,"asideText":509,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":510,"introductionText":18},1102,"Hoe werkt het?","## Hoe het werkt\n\nOm mijn eerste virtuele entiteit te maken heb ik gebruik gemaakt van [een voorbeeld](https://blog.csdn.net/weixin_30709929/article/details/97858860).\n\nVoordat je een virtuele entiteit kunt maken, moet je eerst je externe bron definiëren. Er zijn momenteel dataproviders voor twee type bronnen beschikbaar, namelijk voor ODATA V4 en Azure Cosmos DB.\n\nIk heb lang gezocht naar openbare ODATA bronnen voor mijn test. Ik heb uiteindelijk een [website gevonden waar er tientallen op staan](https://pragmatiqa.com/xodata/odatadir.html) en er daar een van gekozen. Let op dat je voor een virtuele entiteit alleen gebruik kunt maken van data met een GUID als primaire sleutel.",{"__component":500,"id":512,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":513,"introductionText":18},1104,"**Stap 1**. Ga naar Settings/Administration en selecteer Virtual Entity Data Sources.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/1._administration_.png)",{"__component":500,"id":515,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":516,"introductionText":18},1103,"Maak een nieuwe aan, selecteer ODATA V4 Datasource en vul bij de URL de link naar je webservice in.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/2._odata_v4_.png)",{"__component":500,"id":518,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":519,"introductionText":18},1105,"**Stap 2**. Maak een nieuwe entiteit van het type Virtual Entity aan. Kies de data source die je zojuist hebt aangemaakt en gebruik bij External Name en External Collection Name de namen die gebruikt worden in de metadata van je ODATA bron.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/3._virtual_entity_.png)",{"__component":500,"id":521,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":522,"introductionText":18},1108,"**Stap 3**. Definieer een veld voor je primaire sleutel. Ook hier is de External Name de naam van het veld in de externe data bron. Dit is het veld dat een GUID moet zijn.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/4._primaire_sleutel_.png)",{"__component":500,"id":524,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":525,"introductionText":18},1106,"**Stap 4**. Maak veld-definities aan voor de andere attributen die je in CRM wilt gebruiken.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/5._attributen_.png)",{"__component":500,"id":527,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":528,"introductionText":18},1107,"**Stap 5**. Maak formulieren, weergaves en beveiligingsrollen aan voor je nieuwe data.",{"__component":500,"id":530,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":531,"introductionText":18},1109,"## Wat je hiermee kunt\n\nHet opzetten van een virtuele entiteit op basis van een ODATA V4 bron is zeer eenvoudig en duurt nog geen uur als de URL van de webservice beschikbaar is. Andere gegevensbronnen (dan ODATA V4) kunnen ook ontsloten worden, maar daarvoor moet dan een [eigen data provider ontwikkeld worden](https://docs.microsoft.com/en-us/dynamics365/customer-engagement/developer/virtual-entities/custom-ve-data-providers).\n\nFunctioneel zijn er twee scenario’s te bedenken voor het gebruik van deze functie:\n\n1.  Om externe informatie beschikbaar te maken in CRM over het onderwerp van je verkoopkans of je serviceproces. Denk bijvoorbeeld aan bedrijven die diensten bieden voor de scheepvaart, die op zo’n manier gedetailleerde gegevens, inclusief actuele locatie van een schip, kunnen ontsluiten in CRM.\n2.  Om informatie uit interne systemen te ontsluiten in CRM. Denk bijvoorbeeld aan orders of facturen uit je ERP-systeem.\n\nBeide toepassingen maken een naadloze aansluiting van je verkoop- en serviceproces met de omgeving mogelijk, en zullen op die manier een wezenlijke bijdrage kunnen leveren aan het verbeteren van deze processen.\n\nDe eis dat externe data gebruik moet maken van een GUID als primaire sleutel is wel heel beperkend. Hierdoor zullen in de praktijk veel bronnen afvallen.",{"__component":500,"id":533,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":534,"introductionText":18},1110,"Wil jij hiermee aan de slag en kan je onze hulp gebruiken? [Laat het ons weten](/contact); we bespreken graag de mogelijkheden.",{"__component":536,"id":537,"title":18,"showBlankAside":80},"global.social-sharing",121,{"__component":539,"id":540,"name":18,"jobTitle":18},"strapi.author-card",79,{"__component":104,"id":542,"title":543,"aside":18,"postType":107,"limit":108,"expertise":544},90,"Lees ook onze andere berichten",[545],{"id":60,"title":61,"subTitle":62,"description":62,"shortDescription":62,"slug":63,"createdAt":64,"updatedAt":64,"publishedAt":65,"isCoreExpertise":66,"documentId":67,"image":18,"blocks":546,"midPageBlocks":547,"seo":18},[],[],{"__component":117,"id":549,"titleLeft":550,"callToActionTextLeft":120,"callToActionLinkUrlLeft":121,"titleRight":122,"callToActionTextRight":123,"callToActionLinkUrlRight":124,"iconUrlLeft":551,"iconUrlRight":552},148,"Heb je een Microsoft Expert nodig?",{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":57},{"id":60,"name":211,"alternativeText":18,"caption":18,"width":201,"height":201,"formats":18,"hash":212,"ext":203,"mime":204,"size":213,"url":214,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":215,"updatedAt":216,"documentId":217,"publishedAt":57},{"id":554,"metaTitle":555,"metaDescription":556,"structuredData":557,"metaImage":18,"metaSocial":587},170,"Externe data koppelen aan Dynamics 365 | ShareValue","Ontdek hoe je met virtuele entiteiten externe data integreert in Dynamics 365 zonder replicatie, met behulp van OData v4 of een aangepaste data provider.",[558,570],{"url":559,"@type":560,"author":561,"@context":186,"headline":565,"publisher":566,"description":556,"datePublished":13},"https://www.sharevalue.nl/blogs/hoe-krijg-je-informatie-uit-externe-bronnen-in-dynamics-365-met-virtuele-entiteiten","BlogPosting",{"name":474,"@type":562,"jobTitle":563,"worksFor":564},"Person","Consultant",{"name":189,"@type":190},"Externe data in Dynamics 365 met virtuele entiteiten | ShareValue",{"logo":567,"name":189,"@type":190},{"url":568,"@type":569},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject",{"@type":571,"@context":186,"mainEntity":572},"FAQPage",[573,579,583],{"name":574,"@type":575,"acceptedAnswer":576},"Wat zijn virtuele entiteiten in Dynamics 365?","Question",{"text":577,"@type":578},"Virtuele entiteiten stellen je in staat om externe data in Dynamics 365 te tonen alsof het native entiteiten zijn, zonder dat de data fysiek wordt opgeslagen in het CRM-systeem.","Answer",{"name":580,"@type":575,"acceptedAnswer":581},"Welke beperkingen hebben virtuele entiteiten?",{"text":582,"@type":578},"Virtuele entiteiten zijn read-only, vereisen een GUID als primaire sleutel in de externe bron en ondersteunen geen functies zoals auditing, bedrijfsprocesstromen of wachtrijen.",{"name":584,"@type":575,"acceptedAnswer":585},"Hoe configureer je een virtuele entiteit met OData v4?",{"text":586,"@type":578},"Definieer een OData v4-databron in Dynamics 365, maak een nieuwe virtuele entiteit aan en koppel deze aan de databron. Zorg ervoor dat de externe naamgeving overeenkomt met de metadata van de OData-service.",[],{"pagination":589},{"page":590,"pageSize":591},1,100,{},1780583328855]