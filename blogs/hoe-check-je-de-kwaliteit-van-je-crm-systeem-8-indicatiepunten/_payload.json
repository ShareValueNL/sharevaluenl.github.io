[{"data":1,"prerenderedAt":567},["ShallowReactive",2],{"collection-blogs-1833054472":3,"_apollo:default":566},{"data":4,"meta":562},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":59,"author":474,"blocks":499,"seo":527},98,"Hoe check je de kwaliteit van je CRM-systeem? 8 indicatiepunten","Veel bedrijven hebben Microsoft Dynamics CRM systemen waaraan meerdere partners of ZZP’ers gewerkt hebben, die allemaal hun eigen werkwijze en inzichten hebben. Deze verscheidenheid is geen probleem zolang de kwaliteit gewaarborgd is, maar dat is natuurlijk moeilijk in te schatten als je zelf geen expert bent.","hoe-check-je-de-kwaliteit-van-je-crm-systeem-8-indicatiepunten","2023-10-13T10:26:39.621Z","2025-04-22T12:52:45.044Z","2023-10-13T10:26:39.588Z","2019-02-06","o0rkbpevuj37f44eu2ewhgrt",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58},347,"hoe-check-je-de-kwaliteit-van-je-crm-systeem-8-indicatiepunten.jpg",null,1920,1010,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0.jpg","large_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0","image/jpg","large_hoe-check-je-de-kwaliteit-van-je-crm-systeem-8-indicatiepunten.jpg",86.32,1000,526,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0.jpg","small_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0","small_hoe-check-je-de-kwaliteit-van-je-crm-systeem-8-indicatiepunten.jpg",29.89,500,263,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0.jpg","medium_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0","medium_hoe-check-je-de-kwaliteit-van-je-crm-systeem-8-indicatiepunten.jpg",57.06,750,395,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0.jpg","thumbnail_hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0","thumbnail_hoe-check-je-de-kwaliteit-van-je-crm-systeem-8-indicatiepunten.jpg",8.7,245,129,"hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0",230.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/hoe_check_je_de_kwaliteit_van_je_crm_systeem_8_indicatiepunten_c608ff10e0.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:24:28.056Z","yyigea448afaemt67jbbah0l","2026-01-05T12:38:34.018Z",[60,71],{"id":61,"title":62,"subTitle":63,"description":63,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":65,"publishedAt":66,"isCoreExpertise":67,"documentId":68,"image":18,"blocks":69,"midPageBlocks":70,"seo":18},8,"Dynamics 365","","dynamics-365","2023-10-12T11:27:58.808Z","2023-10-12T11:27:58.783Z",false,"dja519itovgg9wq8euq4uocb",[],[],{"id":72,"title":73,"subTitle":74,"description":75,"shortDescription":76,"slug":77,"createdAt":78,"updatedAt":79,"publishedAt":80,"isCoreExpertise":81,"documentId":82,"image":83,"blocks":102,"midPageBlocks":218,"seo":469},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":84,"name":85,"alternativeText":18,"caption":18,"width":86,"height":87,"formats":88,"hash":97,"ext":90,"mime":93,"size":98,"url":99,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":100,"updatedAt":100,"documentId":101,"publishedAt":58},16,"microsoft-365.png",282,130,{"thumbnail":89},{"ext":90,"url":91,"hash":92,"mime":93,"name":94,"path":18,"size":95,"width":50,"height":96},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",[103,196],{"__component":104,"id":105,"title":106,"aside":18,"postType":107,"limit":108,"expertise":109},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",3,[110],{"id":72,"title":73,"subTitle":74,"description":75,"shortDescription":76,"slug":77,"createdAt":78,"updatedAt":79,"publishedAt":80,"isCoreExpertise":81,"documentId":82,"image":111,"blocks":114,"midPageBlocks":125,"seo":179},{"id":84,"name":85,"alternativeText":18,"caption":18,"width":86,"height":87,"formats":112,"hash":97,"ext":90,"mime":93,"size":98,"url":99,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":100,"updatedAt":100,"documentId":101,"publishedAt":58},{"thumbnail":113},{"ext":90,"url":91,"hash":92,"mime":93,"name":94,"path":18,"size":95,"width":50,"height":96},[115,116],{"__component":104,"id":105,"title":106,"aside":18,"postType":107,"limit":108},{"__component":117,"id":118,"titleLeft":119,"callToActionTextLeft":120,"callToActionLinkUrlLeft":121,"titleRight":122,"callToActionTextRight":123,"callToActionLinkUrlRight":124},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[126,133,140,145,150,156,161,168,173],{"__component":127,"id":128,"title":129,"subTitle":130,"content":131,"callToActionText":18,"callToActionLink":18,"colorStyle":132,"showAsides":67},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"__component":127,"id":134,"title":135,"subTitle":136,"content":137,"callToActionText":138,"callToActionLink":121,"colorStyle":139,"showAsides":67},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":127,"id":141,"title":142,"subTitle":143,"content":144,"callToActionText":18,"callToActionLink":18,"colorStyle":132,"showAsides":67},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":127,"id":146,"title":147,"subTitle":148,"content":149,"callToActionText":18,"callToActionLink":18,"colorStyle":139,"showAsides":67},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":127,"id":151,"title":152,"subTitle":153,"content":154,"callToActionText":155,"callToActionLink":121,"colorStyle":132,"showAsides":67},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":127,"id":157,"title":158,"subTitle":159,"content":160,"callToActionText":18,"callToActionLink":18,"colorStyle":139,"showAsides":67},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":127,"id":162,"title":163,"subTitle":164,"content":165,"callToActionText":166,"callToActionLink":167,"colorStyle":132,"showAsides":67},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":127,"id":169,"title":170,"subTitle":171,"content":172,"callToActionText":18,"callToActionLink":18,"colorStyle":139,"showAsides":67},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":174,"id":175,"title":176,"callToActionText":177,"callToActionLinkUrl":178,"body":18},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":180,"metaTitle":181,"metaDescription":182,"structuredData":183},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":184,"@type":185,"@context":186,"provider":187,"areaServed":191,"description":194,"serviceType":195},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":188,"name":189,"@type":190},"https://www.sharevalue.nl","ShareValue","Organization",{"name":192,"@type":193},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":117,"id":118,"titleLeft":119,"callToActionTextLeft":120,"callToActionLinkUrlLeft":121,"titleRight":122,"callToActionTextRight":123,"callToActionLinkUrlRight":124,"iconUrlLeft":197,"iconUrlRight":210},{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":58},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":61,"name":211,"alternativeText":18,"caption":18,"width":201,"height":201,"formats":18,"hash":212,"ext":203,"mime":204,"size":213,"url":214,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":215,"updatedAt":216,"documentId":217,"publishedAt":58},"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",[219,257,287,317,347,377,407,437,467],{"__component":127,"id":128,"title":129,"subTitle":130,"content":131,"callToActionText":18,"callToActionLink":18,"colorStyle":132,"showAsides":67,"imageUrl":220},{"id":221,"name":222,"alternativeText":18,"caption":18,"width":223,"height":224,"formats":225,"hash":252,"ext":23,"mime":229,"size":253,"url":254,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":255,"updatedAt":255,"documentId":256,"publishedAt":58},782,"Teams.jpg",1280,850,{"large":226,"small":233,"medium":239,"thumbnail":245},{"ext":23,"url":227,"hash":228,"mime":229,"name":2