pp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":448,"hash":449,"mime":229,"name":450,"path":18,"size":451,"width":36,"height":238},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":453,"hash":454,"mime":229,"name":455,"path":18,"size":456,"width":43,"height":244},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":458,"hash":459,"mime":229,"name":460,"path":18,"size":461,"width":250,"height":251},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":174,"id":175,"title":176,"callToActionText":177,"callToActionLinkUrl":178,"body":18,"imageUrl":468},{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":58},{"id":180,"metaTitle":181,"metaDescription":182,"structuredData":470,"metaImage":18,"metaSocial":473},{"url":184,"@type":185,"@context":186,"provider":471,"areaServed":472,"description":194,"serviceType":195},{"url":188,"name":189,"@type":190},{"name":192,"@type":193},[],{"id":162,"name":475,"jobTitle":476,"about":18,"createdAt":477,"updatedAt":478,"publishedAt":479,"documentId":480,"image":481,"contactOptions":498},"Jaap","Consultant & Architect","2023-08-18T08:37:46.142Z","2024-04-18T14:14:47.615Z","2023-08-18T08:37:45.364Z","ylun9zjxpvjd4rq1teczcwna",{"id":482,"name":483,"alternativeText":18,"caption":18,"width":484,"height":485,"formats":486,"hash":493,"ext":90,"mime":93,"size":494,"url":495,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":496,"updatedAt":496,"documentId":497,"publishedAt":58},685,"Jaap websitefoto.png",278,326,{"thumbnail":487},{"ext":90,"url":488,"hash":489,"mime":93,"name":490,"path":18,"size":491,"width":492,"height":251},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Jaap_websitefoto_b7bbefc0bd.png","thumbnail_Jaap_websitefoto_b7bbefc0bd","thumbnail_Jaap websitefoto.png",19.14,133,"Jaap_websitefoto_b7bbefc0bd",19.61,"https://incredible-beef-2a6059b946.media.strapiapp.com/Jaap_websitefoto_b7bbefc0bd.png","2024-04-18T14:13:38.415Z","cvbav3qa5a84m18w8fmg5l5c",[],[500,504,507,510,513,520],{"__component":501,"id":502,"title":18,"asideText":63,"underline":67,"centered":67,"blankAside":67,"aside":18,"content":503,"introductionText":18},"global.pagesection",1260,"Daarom wil ik een poging doen om punten te benoemen, die een indicatie geven van de kwaliteit van de verrichte werkzaamheden. Het gaat om indicatoren van kwaliteit, niet het bewijs ervan!\n\nAls kapstok gebruik ik de ISO 25010 Kwaliteitskenmerken van software. De categorieën zijn vet gedrukt.\n\n1.  De functionele geschiktheid van het systeem kan je bijvoorbeeld afmeten aan het gebruik van de standaard functionaliteit van CRM. Als er eigen entiteiten zijn aangemaakt voor bijvoorbeeld organisaties of personen, is dat een aanwijzing dat de ontwikkelaar CRM niet goed genoeg kende om het goed toe te passen. Hetzelfde geldt voor een overdaad aan aanpassingen in het gebruikersinterface d.m.v. javascript, iFrames of anders.\n2.  Aanwijzingen dat de prestatie-efficiëntie niet goed is, zijn bijvoorbeeld:\n    \n    *   als de servers (in een on-premises landschap) continu meer dan 30% CPU gebruiken\n    *   als er voortdurend tientallen process-sessies bestaan met de status “waiting for resources”\n    \n    als de servers (in een on-premises landschap) continu meer dan 30% CPU gebruiken als er voortdurend tientallen process-sessies bestaan met de status “waiting for resources” Als CRM goed geconfigureerd is, vraagt het weinig van de server (in vergelijking tot bijvoorbeeld SharePoint) en zou je bovenstaande punten niet tegen moeten komen.\n    \n3.  Voor een goede uitwisselbaarheid maken de koppelingen altijd gebruik van de web API.\n4.  De bruikbaarheid van het systeem is natuurlijk af te meten aan de gebruikerstevredenheid, maar je kunt daarnaast kijken naar een consistente schermopbouw volgens de richtlijnen van Microsoft, en een herkenbare en consistente layout (namen van secties etc).\n5.  Meetpunten voor de betrouwbaarheid zijn:\n    *   het aantal process-sessies die de status “failed” hebben. Hier ligt een fout aan ten grondslag;\n    *   ongebruikte code en objecten (zoals processen die de status “draft” hebben) moeten verwijderd worden.\n6.  De beveiligbaarheid van het systeem kun je goed afmeten aan het gebruik van de beveiligingsrollen in CRM. Zijn er rollen aangemaakt die specifiek zijn voor de gebruikersgroepen, geven ze niet meer rechten dan nodig? Hoeveel gebruikers hebben de systeembeheerder-rol, en is dat terecht?\n7.  De onderhoudbaarheid van het systeem is cruciaal als je regelmatig andere partijen laat werken aan het systeem. Denk aan:\n    *   het gebruik van naamgevingsconventies en consistent taalgebruik;\n    *   het aanmerken van velden als afhankelijkheid als ze in javascript gebruikt worden;\n    *   de namen van plug-ins en workflows dekken de functionele lading.\n8.  De overdraagbaarheid van het systeem wordt gewaarborgd door:\n    *   een installatie-handleiding;\n    *   het gebruik van een dedicated server voor de CRM-installatie;\n    *   het opslaan van configuratie-waardes in een entiteit (niet hard gecodeerd);\n    *   het niet gebruiken van workflows die over meerdere dagen lopen.",{"__component":501,"id":505,"title":18,"asideText":63,"underline":67,"centered":67,"blankAside":67,"aside":18,"content":506,"introductionText":18},1259,"Op basis van deze vragenlijst kan iedere eigenaar van een CRM-omgeving snel een beeld krijgen van de kwaliteit van zijn of haar systeem. Om zo indien nodig de kwaliteit te verbeteren. Een goed CRM is voor veel organisaties van levensbelang!\n\nHeb je na het lezen van deze blog nog vragen of heb je een ander vraagstuk op het gebied van Dynamics 365.",{"__component":508,"id":509,"title":18,"showBlankAside":81},"global.social-sharing",137,{"__component":511,"id":512,"name":18,"jobTitle":18},"strapi.author-card",95,{"__component":104,"id":514,"title":515,"aside":18,"postType":107,"limit":108,"expertise":516},106,"Lees ook onze andere berichten",[517],{"id":61,"title":62,"subTitle":63,"description":63,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":65,"publishedAt":66,"isCoreExpertise":67,"documentId":68,"image":18,"blocks":518,"midPageBlocks":519,"seo":18},[],[],{"__component":117,"id":521,"titleLeft":522,"callToActionTextLeft":120,"callToActionLinkUrlLeft":523,"titleRight":122,"callToActionTextRight":123,"callToActionLinkUrlRight":524,"iconUrlLeft":525,"iconUrlRight":526},164,"Heb je een Microsoft Expert nodig?","https://www.sharevalue.nl/contact","https://www.sharevalue.nl/word-onze-collega/vacatures",{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":58},{"id":61,"name":211,"alternativeText":18,"caption":18,"width":201,"height":201,"formats":18,"hash":212,"ext":203,"mime":204,"size":213,"url":214,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":215,"updatedAt":216,"documentId":217,"publishedAt":58},{"id":528,"metaTitle":529,"metaDescription":530,"structuredData":531,"metaImage":18,"metaSocial":561},186,"CRM-systeem beoordelen: 8 kwaliteitsindicatoren | ShareValue","Gebruik ISO 25010 om je CRM-systeem te evalueren op functionaliteit, prestaties, beveiliging en onderhoudbaarheid.​",[532,544],{"url":533,"@type":534,"author":535,"@context":186,"headline":529,"publisher":539,"description":543,"datePublished":13},"https://www.sharevalue.nl/blogs/hoe-check-je-de-kwaliteit-van-je-crm-systeem-8-indicatiepunten","BlogPosting",{"name":475,"@type":536,"jobTitle":537,"worksFor":538},"Person","Consultant",{"name":189,"@type":190},{"logo":540,"name":189,"@type":190},{"url":541,"@type":542},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","Gebruik ISO 25010 om je CRM-systeem te evalueren op functionaliteit, prestaties, beveiliging en onderhoudbaarheid.",{"@type":545,"@context":186,"mainEntity":546},"FAQPage",[547,553,557],{"name":548,"@type":549,"acceptedAnswer":550},"Welke kwaliteitsaspecten zijn belangrijk voor een CRM-systeem?","Question",{"text":551,"@type":552},"Belangrijke aspecten zijn functionele geschiktheid, prestatie-efficiëntie, uitwisselbaarheid, bruikbaarheid, betrouwbaarheid, beveiligbaarheid, onderhoudbaarheid en overdraagbaarheid, zoals beschreven in ISO 25010.","Answer",{"name":554,"@type":549,"acceptedAnswer":555},"Hoe kan ik de prestatie-efficiëntie van mijn CRM-systeem beoordelen?",{"text":556,"@type":552},"Controleer serverbelasting (bijv. CPU-gebruik), het aantal actieve processen en wachttijden om te bepalen of het systeem efficiënt presteert.",{"name":558,"@type":549,"acceptedAnswer":559},"Wat zijn tekenen van een slecht onderhouden CRM-systeem?",{"text":560,"@type":552},"Tekenen zijn onder andere ongebruikte of verouderde code, inconsistente naamgeving, ontbrekende documentatie en het ontbreken van duidelijke beveiligingsrollen.",[],{"pagination":563},{"page":564,"pageSize":565},1,100,{},1778233798019]