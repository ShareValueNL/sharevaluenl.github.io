ruimte.jpg",{"large":411,"small":416,"medium":421,"thumbnail":426},{"ext":23,"url":412,"hash":413,"mime":229,"name":414,"path":18,"size":415,"width":29,"height":232},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":417,"hash":418,"mime":229,"name":419,"path":18,"size":420,"width":36,"height":238},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":422,"hash":423,"mime":229,"name":424,"path":18,"size":425,"width":30,"height":244},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":427,"hash":428,"mime":229,"name":429,"path":18,"size":430,"width":250,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"__component":127,"id":169,"title":170,"subTitle":171,"content":172,"callToActionText":18,"callToActionLink":18,"colorStyle":139,"showAsides":66,"imageUrl":437},{"id":438,"name":439,"alternativeText":18,"caption":18,"width":223,"height":224,"formats":440,"hash":461,"ext":23,"mime":229,"size":462,"url":463,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":464,"updatedAt":464,"documentId":465,"publishedAt":57},789,"teamwork.jpg",{"large":441,"small":446,"medium":451,"thumbnail":456},{"ext":23,"url":442,"hash":443,"mime":229,"name":444,"path":18,"size":445,"width":29,"height":232},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":447,"hash":448,"mime":229,"name":449,"path":18,"size":450,"width":36,"height":238},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":452,"hash":453,"mime":229,"name":454,"path":18,"size":455,"width":30,"height":244},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":457,"hash":458,"mime":229,"name":459,"path":18,"size":460,"width":250,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":174,"id":175,"title":176,"callToActionText":177,"callToActionLinkUrl":178,"body":18,"imageUrl":467},{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":57},{"id":180,"metaTitle":181,"metaDescription":182,"structuredData":469,"metaImage":18,"metaSocial":472},{"url":184,"@type":185,"@context":186,"provider":470,"areaServed":471,"description":194,"serviceType":195},{"url":188,"name":189,"@type":190},{"name":192,"@type":193},[],[474,478,481,485,489,492,496,499,502,509],{"__component":475,"id":476,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":477,"introductionText":18},"global.pagesection",1442,"Het is een veld waarin makkelijk typfouten worden gemaakt of klanten geven ‘bewust’ niet de juiste gegevens omdat ze niet lastiggevallen willen worden.\n\nZou het dan niet handig zijn om zonder fouten correcte adressen te laten landen in uw CRM-systeem? In dit artikel wil ik laten zien met welke service je dit kan realiseren. In mijn vorige opdracht heb ik voor het eerst kennis gemaakt met de PDOK-service. PDOK is een gratis zoekservice die voor iedereen beschikbaar is. Men kan zoeken op data uit de Basisregistratie Adressen en Gebouwen, zoals adres, postcode, straat, woonplaats of op een kadastraal perceelnummer.",{"__component":475,"id":479,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":480,"introductionText":18},1441,"![database](https://www.sharevalue.nl/images/sharevalue/blogs/Contactpersoon_Form.01.png)",{"__component":475,"id":482,"title":18,"asideText":483,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":484,"introductionText":18},1443,"PDOK","PDOK was al jaren bekend door o.a. de voormalige “Geocode service”, een betrouwbare dienst die nog gebaseerd was op de verouderde SOAP Web-services. PDOK heeft haar diensten vernieuwd. Als gevolg is de [“Geocode service” uit de productie gehaald](https://www.pdok.nl/-/geocodeerservice-pdok-uit-productie?redirect=/nieuws) en een moderne en up-to-date vervanger geïntroduceerd, namelijk de “Locatieserver”. Deze nieuwe service kan gebruikt worden om via de postcode het bijbehorende adres op te halen. Op deze manier heb je altijd het juiste adres in het CRM-systeem staan. De kern van deze functionaliteit is simpelweg aan de service vragen welke adresgegevens horen bij de opgeven postcode. Vervolgens zal hij deze vraag beantwoorden met de gevonden (geen, een of meerdere) adressen. Tenslotte dienen we deze antwoorden te lezen en de bijbehorende waardes zichtbaar te maken bij de adresvelden van het formulier.\n\nBij mijn vorige opdrachtgever werd al jaren gebruik gemaakt van CRM. Tot een aantal maanden geleden draaiden zij nog op versie CRM 2011. Vanwege het vele (oude) maatwerk zijn upgrades naar de diverse opvolgende versies jaren uitgesteld. Vanuit deze achtergrond ontstond bij mijn opdrachtgever de wens om bij deze upgrade naar CRM 2016 zoveel mogelijk maatwerk te vervangen door standaard functionaliteiten, zonder er functioneel op achteruit te gaan. Dit met als voornaamste doel dat de oplossing beter beheersbaar zou worden en dat toekomstige upgrades minder ingrijpend zullen zijn vanwege de vermindering in de hoeveelheid maatwerk. Aan mij was de taak om Dynamics CRM en dus ook de PDOK-service te implementeren binnen de nieuwe architectuur.",{"__component":475,"id":486,"title":18,"asideText":487,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":488,"introductionText":18},1444,"Voordelen aan de implementatie","Ik ben begonnen met het schrijven van een stuk code voor de implementatie en vond deze dienst steeds interessanter worden. Er zijn namelijk heel veel voordelen aan verbonden, zoals kwalitatief betere data, het kunnen valideren van gegevens en de service wordt automatisch op nationaal niveau ge-update. En wat wellicht nog interessanter is: het is gratis! Het enige wat je nodig hebt is iemand die het kan implementeren in jouw CRM-systeem. Tijdens het implementeren ben ik erachter gekomen dat dit ook een nadeel kan zijn. Mocht de service down zijn, dan kan je geen contact opnemen met een achterliggende organisatie die ondersteuning kan bieden. Natuurlijk blijft het wel altijd mogelijk om de data ook handmatig in te vullen.",{"__component":475,"id":490,"title":18,"asideText":62,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":491,"introductionText":18},1445,"![database](https://www.sharevalue.nl/images/sharevalue/blogs/Contactpersoon_Form.06.png)​",{"__component":475,"id":493,"title":18,"asideText":494,"underline":66,"centered":66,"blankAside":66,"aside":18,"content":495,"introductionText":18},1446,"Ideale uitkomst","Bij mijn opdrachtgever ging het om miljoenen gegevens aan data en was het niet te doen om alle adressen handmatig langs te lopen. De PDOK-service was dus een ideale uitkomst! De gratis zoekservice zou ik ook zeker aanbevelen aan opdrachtgevers met grote hoeveelheid aan data om uiteindelijk tot een kwalitatief betere database te komen.\n\nWil jij deze service ook implementeren in jouw Dynamics 365/ CRM-omgeving? Dat kan! [Neem contact met ons op](/contact) en dan kijken we samen wat we voor jou kunnen betekenen.",{"__component":497,"id":498,"title":18,"showBlankAside":80},"global.social-sharing",148,{"__component":500,"id":501,"name":18,"jobTitle":18},"strapi.author-card",106,{"__component":104,"id":503,"title":504,"aside":18,"postType":107,"limit":108,"expertise":505},117,"Lees ook onze andere berichten",[506],{"id":60,"title":61,"subTitle":62,"description":62,"shortDescription":62,"slug":63,"createdAt":64,"updatedAt":64,"publishedAt":65,"isCoreExpertise":66,"documentId":67,"image":18,"blocks":507,"midPageBlocks":508,"seo":18},[],[],{"__component":117,"id":510,"titleLeft":122,"callToActionTextLeft":123,"callToActionLinkUrlLeft":124,"titleRight":511,"callToActionTextRight":512,"callToActionLinkUrlRight":513,"iconUrlLeft":514,"iconUrlRight":515},175,"Wil je weten waar wij goed in zijn?","Ontdek wat we doen","/wat-we-doen",{"id":60,"name":211,"alternativeText":18,"caption":18,"width":201,"height":201,"formats":18,"hash":212,"ext":203,"mime":204,"size":213,"url":214,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":215,"updatedAt":216,"documentId":217,"publishedAt":57},{"id":198,"name":199,"alternativeText":18,"caption":18,"width":200,"height":201,"formats":18,"hash":202,"ext":203,"mime":204,"size":205,"url":206,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":207,"updatedAt":208,"documentId":209,"publishedAt":57},{"id":517,"metaTitle":518,"metaDescription":519,"structuredData":520,"metaImage":18,"metaSocial":547},197,"Voorkom CRM-databasevervuiling | ShareValue","Gebruik de gratis PDOK Locatieserver om adresgegevens automatisch te valideren in Dynamics CRM en voorkom databasevervuiling.",[521,530],{"url":522,"@type":523,"author":524,"@context":186,"headline":525,"publisher":526,"description":519,"datePublished":13},"https://www.sharevalue.nl/blogs/een-gratis-manier-om-crm-database-vervuiling-te-voorkomen","BlogPosting",{},"Voorkom CRM-databasevervuiling met gratis PDOK-service | ShareValue",{"logo":527,"name":189,"@type":190},{"url":528,"@type":529},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject",{"@type":531,"@context":186,"mainEntity":532},"FAQPage",[533,539,543],{"name":534,"@type":535,"acceptedAnswer":536},"Wat is de PDOK Locatieserver?","Question",{"text":537,"@type":538},"De PDOK Locatieserver is een gratis zoekservice die adresgegevens uit de Basisregistratie Adressen en Gebouwen (BAG) levert, waarmee je via postcode en huisnummer automatisch correcte adresgegevens kunt ophalen.","Answer",{"name":540,"@type":535,"acceptedAnswer":541},"Hoe helpt de PDOK-service bij het voorkomen van CRM-databasevervuiling?",{"text":542,"@type":538},"Door de PDOK-service te integreren in je CRM-systeem, worden adresgegevens automatisch gevalideerd en ingevuld, waardoor typfouten en onjuiste invoer worden voorkomen.",{"name":544,"@type":535,"acceptedAnswer":545},"Is de PDOK-service geschikt voor grote datasets?",{"text":546,"@type":538},"Ja, de PDOK-service is ideaal voor organisaties met grote hoeveelheden data, omdat het handmatig controleren van adressen tijdrovend is en de service automatisch up-to-date gegevens levert.",[],{"pagination":549},{"page":550,"pageSize":551},1,100,{},1779451668121]