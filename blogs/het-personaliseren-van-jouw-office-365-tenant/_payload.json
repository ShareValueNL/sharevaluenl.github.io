99,"name":285,"path":18,"size":286,"width":43,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":23,"url":288,"hash":289,"mime":199,"name":290,"path":18,"size":291,"width":220,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"id":298,"title":299,"subTitle":300,"content":301,"callToActionText":18,"callToActionLink":18,"colorStyle":233,"showAsides":189,"imageUrl":302,"__component":226},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":303,"name":304,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":305,"hash":326,"ext":23,"mime":199,"size":327,"url":328,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":329,"updatedAt":329,"documentId":330,"publishedAt":58,"focalPoint":18},785,"microsoft development.jpg",{"large":306,"small":311,"medium":316,"thumbnail":321},{"ext":23,"url":307,"hash":308,"mime":199,"name":309,"path":18,"size":310,"width":29,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":23,"url":312,"hash":313,"mime":199,"name":314,"path":18,"size":315,"width":36,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":23,"url":317,"hash":318,"mime":199,"name":319,"path":18,"size":320,"width":43,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":322,"hash":323,"mime":199,"name":324,"path":18,"size":325,"width":220,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":332,"title":333,"subTitle":334,"content":335,"callToActionText":336,"callToActionLink":155,"colorStyle":188,"showAsides":189,"imageUrl":337,"__component":226},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":338,"name":339,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":340,"hash":361,"ext":23,"mime":199,"size":362,"url":363,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":364,"updatedAt":364,"documentId":365,"publishedAt":58,"focalPoint":18},786,"migratie.jpg",{"large":341,"small":346,"medium":351,"thumbnail":356},{"ext":23,"url":342,"hash":343,"mime":199,"name":344,"path":18,"size":345,"width":29,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":347,"hash":348,"mime":199,"name":349,"path":18,"size":350,"width":36,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":352,"hash":353,"mime":199,"name":354,"path":18,"size":355,"width":43,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":357,"hash":358,"mime":199,"name":359,"path":18,"size":360,"width":220,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":367,"title":368,"subTitle":369,"content":370,"callToActionText":18,"callToActionLink":18,"colorStyle":233,"showAsides":189,"imageUrl":371,"__component":226},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":372,"name":373,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":374,"hash":395,"ext":23,"mime":199,"size":396,"url":397,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":398,"updatedAt":398,"documentId":399,"publishedAt":58,"focalPoint":18},787,"microsoft security.jpg",{"large":375,"small":380,"medium":385,"thumbnail":390},{"ext":23,"url":376,"hash":377,"mime":199,"name":378,"path":18,"size":379,"width":29,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":381,"hash":382,"mime":199,"name":383,"path":18,"size":384,"width":36,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":386,"hash":387,"mime":199,"name":388,"path":18,"size":389,"width":43,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":391,"hash":392,"mime":199,"name":393,"path":18,"size":394,"width":220,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":401,"title":402,"subTitle":403,"content":404,"callToActionText":405,"callToActionLink":406,"colorStyle":188,"showAsides":189,"imageUrl":407,"__component":226},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":408,"name":409,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":410,"hash":431,"ext":23,"mime":199,"size":432,"url":433,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":434,"updatedAt":434,"documentId":435,"publishedAt":58,"focalPoint":18},788,"vergaderruimte.jpg",{"large":411,"small":416,"medium":421,"thumbnail":426},{"ext":23,"url":412,"hash":413,"mime":199,"name":414,"path":18,"size":415,"width":29,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":417,"hash":418,"mime":199,"name":419,"path":18,"size":420,"width":36,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":422,"hash":423,"mime":199,"name":424,"path":18,"size":425,"width":43,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":427,"hash":428,"mime":199,"name":429,"path":18,"size":430,"width":220,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":437,"title":438,"subTitle":439,"content":440,"callToActionText":18,"callToActionLink":18,"colorStyle":233,"showAsides":189,"imageUrl":441,"__component":226},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":442,"name":443,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":444,"hash":465,"ext":23,"mime":199,"size":466,"url":467,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":468,"updatedAt":468,"documentId":469,"publishedAt":58,"focalPoint":18},789,"teamwork.jpg",{"large":445,"small":450,"medium":455,"thumbnail":460},{"ext":23,"url":446,"hash":447,"mime":199,"name":448,"path":18,"size":449,"width":29,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":451,"hash":452,"mime":199,"name":453,"path":18,"size":454,"width":36,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":456,"hash":457,"mime":199,"name":458,"path":18,"size":459,"width":43,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":461,"hash":462,"mime":199,"name":463,"path":18,"size":464,"width":220,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":471,"title":472,"callToActionText":473,"callToActionLinkUrl":474,"body":18,"imageUrl":475,"__component":476},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":160,"name":161,"alternativeText":18,"caption":18,"width":162,"height":163,"formats":18,"hash":164,"ext":165,"mime":166,"size":167,"url":168,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":169,"updatedAt":170,"documentId":171,"publishedAt":58,"focalPoint":18},"call-to-action.single",[478,483,487,491,495,498,501,580],{"id":479,"title":18,"asideText":480,"underline":189,"centered":189,"blankAside":189,"aside":18,"content":481,"introductionText":18,"__component":482},1139,"","Omdat Microsoft dezelfde Office 365-services biedt aan een ongekende hoeveelheid klanten, wordt het voor iedereen eenvoudig gemaakt om de exact dezelfde Office 365-ervaring te beleven. Alhoewel een groot deel van de Office 365-ervaring consistent is in het hele klantenbestand, staat Microsoft jou wel toe om wat aanpassingen te verrichten.","global.pagesection",{"id":484,"title":18,"asideText":485,"underline":189,"centered":189,"blankAside":189,"aside":18,"content":486,"introductionText":18,"__component":482},1138,"Hoe wijzig je het uiterlijk van de Office 365 portal?","## Het uiterlijk van de Office 365-portal wijzigen\n\nAls je het uiterlijk van de Office 365-portal wilt wijzigen, dan meld je je aan bij het Microsoft Office 365 Admin Center (Beheercentrum). Vervolgens ga je naar Instellingen > Organisatieprofiel (zie figuur 1).\n\n![Figuur 1: Het Microsoft 365 Admin Center (Beheercentrum) biedt verschillende aanpassingsopties.](https://www.sharevalue.nl/images/sharevalue/blogs/admin_center.png)\n\nFiguur 1: Het Microsoft 365 Admin Center (Beheercentrum) biedt verschillende aanpassingsopties.\n\nZoals je in de afbeelding kunt zien, is een van de secties getiteld met “Add custom tiles for your organization” (Aangepaste thema’s voor uw organisatie toevoegen). Als je in dit gedeelte op de knop “Edit” klikt, ga je naar een scherm waarin je het uiterlijk van de Office 365-interface kunt bepalen (zie figuur 2).\n\nHierin kun je een logo en een achtergrondafbeelding toevoegen aan de Office 365-portal. Je kunt zelfs het logo klikbaar maken. Er zijn ook opties voor het regelen van de kleur van de navigatiebalk, tekst- en pictogramkleuren en accentkleuren. Gebruikers hebben de mogelijkheid om hun eigen thema’s te gebruiken, maar er is een optie om te voorkomen dat gebruikers jouw opgegeven thema overschrijven.\n\n![Figuur 2: Je kunt Office 365 voorzien van uw eigen thema en afbeeldingen.](https://www.sharevalue.nl/images/sharevalue/blogs/office_365_thema_en_afbeeldingen.jpg)\n\nFiguur 2: Je kunt Office 365 voorzien van uw eigen thema en afbeeldingen.",{"id":488,"title":18,"asideText":489,"underline":189,"centered":189,"blankAside":189,"aside":18,"content":490,"introductionText":18,"__component":482},1140,"​Tegels toevoegen","## Tegels toevoegen aan Office 365\n\nWeer terug naar het menu “Organization Profile” (figuur 1), hierin vind je ook de optie “Add custom tiles for your organization.” (Aangepaste tegels voor uw organisatie toevoegen). Hierin biedt het Office 365-portaal de gebruikers een reeks klikbare tegels die ze kunnen gebruiken om toegang te krijgen tot zaken als Power BI, OneNote en Planner. Met de optie “Aangepaste tegels” kun je de voorraadtegels van Microsoft aanvullen met enkele eigen tegels.\n\nHelaas kan je niet gewoon een tegel uploaden voor gebruik in Office 365. Zowel de tegel als de toepassing die aan de tegel is gekoppeld, moeten toegankelijk zijn via een URL (figuur 3). De aangepaste tegel dient daarnaast ook een naam te hebben en een korte beschrijving waarvoor deze dient.\n\n![Figuur 3: Microsoft biedt je de mogelijkheid om aangepaste tegels toe te voegen aan het Office 365 portaal.](https://www.sharevalue.nl/images/sharevalue/blogs/office_365_portaal_tegels_toevoegen.jpg)\n\nFiguur 3: Microsoft biedt je de mogelijkheid om aangepaste tegels toe te voegen aan het Office 365 portaal.\n\nHet is goed om te weten dat deze optie je niet beperkt tot het maken van een aangepaste tegel. Als jouw organisatie gebruikmaakt van meerdere Software as a Service (SaaS) toepassingen, kan je deze ook toevoegen. Hierdoor zijn alle toepassingen toegankelijk via het Office 365-portaal. Dat zou de gebruikers een centrale locatie geven voor het dagelijks gebruik van al hun webtoepassingen.",{"id":492,"title":18,"asideText":493,"underline":189,"centered":189,"blankAside":189,"aside":18,"content":494,"introductionText":18,"__component":482},1141,"Gepersonaliseerde helpdesk","## Je eigen contactgegevens als Helpdesk\n\nDe laatste optie die je in figuur 1 ziet, is een optie om contactgegevens op maat aan te leveren voor de Helpdesk. Deze optie staat standaard uitgeschakeld, maar als je op de knop “Bewerken” klikt en vervolgens de Helpdesk-schakelaar op “Aan” zet, krijg je de mogelijkheid om de contactinformatie voor de Helpdesk van jouw organisatie in te voeren (figuur 4).\n\n![Figuur 4: Office 365 biedt de mogelijkheid om aangepaste helpdeskinformatie in te voeren.](https://www.sharevalue.nl/images/sharevalue/blogs/office_365_helpdeskinformatie.jpg)\n\nFiguur 4: Office 365 biedt de mogelijkheid om aangepaste helpdeskinformatie in te voeren.\n\nVermoedelijk laat Microsoft deze optie uitstaan i.v.m. de kleinere organisaties die in geval van een incident rechtstreeks contact opnemen met de ondersteuningsdienst van Microsoft. In grotere organisaties met een interne Helpdesk biedt deze optie de gebruikers echter een plek om hulp te zoeken.\n\nEen van de dingen die ik leuk vind aan het aangepaste Helpdeskcentrum, is dat je niet verplicht bent om alle informatie in te vullen en/of aan te vinken. Dit betekent dat als je wilt dat de gebruikers alleen telefonisch contact met de helpdesk opnemen, kun je het selectievakje van de helpdesktelefoon selecteren en de andere selectievakjes leeg laten. Aan de andere kant kun je ervoor kiezen om alleen het e-mailadres of URL van de Helpdesk weer te geven. In elk geval kun je ervoor kiezen om de contactopties weer te geven die het meest geschikt zijn voor jouw eigen organisatie.\n\nDit is slechts één van de vele opties die Microsoft biedt om werken voor iedereen eenvoudiger en prettiger te maken. Ook als je al aan de slag bent met Office 365, zijn er nog een hoop opties. Zo kan je ook je [Power BI Dashboard aankleden door afbeeldingen toe te voegen](/blogs/kleed-je-power-bi-dashboard-aan-door-afbeeldingen-toe-te-voegen), of [binnen één dag een modern intranet neerzetten.](/blogs/deel-1-hoe-bouw-je-een-modern-intranet-binnen-een-dag)\n\nKan ik of een van mijn collega’s helpen bij het volledig naar wens inrichten van jouw Office 365-omgeving? [Neem vrijblijvend contact met ons op](/contact) om de mogelijkheden te bespreken.",{"id":496,"title":18,"showBlankAside":105,"__component":497},125,"global.social-sharing",{"id":499,"name":18,"jobTitle":18,"__component":500},83,"strapi.author-card",{"id":502,"title":503,"aside":18,"postType":146,"limit":147,"expertise":504,"__component":150},94,"Lees ook onze andere berichten",[505],{"id":96,"title":97,"subTitle":98,"description":99,"shortDescription":100,"slug":101,"createdAt":102,"updatedAt":103,"publishedAt":104,"isCoreExpertise":105,"documentId":106,"image":506,"seo":509,"blocks":514,"midPageBlocks":521},{"id":108,"name":109,"alternativeText":18,"caption":18,"width":110,"height":111,"formats":507,"hash":122,"ext":114,"mime":117,"size":123,"url":124,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":125,"updatedAt":125,"documentId":126,"publishedAt":58,"focalPoint":18},{"thumbnail":508},{"ext":114,"url":115,"hash":116,"mime":117,"name":118,"path":18,"size":119,"width":120,"height":121},{"id":128,"metaTitle":129,"metaDescription":1