[{"data":1,"prerenderedAt":592},["ShallowReactive",2],{"collection-blogs-85775221":3,"_apollo:default":591},{"data":4,"meta":587},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":59,"expertises":94,"blocks":477},86,"Het personaliseren van jouw Office 365 tenant","De meeste bedrijven hebben de \"Look and Feel\" van hun Office 365 standaard ingesteld staan. Maar; wist je dat je Office 365 ook kunt personaliseren? In deze blog laat ik je zien hoe dit in zijn werk gaat.","het-personaliseren-van-jouw-office-365-tenant","2023-10-13T10:26:37.677Z","2025-04-22T12:35:35.045Z","2023-10-13T10:26:37.640Z","2019-07-17","u0zlcra2v8c84m02sft9kttc",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":18},335,"het-personaliseren-van-jouw-office-365-tenant.jpg",null,1074,711,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce.jpg","large_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce","image/jpg","large_het-personaliseren-van-jouw-office-365-tenant.jpg",1287.97,1000,662,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce.jpg","small_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce","small_het-personaliseren-van-jouw-office-365-tenant.jpg",340.78,500,331,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce.jpg","medium_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce","medium_het-personaliseren-van-jouw-office-365-tenant.jpg",748.6,750,497,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce.jpg","thumbnail_het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce","thumbnail_het-personaliseren-van-jouw-office-365-tenant.jpg",80.34,236,156,"het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce",423.02,"https://incredible-beef-2a6059b946.media.strapiapp.com/het_personaliseren_van_jouw_office_365_tenant_fb8a0ca6ce.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:23:59.324Z","hx0czswq5t1gecwokgh9nv03","2026-01-05T12:38:34.018Z",{"id":60,"metaTitle":61,"metaDescription":62,"structuredData":63,"metaImage":18,"metaSocial":93},174,"Office 365 personaliseren: tips voor je tenant | ShareValue","Leer hoe je het uiterlijk van je Office 365-portal aanpast met thema’s, aangepaste tegels en helpdeskinformatie via het Microsoft 365 Admin Center.​",[64,76],{"url":65,"@type":66,"author":67,"@context":68,"headline":61,"publisher":69,"description":75,"datePublished":13},"https://www.sharevalue.nl/blogs/het-personaliseren-van-jouw-office-365-tenant","BlogPosting",{},"https://schema.org",{"logo":70,"name":73,"@type":74},{"url":71,"@type":72},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","ShareValue","Organization","Leer hoe je het uiterlijk van je Office 365-portal aanpast met thema’s, aangepaste tegels en helpdeskinformatie via het Microsoft 365 Admin Center.",{"@type":77,"@context":68,"mainEntity":78},"FAQPage",[79,85,89],{"name":80,"@type":81,"acceptedAnswer":82},"Hoe pas ik het uiterlijk van mijn Office 365-portal aan?","Question",{"text":83,"@type":84},"Meld je aan bij het Microsoft 365 Admin Center, ga naar Instellingen > Organisatieprofiel en bewerk het thema om logo’s, kleuren en achtergrondafbeeldingen toe te voegen.","Answer",{"name":86,"@type":81,"acceptedAnswer":87},"Kan ik aangepaste tegels toevoegen aan Office 365?",{"text":88,"@type":84},"Ja, via het organisatieprofiel kun je aangepaste tegels toevoegen met een naam, beschrijving en URL, zodat gebruikers snel toegang hebben tot interne of externe toepassingen.",{"name":90,"@type":81,"acceptedAnswer":91},"Hoe stel ik aangepaste helpdeskinformatie in?",{"text":92,"@type":84},"In het Microsoft 365 Admin Center kun je aangepaste contactgegevens voor de helpdesk instellen, zoals telefoonnummer, e-mailadres en ondersteunings-URL.",[],[95],{"id":96,"title":97,"subTitle":98,"description":99,"shortDescription":100,"slug":101,"createdAt":102,"updatedAt":103,"publishedAt":104,"isCoreExpertise":105,"documentId":106,"image":107,"seo":127,"blocks":142,"midPageBlocks":182},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":108,"name":109,"alternativeText":18,"caption":18,"width":110,"height":111,"formats":112,"hash":122,"ext":114,"mime":117,"size":123,"url":124,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":125,"updatedAt":125,"documentId":126,"publishedAt":58,"focalPoint":18},16,"microsoft-365.png",282,130,{"thumbnail":113},{"ext":114,"url":115,"hash":116,"mime":117,"name":118,"path":18,"size":119,"width":120,"height":121},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,245,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",{"id":128,"metaTitle":129,"metaDescription":130,"structuredData":131,"metaImage":18,"metaSocial":141},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":132,"@type":133,"@context":68,"provider":134,"areaServed":136,"description":139,"serviceType":140},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service",{"url":135,"name":73,"@type":74},"https://www.sharevalue.nl",{"name":137,"@type":138},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",[],[143,151],{"id":144,"title":145,"aside":18,"postType":146,"limit":147,"expertise":148,"__component":150},166,"Lees meer over Microsoft 365","alle",3,[149],{"id":96,"title":97,"subTitle":98,"description":99,"shortDescription":100,"slug":101,"createdAt":102,"updatedAt":103,"publishedAt":104,"isCoreExpertise":105,"documentId":106},"strapi.related-kennisbank-list",{"id":152,"titleLeft":153,"callToActionTextLeft":154,"callToActionLinkUrlLeft":155,"titleRight":156,"callToActionTextRight":157,"callToActionLinkUrlRight":158,"iconUrlLeft":159,"iconUrlRight":172,"__component":181},211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":160,"name":161,"alternativeText":18,"caption":18,"width":162,"height":163,"formats":18,"hash":164,"ext":165,"mime":166,"size":167,"url":168,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":169,"updatedAt":170,"documentId":171,"publishedAt":58,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":173,"name":174,"alternativeText":18,"caption":18,"width":163,"height":163,"formats":18,"hash":175,"ext":165,"mime":166,"size":176,"url":177,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":178,"updatedAt":179,"documentId":180,"publishedAt":58,"focalPoint":18},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[183,227,263,297,331,366,400,436,470],{"id":184,"title":185,"subTitle":186,"content":187,"callToActionText":18,"callToActionLink":18,"colorStyle":188,"showAsides":189,"imageUrl":190,"__component":226},27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"id":191,"name":192,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":195,"hash":221,"ext":23,"mime":199,"size":222,"url":223,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":224,"updatedAt":224,"documentId":225,"publishedAt":58,"focalPoint":18},782,"Teams.jpg",1280,850,{"large":196,"small":203,"medium":209,"thumbnail":215},{"ext":23,"url":197,"hash":198,"mime":199,"name":200,"path":18,"size":201,"width":29,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Teams_43eca91eed.jpg","large_Teams_43eca91eed","image/jpeg","large_Teams.jpg",75.76,664,{"ext":23,"url":204,"hash":205,"mime":199,"name":206,"path":18,"size":207,"width":36,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Teams_43eca91eed.jpg","small_Teams_43eca91eed","small_Teams.jpg",24.28,332,{"ext":23,"url":210,"hash":211,"mime":199,"name":212,"path":18,"size":213,"width":43,"height":214},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Teams_43eca91eed.jpg","medium_Teams_43eca91eed","medium_Teams.jpg",45.38,498,{"ext":23,"url":216,"hash":217,"mime":199,"name":218,"path":18,"size":219,"width":220,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Teams_43eca91eed.jpg","thumbnail_Teams_43eca91eed","thumbnail_Teams.jpg",8.28,235,"Teams_43eca91eed",119.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/Teams_43eca91eed.jpg","2024-08-08T09:42:56.910Z","ht6rctym4qbbspr1vnahyrg1","global.alternating-page-section",{"id":228,"title":229,"subTitle":230,"content":231,"callToActionText":232,"callToActionLink":155,"colorStyle":233,"showAsides":189,"imageUrl":234,"__component":226},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"id":235,"name":236,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":237,"hash":258,"ext":23,"mime":199,"size":259,"url":260,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":261,"updatedAt":261,"documentId":262,"publishedAt":58,"focalPoint":18},783,"adoptie.jpg",{"large":238,"small":243,"medium":248,"thumbnail":253},{"ext":23,"url":239,"hash":240,"mime":199,"name":241,"path":18,"size":242,"width":29,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_adoptie_dc3bbcacaa.jpg","large_adoptie_dc3bbcacaa","large_adoptie.jpg",140.54,{"ext":23,"url":244,"hash":245,"mime":199,"name":246,"path":18,"size":247,"width":36,"height":208},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_adoptie_dc3bbcacaa.jpg","small_adoptie_dc3bbcacaa","small_adoptie.jpg",46.09,{"ext":23,"url":2