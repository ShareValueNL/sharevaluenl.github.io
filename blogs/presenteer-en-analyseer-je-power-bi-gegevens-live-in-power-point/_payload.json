f-2a6059b946.media.strapiapp.com/folder_d71bf882b0.webp","2023-08-17T13:42:28.245Z","2025-07-22T07:14:07.669Z","exd7vm0cg06bj1vbrpv9qa8a",{"id":442,"metaTitle":443,"metaDescription":444,"structuredData":445,"metaImage":18,"metaSocial":474},109,"Power BI live presenteren in PowerPoint | ShareValue","Koppel Power BI aan PowerPoint en presenteer live data in je slides. Joost laat zien hoe je inzichten deelt zonder ze te exporteren.",[446,457],{"url":447,"@type":448,"author":449,"@context":150,"headline":443,"publisher":452,"description":444,"datePublished":456},"https://www.sharevalue.nl/blogs/presenteer-en-analyseer-je-power-bi-gegevens-live-in-power-point","BlogPosting",{"name":326,"@type":450,"jobTitle":327,"worksFor":451},"Person",{"name":153,"@type":154},{"logo":453,"name":153,"@type":154},{"url":454,"@type":455},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","2023-11-09",{"@type":458,"@context":150,"mainEntity":459},"FAQPage",[460,466,470],{"name":461,"@type":462,"acceptedAnswer":463},"Hoe koppel je Power BI aan PowerPoint?","Question",{"text":464,"@type":465},"Gebruik de Power BI-integratie in PowerPoint om interactieve rapporten in te voegen die live data tonen tijdens je presentatie.","Answer",{"name":467,"@type":462,"acceptedAnswer":468},"Wat zijn de voordelen van live data in presentaties?",{"text":469,"@type":465},"Je hoeft niets meer te exporteren of bij te werken – je laat direct de meest actuele cijfers zien in je presentatie.",{"name":471,"@type":462,"acceptedAnswer":472},"Is er technische kennis nodig om dit te doen?",{"text":473,"@type":465},"Nee, met de juiste rechten en een paar klikken kun je al rapporten embedden in je PowerPoint-slides.",[],{"pagination":476},{"page":477,"pageSize":478},1,100,{},1779187919876]