[{"data":1,"prerenderedAt":606},["ShallowReactive",2],{"collection-blogs--145691842":3,"_apollo:default":605},{"data":4,"meta":601},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":93,"blocks":481},58,"I Love Sitecore (en ik zal het missen). Op naar Sitefinity!","Om met de deur in huis te vallen: ik ben best een beetje bedroefd, want we zijn geen Sitecore-partner meer. Het CMS waar ik de afgelopen jaren veel werk in heb gehad, waar mijn expertise zit. Er zijn echter wat veranderingen in de markt, waardoor wij als bedrijf onze horizon moeten verbreden. Gelukkig hebben wij een gedegen ‘sidekick’ gevonden. En zijn naam is Sitefinity.","i-love-sitecore-en-ik-zal-het-missen-op-naar-sitefinity","2023-10-13T10:26:33.548Z","2025-04-17T13:37:14.406Z","2023-10-13T10:26:33.504Z","2021-02-22","egk6o8nys6ecqm8xj2fg6fsx",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},307,"i-love-sitecore-en-ik-zal-het-missen-op-naar-sitefinity.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_i_love_sitecore_en_ik_zal_het_missen_op_naar_sitefinity_dfae2251ab.jpg","large_i_love_sitecore_en_ik_zal_het_missen_op_naar_sitefinity_dfae2251ab","image/jpg","large_i-love-sitecore-en-ik-zal-het-missen-op-naar-sitefinity.jpg",96.07,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_i_love_sitecore_en_ik_zal_het_missen_op_naar_sitefinity_dfae2251ab.jpg","small_i_love_sitecore_en_ik_z