[{"data":1,"prerenderedAt":629},["ShallowReactive",2],{"collection-blogs-1288226769":3,"_apollo:default":628},{"data":4,"meta":625},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":59,"expertises":97,"blocks":486},61,".NET 5: de kickstart van jouw .NET migratie","Op 10 november zag .NET 5 officieel het levenslicht tijdens een driedaags online event. .NET 5 mag met recht een mijlpaal genoemd worden: wellicht wel het belangrijkste moment in het (bijna) 18-jarig bestaan van .NET. Lees in deze blog waarom dit zo is, wat je ermee kunt en wat de voordelen zijn.",".net-5-de-kickstart-van-jouw-.net-migratie","2023-10-13T10:26:34.286Z","2025-04-17T13:39:51.111Z","2023-10-13T10:26:34.234Z","2020-12-10","g0tj0qesdtxd2c16qn1lcofk",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":18},310,".net-5-de-kickstart-van-jouw-.net-migratie.jpg",null,1920,995,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d.jpg","large_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d","image/jpg","large_.net-5-de-kickstart-van-jouw-.net-migratie.jpg",132.67,1000,518,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d.jpg","small_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d","small_.net-5-de-kickstart-van-jouw-.net-migratie.jpg",34.78,500,259,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d.jpg","medium_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d","medium_.net-5-de-kickstart-van-jouw-.net-migratie.jpg",75.1,750,389,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d.jpg","thumbnail_net_5_de_kickstart_van_jouw_net_migratie_a992b9396d","thumbnail_.net-5-de-kickstart-van-jouw-.net-migratie.jpg",9.41,245,127,"net_5_de_kickstart_van_jouw_net_migratie_a992b9396d",514.71,"https://incredible-beef-2a6059b946.media.strapiapp.com/net_5_de_kickstart_van_jouw_net_migratie_a992b9396d.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:22:55.924Z","qc2jl3iyzabrqz0w56iov93j","2026-01-05T12:38:34.018Z",{"id":60,"metaTitle":61,"metaDescription":62,"structuredData":63,"metaImage":18,"metaSocial":96},149,"Start je .NET-migratie met .NET 5 | ShareValue","Michiel legt uit waarom .NET 5 een mijlpaal is en hoe je je migratie van .NET Framework naar .NET 5 of .NET 6 kunt voorbereiden.",[64,79],{"url":65,"@type":66,"author":67,"@context":74,"headline":61,"publisher":75,"description":62,"datePublished":13},"https://www.sharevalue.nl/blogs/.net-5-de-kickstart-van-jouw-.net-migratie","BlogPosting",{"name":68,"@type":69,"jobTitle":70,"worksFor":71},"Michiel","Person","Developer",{"name":72,"@type":73},"ShareValue","Organization","https://schema.org",{"logo":76,"name":72,"@type":73},{"url":77,"@type":78},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject",{"@type":80,"@context":74,"mainEntity":81},"FAQPage",[82,88,92],{"name":83,"@type":84,"acceptedAnswer":85},"Waarom is .NET 5 een belangrijke mijlpaal?","Question",{"text":86,"@type":87},".NET 5 is open source, cross-platform en biedt betere performance. Het verenigt de .NET-wereld en is de opvolger van .NET Core 3.1.","Answer",{"name":89,"@type":84,"acceptedAnswer":90},"Wat is het verschil tussen .NET 5 en .NET 6?",{"text":91,"@type":87},".NET 6 is de LTS-versie (Long Term Support) die in november 2021 uitkomt. .NET 5 heeft geen LTS, maar is geschikt voor voorbereiding op migratie.",{"name":93,"@type":84,"acceptedAnswer":94},"Hoe begin ik met migreren naar .NET 5?",{"text":95,"@type":87},"Begin met het onderbrengen van business logica in .NET Standard 2.1 class libraries. Dit maakt de code compatibel met zowel .NET Framework als .NET 5.",[],[98,282],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109,"image":110,"seo":18,"blocks":129,"midPageBlocks":165},3,"Microsoft .NET","Maatwerkoplossingen voor ieder vraagstuk","Ons team van .NET-experts staat niet alleen klaar om onze klanten te ondersteunen bij diverse implementatie uitdagingen, maar we zijn ook gespecialiseerd in het testen van applicaties op verschillende niveaus, zoals unit tests, integratietests en acceptatietests. We streven naar uitmuntende testdekking om de stabiliteit en betrouwbaarheid van de applicaties te waarborgen.\n\nDaarnaast zijn we bedreven in het gebruik van verschillende Azure-services om schaalbare en veilige oplossingen te bieden aan onze klanten. Zo bieden we met Azure DevOps krachtige tools voor het beheren van de ontwikkeling, het automatiseren van tests en het geautomatiseerd uitrollen naar acceptatie- of productieomgevingen met CI/CD-pipelines.\n\nHet samenwerken met onze klanten staat centraal in ons werk, en we denken proactief mee om samen de meest optimale oplossingen te realiseren.","In de praktijk komen de .NET developers van ShareValue terecht in allerlei verschillende branches met uiteenlopende technische uitdagingen.","dotnet","2023-08-17T11:19:57.991Z","2024-12-13T12:16:04.480Z","2023-08-17T11:22:08.050Z",false,"v9pl553hsjk98esvs5gzoso3",{"id":111,"name":112,"alternativeText":18,"caption":18,"width":113,"height":114,"formats":115,"hash":124,"ext":117,"mime":120,"size":125,"url":126,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":127,"updatedAt":127,"documentId":128,"publishedAt":58,"focalPoint":18},17,"dotnet_logo.png",282,130,{"thumbnail":116},{"ext":117,"url":118,"hash":119,"mime":120,"name":121,"path":18,"size":122,"width":50,"height":123},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_dotnet_logo_d38dbc3865.png","thumbnail_dotnet_logo_d38dbc3865","image/png","thumbnail_dotnet_logo.png",7.14,113,"dotnet_logo_d38dbc3865",2.93,"https://incredible-beef-2a6059b946.media.strapiapp.com/dotnet_logo_d38dbc3865.png","2023-08-17T09:47:56.313Z","nnimzsossci29qmi8z0texlp",[130,137],{"id":131,"title":132,"aside":18,"postType":133,"limit":99,"expertise":134,"__component":136},167," Lees meer over .NET Development","alle",[135],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109},"strapi.related-kennisbank-list",{"id":138,"titleLeft":139,"callToActionTextLeft":140,"callToActionLinkUrlLeft":141,"titleRight":142,"callToActionTextRight":140,"callToActionLinkUrlRight":141,"iconUrlLeft":143,"iconUrlRight":156,"__component":164},212,"Heb je een .NET expert nodig?","Neem contact met ons op","/contact","Weten welke expert op dit moment beschikbaar is?",{"id":144,"name":145,"alternativeText":18,"caption":18,"width":146,"height":147,"formats":18,"hash":148,"ext":149,"mime":150,"size":151,"url":152,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":153,"updatedAt":154,"documentId":155,"publishedAt":58,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":157,"name":158,"alternativeText":18,"caption":18,"width":147,"height":147,"formats":18,"hash":159,"ext":149,"mime":150,"size":160,"url":161,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":162,"updatedAt":162,"documentId":163,"publishedAt":58,"focalPoint":18},250,"looking-glass.svg","looking_glass_cfa3801802",0.6,"https://incredible-beef-2a6059b946.media.strapiapp.com/looking_glass_cfa3801802.svg","2023-10-11T09:43:10.911Z","suv3p7h0kw7jdnuddk1l2rdu","call-to-action.double",[166,209,242,275],{"id":167,"title":168,"subTitle":18,"content":169,"callToActionText":170,"callToActionLink":141,"colorStyle":18,"showAsides":18,"imageUrl":171,"__component":208},36,"Bouwen en testen","Onze .NET-experts kunnen uiteraard goede en betrouwbare applicaties ontwikkelen met de laatste .NET-versies. Ook zijn onze collega’s ervaren in het onderhouden van oudere software. We kunnen je helpen met het upgraden en uitbreiden van je applicatie zodat deze aan de laatste wensen en eisen voldoet. Het uitvoeren van uitgebreide unit- en integratietests om de stabiliteit van applicaties te waarborgen, wordt meegenomen als standaard onderdeel van het werk. Met een focus op grondige testdekking streven we ernaar om eventuele bugs vroegtijdig op te sporen en op te lossen, waardoor de algehele kwaliteit van jouw product wordt verbeterd.  \n\nVan Blazor Front-End of REST API’s tot database communicatie, onze .NET-experts hebben er ruime ervaring mee.","Weten wat onze experts voor jou kunnen doen?",{"id":172,"name":173,"alternativeText":18,"caption":18,"width":174,"height":175,"formats":176,"hash":203,"ext":23,"mime":180,"size":204,"url":205,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":206,"updatedAt":206,"documentId":207,"publishedAt":58,"focalPoint":18},790,"code matrix.jpg",1280,850,{"large":177,"small":184,"medium":190,"thumbnail":196},{"ext":23,"url":178,"hash":179,"mime":180,"name":181,"path":18,"size":182,"width":29,"height":183},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_code_matrix_939256fff4.jpg","large_code_matrix_939256fff4","image/jpeg","large_code matrix.jpg",164.22,664,{"ext":23,"url":185,"hash":186,"mime":180,"name":187,"path":18,"size":188,"width":36,"height":189},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_code_matrix_939256fff4.jpg","small_code_matrix_939256fff4","small_code matrix.jpg",42.02,332,{"ext":23,"url":191,"hash":192,"mime":180,"name":193,"path":18,"size":194,"width":43,"height":195},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_code_matrix_939256fff4.jpg","medium_code_matrix_939256fff4","medium_code matrix.jpg",97.04,498,{"ext":23,"url":197,"hash":198,"mime":180,"name":199,"path":18,"size":200,"width":201,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_code_matrix_939256fff4.jpg","thumbnail_code_matrix_939256fff4","thumbnail_code matrix.jpg",8.35,235,156,"code_matrix_939256fff4",258.04,"https://incredible-beef-2a6059b946.media.strapiapp.com/code_matrix_939256fff4.jpg","2024-08-09T08:30:59.615Z","s5v68ezvz0ho9m6ot0mbk8z2","global.alternating-page-section",{"id":210,"title":211,"subTitle":18,"content":212,"callToActionText":18,"callToActionLink":18,"colorStyle":18,"showAsides":18,"imageUrl":213,"__component":208},37,"Combineren met Azure","Wil je profiteren van Azure-services voor jouw project? Ons team van experts kan je helpen met het selecteren en opzetten van de juiste services. Of je gebruik wil maken van App services, Function Apps, storage of database oplossingen of bijvoorbeeld een Service Bus, onze experts kunnen je helpen bij het kiezen en het realiseren van stabiele, schaalbare en veilige oplossingen die voldoen aan jouw specifieke behoeften.",{"id":214,"name":215,"alternativeText":18,"caption":18,"width":174,"height":175,"formats":216,"hash":237,"ext":23,"mime":180,"size":238,"url":239,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":240,"updatedAt":240,"documentId":241,"publishedAt":58,"focalPoint":18},791,"service bus.jpg",{"large":217,"small":222,"medium":227,"thumbnail":232},{"ext":23,"url":218,"hash":219,"mime":180,"name":220,"path":18,"size":221,"width":29,"height":183},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_service_bus_2b48e3a7cc.jpg","large_service_bus_2b48e3a7cc","large_service bus.jpg",82.82,{"ext":23,"url":223,"hash":224,"mime":180,"name":225,"path":18,"size":226,"width":36,"height":189},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_service_bus_2b48e3a7cc.jpg","small_service_bus_2b48e3a7cc","small_service bus.jpg",29.35,{"ext":23,"url":228,"hash":229,"mime":180,"name":230,"path":18,"size":231,"width":43,"height":195},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_service_bus_2b48e3a7cc.jpg","medium_service_bus_2b48e3a7cc","medium_service bus.jpg",54.72,{"ext":23,"url":233,"hash":234,"mime":180,"name":235,"path":18,"size":236,"width":201,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_service_bus_2b48e3a7cc.jpg","thumbnail_service_bus_2b48e3a7cc","thumbnail_service bus.jpg",8.71,"service_bus_2b48e3a7cc",117.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/service_bus_2b48e3a7cc.jpg","2024-08-09T08:35:35.231Z","rbpawsulv6vrsistrk2yupwg",{"id":243,"title":244,"subTitle":18,"content":245,"callToActionText":18,"callToActionLink":18,"colorStyle":18,"showAsides":18,"imageUrl":246,"__component":208},35,"Houd het veilig!","Om de toegang tot je producten veilig te houden, kan ons team van .NET-experts je helpen bij het opzetten en onderhouden van authenticatie en autorisatie. Onze experts zijn ervaren in het opzetten de juiste entra diensten zodat de toegang tot zowel Front-End als Back-End of deamon-processen op een juiste manier afgehandeld wordt. Ook kunnen we je helpen met het opzetten van verschillende groepen, rechten en rollen, en deze op de juiste manier toepassen binnen de applicatie zodat onterechte toegang op functieniveau geregeld kan worden. Bij het opzetten en implementeren wordt er rekening gehouden met het reduceren van de administratieve overhead zonder concessies te doen aan de beveiliging.",{"id":247,"name":248,"alternativeText":18,"caption":18,"width":174,"height":175,"formats":249,"hash":270,"ext":23,"mime":180,"size":271,"url":272,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":273,"updatedAt":273,"documentId":274,"publishedAt":58,"focalPoint":18},792,"security dotnet.jpg",{"large":250,"small":255,"medium":260,"thumbnail":265},{"ext":23,"url":251,"hash":252,"mime":180,"name":253,"path":18,"size":254,"width":29,"height":183},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_dotnet_a65d687baf.jpg","large_security_dotnet_a65d687baf","large_security dotnet.jpg",38.7,{"ext":23,"url":256,"hash":257,"mime":180,"name":258,"path":18,"size":259,"width":36,"height":189},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_dotnet_a65d687baf.jpg","small_security_dotnet_a65d687baf","small_security dotnet.jpg",13.37,{"ext":23,"url":261,"hash":262,"mime":180,"name":263,"path":18,"size":264,"width":43,"height":195},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_dotnet_a65d687baf.jpg","medium_security_dotnet_a65d687baf","medium_security dotnet.jpg",24.75,{"ext":23,"url":266,"hash":267,"mime":180,"name":268,"path":18,"size":269,"width":201,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_dotnet_a65d687baf.jpg","thumbnail_security_dotnet_a65d687baf","thumbnail_security dotnet.jpg",4.63,"security_dotnet_a65d687baf",57.25,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_dotnet_a65d687baf.jpg","2024-08-09T08:36:56.895Z","srupv8bm7kvcgseu2efeadhk",{"id":276,"title":277,"callToActionText":278,"callToActionLinkUrl":279,"body":18,"imageUrl":280,"__component":281},46,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij KPN","/klantcases/de-continue-bereikbaarheid-van-een-alarmcentrale",{"id":144,"name":145,"alternativeText":18,"caption":18,"width":146,"height":147,"formats":18,"hash":148,"ext":149,"mime":150,"size":151,"url":152,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":153,"updatedAt":154,"documentId":155,"publishedAt":58,"focalPoint":18},"call-to-action.single",{"id":283,"title":284,"subTitle":101,"description":285,"shortDescription":286,"slug":287,"createdAt":288,"updatedAt":289,"publishedAt":290,"isCoreExpertise":291,"documentId":292,"image":293,"seo":308,"blocks":323,"midPageBlocks":367},10,"Development","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. Van gebruiksvriendelijke interfaces tot krachtige Back-End-architecturen: wij hebben de kennis en ervaring om jouw project tot een succes te maken.","Ons Development-team biedt oplossingen die de verwachtingen van onze opdrachtgevers overtreffen. Wij zijn experts op het gebied van alle aspecten van Development, wat ons in staat stelt om veelzijdige en schaalbare oplossingen te creëren. ","development","2024-12-13T12:15:40.484Z","2025-04-11T13:13:55.384Z","2024-12-13T12:15:42.976Z",true,"lpzfadokpxn5sdnx9czcdg47",{"id":294,"name":295,"alternativeText":18,"caption":18,"width":113,"height":114,"formats":296,"hash":302,"ext":117,"mime":120,"size":303,"url":304,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":305,"updatedAt":306,"documentId":307,"publishedAt":58,"focalPoint":18},950,"Logo Development 2025 web.png",{"thumbnail":297},{"ext":117,"url":298,"hash":299,"mime":120,"name":300,"path":18,"size":301,"width":50,"height":123},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Development_2025_web_d7711df072.png","thumbnail_Logo_Development_2025_web_d7711df072","thumbnail_Logo Development 2025 web.png",8.58,"Logo_Development_2025_web_d7711df072",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Development_2025_web_d7711df072.png","2024-12-17T15:02:47.479Z","2024-12-19T08:35:22.054Z","okwfs117fps338v5fj5dnrpb",{"id":309,"metaTitle":310,"metaDescription":311,"structuredData":312,"metaImage":18,"metaSocial":322},27,"Maatwerk software & integraties – ShareValue Development","Van webapps tot koppelingen: onze developers bouwen slimme oplossingen die passen bij jouw Microsoft-omgeving.",{"url":313,"@type":314,"@context":74,"provider":315,"areaServed":317,"description":320,"serviceType":321},"https://www.sharevalue.nl/wat-we-doen/development","Service",{"url":316,"name":72,"@type":73},"https://www.sharevalue.nl",{"name":318,"@type":319},"Nederland","Country","Onze developers realiseren maatwerkoplossingen binnen Microsoft-omgevingen. Denk aan webapplicaties, API-integraties, extensies voor Microsoft 365 en koppelingen met externe systemen. Technisch sterk én begrijpelijk ingericht.","Maatwerk softwareontwikkeling en integraties",[],[324,340],{"id":325,"title":326,"aside":18,"postType":133,"limit":99,"expertise":327,"__component":136},179,"Lees meer over Development",[328,329,339],{"id":283,"title":284,"subTitle":101,"description":285,"shortDescription":286,"slug":287,"createdAt":288,"updatedAt":289,"publishedAt":290,"isCoreExpertise":291,"documentId":292},{"id":303,"title":330,"subTitle":331,"description":332,"shortDescription":333,"slug":334,"createdAt":335,"updatedAt":336,"publishedAt":337,"isCoreExpertise":108,"documentId":338},"Front-End","Steeds complexer en steeds belangrijker","In een online wereld vol moderne webapplicaties is een goede Front-End onmisbaar. Het is nodig om aan de behoeften en verwachtingen van de gebruikers te voldoen. De interactie voor de gebruiker moet daarbij zo snel en optimaal mogelijk zijn. Met trots kunnen wij zeggen dat juist dáár de kracht van onze Front-End Developers zit.\n\nOnze ervaren Developers staan klaar om jouw team te versterken en te zorgen voor een optimale gebruikerservaring. Of je nu een tijdelijke aanvulling op je team nodig hebt of op zoek bent naar gespecialiseerde kennis voor een specifiek project, onze Front-End Developers zijn uitgerust om de uitdagingen van onze klanten aan te gaan en hun doelen te bereiken.","Onze Front-End developers zijn bedreven in diverse programmeertalen, frameworks en methodieken en daardoor breed inzetbaar.","front-end","2023-08-17T09:50:12.632Z","2024-12-13T12:15:57.609Z","2023-08-17T09:50:14.418Z","l6bdicvjcb7ue03zpciuc888",{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109},{"id":341,"titleLeft":342,"callToActionTextLeft":140,"callToActionLinkUrlLeft":141,"titleRight":343,"callToActionTextRight":344,"callToActionLinkUrlRight":345,"iconUrlLeft":346,"iconUrlRight":357,"__component":164},251,"Heb je een Developer nodig?","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":347,"name":348,"alternativeText":18,"caption":18,"width":349,"height":350,"formats":18,"hash":351,"ext":149,"mime":150,"size":352,"url":353,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":354,"updatedAt":355,"documentId":356,"publishedAt":58,"focalPoint":18},7,"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":358,"name":359,"alternativeText":18,"caption":18,"width":360,"height":350,"formats":18,"hash":361,"ext":149,"mime":150,"size":362,"url":363,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":364,"updatedAt":365,"documentId":366,"publishedAt":58,"focalPoint":18},372,"magnifier.svg",49,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",[368,402,412,446,480],{"id":369,"title":370,"subTitle":18,"content":371,"callToActionText":18,"callToActionLink":18,"colorStyle":372,"showAsides":108,"imageUrl":373,"__component":208},47,"Optimale gebruikerservaring","Een goede Front-End is meer dan alleen een aantrekkelijke interface; het vormt de schakel tussen technologie en eindgebruiker. Onze Developers combineren hun kennis van frameworks zoals React, Angular en Vue met ervaring in geavanceerde technologieën zoals GraphQL en CI/CD pipelines. Dit stelt ons in staat om interactieve, intuïtieve en betrouwbare applicaties te ontwikkelen die voldoen aan de hoogste standaarden.\n\nWij werken nauw samen met UX-designers om via design patterns en design tokens een naadloze integratie van ontwerp naar functionaliteit te realiseren. Dankzij regelmatige LevelUp-sessies, interne projecten en kennisdeling blijven onze Front-End specialisten altijd up-to-date.","Sugar Glaze",{"id":374,"name":375,"alternativeText":18,"caption":18,"width":174,"height":175,"formats":376,"hash":397,"ext":23,"mime":180,"size":398,"url":399,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":400,"updatedAt":400,"documentId":401,"publishedAt":58,"focalPoint":18},904,"development.jpg",{"large":377,"small":382,"medium":387,"thumbnail":392},{"ext":23,"url":378,"hash":379,"mime":180,"name":380,"path":18,"size":381,"width":29,"height":183},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_development_6e5abdca44.jpg","large_development_6e5abdca44","large_development.jpg",129.5,{"ext":23,"url":383,"hash":384,"mime":180,"name":385,"path":18,"size":386,"width":36,"height":189},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_development_6e5abdca44.jpg","small_development_6e5abdca44","small_development.jpg",47.86,{"ext":23,"url":388,"hash":389,"mime":180,"name":390,"path":18,"size":391,"width":43,"height":195},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_development_6e5abdca44.jpg","medium_development_6e5abdca44","medium_development.jpg",86.06,{"ext":23,"url":393,"hash":394,"mime":180,"name":395,"path":18,"size":396,"width":201,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_development_6e5abdca44.jpg","thumbnail_development_6e5abdca44","thumbnail_development.jpg",14.65,"development_6e5abdca44",184.35,"https://incredible-beef-2a6059b946.media.strapiapp.com/development_6e5abdca44.jpg","2024-12-13T12:36:11.969Z","qqi9wubjpzs8w6daj98mtc7a",{"id":360,"title":403,"subTitle":18,"content":404,"callToActionText":18,"callToActionLink":18,"colorStyle":405,"showAsides":108,"imageUrl":406,"__component":208},"Betrouwbaarheid en schaalbaarheid","Voor robuuste Back-End-oplossingen vertrouwen we op onze kennis van .NET. Of het nu gaat om het bouwen van nieuwe applicaties, het onderhouden van bestaande software of het implementeren van geavanceerde authenticatie- en autorisatiesystemen: ons team levert maatwerk dat aansluit bij de specifieke wensen en behoeften van jouw organisatie.\n\nHierbij maken we onder andere gebruik van onze kennis van Azure-services zoals Function Apps, Service Bus en App Services, maar ook tools als Docker en Kubernetes om veilige, schaalbare oplossingen te realiseren.\n\nOnze focus op grondige tests – van unit tests tot integratietests – garandeert stabiliteit en betrouwbaarheid.","White",{"id":214,"name":215,"alternativeText":18,"caption":18,"width":174,"height":175,"formats":407,"hash":237,"ext":23,"mime":180,"size":238,"url":239,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":240,"updatedAt":240,"documentId":241,"publishedAt":58,"focalPoint":18},{"large":408,"small":409,"medium":410,"thumbnail":411},{"ext":23,"url":218,"hash":219,"mime":180,"name":220,"path":18,"size":221,"width":29,"height":183},{"ext":23,"url":223,"hash":224,"mime":180,"name":225,"path":18,"size":226,"width":36,"height":189},{"ext":23,"url":228,"hash":229,"mime":180,"name":230,"path":18,"size":231,"width":43,"height":195},{"ext":23,"url":233,"hash":234,"mime":180,"name":235,"path":18,"size":236,"width":201,"height":202},{"id":413,"title":414,"subTitle":18,"content":415,"callToActionText":18,"callToActionLink":18,"colorStyle":372,"showAsides":108,"imageUrl":416,"__component":208},50,"Full-Stack mogelijkheden","Wat ons uniek maakt, is onze combinatie van Front-End en .NET-expertise. Onze Developers zijn niet alleen gespecialiseerd in het creëren van intuïtieve interfaces, maar beheersen ook de complexiteit van Back-End-architectuur en Azure-integraties. Dit maakt hen volwaardige Full-Stack Developers die moeiteloos schakelen tussen de verschillende onderdelen van jouw project.",{"id":417,"name":418,"alternativeText":18,"caption":18,"width":174,"height":175,"formats":419,"hash":440,"ext":23,"mime":180,"size":441,"url":442,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":443,"updatedAt":444,"documentId":445,"publishedAt":58,"focalPoint":18},778,"stack.jpg",{"large":420,"small":425,"medium":430,"thumbnail":435},{"ext":23,"url":421,"hash":422,"mime":180,"name":423,"path":18,"size":424,"width":29,"height":183},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_stack_fec3a2bfae.jpg","large_stack_fec3a2bfae","large_stack.jpg",95.19,{"ext":23,"url":426,"hash":427,"mime":180,"name":428,"path":18,"size":429,"width":36,"height":189},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_stack_fec3a2bfae.jpg","small_stack_fec3a2bfae","small_stack.jpg",29.21,{"ext":23,"url":431,"hash":432,"mime":180,"name":433,"path":18,"size":434,"width":43,"height":195},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_stack_fec3a2bfae.jpg","medium_stack_fec3a2bfae","medium_stack.jpg",58.57,{"ext":23,"url":436,"hash":437,"mime":180,"name":438,"path":18,"size":439,"width":201,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_stack_fec3a2bfae.jpg","thumbnail_stack_fec3a2bfae","thumbnail_stack.jpg",8.24,"stack_fec3a2bfae",143.32,"https://incredible-beef-2a6059b946.media.strapiapp.com/stack_fec3a2bfae.jpg","2024-08-08T08:26:50.506Z","2024-12-09T10:18:46.269Z","kpz9iiz9dr551k3umhmtwy3k",{"id":447,"title":448,"subTitle":18,"content":449,"callToActionText":450,"callToActionLink":141,"colorStyle":405,"showAsides":108,"imageUrl":451,"__component":208},48,"Samen naar succes","Onze aanpak is erop gericht om samen met jou het optimale resultaat te behalen. Door proactief mee te denken en onze kennis te delen, zorgen we ervoor dat jouw project voldoet aan de hoogste standaarden van gebruiksvriendelijkheid, betrouwbaarheid en veiligheid. Of het nu gaat om een tijdelijke versterking van je team of volledige projectondersteuning: ons Development-team staat voor je klaar.\n\nOntdek wat wij voor jouw project kunnen betekenen."," Neem contact met ons op voor meer informatie!",{"id":452,"name":453,"alternativeText":18,"caption":18,"width":174,"height":175,"formats":454,"hash":475,"ext":23,"mime":180,"size":476,"url":477,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":478,"updatedAt":478,"documentId":479,"publishedAt":58,"focalPoint":18},789,"teamwork.jpg",{"large":455,"small":460,"medium":465,"thumbnail":470},{"ext":23,"url":456,"hash":457,"mime":180,"name":458,"path":18,"size":459,"width":29,"height":183},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":461,"hash":462,"mime":180,"name":463,"path":18,"size":464,"width":36,"height":189},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":466,"hash":467,"mime":180,"name":468,"path":18,"size":469,"width":43,"height":195},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":471,"hash":472,"mime":180,"name":473,"path":18,"size":474,"width":201,"height":202},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":481,"title":482,"callToActionText":483,"callToActionLinkUrl":484,"body":18,"imageUrl":485,"__component":281},103,"Wil je weten wat onze collega’s allemaal kunnen?","Lees de klantcase over ons werk bij Rovict","https://www.sharevalue.nl/klantcases/rovict-vernieuwt-leerlingadministratie-en-leerlingvolgsysteem-esis",{"id":144,"name":145,"alternativeText":18,"caption":18,"width":146,"height":147,"formats":18,"hash":148,"ext":149,"mime":150,"size":151,"url":152,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":153,"updatedAt":154,"documentId":155,"publishedAt":58,"focalPoint":18},[487,492,496,500,504,508,511,515,519,522,525,612],{"id":488,"title":18,"asideText":489,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":490,"introductionText":18,"__component":491},894,"Mijlpaal!","## Waarom is dit zo’n grote mijlpaal?\n\nMet .NET 5 wordt gebroken met het verleden. Tot voor kort werd het .NET Framework (uit 2002) steeds verder ontwikkeld op het bestaande systeem: closed source, Windows only.\n\n.NET 5 is natuurlijk ook niet zomaar ontstaan; het is tenslotte de opvolger van .NET Core 3.1. .NET Core zelf is echter een complete herbouw van .NET en tegelijkertijd alles wat .NET Framework niet is: open source en cross-platform.","global.pagesection",{"id":493,"title":18,"asideText":494,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":495,"introductionText":18,"__component":491},893,"\u003C3","## Microsoft ❤ Open Source\n\nDie trendbreuk is een aantal jaar geleden ingezet door Satya Nadella en tijdens de Microsoft Build van 2019 nog eens bevestigd: Microsoft ❤ Open Source.\n\nIn het tijdperk van Steve Ballmer was dit niet voor te stellen. In de open source wereld werd Microsoft verguisd en ook binnen Microsoft was het niet voor te stellen dat je een presentatie gaf op een Mac.\n\nDit werd ook pijnlijk duidelijk toen op 4 juni 2018 officieel werd aangekondigd dat GitHub voor 7,5 miljard dollar overgenomen zou worden door Microsoft. Concurrent GitLab zag het aantal geïmporteerde projecten [vertienvoudigen](https://twitter.com/gitlab/status/1003409836170547200). Twee jaar later lijkt de angst dat Microsoft GitHub om zeep zou helpen ongegrond. Microsoft helpt mee aan allerlei open source initiatieven, uiteraard ook hun eigen .NET projecten.",{"id":497,"title":18,"asideText":498,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":499,"introductionText":18,"__component":491},890,"Open source en cross platform","## Voordelen van .NET\n\nZoals aangegeven is .NET 5 open source en cross platform. Het voordeel daarvan is dat er meer mogelijkheden zijn voor hosting. Zelfs binnen Azure kan een .NET webapplicatie op Linux draaien. Cross platform zorgt ook voor meer integratie met andere ontwikkelteams en heb je geen last van “vendor lock-in”: .NET 5 werkt bijvoorbeeld ook op [Amazon Web Services (AWS)](https://aws.amazon.com/blogs/developer/net-5-on-aws/) en de [Google Cloud](https://cloud.google.com/blog/topics/developers-practitioners/net-50-google-cloud).\n\nDaarnaast zijn er nog meer voordelen, maar één van de belangrijkste naast de bovenstaande, is de performance. .NET 5 is veel sneller dan zijn voorgangers. Meer informatie daarover staat in de zeer [uitgebreide blog van Microsoft](https://devblogs.microsoft.com/dotnet/performance-improvements-in-net-5/).",{"id":501,"title":18,"asideText":502,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":503,"introductionText":18,"__component":491},891,"","## .NET Roadmap\n\nMet .NET 5 houden we één .NET over. .NET Framework, .NET Standard en .NET Core blijven uiteraard werken, maar verdere ondersteuning houdt wel op.",{"id":505,"title":18,"asideText":506,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":507,"introductionText":18,"__component":491},892,".NET Roadmap","![](https://www.sharevalue.nl/images/sharevalue/blogs/NET_Roadmap.png)\n\n​",{"id":509,"title":18,"asideText":502,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":510,"introductionText":18,"__component":491},895,"De roadmap voor .NET is voor de komende jaren vastgelegd. Vanaf nu zal er elk jaar een nieuwe .NET versie uitgerold worden. In november 2021 zal .NET 6 uitkomen. Net als andere “even” versies, wordt deze met “Long Term Support” (LTS) geleverd worden.\n\nOndanks dat .NET 5.0 geen LTS heeft, kan je er wel bedrijfskritische applicaties mee maken. Indien er echter toch terughoudendheid is en er daarom gekozen wordt om te wachten op .NET 6 (met LTS), dan is het zeker niet het moment om af te wachten. Een migratie kan een hele operatie zijn en dan is 11 maanden voorbereiding zeker aan te bevelen en kan .NET 5 als basis dienen.\n\nEen begin kan zijn om business logica onder te brengen in .NET Standard 2.1 class libraries. Dit is namelijk de laatste versie die zowel door .NET Framework als .NET Core / .NET 5 gebruikt kan worden. Door deze transitie te doen, kan oude code blijven werken en kunnen tegelijk de eerste stappen van de migratie worden genomen.",{"id":512,"title":18,"asideText":513,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":514,"introductionText":18,"__component":491},896,"WebForms","## Voorbeeld ASP.NET WebForms\n\nSommige migraties zijn eenvoudig, omdat de techniek blijft bestaan. Zo is een migratie van ASP.NET MVC naar ASP.NET Core MVC een stuk eenvoudiger te realiseren dan een migratie van ASP.NET WebForms naar een .NET 5 webapplicatie, omdat WebForms niet meer bestaat.\n\n[In een eerdere blog heb ik Blazor besproken](/blogs/je-gehele-site-in-een-taal-met-blazor-brengt-microsoft-front-end-en-back-end-bij-elkaar). Voor developers die nu werken met WebForms is dit een goed alternatief: een lage learning curve en de kennis en expertise is al in huis. En ook Blazor heeft componenten die hergebruikt kunnen worden. Verder kunnen met .NET 5 wel alle moderne technieken gebruikt worden. Unit tests als xUnit en bUnit kunnen gebruikt worden om de huidige functionaliteit te testen in de nieuwe omgeving.\n\nUiteraard zijn er ook andere mogelijkheden om de WebForms applicatie te migreren naar een andere weboplossing. Daarbij zoeken wij altijd naar een oplossing die het beste past bij de omgeving van onze klant.",{"id":516,"title":18,"asideText":517,"underline":108,"centered":108,"blankAside":108,"aside":18,"content":518,"introductionText":18,"__component":491},897,"Een migratie van de oude .NET naar .NET 5.0","## .NET 5.0 Migratiescan\n\nShareValue heeft de kennis in huis om een migratie van een oude .NET versie naar .NET 5 te begeleiden en hier adviezen op te geven. Dit begint met een analyse van het huidige software landschap. Vervolgens brengen we een advies uit, waarbij we ook rekening houden met de impact op de business. Uiteindelijk kunnen we de uitvoering van de migratie samen met de klant realiseren en begeleiden. Wil je hier meer over weten? [Neem dan contact met ons op](/contact).",{"id":520,"title":18,"showBlankAside":291,"__component":521},100,"global.social-sharing",{"id":523,"name":18,"jobTitle":18,"__component":524},58,"strapi.author-card",{"id":526,"title":326,"aside":18,"postType":133,"limit":99,"expertise":527,"__component":136},69,[528,563],{"id":99,"title":100,"subTitle":101,"description":102,"shortDescription":103,"slug":104,"createdAt":105,"updatedAt":106,"publishedAt":107,"isCoreExpertise":108,"documentId":109,"image":529,"seo":18,"blocks":532,"midPageBlocks":539},{"id":111,"name":112,"alternativeText":18,"caption":18,"width":113,"height":114,"formats":530,"hash":124,"ext":117,"mime":120,"size":125,"url":126,"previewUrl":18,"provider":55,"provider_meta