[{"data":1,"prerenderedAt":487},["ShallowReactive",2],{"collection-blogs--1758054114":3,"_apollo:default":486},{"data":4,"meta":482},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":59,"author":324,"blocks":350,"seo":448},23,"Automatiseer nog sneller jouw Excel behoeftes met Power Automate","Excel is een van de meeste gebruikte data-verwerkingsprogramma's in de wereld. En nog steeds erg effectief en geliefd voor diverse doelen in verschillende bedrijfstakken. Hoe mooi zou het zijn als je deze tool aansluit op één van de meest gebruikte werkstroom applicaties, Power Automate?","automatiseer-nog-sneller-jouw-excel-behoeftes-met-power-automate","2023-10-13T10:26:25.937Z","2025-04-15T12:32:16.638Z","2023-10-13T10:26:25.841Z","2023-01-26","kni10q1o1axqw4zkk0csom6b",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58},272,"automatiseer-nog-sneller-jouw-excel-behoeftes-met-power-automate.jpg",null,1280,720,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a.jpg","large_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a","image/jpg","large_automatiseer-nog-sneller-jouw-excel-behoeftes-met-power-automate.jpg",26.8,1000,563,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a.jpg","small_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a","small_automatiseer-nog-sneller-jouw-excel-behoeftes-met-power-automate.jpg",11.2,500,281,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a.jpg","medium_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a","medium_automatiseer-nog-sneller-jouw-excel-behoeftes-met-power-automate.jpg",18.65,750,422,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a.jpg","thumbnail_automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a","thumbnail_automatiseer-nog-sneller-jouw-excel-behoeftes-met-power-automate.jpg",4.12,245,138,"automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a",33.8,"https://incredible-beef-2a6059b946.media.strapiapp.com/automatiseer_nog_sneller_jouw_excel_behoeftes_met_power_automate_69ad7dbf4a.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:22:02.779Z","fuf499qqdesbp5ju98o975ud","2026-01-05T12:38:34.018Z",[60],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":72,"blocks":91,"midPageBlocks":183,"seo":319},7,"Power Platform","Optimaliseer je bedrijfsprocessen met Microsoft Power Platform","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.\n\nBij ShareValue leveren we oplossingen die precies aansluiten op de behoeften van jouw organisatie. Of het nu gaat om het opzetten van een uitgebreide governance- en omgevingsstrategie, het ontwikkelen van een app met bijbehorende automatiseringen of het bevorderen van gebruikersadoptie; wij hebben de juiste expertise in huis.\n\nOnze Power Platform-specialisten, bestaande uit ervaren consultants en developers, hebben een bewezen staat van dienst in diverse sectoren. Zij delen continu hun kennis en passen deze toe op de unieke vraagstukken van onze klanten, waardoor we steeds de meest effectieve en innovatieve oplossingen kunnen bieden.\n","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.","power-platform","2023-10-12T11:27:43.792Z","2025-04-11T13:13:15.099Z","2023-10-12T11:27:43.781Z",true,"prbaerw7gypadu8gfdyg53sy",{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":77,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},927,"Logo PowerPlatform 2025 web png.png",282,130,{"thumbnail":78},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Power_Platform_2025_web_png_4268556f17.png","thumbnail_Logo_Power_Platform_2025_web_png_4268556f17","image/png","thumbnail_Logo PowerPlatform 2025 web png.png",8.26,113,"Logo_Power_Platform_2025_web_png_4268556f17",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Power_Platform_2025_web_png_4268556f17.png","2024-12-16T11:07:06.507Z","a12tjlb3ssr20rrzj9rulb58",[92,160],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97,"expertise":98},"strapi.related-kennisbank-list",164,"Lees meer over het Power Platform","alle",3,[99],{"id":61,"title":62,"subTitle":63,"description":64,"shortDescription":65,"slug":66,"createdAt":67,"updatedAt":68,"publishedAt":69,"isCoreExpertise":70,"documentId":71,"image":100,"blocks":103,"midPageBlocks":114,"seo":143},{"id":73,"name":74,"alternativeText":18,"caption":18,"width":75,"height":76,"formats":101,"hash":86,"ext":79,"mime":82,"size":87,"url":88,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":89,"updatedAt":89,"documentId":90,"publishedAt":58},{"thumbnail":102},{"ext":79,"url":80,"hash":81,"mime":82,"name":83,"path":18,"size":84,"width":50,"height":85},[104,105],{"__component":93,"id":94,"title":95,"aside":18,"postType":96,"limit":97},{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":113},"call-to-action.double",235,"Heb je een Power Platform expert nodig?","Neem contact op voor de mogelijkheden","/contact","Zoek je een nieuwe uitdaging?","Bekijk onze vacatures","/word-onze-collega/vacatures",[115,123,128,132,137],{"__component":116,"id":117,"title":118,"subTitle":18,"content":119,"callToActionText":120,"callToActionLink":110,"colorStyle":121,"showAsides":122},"global.alternating-page-section",16,"Power Platform governance: de balans tussen beveiliging en innovatie","Het is belangrijk om een balans te vinden tussen beveiliging en innovatie binnen jouw organisatie. Hoewel governance noodzakelijk is, moeten je medewerkers en teams de ruimte krijgen om waarde te creëren voor zowel henzelf als de onderneming.\n\nOnze Power Platform-specialisten staan klaar om je te adviseren over de diverse mogelijkheden. We begeleiden je tijdens het ontwikkelen en implementeren van een effectieve governance- en omgevingsstrategie, zodat je het beste uit het Microsoft Power Platform kunt halen.","Wil je meer weten? Neem contact met ons op.","Sugar Glaze",false,{"__component":116,"id":124,"title":125,"subTitle":18,"content":126,"callToActionText":18,"callToActionLink":18,"colorStyle":127,"showAsides":122},17,"Snel maatwerktoepassingen creëren met het Power Platform","Het Power Platform is de ideale oplossing om je verouderde processen en applicaties te stroomlijnen met slimme apps, efficiënte werkstromen en geavanceerde, op maat gemaakte formulieren.\n\nOnze specialisten staan klaar om je te adviseren over de vele mogelijkheden. Heb je meer ondersteuning nodig bij het ontwikkelen van je toepassing? Onze ervaren developers ontwikkelen de toepassing volledig voor je.","White",{"__component":116,"id":129,"title":130,"subTitle":18,"content":131,"callToActionText":18,"callToActionLink":18,"colorStyle":121,"showAsides":122},18,"Power Platform staat aan, wat nu?","Het Power Platform wordt al gebruikt in jouw organisatie. Een aantal enthousiaste collega's hebben al mooie apps gemaakt en je staat op het punt om het Power Platform in te zetten voor bedrijfskritische processen. Maar je weet niet precies hoe je dit het beste kunt aanpakken.\n\nWij begeleiden je in dit proces en samen bepalen we de \"next steps\". Onze architecten voeren een volledige omgevings- en securitycheck uit, wat resulteert in een omgevingsstrategie, governance, en een ontwikkel- en adoptieplan.",{"__component":116,"id":133,"title":134,"subTitle":18,"content":135,"callToActionText":136,"callToActionLink":110,"colorStyle":127,"showAsides":122},19,"Is jouw omgeving veilig en secure?","Onze omgevings- en securitycheck geeft je een helder beeld van de huidige status van je omgeving en laat zien wat je nog kunt doen om toepassingen nog veiliger en consistenter te ontwikkelen.","Wil je de check laten doen?",{"__component":138,"id":139,"title":140,"callToActionText":141,"callToActionLinkUrl":142,"body":18},"call-to-action.single",99,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Stork","/klantcases/stork-focust-op-citizen-development-met-het-microsoft-power-platform",{"id":144,"metaTitle":145,"metaDescription":146,"structuredData":147},26,"Power Platform specialisten – ShareValue helpt vooruit","Haal meer uit Power Apps, Automate en Power BI. Wij helpen bij strategie, ontwikkeling en beheer van jouw Power Platform-omgeving.",{"url":148,"@type":149,"@context":150,"provider":151,"areaServed":155,"description":158,"serviceType":159},"https://www.sharevalue.nl/wat-we-doen/power-platform","Service","https://schema.org",{"url":152,"name":153,"@type":154},"https://www.sharevalue.nl","ShareValue","Organization",{"name":156,"@type":157},"Nederland","Country","ShareValue helpt organisaties om Power Platform optimaal in te zetten. Denk aan Power Apps, Power Automate en Power BI. We bieden begeleiding bij strategie, governance, ontwikkeling en beheer.","Power Platform consultancy",{"__component":106,"id":107,"titleLeft":108,"callToActionTextLeft":109,"callToActionLinkUrlLeft":110,"titleRight":111,"callToActionTextRight":112,"callToActionLinkUrlRight":113,"iconUrlLeft":161,"iconUrlRight":174},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":175,"name":176,"alternativeText":18,"caption":18,"width":165,"height":165,"formats":18,"hash":177,"ext":167,"mime":168,"size":178,"url":179,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":180,"updatedAt":181,"documentId":182,"publishedAt":58},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",[184,221,256,287,317],{"__component":116,"id":117,"title":118,"subTitle":18,"content":119,"callToActionText":120,"callToActionLink":110,"colorStyle":121,"showAsides":122,"imageUrl":185},{"id":186,"name