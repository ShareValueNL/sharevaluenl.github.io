s://incredible-beef-2a6059b946.media.strapiapp.com/small_security_check_94d0553bc3.jpg","small_security_check_94d0553bc3","small_security check.jpg",29.41,{"ext":23,"url":303,"hash":304,"mime":230,"name":305,"path":18,"size":306,"width":43,"height":245},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":308,"hash":309,"mime":230,"name":310,"path":18,"size":311,"width":107,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":138,"id":139,"title":140,"callToActionText":141,"callToActionLinkUrl":142,"body":18,"imageUrl":318},{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58},{"id":144,"metaTitle":145,"metaDescription":146,"structuredData":320,"metaImage":18,"metaSocial":323},{"url":148,"@type":149,"@context":150,"provider":321,"areaServed":322,"description":158,"serviceType":159},{"url":152,"name":153,"@type":154},{"name":156,"@type":157},[],{"id":325,"name":326,"jobTitle":327,"about":18,"createdAt":328,"updatedAt":329,"publishedAt":330,"documentId":331,"image":332,"contactOptions":349},35,"Joost","Consultant","2023-08-18T08:37:46.155Z","2024-03-08T12:46:28.737Z","2023-08-18T08:37:45.395Z","njwfi2eesf691vtpewkga0s1",{"id":333,"name":334,"alternativeText":18,"caption":18,"width":335,"height":336,"formats":337,"hash":344,"ext":79,"mime":82,"size":345,"url":346,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":347,"updatedAt":347,"documentId":348,"publishedAt":58},578,"Joost websitefoto.png",278,326,{"thumbnail":338},{"ext":79,"url":339,"hash":340,"mime":82,"name":341,"path":18,"size":342,"width":343,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Joost_websitefoto_af5f8633d8.png","thumbnail_Joost_websitefoto_af5f8633d8","thumbnail_Joost websitefoto.png",18.83,133,"Joost_websitefoto_af5f8633d8",23.92,"https://incredible-beef-2a6059b946.media.strapiapp.com/Joost_websitefoto_af5f8633d8.png","2024-03-08T12:44:24.321Z","ja3uxwy59jyctja6btxtsrja",[],[351,356,359,362,365,368,371,374,377,428],{"__component":352,"id":353,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":355,"introductionText":18},"global.pagesection",370,"","Deze maand zijn er nieuwe functionaliteiten toegevoegd aan de tab genaamd Automate die je terug kunt vinden in je Excel lint. Vanuit deze tab ben je in staat om Office scripts te maken en aan te sluiten op een Power Automate werkstroom.\n\nOffice script in Excel maakt het mogelijk om jouw Excel taken op verschillende werkboeken en tabbladen te automatiseren. Gebruik dit script om berekeningen te maken, lege kolommen te identificeren en op te tellen of om velden van het ene naar het andere tabblad te verplaatsen. Met de integratie van Power Automate en de daarbij behorende +900 connectoren, zijn de mogelijkheden oneindig. Zo kan je met behulp van de Outlook connector in Power Automate een dagelijks report sturen naar je team met de laatste wijzigingen die zijn gedaan in een werkboek. Dit zijn maar een paar voorbeelden van wat er allemaal mogelijk is als je deze twee krachtpatsers combineert.\n\nDaarbij biedt de Office script in Excel en Power Automate verschillende templates (voorbeelden) aan, waardoor je nog sneller een proces kunt automatiseren.",{"__component":352,"id":357,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":358,"introductionText":18},371,"Je kan beginnen met het maken van je eigen script wanneer je navigeert naar de Automate tab in Excel. Of je pakt een voor gedefinieerd script die je ook nog naar eigen wens kunt aanpassen.   \nVanuit hier kan je de koppeling maken met Power Automate door te klikken op Automate a task (Automatiseer een taak), hierdoor word je naar Power Automate geleid en kun je de werkstroom aanmaken.",{"__component":352,"id":360,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":361,"introductionText":18},372,"![](https://www.sharevalue.nl/images/sharevalue/blogs/Afbeelding_in_blog_Joost_PP_jan_2023_def.jpg)",{"__component":352,"id":363,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":364,"introductionText":18},373,"Deze Automate Tab is beschikbaar voor de gebruikers die over een Office 365 E3 en Office E5 licentie (Windows en Mac) beschikken.",{"__component":352,"id":366,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":367,"introductionText":18},374,"## **Conclusie**\n\nAfzonderlijk van elkaar zijn deze twee applicaties, Excel en Power Automate, behoorlijk krachtig en vriendelijk in gebruik. Om deze samen te voegen is, in mijn beleving, een hele goede en logische stap vooruit. Ik kijk uit naar de mogelijkheden die (nog) gaan komen.",{"__component":352,"id":369,"title":18,"asideText":354,"underline":122,"centered":122,"blankAside":122,"aside":18,"content":370,"introductionText":18},375,"Wil je meer weten over deze functionaliteit of over het Power Platform in het algemeen, neem dan gerust contact op met ons zodat we de mogelijkheden kunnen bespreken.",{"__component":372,"id":373,"title":18,"showBlankAside":70},"global.social-sharing",62,{"__component":375,"id":376,"name":18,"jobTitle":18},"strapi.author-card",20,{"__component":93,"id":378,"title":379,"aside":18,"postType":96,"limit":97,"expertise":380},31,"Lees ook onze 