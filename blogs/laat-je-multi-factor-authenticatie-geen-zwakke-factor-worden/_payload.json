[{"data":1,"prerenderedAt":475},["ShallowReactive",2],{"collection-blogs-450078783":3,"_apollo:default":474},{"data":4,"meta":471},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"seo":59,"expertises":98,"author":302,"blocks":367},24,"Laat je Multi-Factor Authenticatie geen zwakke factor worden","We proberen onze omgevingen zo veilig mogelijk te maken, zonder dat het onwerkbaar wordt voor de gebruikers. De balans hierin vinden is de grote uitdaging: hoe hou je het gebruikersvriendelijk, zonder dat het onveilig wordt? In deze blog zoomen we in op Multi-Factor Authenticatie, en de ontwikkelingen hierin om onze omgeving nóg veiliger te maken.","laat-je-multi-factor-authenticatie-geen-zwakke-factor-worden","2023-10-13T10:26:26.227Z","2025-04-15T12:33:53.018Z","2023-10-13T10:26:25.984Z","2023-01-23","nya0igfvzh5x1kxz9sqh8h2d",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":52,"ext":23,"mime":26,"size":53,"url":54,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":56,"updatedAt":56,"documentId":57,"publishedAt":58,"focalPoint":18},273,"laat-je-multi-factor-authenticatie-geen-zwakke-factor-worden.jpg",null,1280,600,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000.jpg","large_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000","image/jpg","large_laat-je-multi-factor-authenticatie-geen-zwakke-factor-worden.jpg",41.15,1000,469,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000.jpg","small_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000","small_laat-je-multi-factor-authenticatie-geen-zwakke-factor-worden.jpg",15.69,500,234,{"ext":23,"url":39,"hash":40,"mime":26,"name":41,"path":18,"size":42,"width":43,"height":44},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000.jpg","medium_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000","medium_laat-je-multi-factor-authenticatie-geen-zwakke-factor-worden.jpg",27.33,750,352,{"ext":23,"url":46,"hash":47,"mime":26,"name":48,"path":18,"size":49,"width":50,"height":51},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000.jpg","thumbnail_laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000","thumbnail_laat-je-multi-factor-authenticatie-geen-zwakke-factor-worden.jpg",5.87,245,115,"laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000",57.31,"https://incredible-beef-2a6059b946.media.strapiapp.com/laat_je_multi_factor_authenticatie_geen_zwakke_factor_worden_4267686000.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:22:03.941Z","q6a85lihgcif3zeswf2l2kur","2026-01-05T12:38:34.018Z",{"id":60,"metaTitle":61,"metaDescription":62,"structuredData":63,"metaImage":18,"metaSocial":97},112,"Maak MFA geen zwakke schakel in je security | ShareValue","MFA is belangrijk, maar niet waterdicht. Koos laat zien waar je op moet letten en hoe je misbruik voorkomt met slimme instellingen.",[64,80],{"url":65,"@type":66,"author":67,"@context":74,"headline":61,"publisher":75,"description":62,"datePublished":79},"https://www.sharevalue.nl/blogs/laat-je-multi-factor-authenticatie-geen-zwakke-factor-worden","BlogPosting",{"name":68,"@type":69,"jobTitle":70,"worksFor":71},"Koos","Person","Engineer",{"name":72,"@type":73},"ShareValue","Organization","https://schema.org",{"logo":76,"name":72,"@type":73},{"url":77,"@type":78},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","2023-10-19",{"@type":81,"@context":74,"mainEntity":82},"FAQPage",[83,89,93],{"name":84,"@type":85,"acceptedAnswer":86},"Waarom is MFA alleen niet genoeg?","Question",{"text":87,"@type":88},"Aanvallers kunnen MFA-promptmoeheid uitbuiten of phishen op toegangsverzoeken. Alleen MFA activeren is dus niet voldoende.","Answer",{"name":90,"@type":85,"acceptedAnswer":91},"Hoe maak je MFA veiliger?",{"text":92,"@type":88},"Gebruik phishing-resistente methodes zoals FIDO2, contextuele meldingen of nummermatching in je MFA-aanpak.",{"name":94,"@type":85,"acceptedAnswer":95},"Wat adviseert Koos voor organisaties?",{"text":96,"@type":88},"Beoordeel MFA niet als afgevinkt, maar als onderdeel van je bredere securitystrategie met zero trust als uitgangspunt.",[],[99],{"id":100,"title":101,"subTitle":102,"description":103,"shortDescription":104,"slug":105,"createdAt":106,"updatedAt":107,"publishedAt":108,"isCoreExpertise":109,"documentId":110,"image":111,"seo":130,"blocks":144,"midPageBlocks":184},1,"Azure","Hét cloudcomputing platform van Microsoft","Azure is het cloudcomputing platform van Microsoft, dat zowel Infrastructure as a Service (IaaS) als Platform as a Service (PaaS) biedt. Met dit platform kun je applicaties ontwikkelen of een compleet netwerk hosten, en dit alles op een relatief eenvoudige manier beheren. Omdat Azure wordt gehost in managed datacenters over de hele wereld, kun je jouw netwerk of applicatie wereldwijd beschikbaar maken. Microsoft biedt daarnaast een breed scala aan services, zoals Internet of Things (IoT), Azure Kubernetes, Artificial Intelligence (AI) en oplossingen voor het gebruik van Big Data.\n\nOnze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt. Hierbij leveren wij iedere keer maatwerk, want het programma van eisen ziet er telkens anders uit. Of het nu gaat om de ondersteuning van een Azure team of het volledige beheer, onze Azure experts staan voor je klaar. Meer over ons werk lees je onder andere in onze Azure [klantcases](/kennisbank/klantcases/azure) en [blogs](/kennisbank/blogs/azure).\n\n","Onze Azure consultants, engineers en cloud-architecten hebben ervaring met de ontwikkeling, implementatie en het beheer van de verschillende mogelijkheden die Microsoft Azure ons biedt.","azure","2023-08-17T09:47:20.996Z","2025-04-11T13:11:55.618Z","2023-08-17T09:50:22.095Z",true,"eubwn704tlyata6v2q819fn7",{"id":112,"name":113,"alternativeText":18,"caption":18,"width":114,"height":115,"formats":116,"hash":125,"ext":118,"mime":121,"size":126,"url":127,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":128,"updatedAt":128,"documentId":129,"publishedAt":58,"focalPoint":18},657,"mircosoft azure web.png",282,130,{"thumbnail":117},{"ext":118,"url":119,"hash":120,"mime":121,"name":122,"path":18,"size":123,"width":50,"height":124},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_mircosoft_azure_web_031897ebac.png","thumbnail_mircosoft_azure_web_031897ebac","image/png","thumbnail_mircosoft azure web.png",5.54,113,"mircosoft_azure_web_031897ebac",1.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/mircosoft_azure_web_031897ebac.png","2024-04-05T12:52:48.184Z","z9c21qscgi7eh5jijkc40fzv",{"id":6,"metaTitle":131,"metaDescription":132,"structuredData":133,"metaImage":18,"metaSocial":143},"Microsoft Azure-expertise – ShareValue helpt je vooruit","Van beheer tot DevOps: onze Azure-specialisten helpen je om cloudoplossingen slim en veilig in te richten en te optimaliseren.",{"url":134,"@type":135,"@context":74,"provider":136,"areaServed":138,"description":141,"serviceType":142},"https://www.sharevalue.nl/wat-we-doen/azure","Service",{"url":137,"name":72,"@type":73},"https://www.sharevalue.nl",{"name":139,"@type":140},"Nederland","Country","ShareValue helpt organisaties om Microsoft Azure effectief in te zetten. Onze specialisten werken aan cloudmigraties, infrastructuur, security, automation en DevOps-oplossingen.","Microsoft Azure consultancy",[],[145,153],{"id":146,"title":147,"aside":18,"postType":148,"limit":149,"expertise":150,"__component":152},165,"Lees meer over Azure","alle",3,[151],{"id":100,"title":101,"subTitle":102,"description":103,"shortDescription":104,"slug":105,"createdAt":106,"updatedAt":107,"publishedAt":108,"isCoreExpertise":109,"documentId":110},"strapi.related-kennisbank-list",{"id":154,"titleLeft":155,"callToActionTextLeft":156,"callToActionLinkUrlLeft":157,"titleRight":158,"callToActionTextRight":159,"callToActionLinkUrlRight":160,"iconUrlLeft":161,"iconUrlRight":174,"__component":183},209,"Heb je een Azure expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",{"id":162,"name":163,"alternativeText":18,"caption":18,"width":164,"height":165,"formats":18,"hash":166,"ext":167,"mime":168,"size":169,"url":170,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":171,"updatedAt":172,"documentId":173,"publishedAt":58,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":175,"name":176,"alternativeText":18,"caption":18,"width":165,"height":165,"formats":18,"hash":177,"ext":167,"mime":168,"size":178,"url":179,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":180,"updatedAt":181,"documentId":182,"publishedAt":58,"focalPoint":18},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf","call-to-action.double",[185,229,263,295],{"id":186,"title":187,"subTitle":18,"content":188,"callToActionText":189,"callToActionLink":157,"colorStyle":190,"showAsides":191,"imageUrl":192,"__component":228},25,"Azure Security: veiligheid in de cloud ","Voor organisaties is het belangrijk om de digitale infrastructuur te beveiligen in een steeds complexer wordend cyberlandschap. Onze experts helpen graag met behulp van Azure Security; een reeks beveiligingsdiensten en -functies die door Microsoft Azure wordt aangeboden om bedreigingen te detecteren, te voorkomen en erop te reageren. Enkele belangrijke componenten en functies van Azure Security waarmee wij werken zijn Azure Security Center, Microsoft Entra ID, Azure DDoS Protection en Azure Sentinel.","Neem contact op voor meer informatie","Sugar Glaze",false,{"id":193,"name":194,"alternativeText":18,"caption":18,"width":19,"height":195,"formats":196,"hash":223,"ext":23,"mime":200,"size":224,"url":225,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":226,"updatedAt":226,"documentId":227,"publishedAt":58,"focalPoint":18},779,"security azure.jpg",850,{"large":197,"small":204,"medium":210,"thumbnail":216},{"ext":23,"url":198,"hash":199,"mime":200,"name":201,"path":18,"size":202,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_azure_b1610cf1cb.jpg","large_security_azure_b1610cf1cb","image/jpeg","large_security azure.jpg",107.3,664,{"ext":23,"url":205,"hash":206,"mime":200,"name":207,"path":18,"size":208,"width":36,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_azure_b1610cf1cb.jpg","small_security_azure_b1610cf1cb","small_security azure.jpg",39.16,332,{"ext":23,"url":211,"hash":212,"mime":200,"name":213,"path":18,"size":214,"width":43,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_azure_b1610cf1cb.jpg","medium_security_azure_b1610cf1cb","medium_security azure.jpg",71.35,498,{"ext":23,"url":217,"hash":218,"mime":200,"name":219,"path":18,"size":220,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_azure_b1610cf1cb.jpg","thumbnail_security_azure_b1610cf1cb","thumbnail_security azure.jpg",12.37,235,156,"security_azure_b1610cf1cb",150.42,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_azure_b1610cf1cb.jpg","2024-08-08T08:50:26.921Z","z3xlbivuior2upad6adbxjgz","global.alternating-page-section",{"id":230,"title":231,"subTitle":18,"content":232,"callToActionText":18,"callToActionLink":18,"colorStyle":233,"showAsides":191,"imageUrl":234,"__component":228},26,"Azure Kubernetes Service (AKS)","Azure Kubernetes Service (AKS) helpt bij het beheren van applicaties die in containers draaien. Het vereenvoudigt en automatiseert de implementatie, het beheer en de operationele taken van Kubernetes-clusters. Door gebruik te maken van AKS kunnen organisaties zich richten op het ontwikkelen en beheren van hun applicaties, terwijl Microsoft de complexiteit van de Kubernetes-infrastructuur beheert. Hierdoor kunnen organisaties hun software efficiënt, betrouwbaar en kosteneffectief beheren. Doordat onze experts ruime kennis en ervaring hebben met AKS kunnen ze de klanten op een juiste manier helpen.","White",{"id":235,"name":236,"alternativeText":18,"caption":18,"width":19,"height":195,"formats":237,"hash":258,"ext":23,"mime":200,"size":259,"url":260,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":261,"updatedAt":261,"documentId":262,"publishedAt":58,"focalPoint":18},780,"containers.jpg",{"large":238,"small":243,"medium":248,"thumbnail":253},{"ext":23,"url":239,"hash":240,"mime":200,"name":241,"path":18,"size":242,"width":29,"height":203},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_containers_2e766510ad.jpg","large_containers_2e766510ad","large_containers.jpg",163.19,{"ext":23,"url":244,"hash":245,"mime":200,"name":246,"path":18,"size":247,"width":36,"height":209},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_containers_2e766510ad.jpg","small_containers_2e766510ad","small_containers.jpg",49.69,{"ext":23,"url":249,"hash":250,"mime":200,"name":251,"path":18,"size":252,"width":43,"height":215},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_containers_2e766510ad.jpg","medium_containers_2e766510ad","medium_containers.jpg",101.49,{"ext":23,"url":254,"hash":255,"mime":200,"name":256,"path":18,"size":257,"width":221,"height":222},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_containers_2e766510ad.jpg","thumbnail_containers_2e766510ad","thumbnail_containers.jpg",12.65,"containers_2e766510ad",240.51,"https://incredible-beef-2a6059b946.media.strapiapp.com/containers_2e766510ad.jpg","2024-08-08T08:54:58.426Z","idshbfmg66aak9yxdr9d22c7",{"id":6,"title":264,"subTitle":18,"content":265,"callToActionText":18,"callToActionLink":18,"colorStyle":190,"showAsides":191,"imageUrl":266,"__component":228},"Infrastructure as Code (IaC)","Infrastructure as Code (IaC) is het beheren van een Azure cloud-omgeving door middel van code en softwareontwikkelingstechnieken om infrastructuur te automatiseren, te configureren en te beheren. Het biedt versiebeheer voor configuraties, wat samenwerking en terugkeer naar eerdere versies vergemakkelijkt. Bovendien zorgt IaC voor consistentie in verschillende omgevingen en maakt het schaalvergroting eenvoudiger door configuraties te herhalen zonder handmatige ingrepen. \n\nAls je vragen hebt of ondersteuning nodig hebt, kunnen de Azure Experts je alles vertellen over Infrastructure as Code.",{"id":267,"name":268,"alternativeText":18,"caption":18,"width":19,"height":195,"formats":269,"hash":290,"ext":23,"mime":200,"size":291,"url":292,"previewUrl":18,"provider":55,"provider_metadata":18,"createdAt":293,"updatedAt":293,"documentId":294,"publishedAt":58,"focalPoint":18},781,"infrastructure.jpg",{"large":270,"small":275,"medium":280,"thumbnail":285},{"ext":23,"url":271,"hash":272,"mime":200,"name":273,"path":18,"size":274,"width":29,"height":203},"https://i