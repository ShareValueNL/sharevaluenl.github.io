[{"data":1,"prerenderedAt":619},["ShallowReactive",2],{"collection-blogs--1808008319":3,"_apollo:default":618},{"data":4,"meta":614},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":58,"author":18,"blocks":462,"seo":581},113,"Inspiratie opdoen tijdens de SharePoint Conference in Las Vegas","De afgelopen jaren is de wereld van de SharePoint-ontwikkelaar sterk veranderd. Naast SharePoint on-premise krijgen wij te maken met oplossingen binnen Office 365 en oplossingen gebouwd op Azure. Waar de ontwikkelaar vroeger .NET code kon schrijven, moet dit nu met het nieuwe SharePoint Framework grotendeels met Client-side code in JavaScript gebeuren.","inspiratie-opdoen-tijdens-de-sharepoint-conference-in-las-vegas","2023-10-13T10:26:42.737Z","2025-04-22T13:09:30.107Z","2023-10-13T10:26:42.690Z","2018-04-19","pscf7896qqw4z0v5n9rb02ki",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57},362,"inspiratie-opdoen-tijdens-de-sharepoint-conference-in-las-vegas.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3.jpg","large_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3","image/jpg","large_inspiratie-opdoen-tijdens-de-sharepoint-conference-in-las-vegas.jpg",147.51,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3.jpg","small_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3","small_inspiratie-opdoen-tijdens-de-sharepoint-conference-in-las-vegas.jpg",44.3,195,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3.jpg","medium_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3","medium_inspiratie-opdoen-tijdens-de-sharepoint-conference-in-las-vegas.jpg",91.97,750,293,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3.jpg","thumbnail_inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3","thumbnail_inspiratie-opdoen-tijdens-de-sharepoint-conference-in-las-vegas.jpg",11.3,245,96,"inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3",215.65,"https://incredible-beef-2a6059b946.media.strapiapp.com/inspiratie_opdoen_tijdens_de_sharepoint_conference_in_las_vegas_274b2e28c3.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:24:57.940Z","ybf60644jew9bli95vlgd73z","2026-01-05T12:38:34.018Z",[59],{"id":60,"title":61,"subTitle":62,"description":63,"shortDescription":64,"slug":65,"createdAt":66,"updatedAt":67,"publishedAt":68,"isCoreExpertise":69,"documentId":70,"image":71,"blocks":89,"midPageBlocks":207,"seo":457},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":72,"name":73,"alternativeText":18,"caption":18,"width":74,"height":75,"formats":76,"hash":84,"ext":78,"mime":81,"size":85,"url":86,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":87,"updatedAt":87,"documentId":88,"publishedAt":57},16,"microsoft-365.png",282,130,{"thumbnail":77},{"ext":78,"url":79,"hash":80,"mime":81,"name":82,"path":18,"size":83,"width":49,"height":6},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",[90,184],{"__component":91,"id":92,"title":93,"aside":18,"postType":94,"limit":95,"expertise":96},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",3,[97],{"id":60,"title":61,"subTitle":62,"description":63,"shortDescription":64,"slug":65,"createdAt":66,"updatedAt":67,"publishedAt":68,"isCoreExpertise":69,"documentId":70,"image":98,"blocks":101,"midPageBlocks":112,"seo":167},{"id":72,"name":73,"alternativeText":18,"caption":18,"width":74,"height":75,"formats":99,"hash":84,"ext":78,"mime":81,"size":85,"url":86,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":87,"updatedAt":87,"documentId":88,"publishedAt":57},{"thumbnail":100},{"ext":78,"url":79,"hash":80,"mime":81,"name":82,"path":18,"size":83,"width":49,"height":6},[102,103],{"__component":91,"id":92,"title":93,"aside":18,"postType":94,"limit":95},{"__component":104,"id":105,"titleLeft":106,"callToActionTextLeft":107,"callToActionLinkUrlLeft":108,"titleRight":109,"callToActionTextRight":110,"callToActionLinkUrlRight":111},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[113,121,128,133,138,144,149,156,161],{"__component":114,"id":115,"title":116,"subTitle":117,"content":118,"callToActionText":18,"callToActionLink":18,"colorStyle":119,"showAsides":120},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",false,{"__component":114,"id":122,"title":123,"subTitle":124,"content":125,"callToActionText":126,"callToActionLink":108,"colorStyle":127,"showAsides":120},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":114,"id":129,"title":130,"subTitle":131,"content":132,"callToActionText":18,"callToActionLink":18,"colorStyle":119,"showAsides":120},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":114,"id":134,"title":135,"subTitle":136,"content":137,"callToActionText":18,"callToActionLink":18,"colorStyle":127,"showAsides":120},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":114,"id":139,"title":140,"subTitle":141,"content":142,"callToActionText":143,"callToActionLink":108,"colorStyle":119,"showAsides":120},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":114,"id":145,"title":146,"subTitle":147,"content":148,"callToActionText":18,"callToActionLink":18,"colorStyle":127,"showAsides":120},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":114,"id":150,"title":151,"subTitle":152,"content":153,"callToActionText":154,"callToActionLink":155,"colorStyle":119,"showAsides":120},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":114,"id":157,"title":158,"subTitle":159,"content":160,"callToActionText":18,"callToActionLink":18,"colorStyle":127,"showAsides":120},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":162,"id":163,"title":164,"callToActionText":165,"callToActionLinkUrl":166,"body":18},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":168,"metaTitle":169,"metaDescription":170,"structuredData":171},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":172,"@type":173,"@context":174,"provider":175,"areaServed":179,"description":182,"serviceType":183},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":176,"name":177,"@type":178},"https://www.sharevalue.nl","ShareValue","Organization",{"name":180,"@type":181},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":104,"id":105,"titleLeft":106,"callToActionTextLeft":107,"callToAct