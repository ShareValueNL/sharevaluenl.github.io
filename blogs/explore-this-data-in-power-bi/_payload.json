beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":310,"hash":311,"mime":26,"name":312,"path":18,"size":313,"width":110,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":141,"id":142,"title":143,"callToActionText":144,"callToActionLinkUrl":145,"body":18,"imageUrl":320},{"id":165,"name":166,"alternativeText":18,"caption":18,"width":167,"height":168,"formats":18,"hash":169,"ext":170,"mime":171,"size":172,"url":173,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":174,"updatedAt":175,"documentId":176,"publishedAt":61},{"id":147,"metaTitle":148,"metaDescription":149,"structuredData":322,"metaImage":18,"metaSocial":325},{"url":151,"@type":152,"@context":153,"provider":323,"areaServed":324,"description":161,"serviceType":162},{"url":155,"name":156,"@type":157},{"name":159,"@type":160},[],{"id":327,"name":328,"jobTitle":329,"about":18,"createdAt":330,"updatedAt":331,"publishedAt":332,"documentId":333,"image":334,"contactOptions":351},80,"Ramon","Consultant","2023-08-18T08:37:46.233Z","2024-03-18T14:33:03.326Z","2023-08-18T08:37:46.045Z","qckf06atobvgc4uvlhydyz6b",{"id":335,"name":336,"alternativeText":18,"caption":18,"width":337,"height":338,"formats":339,"hash":346,"ext":82,"mime":85,"size":347,"url":348,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":349,"updatedAt":349,"documentId":350,"publishedAt":61},601,"Ramon websitefoto.png",278,326,{"thumbnail":340},{"ext":82,"url":341,"hash":342,"mime":85,"name":343,"path":18,"size":344,"width":345,"height":218},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Ramon_websitefoto_446734af35.png","thumbnail_Ramon_websitefoto_446734af35","thumbnail_Ramon websitefoto.png",17.85,133,"Ramon_websitefoto_446734af35",19.85,"https://incredible-beef-2a6059b946.media.strapiapp.com/Ramon_websitefoto_446734af35.png","2024-03-18T14:32:17.684Z","j2cnfzt43m3xpeo3zt5cj4kw",[],[353,357,360,363,366,369,372,375,378,408],{"__component":354,"id":355,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":356,"introductionText":18},"global.pagesection",4188,"Binnen een organisatie wordt vaak met veel Power BI-rapporten gewerkt. Al deze rapporten zijn via de Power BI Service beschikbaar voor gebruikers en worden onderhouden door Power Platform Developers. Toch heb je als gebruiker vaak specifieke wensen. Je wilt snel de juiste informatie kunnen inzien, ook als die niet standaard in het rapport staat. Bijvoorbeeld: je wilt zelf even iets uitzoeken, zonder dat de maker dit eerst moet bouwen. Met Explore this data kun je dan zelf op ontdekkingstocht binnen de beschikbare data.",{"__component":354,"id":358,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":359,"introductionText":18},4189,"## Voorbeeldcasus\n\nAls voorbeeld nemen we Bedrijf X. Dit bedrijf heeft klanten verdeeld over verschillende landen in Europa. Klantdata wordt inzichtelijk gemaakt met Power BI en aan de gebruikers van de organisatie aangeboden in de Power BI Service. Medewerkers van de organisatie kunnen gebruikmaken van alle visualisaties die in de rapporten zijn opgenomen.\n\n![Blog PowerBI afbeelding 1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Power_BI_afbeelding_1_201f8bbfda.png)\n_Afbeelding 1 Power BI rapport in de Power BI Service_\n\nIn bovenstaand rapport is al veel informatie beschikbaar voor de gebruikers. Er zijn enkele filters om in te zoomen op specifieke informatie. Daarnaast bevat het rapport een visualisatie waarin de verkoop in Europa te zien is, met extra details wanneer je met de muis over een datapunt beweegt.\nToch zijn er nog veel andere visualisaties mogelijk die in dit rapport getoond zouden kunnen worden. Stel dat je als gebruiker per jaar en per land de totale verkoop in één overzicht wilt zien.\n\nNormaal gesproken dien je hiervoor een verzoek in bij de Power Platform Developers. Dit wordt besproken, geprioriteerd en vervolgens ingepland. Er kan dan enige tijd overheen gaan voordat de gewenste visualisatie beschikbaar is in de Power BI Service.\nHier biedt de functionaliteit ‘Explore this data’ uitkomst. Hiermee kun je als gebruiker zelf aan de slag met de data die in de visualisaties wordt gebruikt.",{"__component":354,"id":361,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":362,"introductionText":18},4190,"## Stap-voor-stap gebruik\n\nDoor op de drie puntjes rechtsboven in een visualisatie te klikken en vervolgens ‘Explore this data’ te selecteren, word je automatisch naar een pop-upscherm geleid.\n\n![Blog PowerBI afbeelding 2.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Power_BI_afbeelding_2_b0f61795c8.png)\n_Afbeelding 2 Selecteer 'Explore this data' vanuit een visualisatie_\n\nIn dit scherm kun je zelf werken met alle data die in deze visualisatie wordt gebruikt. Je ziet in eerste instantie een versimpelde versie van het ontwikkelscherm, met aan de linkerzijde de tabellen en velden die op dat moment beschikbaar zijn.\n\n![Blog PowerBI afbeelding 3.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Power_BI_afbeelding_3_44a5e9addb.png)\n_Afbeelding 3 Pop-up scherm 'Explore this data'_\n\nBinnen dit scherm kun je data selecteren, visualisaties aanpassen en extra inzichten creëren. Je kunt het scherm op elk moment sluiten zonder iets op te slaan; in dat geval verandert er niets aan het oorspronkelijke rapport.",{"__component":354,"id":364,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":365,"introductionText":18},4191,"## Een nieuwe visualisatie maken\nZoals eerder genoemd, willen we in dit voorbeeld per jaar en per land de totale verkoop weergeven. Dit doet je als volgt:\n1. Selecteer in het scherm de velden Year, Country en Profit.\n2. Kies een visualisatie die je passend vindt. Hierbij kan gekozen worden uit alle visualisaties.\n3. Bekijk het eindresultaat: een duidelijk overzicht van de gewenste informatie.\n\n![Blog PowerBI afbeelding 4.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Blog_Power_BI_afbeelding_4_3df39d961a.png)\n_Afbeelding 4 Een nieuwe visualisatie maken_\n\nIn deze voorbeeldcasus is slechts één tabel binnen het datamodel gebruikt en een eenvoudige tabelvisualisatie gekozen. De mogelijkheden zijn echter zeer divers. Je kunt werken met meerdere tabellen, filters toepassen, beperkingen per rij instellen en zelfs jouw gemaakte visualisaties opslaan in jouw Workspace om ze vervolgens te delen met collega’s.",{"__component":354,"id":367,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":368,"introductionText":18},4192,"## Extra informatie\n- Status: deze functionaliteit is momenteel nog in Preview. Het is nog niet bekend wanneer deze algemeen beschikbaar wordt.\n- Beveiliging: je ziet alleen data waarvoor jij rechten hebt.\n- Opslaan: jouw wijzigingen worden alleen opgeslagen als je dat zelf kiest.\n- Beschikbaarheid: deze functionaliteit kan door jouw beheerder geactiveerd en gedeactiveerd worden voor gebruik binnen de rapporten.",{"__component":354,"id":370,"title":18,"asideText":18,"underline":125,"centered":125,"blankAside":125,"aside":18,"content":371,"introductionText":18},4193,"## Conclusie\n\nMet ‘Explore this data’ in Power BI Service kun jij zelf snel aanvullende inzichten creëren, zonder afhankelijk te zijn van aanpassingen door developers. Hierbij heb je de mogelijkheden die een developer ook heeft, enkel met de data die jij ter beschikking hebt.\n\nWil je meer weten over deze functionaliteit of andere tips? Neem gerust [contact](https://www.sharevalue.nl/contact) met ons op.\n",{"__component":373,"id":374,"title":18,"showBlankAside":125},"global.social-sharing",464,{"__component":376,"id":377,"name":18,"jobTitle":18},"strapi.author-card",360,{"__component":109,"id":379,"titleLeft":380,"callToActionTextLeft":381,"callToActionLinkUrlLeft":113,"titleRight":382,"callToActionTextRight":383,"callToActionLinkUrlRight":384,"iconUrlLeft":385,"iconUrlRight":396},528,"Heb je een Power Platform Consultant nodig?","Neem contact met ons op","Meer lezen over Power Platform?","Klik hier","/wat-we-doen/power-platform",{"id":386,"name":387,"alternativeText":18,"caption":18,"width":388,"height":389,"formats":18,"hash":390,"ext":170,"mime":171,"size":391,"url":392,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":393,"updatedAt":394,"documentId":395,"publishedAt":61},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",{"id":397,"name":398,"alternativeText":18,"caption":18,"width":399,"height":399,"formats":18,"hash":400,"ext":401,"mime":402,"size":403,"url":404,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":405,"updatedAt":406,"documentId":407,"publishedAt":61},37,"folder.webp",56,"folder_d71bf882b0",".webp","image/webp",0.6,"https://incredible-beef-2a6059b946.media.strapiapp.com/folder_d71bf882b0.webp","2023-08-17T13:42:28.245Z","2025-07-22T07:14:07.669Z","exd7vm0cg06bj1vbrpv9qa8a",{"__component":96,"id":409,"title":410,"aside":18,"postType":411,"limit":100,"expertise":412},408,"Lees meer over Power Platform","blogs",[413],{"id":64,"title":65,"subTitle":66,"description":67,"shortDescription":68,"slug":69,"createdAt":70,"updatedAt":71,"publishedAt":72,"isCoreExpertise":73,"documentId":74,"image":414,"blocks":417,"midPageBlocks":424,"seo":455},