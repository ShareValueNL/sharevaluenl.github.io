[{"data":1,"prerenderedAt":612},["ShallowReactive",2],{"collection-blogs-951012267":3,"_apollo:default":611},{"data":4,"meta":607},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":58,"expertises":102,"blocks":485},116,"Vijf aandachtspunten bij het inrichten en gebruiken van Microsoft Teams","Microsoft Teams is een populaire samenwerkingsapp voor o.a. teams, werkgroepen, projecten en afdelingen. De Office 365 app lijkt veel belovend als het gaat om online samenwerken. Microsoft zet er dan ook vol op in. In deze blog beschrijf ik vijf punten waaraan je aandacht moet besteden als je Microsoft Teams gaat inrichten en gebruiken in je organisatie of bedrijf.","vijf-aandachtspunten-bij-het-inrichten-en-gebruiken-van-microsoft-teams","2023-10-13T10:26:43.053Z","2025-04-22T15:15:40.701Z","2023-10-13T10:26:42.999Z","2018-03-19","tsd6i7jofc7vjlhiajbibj5d",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57,"focalPoint":18},365,"vijf-aandachtspunten-bij-het-inrichten-en-gebruiken-van-microsoft-teams.jpg",null,1274,603,{"large":22,"small":31,"medium":38,"thumbnail":45},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_vijf_aandachtspunten_bij_het_inrichten_en_gebruiken_van_microsoft_teams_c0a4811e37.jpg","large_vijf_aandachtspunten_bij_het_inrichten_en_gebruiken_van_microsoft_teams_c0a4811e37","image/jpg","large_vijf-aandachtspunten-bij-het-inrichten-en-gebruiken-van-microsoft-teams.jpg",44.87,1000,473,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":37},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vijf_aandachtspu