[{"data":1,"prerenderedAt":673},["ShallowReactive",2],{"collection-blogs--1820061850":3,"_apollo:default":672},{"data":4,"meta":669},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":58,"author":462,"blocks":488,"seo":632},4,"Outlook is vernieuwd! Welke nieuwe functionaliteiten zijn er en wat komt er nog aan? ","Microsoft heeft onlangs de nieuwe versie van Outlook beschikbaar gemaakt. Deze update geeft een nieuwe verfrissende look aan het programma. Daarnaast brengt het ook nieuwe handige functies met zich mee die het zeker de moeite waard maken om alvast over te stappen naar de nieuwe Outlook versie. De komende tijd zullen er meer nieuwe features toegevoegd worden aan deze versie. Wanneer Microsoft klaar is met het programmeren van de nieuwe versie zal ieders standaard Mail en Outlook desktop app omgezet worden. ","outlook-is-vernieuwd-welke-nieuwe-functionaliteiten-zijn-er-en-wat-komt-er-nog-aan","2023-10-13T10:26:21.941Z","2025-04-15T08:26:46.821Z","2023-10-13T10:26:21.580Z","2023-10-05","y61u9afp8umzbxw2j9kot2u8",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57},253,"outlook-is-vernieuwd-welke-nieuwe-functionaliteiten-zijn-er-en-wat-komt-er-nog-aan.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_outlook_is_vernieuwd_welke_nieuwe_functionaliteiten_zijn_er_en_wat_komt_er_nog_aan_17bad944f3.jpg","large_outlook_is_vernieuwd_welke_nieuwe_functionaliteiten_zijn_er_en_wat_komt_er_nog_aan_17bad944f3","image/jpg","large_outlook-is-vernieuwd-welke-nieuwe-functionaliteiten-zijn-er-en-wat-komt-er-n