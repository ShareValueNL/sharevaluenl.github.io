um":440,"thumbnail":445},{"ext":23,"url":431,"hash":432,"mime":217,"name":433,"path":18,"size":434,"width":29,"height":220},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":436,"hash":437,"mime":217,"name":438,"path":18,"size":439,"width":20,"height":226},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":441,"hash":442,"mime":217,"name":443,"path":18,"size":444,"width":42,"height":232},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":446,"hash":447,"mime":217,"name":448,"path":18,"size":449,"width":238,"height":239},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":162,"id":163,"title":164,"callToActionText":165,"callToActionLinkUrl":166,"body":18,"imageUrl":456},{"id":186,"name":187,"alternativeText":18,"caption":18,"width":188,"height":189,"formats":18,"hash":190,"ext":191,"mime":192,"size":193,"url":194,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":195,"updatedAt":196,"documentId":197,"publishedAt":57},{"id":168,"metaTitle":169,"metaDescription":170,"structuredData":458,"metaImage":18,"metaSocial":461},{"url":172,"@type":173,"@context":174,"provider":459,"areaServed":460,"description":182,"serviceType":183},{"url":176,"name":177,"@type":178},{"name":180,"@type":181},[],{"id":463,"name":464,"jobTitle":465,"about":18,"createdAt":466,"updatedAt":467,"publishedAt":468,"documentId":469,"image":470,"contactOptions":487},81,"Michelle","Consultant","2023-10-12T10:04:21.815Z","2024-03-11T12:18:40.835Z","2023-10-12T10:04:22.884Z","d19jpcqp626wht32twuhhay5",{"id":471,"name":472,"alternativeText":18,"caption":18,"width":473,"height":474,"formats":475,"hash":482,"ext":77,"mime":80,"size":483,"url":484,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":485,"updatedAt":485,"documentId":486,"publishedAt":57},552,"Michelle websitefoto.png",278,326,{"thumbnail":476},{"ext":77,"url":477,"hash":478,"mime":80,"name":479,"path":18,"size":480,"width":481,"height":239},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Michelle_websitefoto_81ae8119a0.png","thumbnail_Michelle_websitefoto_81ae8119a0","thumbnail_Michelle websitefoto.png",20.91,133,"Michelle_websitefoto_81ae8119a0",27.85,"https://incredible-beef-2a6059b946.media.strapiapp.com/Michelle_websitefoto_81ae8119a0.png","2024-03-05T12:43:59.434Z","crjgodfat7routsay7c1ngne",[],[489,494,497,501,504,507,511,514,517,521,524,527,530,533,536,615],{"__component":490,"id":491,"title":18,"asideText":18,"underline":120,"centered":120,"blankAside":120,"aside":492,"content":493,"introductionText":18},"global.pagesection",180,"","Momenteel zijn er al nieuwe functies die de overstap naar de nieuwe outlook versie interessant zouden kunnen maken. Enkele van deze functies worden verderop in deze blog ook uitgelicht. Let er wel op dat deze versie nog een preview versie is om de nieuwe functionaliteiten in te testen, deze is daarom beperkter in functionaliteit. Als de nieuwe versie nog niet alle functies heeft waar je gebruik van maakt binnen Outlook, kun je altijd eenvoudig de oude versie terugzetten door de schuifknop weer aan te klikken.",{"__component":490,"id":495,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":496,"introductionText":18},181,"## Hoe schakel je dit in?\n\nHet enige wat je hoeft te doen om de nieuwe Outlook versie uit te proberen is rechts boven in jouw applicatie op de schuifknop te klikken.",{"__component":490,"id":498,"title":18,"asideText":499,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":500,"introductionText":18},182,"Zet de schuifknop om!","![](https://www.sharevalue.nl/images/sharevalue/blogs/outlook1.png)\n",{"__component":490,"id":502,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":503,"introductionText":18},184,"Daarna wordt Outlook afgesloten en automatisch in de nieuwe versie opgestart. Na het overzetten van het programma worden er gelijk nieuwe functies beschikbaar gesteld.",{"__component":490,"id":505,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":506,"introductionText":18},183,"## Verzending mails inplannen\n\nIn deze versie is het mogelijk om tijdens het schrijven van een e-mail de verzending ervan in te plannen door op de uitklapknop naast de verzendknop te klikken en ‘Verzending plannen’ te selecteren. Het plannen van de verzending van e-mails kan bijzonder handig zijn als je mails verstuurt naar een andere tijdzone of wanneer het van belang is dat een e-mail op een specifiek moment wordt afgeleverd.",{"__component":490,"id":508,"title":18,"asideText":509,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":510,"introductionText":18},185,"Inplannen mails verzenden","![](https://www.sharevalue.nl/images/sharevalue/blogs/outlook2.png)",{"__component":490,"id":512,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":513,"introductionText":18},187,"Als je hierop klikt komen er een aantal voorstellen tevoorschijn. Als je verder klikt op ‘Aangepaste tijd’ is het mogelijk om een andere tijd in te stellen voor het versturen.  Wanneer dit ingesteld is en je mail geschreven is kun je op ‘Verzenden’ klikken en beland je mail in de conceptenmap tot het moment dat deze verzonden wordt. Deze functie is afgelopen juli uitgebracht.",{"__component":490,"id":515,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":516,"introductionText":18},186,"## Beschikbaarheid in detail weergeven\n\nDaarnaast  is het nu binnen de agenda functie mogelijk om je beschikbaarheid in meer detail aan te geven. In de huidige outlook versie is het mogelijk om je werkdagen in te stellen en de bijbehorende werktijden die voor elke werkdag hetzelfde worden weergegeven. In de nieuwe versie kun je niet alleen voor elke werkdag andere tijden instellen, maar ook op welke locatie je die werkdag aanwezig bent. Dit is vooral handig omdat het steeds normaler is geworden dat veel mensen hybride werken. Op deze manier kun je dit standaard laten weten en hoeven collega’s hier niet meer naar te vragen, maar kunnen zij dit zelf zien.\n\nOm in de nieuwe versie je beschikbare tijden aan te geven navigeer je naar de agenda. Klik daar bovenaan op ‘Weergeven’ > ‘Agenda instellingen’. In het menu dat naar voren komt klik je op ‘Werkuren en locatie’ Hier kun je per dag je werkdagen en -uren en locatie invoeren.\n\nVerder is het mogelijk om op één dag in te stellen dat je op verschillende tijden van de dag extern of op kantoor werkt. Dit kun je doen door naast het aangeven van je locatie op het plusje te klikken. Binnen dit menu is het ook mogelijk om aan te geven dat je locatie niet in je agenda weergegeven wordt.  \nEen ingevulde werkweek zou er dan als volgt uit kunnen zien:",{"__component":490,"id":518,"title":18,"asideText":519,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":520,"introductionText":18},188,"Stel je werkuren en locatie in","![](https://www.sharevalue.nl/images/sharevalue/blogs/outlook3.png)",{"__component":490,"id":522,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":523,"introductionText":18},189,"## Functionaliteiten waar nog aan wordt gewerkt\n\nMicrosoft is momenteel nog bezig met het maken en implementeren van ondersteuning voor meerdere accounts. Daarnaast zullen zij in de toekomst ook andere email services ondersteunen zoals Gmail, Yahoo, iCloud en IMAP. Gmail zal als een van de eerste uitgerold worden en Outlook zal hier ook ondersteuning bieden voor de Google Calendar en Contacts inhoud. Het doel van Microsoft is om tegen het einde van 2024 iedereen over te zetten naar deze nieuwe versie en daarom zullen alle geplande functionaliteiten tegen die tijd uitgebracht moeten zijn.",{"__component":490,"id":525,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":526,"introductionText":18},190,"## Conclusie\n\nAls je na dit verhaal geïnteresseerd bent in deze functies en de nieuwe stijl van Outlook, kun je nu gelijk al een kijkje nemen. In de toekomst zal Microsoft meer functies toevoegen en verbeteren. Dus ook al verander je nu nog niet naar de nieuwe versie, hou vooral de updates in de gaten!",{"__component":490,"id":528,"title":18,"asideText":492,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":529,"introductionText":18},191,"Wil je meer weten over deze functionaliteit? Neem dan gerust contact met ons op, zodat we de mogelijkheden kunnen bespreken.",{"__component":531,"id":532,"title":18,"showBlankAside":68},"global.social-sharing",43,{"__component":534,"id":535,"name":18,"jobTitle":18},"strapi.author-card",1,{"__component":91,"id":537,"title":538,"aside":18,"postType":94,"limit":95,"expertise":539},12,"Lees ook onze andere berichten",[540],{"id":6,"title":60,"subTitle":61,"description":62,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":66,"publishedAt":67,"isCoreExpertise":68,"documentId":69,"image":541,"blocks":544,"midPageBlocks":551,"seo":610},{"id":71,"name":72,"alternativeText":18,"caption":18,"width":73,"height":74,"formats":542,"hash":84,"ext":77,"mime":80,"size":85,"url":86,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":87,"updatedAt":87,"documentId":88,"publishedAt":57},{"thumbnail":543},{"ext":77,"url":78,"hash":79,"mime":80,"name":81,"path":18,"size":82,"width":49,"height":83},[545,548],{"__component":91,"id":92,"title":93,"aside":18,"postType":94,"limit":95,"expertise":546},[547],{"id":6,"title":60,"subTitle":61,"description":62,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":66,"publishedAt":67,"isCoreExpertise":68,"documentId":69},{"__component":104,"id":105,"titleLeft":106,"callToActionTextLeft":107,"callToActionLinkUrlLeft":108,"titleRight":109,"callToActionTextRight":110,"callToActionLinkUrlRight":111,"iconUrlLeft":549,"iconUrlRight":550},{"id":186,"name":187,"alternativeText":18,"caption":18,"width":188,"height":189,"formats":18,"hash":190,"ext":191,"mime":192,"size":193,"url":194,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":195,"updatedAt":196,"documentId":197,"publishedAt":57},{"id":199,"name":200,"alternativeText":18,"caption":18,"width":189,"height":189,"formats":18,"hash":201,"ext":191,"mime":192,"size":202,"url":203,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":204,"updatedAt":205,"documentId":206,"publishedAt":57},[552,559,566,573,580,587,594,601,608],{"__component":114,"id":115,"title":116,"subTitle":117,"content":118,"callToActionText":18,"callToActionLink":18,"colorStyle":119,"showAsides":120,"imageUrl":553},{"id":210,"name":211,"alternativeText":18,"caption":18,"width":19,"height":212,"formats":554,"hash":240,"ext":23,"mime":217,"size":241,"url":242,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":243,"updatedAt":243,"documentId":244,"publishedAt":57},{"large":555,"small":556,"medium":557,"thumbnail":558},{"ext":23,"url":215,"hash":216,"mime":217,"name":218,"path":18,"size":219,"width":29,"height":220},{"ext":23,"url":222,"hash":223,"mime":217,"name":224,"path":18,"size":225,"width":20,"height":226},{"ext":23,"url":228,"hash":229,"mime":217,"name":230,"path":18,"size":231,"width":42,"height":232},{"ext":23,"url":234,"hash":235,"mime":217,"name":236,"path":18,"size":237,"width":238,"height":239}