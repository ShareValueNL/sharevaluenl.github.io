[{"data":1,"prerenderedAt":610},["ShallowReactive",2],{"collection-blogs-366181290":3,"_apollo:default":609},{"data":4,"meta":605},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"author":18,"seo":57,"expertises":96,"blocks":484},44,".NET 6: En wat is jouw excuus?","Je kan veel van Microsoft zeggen, maar stilgezeten hebben ze dit jaar in ieder geval niet. Op 5 Oktober lanceert Microsoft Windows 11. Een maand later, op 8 november, wordt Visual Studio 2022 gelanceerd en de dag daarna is .NET 6 en C# 10 beschikbaar.",".net-6-en-wat-is-jouw-excuus","2023-10-13T10:26:31.252Z","2025-04-15T12:58:03.831Z","2023-10-13T10:26:30.825Z","2021-11-04","luioex2gjowpyz89cwm4vj2w",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":50,"ext":23,"mime":26,"size":51,"url":52,"previewUrl":18,"provider":53,"provider_metadata":18,"createdAt":54,"updatedAt":54,"documentId":55,"publishedAt":56,"focalPoint":18},293,".net-6-en-wat-is-jouw-excuus.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":43},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_net_6_en_wat_is_jouw_excuus_e52e805653.jpg","large_net_6_en_wat_is_jouw_excuus_e52e805653","image/jpg","large_.net-6-en-wat-is-jouw-excuus.jpg",38.24,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_net_6_en_wat_is_jouw_excuus_e52e805653.jpg","small_net_6_en_wat_is_jouw_excuus_e52e805653","small_.net-6-en-wat-is-jouw-excuus.jpg",11.78,195,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":16},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_net_6_en_wat_is_jouw_excuus_e52e805653.jpg","medium_net_6_en_wat_is_jouw_excuus_e52e805653","medium_.net-6-en-wat-is-jouw-excuus.jpg",23.34,750,{"ext":23,"url":44,"hash":45,"mime":26,"name":46,"path":18,"size":47,"width":48,"height":49},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_net_6_en_wat_is_jouw_excuus_e52e805653.jpg","thumbnail_net_6_en_wat_is_jouw_excuus_e52e805653","thumbnail_.net-6-en-wat-is-jouw-excuus.jpg",3.81,245,96,"net_6_en_wat_is_jouw_excuus_e52e805653",47.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/net_6_en_wat_is_jouw_excuus_e52e805653.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:22:27.829Z","jnjo6xeh37tbu1gii5biqb3r","2026-01-05T12:38:34.018Z",{"id":58,"metaTitle":59,"metaDescription":60,"structuredData":61,"metaImage":18,"metaSocial":95},132,".NET 6: wat is jouw excuus? | ShareValue","Michiel deelt zijn must-watch sessies van .NET Conf 2021 en licht de belangrijkste vernieuwingen in .NET 6 en C# 10 toe.​",[62,78],{"url":63,"@type":64,"author":65,"@context":72,"headline":59,"publisher":73,"description":77,"datePublished":13},"https://www.sharevalue.nl/blogs/.net-6-en-wat-is-jouw-excuus","BlogPosting",{"name":66,"@type":67,"jobTitle":68,"worksFor":69},"Michiel","Person","Developer",{"name":70,"@type":71},"ShareValue","Organization","https://schema.org",{"logo":74,"name":70,"@type":71},{"url":75,"@type":76},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","Michiel deelt zijn must-watch sessies van .NET Conf 2021 en licht de belangrijkste vernieuwingen in .NET 6 en C# 10 toe.",{"@type":79,"@context":72,"mainEntity":80},"FAQPage",[81,87,91],{"name":82,"@type":83,"acceptedAnswer":84},"Wat is nieuw in .NET 6?","Question",{"text":85,"@type":86},"Onder andere Minimal APIs, verbeterde prestaties, ondersteuning voor Blazor en cross-platform mogelijkheden.","Answer",{"name":88,"@type":83,"acceptedAnswer":89},"Wat zijn de hoogtepunten van .NET Conf 2021?",{"text":90,"@type":86},"Sessie over C# 10, Minimal APIs, Blazor, testen in .NET en cross-platform database ondersteuning met EF Core.",{"name":92,"@type":83,"acceptedAnswer":93},"Waarom zou ik upgraden naar .NET 6?",{"text":94,"@type":86},"Voor betere prestaties, moderne features en langdurige ondersteuning vanuit Microsoft.",[],[97,280],{"id":98,"title":99,"subTitle":100,"description":101,"shortDescription":102,"slug":103,"createdAt":104,"updatedAt":105,"publishedAt":106,"isCoreExpertise":107,"documentId":108,"image":109,"seo":18,"blocks":128,"midPageBlocks":164},3,"Microsoft .NET","Maatwerkoplossingen voor ieder vraagstuk","Ons team van .NET-experts staat niet alleen klaar om onze klanten te ondersteunen bij diverse implementatie uitdagingen, maar we zijn ook gespecialiseerd in het testen van applicaties op verschillende niveaus, zoals unit tests, integratietests en acceptatietests. We streven naar uitmuntende testdekking om de stabiliteit en betrouwbaarheid van de applicaties te waarborgen.\n\nDaarnaast zijn we bedreven in het gebruik van verschillende Azure-services om schaalbare en veilige oplossingen te bieden aan onze klanten. Zo bieden we met Azure DevOps krachtige tools voor het beheren van de ontwikkeling, het automatiseren van tests en het geautomatiseerd uitrollen naar acceptatie- of productieomgevingen met CI/CD-pipelines.\n\nHet samenwerken met onze klanten staat centraal in ons werk, en we denken proactief mee om samen de meest optimale oplossingen te realiseren.","In de praktijk komen de .NET developers van ShareValue terecht in allerlei verschillende branches met uiteenlopende technische uitdagingen.","dotnet","2023-08-17T11:19:57.991Z","2024-12-13T12:16:04.480Z","2023-08-17T11:22:08.050Z",false,"v9pl553hsjk98esvs5gzoso3",{"id":110,"name":111,"alternativeText":18,"caption":18,"width":112,"height":113,"formats":114,"hash":123,"ext":116,"mime":119,"size":124,"url":125,"previewUrl":18,"provider":53,"provider_metadata":18,"createdAt":126,"updatedAt":126,"documentId":127,"publishedAt":56,"focalPoint":18},17,"dotnet_logo.png",282,130,{"thumbnail":115},{"ext":116,"url":117,"hash":118,"mime":119,"name":120,"path":18,"size":121,"width":48,"height":122},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_dotnet_logo_d38dbc3865.png","thumbnail_dotnet_logo_d38dbc3865","image/png","thumbnail_dotnet_logo.png",7.14,113,"dotnet_logo_d38dbc3865",2.93,"https://incredible-beef-2a6059b946.media.strapiapp.com/dotnet_logo_d38dbc3865.png","2023-08-17T09:47:56.313Z","nnimzsossci29qmi8z0texlp",[129,136],{"id":130,"title":131,"aside":18,"postType":132,"limit":98,"expertise":133,"__component":135},167," Lees meer over .NET Development","alle",[134],{"id":98,"title":99,"subTitle":100,"description":101,"shortDescription":102,"slug":103,"createdAt":104,"updatedAt":105,"publishedAt":106,"isCoreExpertise":107,"documentId":108},"strapi.related-kennisbank-list",{"id":137,"titleLeft":138,"callToActionTextLeft":139,"callToActionLinkUrlLeft":140,"titleRight":141,"callToActionTextRight":139,"callToActionLinkUrlRight":140,"iconUrlLeft":142,"iconUrlRight":155,"__component":163},212,"Heb je een .NET expert nodig?","Neem contact met ons op","/contact","Weten welke expert op dit moment beschikbaar is?",{"id":143,"name":144,"alternativeText":18,"caption":18,"width":145,"height":146,"formats":18,"hash":147,"ext":148,"mime":149,"size":150,"url":151,"previewUrl":18,"provider":53,"provider_metadata":18,"createdAt":152,"updatedAt":153,"documentId":154,"publishedAt":56,"focalPoint":18},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":156,"name":157,"alternativeText":18,"caption":18,"width":146,"height":146,"formats":18,"hash":158,"ext":148,"mime":149,"size":159,"url":160,"previewUrl":18,"provider":53,"provider_metadata":18,"createdAt":161,"updatedAt":161,"documentId":162,"publishedAt":56,"focalPoint":18},250,"looking-glass.svg","looking_glass_cfa3801802",0.6,"https://incredible-beef-2a6059b946.media.strapiapp.com/looking_glass_cfa3801802.svg","2023-10-11T09:43:10.911Z","suv3p7h0kw7jdnuddk1l2rdu","call-to-action.double",[165,207,240,273],{"id":166,"title":167,"subTitle":18,"content":168,"callToActionText":169,"callToActionLink":140,"colorStyle":18,"showAsides":18,"imageUrl":170,"__component":206},36,"Bouwen en testen","Onze .NET-experts kunnen uiteraard goede en betrouwbare applicaties ontwikkelen met de laatste .NET-versies. Ook zijn onze collega’s ervaren in het onderhouden van oudere software. We kunnen je helpen met het upgraden en uitbreiden van je applicatie zodat deze aan de laatste wensen en eisen voldoet. Het uitvoeren van uitgebreide unit- en integratietests om de stabiliteit van applicaties te waarborgen, wordt meegenomen als standaard onderdeel van het werk. Met een focus op grondige testdekking streven we ernaar om eventuele bugs vroegtijdig op te sporen en op te lossen, waardoor de algehele kwaliteit van jouw product wordt verbeterd.  \n\nVan Blazor Front-End of REST API’s tot database communicatie, onze .NET-experts hebben er ruime ervaring mee.","Weten wat onze experts voor jou kunnen doen?",{"id":171,"name":172,"alternativeText":18,"caption":18,"width":19,"height":173,"formats":174,"hash":201,"ext":23,"mime":178,"size":202,"url":203,"previewUrl":18,"provider":53,"provider_metadata":18,"createdAt":204,"updatedAt":204,"documentId":205,"publishedAt":56,"focalPoint":18},790,"code matrix.jpg",850,{"large":175,"small":182,"medium":188,"thumbnail":194},{"ext":23,"url":176,"hash":177,"mime":178,"name":179,"path":18,"size":180,"width":29,"height":181},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_code_matrix_939256fff4.jpg","large_code_matrix_939256fff4","image/jpeg","large_code matrix.jpg",164.22,664,{"ext":23,"url":183,"hash":184,"mime":178,"name":185,"path":18,"size":186,"width":20,"height":187},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_code_matrix_939256fff4.jpg","small_code_matrix_939256fff4","small_code matrix.jpg",42.02,332,{"ext":23,"url":189,"hash":190,"mime":178,"name":191,"path":18,"size":192,"width":42,"height":193},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_code_matrix_939256fff4.jpg","medium_code_matrix_939256fff4","medium_code matrix.jpg",97.04,498,{"ext":23,"url":195,"hash":196,"mime":178,"name":197,"path":18,"size":198,"width":199,"height":200},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_code_matrix_939256fff4.jpg","thumbnail_code_matrix_939256fff4","thumbnail_code matrix.jpg",8.35,235,156,"code_matrix_939256fff4",258.04,"https://incredible-beef-2a6059b946.media.strapiapp.com/code_matrix_939256fff4.jpg","2024-08-09T08:30:59.615Z","s5v68ezvz0ho9m6ot0mbk8z2","global.alternating-page-section",{"id":208,"title":209,"subTitle":18,"content":210,"callToActionText":18,"callToActionLink":18,"colorStyle":18,"showAsides":18,"imageUrl":211,"__component":206},37,"Combineren met Azure","Wil je profiteren van Azure-services voor jouw project? Ons team van experts kan je helpen met het selecteren en opzetten van de juiste services. Of je gebruik wil maken van App services, Function Apps, storage of database oplossingen of bijvoorbeeld een Service Bus, onze experts kunnen je helpen bij het kiezen en het realiseren van stabiele, schaalbare en veilige oplossingen die voldoen aan jouw specifieke behoeften.",{"id":212,"name":213,"alternativeText":18,"caption":18,"width":19,"height":173,"formats":214,"hash":235,"ext":23,"mime":178,"size":236,"url":237,"previewUrl":18,"provider":53,"provider_metadata":18,"createdAt":238,"updatedAt":238,"documentId":239,"publishedAt":56,"focalPoint":18},791,"service bus.jpg",{"large":215,"small":220,"medium":225,"thumbnail":230},{"ext":23,"url":216,"hash":217,"mime":178,"name":218,"path":18,"size":219,"width":29,"height":181},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_service_bus_2b48e3a7cc.jpg","large_service_bus_2b48e3a7cc","large_service bus.jpg",82.82,{"ext":23,"url"