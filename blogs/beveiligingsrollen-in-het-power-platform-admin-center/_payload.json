s://incredible-beef-2a6059b946.media.strapiapp.com/small_power_platform_39c53ca01e.jpg","small_power_platform_39c53ca01e","small_power platform.jpg",66.01,{"ext":23,"url":270,"hash":271,"mime":228,"name":272,"path":18,"size":273,"width":42,"height":243},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_power_platform_39c53ca01e.jpg","medium_power_platform_39c53ca01e","medium_power platform.jpg",131.84,{"ext":23,"url":275,"hash":276,"mime":228,"name":277,"path":18,"size":278,"width":105,"height":213},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_power_platform_39c53ca01e.jpg","thumbnail_power_platform_39c53ca01e","thumbnail_power platform.jpg",17.35,"power_platform_39c53ca01e",304.58,"https://incredible-beef-2a6059b946.media.strapiapp.com/power_platform_39c53ca01e.jpg","2024-08-01T11:43:50.458Z","2024-08-01T11:43:59.138Z","gic37kkycc1gz3zx65l4himw",{"__component":114,"id":131,"title":132,"subTitle":18,"content":133,"callToActionText":134,"callToActionLink":108,"colorStyle":125,"showAsides":120,"imageUrl":286},{"id":287,"name":288,"alternativeText":18,"caption":18,"width":19,"height":223,"formats":289,"hash":310,"ext":23,"mime":228,"size":311,"url":312,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":313,"updatedAt":313,"documentId":314,"publishedAt":57},763,"security check.jpg",{"large":290,"small":295,"medium":300,"thumbnail":305},{"ext":23,"url":291,"hash":292,"mime":228,"name":293,"path":18,"size":294,"width":29,"height":231},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_security_check_94d0553bc3.jpg","large_security_check_94d0553bc3","large_security check.jpg",137.47,{"ext":23,"url":296,"hash":297,"mime":228,"name":298,"path":18,"size":299,"width":20,"height":237},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_security_check_94d0553bc3.jpg","small_security_check_94d0553bc3","small_security check.jpg",29.41,{"ext":23,"url":301,"hash":302,"mime":228,"name":303,"path":18,"size":304,"width":42,"height":243},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_security_check_94d0553bc3.jpg","medium_security_check_94d0553bc3","medium_security check.jpg",73.22,{"ext":23,"url":306,"hash":307,"mime":228,"name":308,"path":18,"size":309,"width":105,"height":213},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_security_check_94d0553bc3.jpg","thumbnail_security_check_94d0553bc3","thumbnail_security check.jpg",6.55,"security_check_94d0553bc3",226.1,"https://incredible-beef-2a6059b946.media.strapiapp.com/security_check_94d0553bc3.jpg","2024-08-01T11:41:12.246Z","dqqmxds1uyfy5mz84go1knv5",{"__component":136,"id":137,"title":138,"callToActionText":139,"callToActionLinkUrl":140,"body":18,"imageUrl":316},{"id":160,"name":161,"alternativeText":18,"caption":18,"width":162,"height":163,"formats":18,"hash":164,"ext":165,"mime":166,"size":167,"url":168,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":169,"updatedAt":170,"documentId":171,"publishedAt":57},{"id":142,"metaTitle":143,"metaDescription":144,"structuredData":318,"metaImage":18,"metaSocial":321},{"url":146,"@type":147,"@context":148,"provider":319,"areaServed":320,"description":156,"serviceType":157},{"url":150,"name":151,"@type":152},{"name":154,"@type":155},[],{"id":323,"name":324,"jobTitle":325,"about":18,"createdAt":326,"updatedAt":327,"publishedAt":328,"documentId":329,"image":330,"contactOptions":347},35,"Joost","Consultant","2023-08-18T08:37:46.155Z","2024-03-08T12:46:28.737Z","2023-08-18T08:37:45.395Z","njwfi2eesf691vtpewkga0s1",{"id":331,"name":332,"alternativeText":18,"caption":18,"width":333,"height":334,"formats":335,"hash":342,"ext":77,"mime":80,"size":343,"url":344,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":345,"updatedAt":345,"documentId":346,"publishedAt":57},578,"Joost websitefoto.png",278,326,{"thumbnail":336},{"ext":77,"url":337,"hash":338,"mime":80,"name":339,"path":18,"size":340,"width":341,"height":213},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Joost_websitefoto_af5f8633d8.png","thumbnail_Joost_websitefoto_af5f8633d8","thumbnail_Joost websitefoto.png",18.83,133,"Joost_websitefoto_af5f8633d8",23.92,"https://incredible-beef-2a6059b946.media.strapiapp.com/Joost_websitefoto_af5f8633d8.png","2024-03-08T12:44:24.321Z","ja3uxwy59jyctja6btxtsrja",[],[349,354,357,360,363,366,369,372,375,378,381,384,435],{"__component":350,"id":351,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":353,"introductionText":18},"global.pagesection",208,"","Wanneer je, als maker, een App of Flow ontwikkelt, zie je niet direct wat er op de achtergrond ingeregeld wordt om jouw creatie binnen de gestelde kaders van het bedrijf veilig te kunnen inzetten.\n\nDeze instellingen worden vaak door een beheerder aangescherpt binnen het Power Platform beheercenter. Een van deze instellingen die beheerders kunnen inzetten zijn beveiligingsrollen (security roles). Met deze beveiligingsrollen geef je gebruikers de juiste rechten op de verschillende omgevingen. Deze manier van rechten geven gaat veranderen.",{"__component":350,"id":355,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":356,"introductionText":18},206,"## De nieuwe indeling\n\nLaten we eens kijken naar de nieuwe functionele indeling voor beveiligingsrollen in het Power Platform-beheercentrum. Om toegang te krijgen tot de beveiligingsrollen, openen we eerst het Power Platform beheercentrum (admin center), daarna selecteer je de omgeving waarop je dit wilt toepassen. Vervolgens open je de instellingen en selecteer je de beveiligingsrollen.",{"__component":350,"id":358,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":359,"introductionText":18},210,"![](https://www.sharevalue.nl/images/sharevalue/blogs/beveiligingsrollen_1.png)\n\nZodra je op de beveiligingsrollen klikt, word je naar de lijst met beveiligingsrollen genavigeerd. Hier is de eerste wijziging al meteen zichtbaar.\n\nEen schakelaar boven in je scherm die standaard is ingeschakeld. Deze laat alleen de bovenliggende beveiligingsrollen (rootniveau) zien.",{"__component":350,"id":361,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":362,"introductionText":18},207,"Wanneer je op de drie stippen (...) naast een bepaalde beveiligingsrol klikt, krijg je de mogelijkheid om een rol te bewerken. Wanneer we op de knop bewerken klikken, zien we een nieuw scherm met de beveiligingsroleditor. \n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/beveiligingsrollen_2.png)",{"__component":350,"id":364,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":365,"introductionText":18},209,"Bovenaan het scherm hebben we de optie van de privilege-erfenis voor de leden van groep. \n\n(1) Hier selecteer je het toegangsniveau voor directe gebruikers en teamniveau of alleen teamniveau. Rechtsonder zie je drie tabbladen voor de soorten rechten die je wil wijzigen zoals: tabellen, diversen of privacy gerelateerd.\n\nOnderaan dit tabblad is er een vervolgkeuzelijst met 3 opties waarmee je: alleen toegewezen tabellen / bevoegdheden of alle toegewezen tabellen / bevoegdheden of niet-toegewezen tabellen / bevoegdheden kan weergeven. \n\n(2) Met deze keuzelijst hoef je niet meer naar een bepaalde rol te zoeken als je de rechten wilt wijzigen. Je kan ervoor kiezen om alleen de rechten te laten zien die in gebruik zijn. Of als het nodig is om nieuwe rechten in te stellen, selecteer je het niet-toegewezen overzicht.",{"__component":350,"id":367,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":368,"introductionText":18},213,"![](https://www.sharevalue.nl/images/sharevalue/blogs/beveiligingsrollen_3.png)\n\nZodra je het type bevoegdheden hebt geselecteerd dat je wil wijzigen: Tabellen, Diversen of Privacy, zie je meteen de lijst met bevoegdheden en kan je een rij selecteren om de bevoegdheden te wijzigen. \n\nElke rij toont een vervolgkeuzelijst waarin je de bevoegdheid naar keuze kunt wijzigen.",{"__component":350,"id":370,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":371,"introductionText":18},211,"![](https://www.sharevalue.nl/images/sharevalue/blogs/beveiligingsrollen_4.png)\n\nJe kan hetzelfde doen voor diverse en privacy privileges. Je zult merken dat privacy privileges bovenaan een banner heeft die aangeeft dat elk van deze privileges het mogelijk maakt om de gegevens buiten de dataverse-omgeving te verwijderen, zoals exporteren naar Excel, synchroniseren met Outlook of afdruk samenvoegen.",{"__component":350,"id":373,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":374,"introductionText":18},212,"![](https://www.sharevalue.nl/images/sharevalue/blogs/beveiligingsrollen_5.png)\n\nMet behulp van de oude portal hadden we de mogelijkheid om de bevoegdheden voor de hele rij te wijzigen. Die functionaliteit is veranderd in de nieuwe interface. Wanneer je een rij selecteert, en klikt op de opties Meer (...), selecteer dan machtigingsinstellingen. Nu kan je de machtigingen vanuit een vooraf gedefinieerde lijst kiezen zoals: Geen toegang, Volledige toegang, Samenwerken, Privé, Referentie of Aangepast.",{"__component":350,"id":376,"title":18,"asideText":352,"underline":120,"centered":120,"blankAside":120,"aside":18,"content":377,"introductionText":18},214,"## Conclusie\n\nMet de komst van dit nieuwe uiterlijk en manier van beveiligingenrollen toekennen, geef je de Power Platform beheerders de mogelijkheid om efficiëntie en makkelijker beveiligingsrollen in te stellen voor de hele organisatie of alleen op persoons niveau. Kortom; een wijziging die erg welkom is en een positieve impact gaat geven in het beheer van Het Power Platform.\n\nWil je meer weten over deze functionaliteit of over het Power Platform in het algemeen? [Neem dan gerust contact op met ons](/contact) zodat we de mogelijkheden kunnen bespreken.",{"__component":379,"id":380,"title":18,"showBlankAside":68},"global.social-sharing",46,{"__component":382,"id":383,"name":18,"jobTitle":18},"strapi.author-card",4,{"__component":91,"id":385,"title":386,"aside":18,"postType":94,"limit":95,"expertise":387},15,"Lees ook onze andere berichten",[388],{"id":6,"title":60,"subTitle":61,"description":62,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":66,"publishedAt":67,"isCoreExpertise":68,"documentId":69,"image":389,"blocks":392,"midPageBlocks":399,"seo":430},{"id":71,"name":72,"alternativeText":18,"caption":18,"width":73,"height":74,"formats":390,"hash":84,"ext":77,"mime":80,"size":85,"url":86,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":87,"updatedAt":87,"documentId":88,"publishedAt":57},{"thumbnail":391},{"ext":77,"url":78,"hash":79,"mime":80,"name":81,"path":18,"size":82,"width":49,"height":83},[393,396],{"__component":91,"id":92,"title":93,"aside":18,"postType":94,"limit":95,"expertise":394},[395],{"id":6,"title":60,"subTitle":61,"description":62,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":66,"publishedAt":67,"isCoreExpertise":68,"documentId":69},{"__component":104,"id":105,"titleLeft":106,"callToActionTextLeft":107,"callToActionLinkUrlLeft":108,"titleRight":109,"callToActionTextRight":110,"callToActionLinkUrlRight":111,"iconUrlLeft":397,"iconUrlRight":398},{"id":160,"name":161,"alternativeText":18,"caption":18,"width":162,"height":163,"formats":18,"hash":164,"ext":165,"mime":166,"size":167,"url":168,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":169,"updatedAt":170,"documentId":171,"publishedAt":57},{"id":173,"name":174,"alternativeText":18,"caption":18,"width":163,"height":163,"formats":18,"hash":175,"ext":165,"mime":166,"size":176,"url":177,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":178,"updatedAt":1