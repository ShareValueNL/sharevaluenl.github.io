:144,"structuredData":431,"metaImage":18,"metaSocial":434},{"url":146,"@type":147,"@context":148,"provider":432,"areaServed":433,"description":156,"serviceType":157},{"url":150,"name":151,"@type":152},{"name":154,"@type":155},[],{"__component":104,"id":436,"titleLeft":106,"callToActionTextLeft":437,"callToActionLinkUrlLeft":438,"titleRight":439,"callToActionTextRight":440,"callToActionLinkUrlRight":441,"iconUrlLeft":442,"iconUrlRight":443},73,"Neem contact met ons op","https://www.sharevalue.nl/contact","Hoor van onze experts hoe leuk ShareValue is","Lees de verhalen van onze collega's","https://www.sharevalue.nl/word-onze-collega/collegas-aan-het-woord",{"id":160,"name":161,"alternativeText":18,"caption":18,"width":162,"height":163,"formats":18,"hash":164,"ext":165,"mime":166,"size":167,"url":168,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":169,"updatedAt":170,"documentId":171,"publishedAt":57},{"id":6,"name":444,"alternativeText":18,"caption":18,"width":445,"height":446,"formats":18,"hash":447,"ext":165,"mime":166,"size":448,"url":449,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":450,"updatedAt":451,"documentId":452,"publishedAt":57},"people.svg",83,60,"people_6bb632d0d7",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":454,"metaTitle":455,"metaDescription":456,"structuredData":457,"metaImage":18,"metaSocial":486},101,"Beveiligingsrollen in Power Platform beheren | ShareValue","Leer hoe je beveiligingsrollen instelt in het Power Platform admin center – slim en overzichtelijk toegangsbeheer geregeld.",[458,469],{"url":459,"@type":460,"author":461,"@context":148,"headline":455,"publisher":464,"description":456,"datePublished":468},"https://www.sharevalue.nl/blogs/beveiligingsrollen-in-het-power-platform-admin-center","BlogPosting",{"name":324,"@type":462,"jobTitle":325,"worksFor":463},"Person",{"name":151,"@type":152},{"logo":465,"name":151,"@type":152},{"url":466,"@type":467},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","2024-02-29",{"@type":470,"@context":148,"mainEntity":471},"FAQPage",[472,478,482],{"name":473,"@type":474,"acceptedAnswer":475},"Wat kun je met beveiligingsrollen in het Power Platform?","Question",{"text":476,"@type":477},"Met beveiligingsrollen beheer je wie toegang heeft tot welke functionaliteiten binnen Power Platform-omgevingen.","Answer",{"name":479,"@type":474,"acceptedAnswer":480},"Waar stel je beveiligingsrollen in voor Power Platform?",{"text":481,"@type":477},"Je stelt beveiligingsrollen in via het Power Platform admin center op de beheerpagina van de betreffende omgeving.",{"name":483,"@type":474,"acceptedAnswer":484},"Welke tip geeft Joost voor het werken met beveiligingsrollen?",{"text":485,"@type":477},"Geef alleen toegang tot wat iemand nodig heeft voor zijn rol – niet meer, niet minder.",[],{"pagination":488},{"page":489,"pageSize":490},1,100,{},1779452314358]