[{"data":1,"prerenderedAt":492},["ShallowReactive",2],{"collection-blogs--851161746":3,"_apollo:default":491},{"data":4,"meta":487},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":58,"author":322,"blocks":348,"seo":453},7,"Beveiligingsrollen in het Power Platform Admin Center","Dat je beveiligingsrollen kunt gebruiken is niet nieuw, de manier hoe je deze inzet gaat wel veranderen. Deze maand zal je enkele wijzigingen tegenkomen in de manier waarop beveiligingsrollen worden geopend vanuit het Power Platform beheercentrum.\n\n","beveiligingsrollen-in-het-power-platform-admin-center","2023-10-13T10:26:22.830Z","2025-04-15T11:32:59.826Z","2023-10-13T10:26:22.672Z","2023-06-29","hdvltvzohd3p7tuaanrdyxwr",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":51,"ext":23,"mime":26,"size":52,"url":53,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":55,"updatedAt":55,"documentId":56,"publishedAt":57},256,"beveiligingsrollen-in-het-power-platform-admin-center.jpg",null,1280,500,{"large":22,"small":31,"medium":37,"thumbnail":44},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534.jpg","large_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534","image/jpg","large_beveiligingsrollen-in-het-power-platform-admin-center.jpg",108.07,1000,391,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":20,"height":36},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534.jpg","small_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534","small_beveiligingsrollen-in-het-power-platform-admin-center.jpg",34.7,195,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534.jpg","medium_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534","medium_beveiligingsrollen-in-het-power-platform-admin-center.jpg",69.6,750,293,{"ext":23,"url":45,"hash":46,"mime":26,"name":47,"path":18,"size":48,"width":49,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534.jpg","thumbnail_beveiligingsrollen_in_het_power_platform_admin_center_907aca6534","thumbnail_beveiligingsrollen-in-het-power-platform-admin-center.jpg",8.05,245,96,"beveiligingsrollen_in_het_power_platform_admin_center_907aca6534",155.67,"https://incredible-beef-2a6059b946.media.strapiapp.com/beveiligingsrollen_in_het_power_platform_admin_center_907aca6534.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:21:12.038Z","mhqoois738emlrcfyra1ilnn","2026-01-05T12:38:34.018Z",[59],{"id":6,"title":60,"subTitle":61,"description":62,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":66,"publishedAt":67,"isCoreExpertise":68,"documentId":69,"image":70,"blocks":89,"midPageBlocks":181,"seo":317},"Power Platform","Optimaliseer je bedrijfsprocessen met Microsoft Power Platform","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.\n\nBij ShareValue leveren we oplossingen die precies aansluiten op de behoeften van jouw organisatie. Of het nu gaat om het opzetten van een uitgebreide governance- en omgevingsstrategie, het ontwikkelen van een app met bijbehorende automatiseringen of het bevorderen van gebruikersadoptie; wij hebben de juiste expertise in huis.\n\nOnze Power Platform-specialisten, bestaande uit ervaren consultants en developers, hebben een bewezen staat van dienst in diverse sectoren. Zij delen continu hun kennis en passen deze toe op de unieke vraagstukken van onze klanten, waardoor we steeds de meest effectieve en innovatieve oplossingen kunnen bieden.\n","Het Microsoft Power Platform biedt een uitgebreide suite van tools voor het automatiseren en optimaliseren van bedrijfsprocessen, het analyseren van gegevens en ontwikkelen van op maat gemaakte applicaties.","power-platform","2023-10-12T11:27:43.792Z","2025-04-11T13:13:15.099Z","2023-10-12T11:27:43.781Z",true,"prbaerw7gypadu8gfdyg53sy",{"id":71,"name":72,"alternativeText":18,"caption":18,"width":73,"height":74,"formats":75,"hash":84,"ext":77,"mime":80,"size":85,"url":86,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":87,"updatedAt":87,"documentId":88,"publishedAt":57},927,"Logo PowerPlatform 2025 web png.png",282,130,{"thumbnail":76},{"ext":77,"url":78,"hash":79,"mime":80,"name":81,"path":18,"size":82,"width":49,"height":83},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Logo_Power_Platform_2025_web_png_4268556f17.png","thumbnail_Logo_Power_Platform_2025_web_png_4268556f17","image/png","thumbnail_Logo PowerPlatform 2025 web png.png",8.26,113,"Logo_Power_Platform_2025_web_png_4268556f17",2,"https://incredible-beef-2a6059b946.media.strapiapp.com/Logo_Power_Platform_2025_web_png_4268556f17.png","2024-12-16T11:07:06.507Z","a12tjlb3ssr20rrzj9rulb58",[90,158],{"__component":91,"id":92,"title":93,"aside":18,"postType":94,"limit":95,"expertise":96},"strapi.related-kennisbank-list",164,"Lees meer over het Power Platform","alle",3,[97],{"id":6,"title":60,"subTitle":61,"description":62,"shortDescription":63,"slug":64,"createdAt":65,"updatedAt":66,"publishedAt":67,"isCoreExpertise":68,"documentId":69,"image":98,"blocks":101,"midPageBlocks":112,"seo":141},{"id":71,"name":72,"alternativeText":18,"caption":18,"width":73,"height":74,"formats":99,"hash":84,"ext":77,"mime":80,"size":85,"url":86,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":87,"updatedAt":87,"documentId":88,"publishedAt":57},{"thumbnail":100},{"ext":77,"url":78,"hash":79,"mime":80,"name":81,"path":18,"size":82,"width":49,"height":83},[102,103],{"__component":91,"id":92,"title":93,"aside":18,"postType":94,"limit":95},{"__component":104,"id":105,"titleLeft":106,"callToActionTextLeft":107,"callToActionLinkUrlLeft":108,"titleRight":109,"callToActionTextRight":110,"callToActionLinkUrlRight":111},"call-to-action.double",235,"Heb je een Power Platform expert nodig?","Neem contact op voor de mogelijkheden","/contact","Zoek je een nieuwe uitdaging?","Bekijk onze vacatures","/word-onze-collega/vacatures",[113,121,126,130,135],{"__component":114,"id":115,"title":116,"subTitle":18,"content":117,"callToActionText":118,"callToActionLink":108,"colorStyle":119,"showAsides":120},"global.alternating-page-section",16,"Power Platform governance: de balans tussen beveiliging en innovatie","Het is belangrijk om een balans te vinden tussen beveiliging en innovatie binnen jouw organisatie. Hoewel governance noodzakelijk is, moeten je medewerkers en teams de ruimte krijgen om waarde te creëren voor zowel henzelf als de onderneming.\n\nOnze Power Platform-specialisten staan klaar om je te adviseren over de diverse mogelijkheden. We begeleiden je tijdens het ontwikkelen en implementeren van een effectieve governance- en omgevingsstrategie, zodat je het beste uit het Microsoft Power Platform kunt halen.","Wil je meer weten? Neem contact met ons op.","Sugar Glaze",false,{"__component":114,"id":122,"title":123,"subTitle":18,"content":124,"callToActionText":18,"callToActionLink":18,"colorStyle":125,"showAsides":120},17,"Snel maatwerktoepassingen creëren met het Power Platform","Het Power Platform is de ideale oplossing om je verouderde processen en applicaties te stroomlijnen met slimme apps, efficiënte werkstromen en geavanceerde, op maat gemaakte formulieren.\n\nOnze specialisten staan klaar om je te adviseren over de vele mogelijkheden. Heb je meer ondersteuning nodig bij het ontwikkelen van je toepassing? Onze ervaren developers ontwikkelen de toepassing volledig voor je.","White",{"__component":114,"id":127,"title":128,"subTitle":18,"content":129,"callToActionText":18,"callToActionLink":18,"colorStyle":119,"showAsides":120},18,"Power Platform staat aan, wat nu?","Het Power Platform wordt al gebruikt in jouw organisatie. Een aantal enthousiaste collega's hebben al mooie apps gemaakt en je staat op het punt om het Power Platform in te zetten voor bedrijfskritische processen. Maar je weet niet precies hoe je dit het beste kunt aanpakken.\n\nWij begeleiden je in dit proces en samen bepalen we de \"next steps\". Onze architecten voeren een volledige omgevings- en securitycheck uit, wat resulteert in een omgevingsstrategie, governance, en een ontwikkel- en adoptieplan.",{"__component":114,"id":131,"title":132,"subTitle":18,"content":133,"callToActionText":134,"callToActionLink":108,"colorStyle":125,"showAsides":120},19,"Is jouw omgeving veilig en secure?","Onze omgevings- en securitycheck geeft je een helder beeld van de huidige status van je omgeving en laat zien wat je nog kunt doen om toepassingen nog veiliger en consistenter te ontwikkelen.","Wil je de check laten doen?",{"__component":136,"id":137,"title":138,"callToActionText":139,"callToActionLinkUrl":140,"body":18},"call-to-action.single",99,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Stork","/klantcases/stork-focust-op-citizen-development-met-het-microsoft-power-platform",{"id":142,"metaTitle":143,"metaDescription":144,"structuredData":145},26,"Power Platform specialisten – ShareValue helpt vooruit","Haal meer uit Power Apps, Automate en Power BI. Wij helpen bij strategie, ontwikkeling en beheer van jouw Power Platform-omgeving.",{"url":146,"@type":147,"@context":148,"provider":149,"areaServed":153,"description":156,"serviceType":157},"https://www.sharevalue.nl/wat-we-doen/power-platform","Service","https://schema.org",{"url":150,"name":151,"@type":152},"https://www.sharevalue.nl","ShareValue","Organization",{"name":154,"@type":155},"Nederland","Country","ShareValue helpt organisaties om Power Platform optimaal in te zetten. Denk aan Power Apps, Power Automate en Power BI. We bieden begeleiding bij strategie, governance, ontwikkeling en beheer.","Power Platform consultancy",{"__component":104,"id":105,"titleLeft":106,"callToActionTextLeft":107,"callToActionLinkUrlLeft":108,"titleRight":109,"callToActionTextRight":110,"callToActionLinkUrlRight":111,"iconUrlLeft":159,"iconUrlRight":172},{"id":160,"name":161,"alternativeText":18,"caption":18,"width":162,"height":163,"formats":18,"hash":164,"ext":165,"mime":166,"size":167,"url":168,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":169,"updatedAt":170,"documentId":171,"publishedAt":57},6,"bulb.svg",71,70,"bulb_dd2e1d4efb",".svg","image/svg+xml",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":173,"name":174,"alternativeText":18,"caption":18,"width":163,"height":163,"formats":18,"hash":175,"ext":165,"mime":166,"size":176,"url":177,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":178,"updatedAt":179,"documentId":180,"publishedAt":57},8,"briefcase.svg","briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",[182,219,254,285,315],{"__component":114,"id":115,"title":116,"subTitle":18,"content":117,"callToActionText":118,"callToActionLink":108,"colorStyle":119,"showAsides":120,"imageUrl":183},{"id":184,"name":185,"alternativeText":18,"caption":18,"width":186,"height":187,"formats":188,"hash":214,"ext":77,"mime":80,"size":215,"url":216,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":217,"updatedAt":217,"documentId":218,"p