onLink":153,"colorStyle":186,"showAsides":187,"imageUrl":334,"__component":223},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":335,"name":336,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":337,"hash":358,"ext":23,"mime":26,"size":359,"url":360,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":361,"updatedAt":361,"documentId":362,"publishedAt":61,"focalPoint":18},786,"migratie.jpg",{"large":338,"small":343,"medium":348,"thumbnail":353},{"ext":23,"url":339,"hash":340,"mime":26,"name":341,"path":18,"size":342,"width":29,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":344,"hash":345,"mime":26,"name":346,"path":18,"size":347,"width":20,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":349,"hash":350,"mime":26,"name":351,"path":18,"size":352,"width":44,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":354,"hash":355,"mime":26,"name":356,"path":18,"size":357,"width":216,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":364,"title":365,"subTitle":366,"content":367,"callToActionText":18,"callToActionLink":18,"colorStyle":230,"showAsides":187,"imageUrl":368,"__component":223},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":369,"name":370,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":371,"hash":392,"ext":23,"mime":26,"size":393,"url":394,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":395,"updatedAt":395,"documentId":396,"publishedAt":61,"focalPoint":18},787,"microsoft security.jpg",{"large":372,"small":377,"medium":382,"thumbnail":387},{"ext":23,"url":373,"hash":374,"mime":26,"name":375,"path":18,"size":376,"width":29,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":378,"hash":379,"mime":26,"name":380,"path":18,"size":381,"width":20,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":383,"hash":384,"mime":26,"name":385,"path":18,"size":386,"width":44,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":388,"hash":389,"mime":26,"name":390,"path":18,"size":391,"width":216,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":398,"title":399,"subTitle":400,"content":401,"callToActionText":402,"callToActionLink":403,"colorStyle":186,"showAsides":187,"imageUrl":404,"__component":223},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":405,"name":406,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":407,"hash":428,"ext":23,"mime":26,"size":429,"url":430,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":431,"updatedAt":431,"documentId":432,"publishedAt":61,"focalPoint":18},788,"vergaderruimte.jpg",{"large":408,"small":413,"medium":418,"thumbnail":423},{"ext":23,"url":409,"hash":410,"mime":26,"name":411,"path":18,"size":412,"width":29,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":414,"hash":415,"mime":26,"name":416,"path":18,"size":417,"width":20,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":419,"hash":420,"mime":26,"name":421,"path":18,"size":422,"width":44,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":424,"hash":425,"mime":26,"name":426,"path":18,"size":427,"width":216,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":434,"title":435,"subTitle":436,"content":437,"callToActionText":18,"callToActionLink":18,"colorStyle":230,"showAsides":187,"imageUrl":438,"__component":223},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":439,"name":440,"alternativeText":18,"caption":18,"width":19,"height":191,"formats":441,"hash":462,"ext":23,"mime":26,"size":463,"url":464,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":465,"updatedAt":465,"documentId":466,"publishedAt":61,"focalPoint":18},789,"teamwork.jpg",{"large":442,"small":447,"medium":452,"thumbnail":457},{"ext":23,"url":443,"hash":444,"mime":26,"name":445,"path":18,"size":446,"width":29,"height":198},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":448,"hash":449,"mime":26,"name":450,"path":18,"size":451,"width":20,"height":204},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":453,"hash":454,"mime":26,"name":455,"path":18,"size":456,"width":44,"height":210},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":458,"hash":459,"mime":26,"name":460,"path":18,"size":461,"width":216,"height":217},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":468,"title":469,"callToActionText":470,"callToActionLinkUrl":471,"body":18,"imageUrl":472,"__component":473},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":61,"focalPoint":18},"call-to-action.single",[475,479,482,485,488,491,494,497,500,504,522],{"id":476,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":477,"introductionText":18,"__component":478},2209,"## Wat is Microsoft Lists?\n\nMicrosoft Lists is een tool binnen Microsoft 365 waarmee je eenvoudig lijsten maakt, beheert en deelt. Je gebruikt het voor uiteenlopende toepassingen: van het bijhouden van taken en klantverzoeken tot het uitvoeren van risicoanalyses of het plannen van content. Dankzij de overzichtelijke en gebruiksvriendelijke interface integreer je Lists moeiteloos in je dagelijkse werkprocessen. Dat maakt het een praktische en toegankelijke oplossing voor iedereen die meer grip wil op informatie en processen.\n\n![MS Lists afb 1.jpg](https://incredible-beef-2a6059b946.media.strapiapp.com/MS_Lists_afb_1_cf9cf36c42.jpg)","global.pagesection",{"id":480,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":481,"introductionText":18,"__component":478},2210,"## Wat zijn de voordelen van Microsoft Lists?\n\nMicrosoft Lists biedt veel handige functies die je direct kunt gebruiken om informatie gestructureerd te beheren. Je kunt snel aan de slag met een bestaand sjabloon, of je bouwt een eigen lijst helemaal op maat. De tool is flexibel in gebruik en sluit goed aan op verschillende werkprocessen.\n\nEen aantal voordelen op een rij:\n- Flexibele kolommen: voeg verschillende gegevenstypen toe, zoals tekstvelden, keuzelijsten, datums, personen of afbeeldingen.\n- Overzichtelijke weergaven: sorteer, groepeer en filter informatie zoals jij dat prettig vindt.\n- Automatisering via Power Automate: stel meldingen of goedkeuringsflows in, zodat processen automatisch verlopen.\n- Realtime samenwerking: deel lijsten met collega’s en werk er tegelijkertijd in, direct vanuit de browser of Teams.\n- Toegang via de app: gebruik de Microsoft Lists-app om ook onderweg je lijsten te bekijken en bij te werken.\n\nDeze combinatie van eenvoud, flexibiliteit en integratie maakt Lists een krachtig hulpmiddel voor teams die efficiënter willen werken.\n",{"id":483,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":484,"introductionText":18,"__component":478},2211,"## Hoe past Lists in Microsoft 365?\n\nMicrosoft Lists werkt naadloos samen met andere tools binnen Microsoft 365:\n- Teams: Voeg een lijst toe als tabblad in een kanaal, voor directe toegang en samenwerking.\n- Outlook: Synchroniseer taken en ontvang meldingen om niets te missen.\n- Planner: Koppel taken direct aan lijstitems voor overzichtelijk projectmanagement.\n- Power Automate: Automatiseer goedkeuringen, notificaties en workflows voor efficiënte processen.\n- Power BI: Visualiseer en analyseer lijstgegevens via dashboards.\n\nZo vormt Lists een flexibel onderdeel van je digitale werkplek.\n",{"id":486,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":487,"introductionText":18,"__component":478},2212,"## Voorbeelden uit de praktijk\n\nEen aantal voorbeelden hoe je Microsoft Lists in het dagelijks werk slim kunt inzetten:\n\n**Contractbeheer**: Houd eenvoudig bij welke contracten lopen, wie de leverancier is, wanneer het afloopt en wie verantwoordelijk is. Gebruik Power Automate voor herinneringen.\n\n**Contentplanning**: Ideaal voor communicatie- of marketingteams. Plan publicaties per kanaal en houd overzicht over status, verantwoordelijken en deadlines.\n\n**Incidentregistratie**: Log meldingen met locatie, ernst, melder en opvolging. Kleurcodering en filters maken het overzichtelijk.\n\n**Onboarding checklists**: Zorg dat nieuwe collega’s niets missen. Maak een lijst met taken, wijs verantwoordelijken aan en houd voortgang bij.\n\n**Verjaardagenlijst op intranet**: Koppel Lists aan een SharePoint-pagina en laat automatisch verjaardagen van collega’s zien, inclusief foto en team. Goed voor de teamspirit!",{"id":489,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":490,"introductionText":18,"__component":478},2213,"## Aan de slag met Microsoft Lists\n\nWil je zelf ervaren hoe eenvoudig Microsoft Lists werkt? Met deze tips kom je snel op gang:\n- Begin klein: Start met een eenvoudige lijst en breid stap voor stap uit.\n- Maak gebruik van sjablonen: Microsoft biedt handige standaardmodellen, bijvoorbeeld voor issue tracking en asset management.\n- Betrek je collega’s: Vraag input van eindgebruikers bij het bepalen van kolommen en weergaven. Zo sluit de lijst beter aan op hun werk.\n- Integreer in bestaande processen: Zorg dat Lists onderdeel wordt van je huidige werkstromen, zodat het direct waarde toevoegt.\n\n![MS Lists afb 2.jpg](https://incredible-beef-2a6059b946.media.strapiapp.com/MS_Lists_afb_2_bb24187f52.jpg)",{"id":492,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":493,"introductionText":18,"__component":478},2214,"## Hoe ShareValue jou kan helpen\n\nBij ShareValue begrijpen we hoe complex het kan zijn om nieuwe tools te implementeren en te integreren binnen jouw organisatie. Onze experts ondersteunen je graag bij:\n- Het inrichten van Microsoft Lists op basis van jouw specifieke behoeften.\n- De integratie van Microsoft Lists met het Microsoft 365-ecosysteem.\n- Het bevorderen van adoptie door middel van trainingen en begeleiding.",{"id":495,"title":18,"asideText":18,"underline":187,"centered":187,"blankAside":187,"aside":18,"content":496,"introductionText":18,"__component":478},2215,"## Conclusie\n\nMicrosoft Lists biedt geavanceerde functionaliteit en gebruiksvriendelijkheid die verder gaat dan traditionele spreadsheets. Het stelt jou en je organisatie in staat om werkzaamheden beter te structureren en processen te optimaliseren. Met Lists beschik je over een flexibel platform dat volledig geïntegreerd is met het Microsoft 365-ecosysteem, waardoor je efficiëntie en samenwerking duurzaam kunt verbeteren.\n\nWil je ontdekken hoe Lists jouw werk slimmer maakt? Neem [contact](https://sharevalue.nl/#/contact) met ons op, we denken graag met je mee.\n",{"id":498,"title":18,"showBlankAside":187,"__component":499},241,"global.social-sharing",{"id":501,"name":71,"jobTitle":502,"__component":503},180,"Consultant","strapi.author-card",{"id":505,"titleLeft":506,"callToActionTextLeft":152,"callToActionLinkUrlLeft":153,"titleRight":507,"callToActionTextRight":508,"callToActionLinkUrlRight":509,"iconUrlLeft":510,"iconUrlRight":521,"__component":179},292,"Heb je een Microsoft 365-expert nodig?","Werken in ons Microsoft 365-team?","Bekijk onze Microsoft 365-vacatures","/word-onze-collega/microsoft-365/vacatures",{"id":511,"name":512,"alternativeText":18,"caption":18,"width":513,"height":514,"formats":18,"hash":515,"ext":163,"mime":164,"size":516,"url":517,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":518,"updatedAt":519,"documentId":520,"publishedAt":61,"focalPoint":18},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",{"id":158,"name":159,"alternativeText":18,"caption":18,"width":160,"height":161,"formats":18,"hash":162,"ext":163,"mime":164,"size":165,"url":166,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":167,"updatedAt":168,"documentId":169,"publishedAt":61,"focalPoint":18},{"id":523,"title":143,"aside":18,"postType":524,"limit":145,"expertise":525,"__component":148},202,"blogs",[526],{"id":96,"title":84,"subTitle":97,"description":98,"shortDescription":99,"slug":100,"createdAt":101,"updatedAt":102,"publishedAt":103,"isCoreExpertise":104,"documentId":105,"image":527,"seo":530,"blocks":535,"midPageBlocks":542},{"id":107,"name":108,"alternativeText":18,"caption":18,"width":109,"height":110,"formats":528,"hash":120,"ext":113,"mime":116,"size":121,"url":122,"previewUrl":18,"provider":58,"provider_metadata":18,"createdAt":123,"updatedAt":123,"documentId":124,"publishedAt":61,"focalPoint":18},{"thumbnail":529},{"ext":113,"url":114,"hash":115,"mime":116,"name":117,"path":18,"size":118,"width":52,"height":119},{"id":126,"m