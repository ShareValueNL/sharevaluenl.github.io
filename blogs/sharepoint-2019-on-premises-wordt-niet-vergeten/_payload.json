iapp.com/large_trends_e84a321990.jpg","large_trends_e84a321990","large_trends.jpg",198.92,{"ext":23,"url":244,"hash":245,"mime":165,"name":246,"path":18,"size":247,"width":36,"height":174},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_trends_e84a321990.jpg","small_trends_e84a321990","small_trends.jpg",59.76,{"ext":23,"url":249,"hash":250,"mime":165,"name":251,"path":18,"size":252,"width":43,"height":180},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_trends_e84a321990.jpg","medium_trends_e84a321990","medium_trends.jpg",122.64,{"ext":23,"url":254,"hash":255,"mime":165,"name":256,"path":18,"size":257,"width":186,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_trends_e84a321990.jpg","thumbnail_trends_e84a321990","thumbnail_trends.jpg",14,"trends_e84a321990",298.15,"https://incredible-beef-2a6059b946.media.strapiapp.com/trends_e84a321990.jpg","2024-08-08T09:50:10.558Z","sm5uc5n6zntdts2b84smn9ie",{"id":264,"title":265,"subTitle":266,"content":267,"callToActionText":18,"callToActionLink":18,"colorStyle":199,"showAsides":156,"imageUrl":268,"__component":192},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"id":269,"name":270,"alternativeText":18,"caption":18,"width":20,"height":160,"formats":271,"hash":292,"ext":23,"mime":165,"size":293,"url":294,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":295,"updatedAt":295,"documentId":296,"publishedAt":57,"focalPoint":18},785,"microsoft development.jpg",{"large":272,"small":277,"medium":282,"thumbnail":287},{"ext":23,"url":273,"hash":274,"mime":165,"name":275,"path":18,"size":276,"width":29,"height":168},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_development_0466304f1a.jpg","large_microsoft_development_0466304f1a","large_microsoft development.jpg",212.98,{"ext":23,"url":278,"hash":279,"mime":165,"name":280,"path":18,"size":281,"width":36,"height":174},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_development_0466304f1a.jpg","small_microsoft_development_0466304f1a","small_microsoft development.jpg",82.36,{"ext":23,"url":283,"hash":284,"mime":165,"name":285,"path":18,"size":286,"width":43,"height":180},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_development_0466304f1a.jpg","medium_microsoft_development_0466304f1a","medium_microsoft development.jpg",145.39,{"ext":23,"url":288,"hash":289,"mime":165,"name":290,"path":18,"size":291,"width":186,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_development_0466304f1a.jpg","thumbnail_microsoft_development_0466304f1a","thumbnail_microsoft development.jpg",19.5,"microsoft_development_0466304f1a",303.17,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_development_0466304f1a.jpg","2024-08-08T09:53:15.803Z","ryasrsii36mo66jfb0jpir09",{"id":298,"title":299,"subTitle":300,"content":301,"callToActionText":302,"callToActionLink":122,"colorStyle":155,"showAsides":156,"imageUrl":303,"__component":192},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"id":304,"name":305,"alternativeText":18,"caption":18,"width":20,"height":160,"formats":306,"hash":327,"ext":23,"mime":165,"size":328,"url":329,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":330,"updatedAt":330,"documentId":331,"publishedAt":57,"focalPoint":18},786,"migratie.jpg",{"large":307,"small":312,"medium":317,"thumbnail":322},{"ext":23,"url":308,"hash":309,"mime":165,"name":310,"path":18,"size":311,"width":29,"height":168},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_migratie_9523b90d9c.jpg","large_migratie_9523b90d9c","large_migratie.jpg",65.55,{"ext":23,"url":313,"hash":314,"mime":165,"name":315,"path":18,"size":316,"width":36,"height":174},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_migratie_9523b90d9c.jpg","small_migratie_9523b90d9c","small_migratie.jpg",19.03,{"ext":23,"url":318,"hash":319,"mime":165,"name":320,"path":18,"size":321,"width":43,"height":180},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_migratie_9523b90d9c.jpg","medium_migratie_9523b90d9c","medium_migratie.jpg",38.05,{"ext":23,"url":323,"hash":324,"mime":165,"name":325,"path":18,"size":326,"width":186,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_migratie_9523b90d9c.jpg","thumbnail_migratie_9523b90d9c","thumbnail_migratie.jpg",6.07,"migratie_9523b90d9c",105.79,"https://incredible-beef-2a6059b946.media.strapiapp.com/migratie_9523b90d9c.jpg","2024-08-08T09:57:51.435Z","l4v1r924khiu677twqr154bu",{"id":333,"title":334,"subTitle":335,"content":336,"callToActionText":18,"callToActionLink":18,"colorStyle":199,"showAsides":156,"imageUrl":337,"__component":192},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"id":338,"name":339,"alternativeText":18,"caption":18,"width":20,"height":160,"formats":340,"hash":361,"ext":23,"mime":165,"size":362,"url":363,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":364,"updatedAt":364,"documentId":365,"publishedAt":57,"focalPoint":18},787,"microsoft security.jpg",{"large":341,"small":346,"medium":351,"thumbnail":356},{"ext":23,"url":342,"hash":343,"mime":165,"name":344,"path":18,"size":345,"width":29,"height":168},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_microsoft_security_32a9b008d7.jpg","large_microsoft_security_32a9b008d7","large_microsoft security.jpg",164.98,{"ext":23,"url":347,"hash":348,"mime":165,"name":349,"path":18,"size":350,"width":36,"height":174},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_microsoft_security_32a9b008d7.jpg","small_microsoft_security_32a9b008d7","small_microsoft security.jpg",42.07,{"ext":23,"url":352,"hash":353,"mime":165,"name":354,"path":18,"size":355,"width":43,"height":180},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_microsoft_security_32a9b008d7.jpg","medium_microsoft_security_32a9b008d7","medium_microsoft security.jpg",95.92,{"ext":23,"url":357,"hash":358,"mime":165,"name":359,"path":18,"size":360,"width":186,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_security_32a9b008d7.jpg","thumbnail_microsoft_security_32a9b008d7","thumbnail_microsoft security.jpg",9,"microsoft_security_32a9b008d7",254.11,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_security_32a9b008d7.jpg","2024-08-08T09:59:12.203Z","s7y4pqdrz66q79moz4tdfnpj",{"id":367,"title":368,"subTitle":369,"content":370,"callToActionText":371,"callToActionLink":372,"colorStyle":155,"showAsides":156,"imageUrl":373,"__component":192},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"id":374,"name":375,"alternativeText":18,"caption":18,"width":20,"height":160,"formats":376,"hash":397,"ext":23,"mime":165,"size":398,"url":399,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":400,"updatedAt":400,"documentId":401,"publishedAt":57,"focalPoint":18},788,"vergaderruimte.jpg",{"large":377,"small":382,"medium":387,"thumbnail":392},{"ext":23,"url":378,"hash":379,"mime":165,"name":380,"path":18,"size":381,"width":29,"height":168},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_vergaderruimte_cdd4afc99d.jpg","large_vergaderruimte_cdd4afc99d","large_vergaderruimte.jpg",82.12,{"ext":23,"url":383,"hash":384,"mime":165,"name":385,"path":18,"size":386,"width":36,"height":174},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_vergaderruimte_cdd4afc99d.jpg","small_vergaderruimte_cdd4afc99d","small_vergaderruimte.jpg",29.05,{"ext":23,"url":388,"hash":389,"mime":165,"name":390,"path":18,"size":391,"width":43,"height":180},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vergaderruimte_cdd4afc99d.jpg","medium_vergaderruimte_cdd4afc99d","medium_vergaderruimte.jpg",54.2,{"ext":23,"url":393,"hash":394,"mime":165,"name":395,"path":18,"size":396,"width":186,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vergaderruimte_cdd4afc99d.jpg","thumbnail_vergaderruimte_cdd4afc99d","thumbnail_vergaderruimte.jpg",7.86,"vergaderruimte_cdd4afc99d",116.97,"https://incredible-beef-2a6059b946.media.strapiapp.com/vergaderruimte_cdd4afc99d.jpg","2024-08-08T10:05:15.617Z","nq4ffbr226wju4kall797zm2",{"id":403,"title":404,"subTitle":405,"content":406,"callToActionText":18,"callToActionLink":18,"colorStyle":199,"showAsides":156,"imageUrl":407,"__component":192},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"id":408,"name":409,"alternativeText":18,"caption":18,"width":20,"height":160,"formats":410,"hash":431,"ext":23,"mime":165,"size":432,"url":433,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":434,"updatedAt":434,"documentId":435,"publishedAt":57,"focalPoint":18},789,"teamwork.jpg",{"large":411,"small":416,"medium":421,"thumbnail":426},{"ext":23,"url":412,"hash":413,"mime":165,"name":414,"path":18,"size":415,"width":29,"height":168},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_teamwork_8f4a7b0c14.jpg","large_teamwork_8f4a7b0c14","large_teamwork.jpg",80.4,{"ext":23,"url":417,"hash":418,"mime":165,"name":419,"path":18,"size":420,"width":36,"height":174},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_teamwork_8f4a7b0c14.jpg","small_teamwork_8f4a7b0c14","small_teamwork.jpg",27.14,{"ext":23,"url":422,"hash":423,"mime":165,"name":424,"path":18,"size":425,"width":43,"height":180},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":427,"hash":428,"mime":165,"name":429,"path":18,"size":430,"width":186,"height":50},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"id":437,"title":438,"callToActionText":439,"callToActionLinkUrl":440,"body":18,"imageUrl":441,"__component":442},48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":127,"name":128,"alternativeText":18,"caption":18,"width":129,"height":130,"formats":18,"hash":131,"ext":132,"mime":133,"size":134,"url":135,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":136,"updatedAt":137,"documentId":138,"publishedAt":57,"focalPoint":18},"call-to-action.single",[444,449,452,455,458,462,465,469,472,476,479,482,486,489,493,496,499,503,506,509,588],{"id":445,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":447,"introductionText":18,"__component":448},1478,"","In dit artikel zullen we dieper ingaan op de aangekondigde features, de release tijdslijn en in mijn ogen net zo belangrijk: de missende features in SharePoint 2019 ten opzichte van de cloud-versie van SharePoint in Office 365.","global.pagesection",{"id":450,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":451,"introductionText":18,"__component":448},1477,"## Cloud versus on-premises\n\nOn-premises houdt in dat de applicatie geïnstalleerd staat op servers die door de gebruiker zelf worden onderhouden. Dit kunnen servers in een eigen serverpark zijn, maar ook bijvoorbeeld virtuele servers in Azure. Het grote verschil met de clouddiensten die kunnen worden afgenomen is dat bij on-premises de verantwoordelijkheid voor het beheer, zoals updates en security, volledig bij de gebruiker ligt. Bij een clouddienst zoals Office 365 heeft de gebruiker geen invloed op inrichting en het onderhoud van de servers en worden updates geïnitieerd vanuit de aanbieder. Dit kan een voordeel zijn omdat veel werk uit handen wordt genomen, maar het kan ook lastige situaties met zich meebrengen als er bijvoorbeeld een feature die in gebruik is wordt verwijderd of aangepast.\n\nSteeds meer gebruikers stappen over op de cloudiensten van Microsoft, maar 30% van de wereldwijde SharePoint gebruikers gebruikt de on-premise versie. Nu is het nog wel zo dat van die on-premise gebruikers ongeveer 40% een hybride scenario heeft, waarbij een gedeelte van de omgeving on-premise staat en een gedeelte in de cloud. Op deze manier kunnen die gebruikers wel alle nieuwe functionaliteiten van SharePoint in Office 365 gebruiken, maar blijft hun bedrijfskritische data opgeslagen op hun eigen on-premise servers.",{"id":453,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":454,"introductionText":18,"__component":448},1479,"![sharepoint](https://www.sharevalue.nl/images/sharevalue/blogs/afb_1.png)",{"id":456,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":457,"introductionText":18,"__component":448},1480,"## Functionaliteiten van SharePoint 2019",{"id":459,"title":18,"asideText":460,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":461,"introductionText":18,"__component":448},1481,"SharePoint server 2019","![spaces](https://www.sharevalue.nl/images/sharevalue/blogs/afb_2.png)",{"id":463,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":464,"introductionText":18,"__component":448},1482,"Het ontwikkelteam van SharePoint 2019 probeert qua functionaliteiten zoveel mogelijk de Office 365 cloud-variant van SharePoint bij te houden. Echter, omdat het twee verschillende ontwikkelteams zijn en het release proces anders loopt, is dit niet altijd mogelijk. De visie van Microsoft is dat een gebruiker in een hybride scenario niet mag merken of er wordt gewerkt op de cloud-omgeving of op de on-premises versie. In SharePoint 2019 zal dan ook voor eerst op een on-premises versie de modern sites en modern list experience aanwezig zijn. Deze moderne layout van de communication en team sites biedt een gebruiksvriendelijkere user experience en is volledig responsive zodat de sites ook goed getoond worden op mobiele apparaten.\n\nDe modern teamsites zullen zonder de gekoppelde groups komen, zoals nu het geval is op Office 365. De groups-functionaliteit is op dit moment niet on-premises beschikbaar omdat dit vanuit het mail programma Exchange wordt geregeld en dit niet on-premises beschikbaar is.\n\nOp de modern pages worden ook SharePoint Framework webparts ondersteunt. Op dit moment, op SharePoint 2016 on-premises, kan gebruik gemaakt worden van SharePoint Framework webparts echter loopt het framework daar op dit moment wel vier versies achter op de cloud-versie. In SharePoint 2019 zal dit versie verschil kleiner worden en zullen ook de SharePoint Framework Extensions gebruikt kunnen worden. Met deze extensions kan bijvoorbeeld ook de header en footer worden geinvloed met de SharePoint Framework code.",{"id":466,"title":18,"asideText":467,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":468,"introductionText":18,"__component":448},1483,"het klassieke design naast het modern design","![modern design](https://www.sharevalue.nl/images/sharevalue/blogs/afb_3.png)",{"id":470,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":471,"introductionText":18,"__component":448},1484,"Een andere functionaliteit welke is overgenomen vanuit de cloud-versie van SharePoint is site designs. Site designs zijn scripts waarin de verschillende acties worden aangegeven welke uitgevoerd moeten worden nadat een site met het betreffende site design is aangemaakt. Door middel van site designs kan het aanmaken van sites gestandaardiseerd worden om zo een consistente look en feel te creëren, maar ook om bijvoorbeeld standaard lijsten, content types en pagina’s aan te maken.",{"id":473,"title":18,"asideText":474,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":475,"introductionText":18,"__component":448},1485,"Door een site design te kiezen wordt er script gestart waar de gebruiker ook feedback van ontvangt","![](https://www.sharevalue.nl/images/sharevalue/blogs/afb_4.png)",{"id":477,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":478,"introductionText":18,"__component":448},1486,"Omdat Microsoft een cloudfirst-strategie hanteert is het voor Microsoft ook erg belangrijk om te voorzien in hybride scenario’s. In SharePoint 2019 proberen zij de gebruiker zoveel mogelijk te begeleiden bij het opstellen en implementeren van hybride scenario’s. In SharePoint 2019 is het mogelijk om via de SharePoint Central Administration een hybride omgeving in te richten. Ook is de integratie tussen on-premises en cloud verbetert. Er zijn verbeteringen op het gebied van hybrid search, flow en powerapps integratie.\n\nNaast de bovenstaande functionaliteiten zijn de volgende ook nog aangekondigd en hierover zal de komende tijd meer informatie beschikbaar komen:\n\n*   Project Server 2019\n*   Modern lists experience met column formatting\n*   SharePoint home\n*   Team news\n*   Vernieuwde Mobile app",{"id":480,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":481,"introductionText":18,"__component":448},1488,"## Wat zit er niet in SharePoint 2019?\n\nNaast alle nieuwe en verbeterde functionaliteiten die wel in SharePoint 2019 zitten, is er een drietal functionaliteiten die niet aanwezig zullen zijn. In mijn ogen zijn dit vrij grote missers en tijdens de conferentie werd dit ook duidelijk door de vele vragen uit het publiek waarom deze zaken missen.\n\nSharePoint 2019 zal geen hub site-functionaliteit bevatten. Dit is de grootste misser omdat Microsoft zelf op Office 365 de hub sites promoot als de nieuwe manier om je intranet op te bouwen. Bij hub sites worden site collecties gekoppeld aan de ‘bovenliggende’ hub site, waarna het design en de navigatie van hub site met de ‘onderliggende’ sites wordt gedeeld.",{"id":483,"title":18,"asideText":484,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":485,"introductionText":18,"__component":448},1487,"Geen hub site-functionaliteit","![hubsite](https://www.sharevalue.nl/images/sharevalue/blogs/afb_5.png)",{"id":487,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":488,"introductionText":18,"__component":448},1489,"SharePoint 2019 zal ook geen on-premises versie van Flow bevatten. Dit ondanks dat er geruchten gingen dat dit wel het geval zou zijn. In plaats van on-premises Flow zal er een verbeterde connector beschikbaar zijn om te verbinden met de cloud-variant van Flow. Ook is de Workflow Manager aangepakt in SharePoint 2019 welke nu robuuster en betrouwbaarder zou moeten zijn dan in het verleden. Op deze Workflow Manager kunnen workflow 2010 en workflow 2013 workflows worden gebruikt. Er komt geen nieuw workflow platform.",{"id":490,"title":18,"asideText":491,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":492,"introductionText":18,"__component":448},1490,"Geen nieuw workflow-platform","![workflow](https://www.sharevalue.nl/images/sharevalue/blogs/afb_6.png)",{"id":494,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":495,"introductionText":18,"__component":448},1491,"De laatste missende functionaliteit is dat SharePoint Framework webparts niet wordt ondersteund in de klassieke pagina’s. Op SharePoint in Office 365 is dit nu wel het geval, maar on-premises zal dit dus zo zijn. Een gemiste kans, want daardoor zal voor de klassieke sites nog steeds op de ouderwetse manier moeten worden ontwikkeld en kunnen webparts ook niet makkelijk worden omgezet van Office 365 naar on-premises. Zeker ook omdat aangegeven is dat het vervangen van de klassieke sites zoals de publishing sites niet op de roadmap staat van Office 365 of van SharePoint 2019 en wij dus voorlopig dit site template nog steeds zullen gebruiken.",{"id":497,"title":18,"asideText":446,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":498,"introductionText":18,"__component":448},1492,"## Release Window\n\n![release](https://www.sharevalue.nl/images/sharevalue/blogs/afb_7.png)",{"id":500,"title":18,"asideText":501,"underline":156,"centered":156,"blankAside":156,"aside":18,"content":502,"introductionText":18,"__component":448},1493,"Release herfst 2018","SharePoint 2019 zal in de zomer van 2018 beschikbaar komen als preview-versie en zal in de herfst van 2018 officieel gereleased worden. De servers waar SharePoint 2019 op kan draaien zullen minimaal Windows server 2016 en SQL server 2016 moeten hebben.\n\nAl met al denk ik dat het ontwikkelteam van SharePoint 2019 een mooie nieuwe on-premises versie heeft neergezet. En ondanks een aantal missers bevat SharePoint 2019 voldoende functionaliteiten om de komende jaren on-premises gebruikers tevreden te stellen. De betere ondersteuning voor hybride scenario’s zal ervoor zorgen dat de gebruikers hun missende functionaliteiten wellicht in de cloud zullen gaan gebruiken. En ik vermoed dat voordat SharePoint 2019 gereleased wordt, de hub site-functionaliteit alsnog wordt toegevoegd.",{"id":504,"title":18,"showBlankAside":69,"__component":505},150,"global.social-sharing",{"id":507,"name":18,"jobTitle":18,"__component":508},108,"strapi.author-card",{"id":510,"title":511,"aside":18,"postType":113,"limit":114,"expertise":512,"__component":117},119,"Lees ook onze andere berichten",[513]