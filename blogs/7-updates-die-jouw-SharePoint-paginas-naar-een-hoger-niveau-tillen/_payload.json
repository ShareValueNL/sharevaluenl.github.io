ia.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":163,"id":164,"title":165,"callToActionText":166,"callToActionLinkUrl":167,"body":18,"imageUrl":456},{"id":187,"name":188,"alternativeText":18,"caption":18,"width":189,"height":190,"formats":18,"hash":191,"ext":192,"mime":193,"size":194,"url":195,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":196,"updatedAt":197,"documentId":198,"publishedAt":57},{"id":169,"metaTitle":170,"metaDescription":171,"structuredData":458,"metaImage":18,"metaSocial":461},{"url":173,"@type":174,"@context":175,"provider":459,"areaServed":460,"description":183,"serviceType":184},{"url":177,"name":178,"@type":179},{"name":181,"@type":182},[],{"id":463,"name":464,"jobTitle":465,"about":18,"createdAt":466,"updatedAt":467,"publishedAt":468,"documentId":469,"image":470,"contactOptions":487},81,"Michelle","Consultant","2023-10-12T10:04:21.815Z","2024-03-11T12:18:40.835Z","2023-10-12T10:04:22.884Z","d19jpcqp626wht32twuhhay5",{"id":471,"name":472,"alternativeText":18,"caption":18,"width":473,"height":474,"formats":475,"hash":482,"ext":78,"mime":81,"size":483,"url":484,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":485,"updatedAt":485,"documentId":486,"publishedAt":57},552,"Michelle websitefoto.png",278,326,{"thumbnail":476},{"ext":78,"url":477,"hash":478,"mime":81,"name":479,"path":18,"size":480,"width":481,"height":239},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Michelle_websitefoto_81ae8119a0.png","thumbnail_Michelle_websitefoto_81ae8119a0","thumbnail_Michelle websitefoto.png",20.91,133,"Michelle_websitefoto_81ae8119a0",27.85,"https://incredible-beef-2a6059b946.media.strapiapp.com/Michelle_websitefoto_81ae8119a0.png","2024-03-05T12:43:59.434Z","crjgodfat7routsay7c1ngne",[],[489,494,498,502,505,508,586],{"__component":490,"id":491,"title":18,"asideText":18,"underline":121,"centered":121,"blankAside":121,"aside":492,"content":493,"introductionText":18},"global.pagesection",1857,"","### 1. Krijg hulp van Copilot bij het maken van je SharePoint-pagina's\nMicrosoft Copilot voor Microsoft 365 wordt de afgelopen tijd al vaak genoemd in combinatie met veel andere Microsoft 365 apps. Binnenkort kun je deze tool ook in SharePoint gebruiken. Let wel op, dit geldt alleen voor gebruikers met een Copilot voor Microsoft 365 licentie. Met behulp van Copilot in SharePoint kun je met een prompt een eerste opzet voor een SharePoint-pagina genereren. Hierdoor hoef je niet meer helemaal vanaf een lege pagina te beginnen, maar heb je direct een basis voor de pagina die je wilt maken. Bovendien kan Copilot je helpen bij het opstellen en nakijken van teksten voor je SharePoint-pagina.\n\n### 2. Bewerk SharePoint-pagina's tegelijk met je collega's\nHet kan erg vervelend zijn als een collega een SharePoint-pagina aan het bewerken is zonder deze op te slaan. Vaak blijven bewerkingsschermen openstaan, waardoor anderen moeten wachten tot de collega de pagina opslaat of de wijzigingen overschrijven. Dankzij deze nieuwe update kunnen collega’s nu gelijktijdig de pagina aanpassen.\n\nBovendien kunnen auteurs nu commentaar achterlaten op een pagina, die alleen andere auteurs kunnen zien wanneer ze de pagina bewerken. Zo kun je makkelijker onderling communiceren over de inhoud van de pagina zonder dat bezoekers dit merken.",{"__component":490,"id":495,"title":18,"asideText":18,"underline":121,"centered":121,"blankAside":121,"aside":496,"content":497,"introductionText":18},1858,"Figuur 1: Werk samen en gebruik nieuwe opties zoals Copilot en het Banner webpart","![updates sharepoint 1.png](https://incredible-beef-2a6059b946.media.strapiapp.com/updates_sharepoint_1_ca915fe612.png)\n\n### 3. Gebruik meer mogelijkheden voor het vormgeven van je paginasecties\nOp dit moment zijn de secties op een SharePoint-pagina erg statisch vormgegeven. Je kunt een sectie een achtergrond van een paar kleurtjes geven en je kan zelf de grootte van de sectie niet aangeven. Deze zomer kun je met de nieuwe update afbeeldingen als achtergrond voor secties instellen en de grootte van de secties naar wens aanpassen. Dit kan jouw webpagina's nog dynamischer maken!\n\n### 4. Personaliseer jouw SharePoint met het nieuwe SharePoint Brand Center\nOp dit moment kun je binnen SharePoint gebruikmaken van een beperkt aantal lettertypen en thema’s bij het opstellen van webpagina’s. Dankzij het SharePoint Brand Center kun je nu binnen je organisatie lettertypen en thema’s toevoegen, zodat je jouw huisstijl ook op SharePoint-pagina’s kunt gebruiken. Op deze manier kun je jouw SharePoint-pagina's nog meer een eigen twist geven.\n\n### 5. Krijg voorstellen voor het vormgeven van je pagina's\nHet kan soms wat lastig zijn om jouw visie over te brengen naar een SharePoint-pagina. Met behulp van slimme suggesties voor het indelen van de secties of het toevoegen van webparts kan SharePoint binnenkort helpen bij het realiseren van de pagina die jij voor ogen hebt. Vanuit de suggesties kun je eenvoudig webparts slepen naar de plek in de pagina waar je deze wilt hebben. Voorgestelde indelingen worden automatisch aangebracht zodra je op het voorstel klikt. Als je deze indeling toch niet wilt, kun je gemakkelijk teruggaan naar de pagina die je daarvoor had.\n\n### 6. Personaliseer de webparts op je pagina's\nVerschillende bestaande webparts krijgen meer opties. Zo krijgt het Hero-webpart de optie om deze vorm te geven als een carrousel, en krijgen verschillende webparts die met afbeeldingen werken de optie om deze een andere vorm te geven. Zo kun je wat speelser omgaan met je content en deze op nog meer manieren weergeven op je pagina's.\n\n### 7. Update de paginatitels met het nieuwe Banner webpart\nMomenteel zijn titels op sommige soorten pagina's verplicht. Dit is niet altijd even wenselijk, en er zijn ook weinig opties om de paginatitel aan te passen. Met deze vernieuwing worden paginatitels niet langer verplicht gesteld. In plaats daarvan kun je gebruikmaken van het nieuwe Banner-webpart. Dit webpart is dynamischer ingesteld dan paginatitels en stelt je in staat om meerdere banners aan een pagina toe te voegen.\n\n## Wanneer zijn deze mooie updates te gebruiken?\nEen deel van deze vernieuwingen is al uitgebracht, en helaas zullen sommige updates nog op zich moeten laten wachten. De meeste updates worden in de loop van de zomer uitgerold, en tegen het eind van het jaar zal de SharePoint-optimalisatie volgens planning voltooid moeten zijn. Hieronder vind je de huidige planning die Microsoft heeft gepubliceerd voor de SharePoint-vernieuwingen.",{"__component":490,"id":499,"title":18,"asideText":18,"underline":121,"centered":121,"blankAside":121,"aside":500,"content":501,"introductionText":18},1859,"Figuur 2: De planning voor Microsoft SharePoint innovatie","![updates sharepoint 2.png](https://incredible-beef-2a6059b946.media.strapiapp.com/updates_sharepoint_2_0b16306a90.png)\n\n## Afsluiting\n\nKortom, al deze nieuwe of verbeterde functionaliteiten kunnen de SharePoint-pagina’s binnen je organisatie naar een hoger niveau tillen. Je kunt mooiere pagina’s maken, gemakkelijker samenwerken en meer hulp en advies krijgen tijdens het opstellen. Hou dus zeker jouw SharePoint-omgeving in de gaten voor deze nieuwe opties. Misschien is het handig om alvast na te denken over welke wijzigingen jij graag binnen de pagina’s van je organisatie wilt aanbrengen en bespreek dit met de beheerders.\n\nHeb je meer hulp nodig bij het implementeren van vernieuwingen binnen jouw SharePoint? Onze consultants hebben de laatste kennis en helpen je graag bij het realiseren van jouw wensen!\n",{"__component":503,"id":504,"title":18,"showBlankAside":121},"global.social-sharing",198,{"__component":506,"id":507,"name":18,"jobTitle":18},"strapi.author-