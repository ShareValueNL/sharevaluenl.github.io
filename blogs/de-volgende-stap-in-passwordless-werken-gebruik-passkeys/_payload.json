xt":143,"provider":365,"areaServed":366,"description":151,"serviceType":152},{"url":145,"name":146,"@type":147},{"name":149,"@type":150},[],{"__component":105,"id":369,"titleLeft":370,"callToActionTextLeft":371,"callToActionLinkUrlLeft":109,"titleRight":372,"callToActionTextRight":373,"callToActionLinkUrlRight":374,"iconUrlLeft":375,"iconUrlRight":386},266,"Kan je een Azure Engineer gebruiken?","Neem contact met ons op om de mogelijkheden te bespreken","Wil je aan de slag als Engineer bij ShareValue?","Lees hoe leuk het bij ons is!","/word-onze-collega/azure",{"id":376,"name":377,"alternativeText":18,"caption":18,"width":378,"height":379,"formats":18,"hash":380,"ext":160,"mime":161,"size":381,"url":382,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":383,"updatedAt":384,"documentId":385,"publishedAt":57},372,"magnifier.svg",49,60,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",{"id":168,"name":169,"alternativeText":18,"caption":18,"width":158,"height":158,"formats":18,"hash":170,"ext":160,"mime":161,"size":171,"url":172,"previewUrl":18,"provider":54,"provider_metadata":18,"createdAt":173,"updatedAt":174,"documentId":175,"publishedAt":57},{"id":388,"metaTitle":389,"metaDescription":390,"structuredData":391,"metaImage":18,"metaSocial":425},62,"Passkeys: veilig en wachtwoordloos werken | ShareValue","Passkeys bieden een veilig alternatief voor wachtwoorden. ShareValue helpt organisaties bij de implementatie van deze moderne authenticatiemethode.",{"faq":392,"url":415,"@type":416,"author":417,"@context":143,"headline":419,"publisher":420,"description":424,"dateModified":13,"datePublished":13,"mainEntityOfPage":415},[393,399,403,407,411],{"name":394,"@type":395,"acceptedAnswer":396},"Wat zijn passkeys?","Question",{"text":397,"@type":398},"Passkeys zijn passwordless authenticatiemethoden gebaseerd op private/public key paren, waarbij gebruikers inloggen via biometrie, pincode of patroon in plaats van wachtwoorden.","Answer",{"name":400,"@type":395,"acceptedAnswer":401},"Wat zijn de voordelen van passkeys?",{"text":402,"@type":398},"Passkeys bieden een passwordless ervaring, snellere inlogtijden, verhoogde veiligheid, zijn beschikbaar op meerdere apparaten en verminderen risico's zoals phishing en credential stuffing.",{"name":404,"@type":395,"acceptedAnswer":405},"Hoe werken passkeys?",{"text":406,"@type":398},"Passkeys gebruiken een privé- en publieke sleutel. De privésleutel wordt op het apparaat van de gebruiker opgeslagen, terwijl de publieke sleutel naar de server wordt gestuurd voor authenticatie.",{"name":408,"@type":395,"acceptedAnswer":409},"Zijn passkeys al beschikbaar?",{"text":410,"@type":398},"Ja, passkeys zijn sinds januari beschikbaar in Microsoft Authenticator in Global Availability. Bedrijven kunnen deze technologie inschakelen via de authentication methods policy.",{"name":412,"@type":395,"acceptedAnswer":413},"Waarom zijn passkeys veiliger dan traditionele wachtwoorden?",{"text":414,"@type":398},"Passkeys verminderen het risico op phishing en credential stuffing doordat ze geen wachtwoorden gebruiken, die vaak hergebruikt worden en vatbaar zijn voor aanvallen.","https://www.sharevalue.nl/blogs/wat-zijn-passkeys-en-waarom-zijn-ze-de-toekomst-van-digitale-veiligheid","BlogPosting",{"name":282,"@type":418,"jobTitle":283},"Person","Wat zijn passkeys en waarom zijn ze de toekomst van digitale veiligheid? | ShareValue",{"logo":421,"name":146,"@type":147},{"url":422,"@type":423},"https://www.sharevalue.nl/logo.png","ImageObject","Ontdek de voordelen van passkeys, de passwordless authentificatiemethode die veiliger en gebruiksvriendelijker is dan traditionele wachtwoorden.",[],{"pagination":427},{"page":60,"pageSize":428},100,{},1779452330776]