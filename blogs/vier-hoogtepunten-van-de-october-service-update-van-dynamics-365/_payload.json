width":36,"height":238},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_teamwork_8f4a7b0c14.jpg","medium_teamwork_8f4a7b0c14","medium_teamwork.jpg",51.59,{"ext":23,"url":451,"hash":452,"mime":222,"name":453,"path":18,"size":454,"width":244,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_teamwork_8f4a7b0c14.jpg","thumbnail_teamwork_8f4a7b0c14","thumbnail_teamwork.jpg",8.11,"teamwork_8f4a7b0c14",116.53,"https://incredible-beef-2a6059b946.media.strapiapp.com/teamwork_8f4a7b0c14.jpg","2024-08-08T10:07:23.468Z","uo85gvimf7llsbaoahqw08m3",{"__component":167,"id":168,"title":169,"callToActionText":170,"callToActionLinkUrl":171,"body":18,"imageUrl":461},{"id":191,"name":192,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":18,"hash":195,"ext":196,"mime":197,"size":198,"url":199,"previewUrl":18,"provider":47,"provider_metadata":18,"createdAt":200,"updatedAt":201,"documentId":202,"publishedAt":50},{"id":173,"metaTitle":174,"metaDescription":175,"structuredData":463,"metaImage":18,"metaSocial":466},{"url":177,"@type":178,"@context":179,"provider":464,"areaServed":465,"description":187,"serviceType":188},{"url":181,"name":182,"@type":183},{"name":185,"@type":186},[],{"id":155,"name":468,"jobTitle":469,"about":18,"createdAt":470,"updatedAt":471,"publishedAt":472,"documentId":473,"image":474,"contactOptions":491},"Jaap","Consultant & Architect","2023-08-18T08:37:46.142Z","2024-04-18T14:14:47.615Z","2023-08-18T08:37:45.364Z","ylun9zjxpvjd4rq1teczcwna",{"id":475,"name":476,"alternativeText":18,"caption":18,"width":477,"height":478,"formats":479,"hash":486,"ext":82,"mime":85,"size":487,"url":488,"previewUrl":18,"provider":47,"provider_metadata":18,"createdAt":489,"updatedAt":489,"documentId":490,"publishedAt":50},685,"Jaap websitefoto.png",278,326,{"thumbnail":480},{"ext":82,"url":481,"hash":482,"mime":85,"name":483,"path":18,"size":484,"width":485,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Jaap_websitefoto_b7bbefc0bd.png","thumbnail_Jaap_websitefoto_b7bbefc0bd","thumbnail_Jaap websitefoto.png",19.14,133,"Jaap_websitefoto_b7bbefc0bd",19.61,"https://incredible-beef-2a6059b946.media.strapiapp.com/Jaap_websitefoto_b7bbefc0bd.png","2024-04-18T14:13:38.415Z","cvbav3qa5a84m18w8fmg5l5c",[],[493,497,500,504,507,511,514,518,521,525,528,531,538],{"__component":494,"id":495,"title":18,"asideText":55,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":496,"introductionText":18},"global.pagesection",1526,"Deze update wordt momenteel uitgerold en er zijn nog veel eindgebruikers van Dynamics 365 die de update nog niet hebben. In deze blog beschrijf ik de vier hoogtepunten van deze update.",{"__component":494,"id":498,"title":18,"asideText":55,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":499,"introductionText":18},1527,"### **1\\. Multi-select option sets**",{"__component":494,"id":501,"title":18,"asideText":502,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":503,"introductionText":18},1528,"Meerdere opties kiezen","Een option-set is een keuzelijstje waaruit de gebruiker een waarde kan selecteren. De multi-select option-set is een nieuw soort keuzelijst waarmee de gebruiker meerdere opties kan kiezen. Zie het schermvoorbeeld waar twee skills zijn geselecteerd.Tot nu toe kon een option-set altijd maar één waarde bevatten. Als je meerdere opties wilde toestaan was een “stamtabel”-entiteit nodig en een 1-N relatie, of moest je creatief zijn. In de nieuwe update kan een option set-dus meerdere waarden bevatten.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Multi-select_Options_Sets__Dynamics_365.png)",{"__component":494,"id":505,"title":18,"asideText":55,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":506,"introductionText":18},1529,"### 2\\. NOT IN support for advanced find",{"__component":494,"id":508,"title":18,"asideText":509,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":510,"introductionText":18},1530,"Zoeken naar ontbrekende gegevens","Iedere gebruiker die aan de slag gaat met Geavanceerd Zoeken komt vroeg of laat met de vraag hoe je een opdracht kunt maken om te zoeken naar ontbrekende gegevens. Bijvoorbeeld naar alle verkoopkansen zonder offerte. Of klanten zonder een bezoek in het laatste jaar. Met deze nieuwe feature wordt het eindelijk mogelijk om dat te doen in de Geavanceerd Zoeken functie.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Not_In_support_for_advanced_find.png)",{"__component":494,"id":512,"title":18,"asideText":55,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":513,"introductionText":18},1531,"### 3\\. Prospect to cash integration",{"__component":494,"id":515,"title":18,"asideText":516,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":517,"introductionText":18},1532,"​Integratie van het gehele bedrijfsproces","Toen Satya Nadella vorig jaar Dynamics 365 lanceerde, maakte hij al duidelijk dat hij een verregaande integratie van de Dynamics-platformen ambieerde. Prospect to cash noemde hij dat: een integratie van het hele bedrijfsproces, vanaf een prospect in CRM, via orders en facturen naar cash. Nu ziet de eerste stap het licht: met de Common Data Service wordt het mogelijk om accounts, contacts, products, quotes, orders en invoices van CRM te synchroniseren met Microsoft Dynamics for Operations (vroeger Dynamics AX). Op deze manier kan uiteindelijk het hele bedrijfsproces geïntegreerd worden met Dynamics 365.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Prospect_to_cash_integration.png)",{"__component":494,"id":519,"title":18,"asideText":55,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":520,"introductionText":18},1533,"### 4\\. Virtual entities",{"__component":494,"id":522,"title":18,"asideText":523,"underline":59,"centered":59,"blankAside":59,"aside":18,"content":524,"introductionText":18},1534,"Virtuele entiteiten","Met virtual entities wordt het mogelijk om data uit een ander systeem te tonen alsof het in CRM staat. Voor zo’n virtual entity kun je formulieren maken, en het tonen in subgrids, net als met gewone CRM-data. Denk bijvoorbeeld aan het tonen van facturen uit je boekhoudingspakket. Met een virtual entity kun je die informatie in CRM laten zien op het organisatie scherm, alsof de facturen in CRM staan opgeslagen.\n\n![](https://www.sharevalue.nl/images/sharevalue/blogs/Virtual_Entities.png)\n\nPersoonlijk vind ik dit de vier hoogtepunten van deze update van Dynamics 365. Ik hoop dat ik wat meer inzicht heb gegeven in wat de eindgebruikers, die de uitrol van deze update nog niet hebben gehad, kunnen verwachten. Wil jij meer weten over deze update van Dynamics 365 of heb je een ander vraagstuk op het gebied van Dynamics 365? Aarzel dan niet en neem [contact](/contact) met ons op. Wij helpen en denken graag met je mee.",{"__component":526,"id":527,"title":18,"showBlankAside":73},"global.social-sharing",154,{"__component":529,"id":530,"name":18,"jobTitle":18},"strapi.author-card",112,{"__component":97,"id":532,"title":533,"aside":18,"postType":100,"limit":101,"expertise":534},123,"Lees ook onze andere berichten",[535],{"id":53,"title":54,"subTitle":55,"description":55,"shortDescription":55,"slug":56,"createdAt":57,"updatedAt":57,"publishedAt":58,"isCoreExpertise":59,"documentId":60,"image":18,"blocks":536,"midPageBlocks":537,"seo":18},[],[],{"__component":110,"id":539,"titleLeft":115,"callToActionTextLeft":116,"callToActionLinkUrlLeft":540,"titleRight":541,"callToActionTextRight":542,"callToActionLinkUrlRight":543,"iconUrlLeft":544,"iconUrlRight":545},180,"https://www.sharevalue.nl/word-onze-collega/vacatures","Wil je weten waar wij goed in zijn?","Ontdek wat we doen","/wat-we-doen",{"id":53,"name":204,"alternativeText":18,"caption":18,"width":194,"height":194,"formats":18,"hash":205,"ext":196,"mime":197,"size":206,"url":207,"previewUrl":18,"provider":47,"provider_metadata":18,"createdAt":208,"updatedAt":209,"documentId":210,"publishedAt":50},{"id":191,"name":192,"alternativeText":18,"caption":18,"width":193,"height":194,"formats":18,"hash":195,"ext":196,"mime":197,"size":198,"url":199,"previewUrl":18,"provider":47,"provider_metadata":18,"createdAt":200,"updatedAt":201,"documentId":202,"publishedAt":50},{"id":547,"metaTitle":548,"metaDescription":549,"structuredData":550,"metaImage":18,"metaSocial":590},202,"Dynamics 365 oktober-update: 4 verbeteringen | ShareValue","Ontdek de vier hoogtepunten in de oktober-update van Dynamics 365: AI-ondersteuning, Copilot-integratie, verbeterde case grids en selfservice-opties.",[551,565],{"url":552,"@type":553,"author":554,"@context":179,"headline":558,"publisher":559,"description":563,"datePublished":564},"https://www.sharevalue.nl/blogs/vier-hoogtepunten-van-de-october-service-update-van-dynamics-365","BlogPosting",{"url":555,"name":468,"@type":556,"jobTitle":557},"https://www.sharevalue.nl/consultants/jaap","Person","Consultant","Dynamics 365 oktober-update: 4 belangrijke verbeteringen | ShareValue",{"logo":560,"name":182,"@type":183},{"url":561,"@type":562},"https://www.sharevalue.nl/_nuxt/img/sharevalue-logo.3c5e7cb.svg","ImageObject","Ontdek de vier belangrijkste verbeteringen in de oktober-service-update van Dynamics 365: AI-ondersteuning, Copilot-integratie, verbeterde case grids en nieuwe selfservice-opties.","2024-10-15",{"@type":566,"@context":179,"mainEntity":567},"FAQPage",[568,574,578,582,586],{"name":569,"@type":570,"acceptedAnswer":571},"Wat zijn de belangrijkste verbeteringen in de oktober-update van Dynamics 365?","Question",{"text":572,"@type":573},"De oktober-update introduceert AI-ondersteuning voor agenten, Copilot-integratie voor casebeheer, verbeterde case grids voor efficiënter werken en nieuwe selfservice-opties voor klanten.","Answer",{"name":575,"@type":570,"acceptedAnswer":576},"Hoe verbetert de AI-ondersteuning de agentproductiviteit?",{"text":577,"@type":573},"AI-ondersteuning helpt agenten bij het snel vinden van oplossingen door automatisch antwoorden voor te stellen en case-informatie samen te vatten, waardoor de responstijd wordt verkort.",{"name":579,"@type":570,"acceptedAnswer":580},"Wat is de rol van Copilot in de oktober-update?",{"text":581,"@type":573},"Copilot fungeert als een virtuele assistent die agenten ondersteunt bij het beheren van cases, het genereren van antwoorden en het verbeteren van de algehele klantinteractie.",{"name":583,"@type":570,"acceptedAnswer":584},"Hoe verbeteren de nieuwe case grids de agentervaring?",{"text":585,"@type":573},"De nieuwe case grids bieden een overzichtelijke weergave van belangrijke case-informatie, waardoor agenten snel prioriteiten kunnen stellen en efficiënter kunnen werken.",{"name":587,"@type":570,"acceptedAnswer":588},"Wat zijn de voordelen van de nieuwe selfservice-opties?",{"text":589,"@type":573},"De nieuwe selfservice-opties stellen klanten in staat om zelfstandig antwoorden te vinden en problemen op te lossen, wat de klanttevredenheid verhoogt en de werklast voor agenten vermindert.",[],{"pagination":592},{"page":593,"pageSize":594},1,100,{},1782465848665]