[{"data":1,"prerenderedAt":596},["ShallowReactive",2],{"collection-blogs--167714386":3,"_apollo:default":595},{"data":4,"meta":591},[5],{"id":6,"title":7,"excerpt":8,"slug":9,"createdAt":10,"updatedAt":11,"publishedAt":12,"backDate":13,"documentId":14,"imageUrl":15,"expertises":51,"author":467,"blocks":492,"seo":546},115,"Vier hoogtepunten van de October Service Update van Dynamics 365","Na lang wachten werd vorig jaar oktober dan eindelijk de nieuwe update van Dynamics 365 gelanceerd. Heel toepasselijk heeft Microsoft ook besloten hem te hernoemen naar de October Service Update. Het versie nummer is 9.0.0.2072. Oktober 2017, dat is toch al oud nieuws zou je denken. Niks is minder waar.","vier-hoogtepunten-van-de-october-service-update-van-dynamics-365","2023-10-13T10:26:42.951Z","2025-04-22T15:13:52.414Z","2023-10-13T10:26:42.887Z","2018-03-26","ffefgdxotf5sl1cgywkeal0f",{"id":16,"name":17,"alternativeText":18,"caption":18,"width":19,"height":20,"formats":21,"hash":44,"ext":23,"mime":26,"size":45,"url":46,"previewUrl":18,"provider":47,"provider_metadata":18,"createdAt":48,"updatedAt":48,"documentId":49,"publishedAt":50},364,"vier-hoogtepunten-van-de-october-service-update-van-dynamics-365.jpg",null,840,560,{"small":22,"medium":31,"thumbnail":37},{"ext":23,"url":24,"hash":25,"mime":26,"name":27,"path":18,"size":28,"width":29,"height":30},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/small_vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad.jpg","small_vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad","image/jpg","small_vier-hoogtepunten-van-de-october-service-update-van-dynamics-365.jpg",49.39,500,333,{"ext":23,"url":32,"hash":33,"mime":26,"name":34,"path":18,"size":35,"width":36,"height":29},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad.jpg","medium_vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad","medium_vier-hoogtepunten-van-de-october-service-update-van-dynamics-365.jpg",110.78,750,{"ext":23,"url":38,"hash":39,"mime":26,"name":40,"path":18,"size":41,"width":42,"height":43},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad.jpg","thumbnail_vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad","thumbnail_vier-hoogtepunten-van-de-october-service-update-van-dynamics-365.jpg",11.2,234,156,"vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad",140.52,"https://incredible-beef-2a6059b946.media.strapiapp.com/vier_hoogtepunten_van_de_october_service_update_van_dynamics_365_7f5d960fad.jpg","strapi-provider-upload-strapi-cloud","2023-10-13T10:25:01.323Z","i1rq160mu58nn54xnt6wqr7n","2026-01-05T12:38:34.018Z",[52,63],{"id":53,"title":54,"subTitle":55,"description":55,"shortDescription":55,"slug":56,"createdAt":57,"updatedAt":57,"publishedAt":58,"isCoreExpertise":59,"documentId":60,"image":18,"blocks":61,"midPageBlocks":62,"seo":18},8,"Dynamics 365","","dynamics-365","2023-10-12T11:27:58.808Z","2023-10-12T11:27:58.783Z",false,"dja519itovgg9wq8euq4uocb",[],[],{"id":64,"title":65,"subTitle":66,"description":67,"shortDescription":68,"slug":69,"createdAt":70,"updatedAt":71,"publishedAt":72,"isCoreExpertise":73,"documentId":74,"image":75,"blocks":95,"midPageBlocks":211,"seo":462},4,"Microsoft 365","Onmisbaar voor je bedrijfsvoering en onderlinge samenwerking","Microsoft 365 is de complete oplossing om overal en op elk apparaat samen te werken. Of je nu met al je collega's op kantoor werkt, iedereen vanuit huis werkt, of een combinatie daarvan. Je kunt overal met je team vanuit de Cloud samenwerken op een veilige manier. Op deze manier kun je optimaal samenwerken tussen teams, apparaten en verschillende platforms.\n\nShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis. Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken. Onze architecten, consultants, developers en engineers hebben de ervaring om jouw organisatie naar een hoger niveau te tillen. Deze kennis en ervaring delen zij continu onderling en zetten deze in bij onze klanten. Zo kunnen wij jou het beste helpen met alle kennis die bij ShareValue in huis is. De opdrachten die wij uitvoeren variëren van enkele dagen tot meerdere jaren, van consultancy van enkele dagdelen tot het uitvoeren van een volledig adoptieproces. Maatwerk is misschien wel het beste alomvattende woord: geen klant en geen opdracht zijn hetzelfde.\n\nOns werkveld bestaat uit grote overheidsinstanties, commerciële bedrijven en het MKB. Van de Nederlandse Spoorwegen tot de grote banken, van Ministeries tot Universiteiten, van ‘s HeerenLoo tot Provincie Utrecht. Wordt jouw bedrijf de volgende in dit lijstje?","Van migratie- en adoptietrajecten tot technische implementaties en beveiligingsvraagstukken; ShareValue heeft voor elke situatie de juiste Microsoft 365-experts in huis.","microsoft-365","2023-08-17T11:23:35.476Z","2025-05-12T11:58:53.037Z","2023-08-17T11:26:21.327Z",true,"ci9jcjkdq0gjpkaebdvdf08c",{"id":76,"name":77,"alternativeText":18,"caption":18,"width":78,"height":79,"formats":80,"hash":90,"ext":82,"mime":85,"size":91,"url":92,"previewUrl":18,"provider":47,"provider_metadata":18,"createdAt":93,"updatedAt":93,"documentId":94,"publishedAt":50},16,"microsoft-365.png",282,130,{"thumbnail":81},{"ext":82,"url":83,"hash":84,"mime":85,"name":86,"path":18,"size":87,"width":88,"height":89},".png","https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_microsoft_365_d759cc1566.png","thumbnail_microsoft_365_d759cc1566","image/png","thumbnail_microsoft-365.png",6.21,245,113,"microsoft_365_d759cc1566",1.89,"https://incredible-beef-2a6059b946.media.strapiapp.com/microsoft_365_d759cc1566.png","2023-08-17T09:47:56.299Z","a4mm3xrykl81dq16yqgh2jwa",[96,189],{"__component":97,"id":98,"title":99,"aside":18,"postType":100,"limit":101,"expertise":102},"strapi.related-kennisbank-list",166,"Lees meer over Microsoft 365","alle",3,[103],{"id":64,"title":65,"subTitle":66,"description":67,"shortDescription":68,"slug":69,"createdAt":70,"updatedAt":71,"publishedAt":72,"isCoreExpertise":73,"documentId":74,"image":104,"blocks":107,"midPageBlocks":118,"seo":172},{"id":76,"name":77,"alternativeText":18,"caption":18,"width":78,"height":79,"formats":105,"hash":90,"ext":82,"mime":85,"size":91,"url":92,"previewUrl":18,"provider":47,"provider_metadata":18,"createdAt":93,"updatedAt":93,"documentId":94,"publishedAt":50},{"thumbnail":106},{"ext":82,"url":83,"hash":84,"mime":85,"name":86,"path":18,"size":87,"width":88,"height":89},[108,109],{"__component":97,"id":98,"title":99,"aside":18,"postType":100,"limit":101},{"__component":110,"id":111,"titleLeft":112,"callToActionTextLeft":113,"callToActionLinkUrlLeft":114,"titleRight":115,"callToActionTextRight":116,"callToActionLinkUrlRight":117},"call-to-action.double",211,"Heb je een Microsoft 365 expert nodig?","Neem contact met ons op","/contact","Zoek je een nieuwe baan?","Bekijk onze vacatures","/word-onze-collega/vacatures",[119,126,133,138,143,149,154,161,166],{"__component":120,"id":121,"title":122,"subTitle":123,"content":124,"callToActionText":18,"callToActionLink":18,"colorStyle":125,"showAsides":59},"global.alternating-page-section",27,"Teams","Innoveer je samenwerking","De meeste mensen zijn al bekend met het online vergaderen binnen Teams. Maar er zijn nog veel meer mogelijkheden om de samenwerking binnen je organisatie te verbeteren met een goede Microsoft Teams-implementatie. Onze consultants kunnen de manier van werken met Teams binnen jouw organisatie verbeteren met behulp van verschillende Teams apps zoals Planner, OneNote, Loop en meer. Daarnaast kunnen zij best practices opstellen en helpen bij het implementeren van de nieuwste Teams-innovaties. Met hun kennis kunnen onze consultants op directieniveau meedenken en adviseren over de juiste Teams implementatie. ","Sugar Glaze",{"__component":120,"id":127,"title":128,"subTitle":129,"content":130,"callToActionText":131,"callToActionLink":114,"colorStyle":132,"showAsides":59},28,"Adoptie","Adoptie van Microsoft 365 diensten","Het aanschaffen van een programma of pakket kan iedereen. Maar ervoor zorgen dat je medewerkers optimaal gebruik maken van de mogelijkheden die Microsoft biedt, is een ander verhaal. Onze experts zorgen ervoor dat jouw medewerkers methodisch leren werken met Microsoft 365 programma’s. Deze methode, de adoptiestraat, is al bij vele ShareValue-klanten met groot succes uitgevoerd. Wordt jouw organisatie de volgende?","Meer weten over de ShareValue adoptiestraat?","White",{"__component":120,"id":134,"title":135,"subTitle":136,"content":137,"callToActionText":18,"callToActionLink":18,"colorStyle":125,"showAsides":59},31,"Microsoft trends","Advies over de nieuwste Microsoft-ontwikkelingen","Microsoft blijft constant vernieuwen, waardoor het moeilijk kan zijn om up-to-date te blijven. Wij helpen je graag met de laatste updates. Of het nu gaat over Loop, Places, Planner of Copilot; onze experts hebben de laatste kennis paraat om je op weg te helpen.",{"__component":120,"id":139,"title":140,"subTitle":141,"content":142,"callToActionText":18,"callToActionLink":18,"colorStyle":132,"showAsides":59},29,"Microsoft Development","Breid je Microsoftmogelijkheden uit","Microsoft biedt al een volledig pakket waarin de meeste mensen hun werkzaamheden kunnen uitvoeren. Heeft jouw organisatie toch nog extra maatwerkwensen om de Microsoft 365-omgeving beter laten aansluiten op jouw behoeften? Onze Microsoft Developers staan voor je klaar!",{"__component":120,"id":144,"title":145,"subTitle":146,"content":147,"callToActionText":148,"callToActionLink":114,"colorStyle":125,"showAsides":59},30,"Migratie","Migreer je documenten veilig","Steeds meer bedrijven migreren hun data naar Microsoft 365. Het begeleiden van dit proces en het maken van de juiste beslissingen is cruciaal voor een succesvolle migratie. Onze consultants hebben ervaring met datamigratie naar Microsoft 365 en kunnen ook jouw medewerkers trainen om optimaal met deze verandering om te gaan.","Kunnen wij je helpen met je migratie?",{"__component":120,"id":150,"title":151,"subTitle":152,"content":153,"callToActionText":18,"callToActionLink":18,"colorStyle":132,"showAsides":59},33,"Security","Advies over beveiliging binnen jouw bedrijf","Het regelen en monitoren van beveiliging blijft altijd een belangrijke maar complexe zaak. Of het nu gaat om documentbeveiliging, het waarborgen van een Zero-Trust Policy, of het beveiligen van jouw organisaties Microsoft 365 apps. Wij helpen je graag om jouw omgeving veiliger te maken. ",{"__component":120,"id":155,"title":156,"subTitle":157,"content":158,"callToActionText":159,"callToActionLink":160,"colorStyle":125,"showAsides":59},32,"Teams Store","Optimaliseer je hardware","Teams Store, onderdeel van ShareValue, biedt onze klanten kennis en expertise op het gebied van audiovisuele communicatie. Of je nu een kleine vergaderruimte wilt uitrusten met een professionele microfoon of een compleet auditorium wilt voorzien van de nieuwste projectietechnologie, Teams Store heeft de oplossing. Wij zijn meer dan alleen een leverancier; we zijn de kennispartner die van A tot Z ontzorgt.\n\nWat kun je van Teams Store verwachten?\n- **Deskundig advies**: onze ervaren adviseurs helpen je graag bij het kiezen van de juiste apparatuur en het ontwerpen van een systeem dat perfect aansluit bij de wensen en het budget van jouw organisatie.\n- **Installatie en onderhoud**: wij zorgen voor de professionele installatie van de apparatuur en bieden uitgebreide onderhoudscontracten om jouw investering te beschermen.\n- **Training en ondersteuning**: onze ShareValue IT-experts geven trainingen aan jouw medewerkers om ze te leren omgaan met de nieuwe apparatuur. Je kunt ook altijd bij ons terecht voor ondersteuning en service.","Bekijk de website van Teams Store","https://teamsstore.nl/",{"__component":120,"id":162,"title":163,"subTitle":164,"content":165,"callToActionText":18,"callToActionLink":18,"colorStyle":132,"showAsides":59},34,"Andere expertises","Creëer een totaaloplossing voor jouw Microsoft 365 omgeving","Onze Microsoft 365 consultants werken ook graag samen met bijvoorbeeld [Power Platform-experts](/expertises/power-platform) en [Azure-engineers](/expertises/azure) om het meeste uit jouw Microsoft 365 omgeving te halen. Hierdoor is het bij ShareValue mogelijk om een totaaloplossing voor jouw bedrijf te vinden die op al jouw Microsoft 365 wensen aansluit.",{"__component":167,"id":168,"title":169,"callToActionText":170,"callToActionLinkUrl":171,"body":18},"call-to-action.single",48,"Wil je weten wat onze collega's allemaal kunnen?","Lees de klantcase over ons werk bij Groeneveld-BEKA","/klantcases/gesmeerde-digitale-interne-communicatie-bij-groeneveld-beka-in-share-point-online",{"id":173,"metaTitle":174,"metaDescription":175,"structuredData":176},25,"Microsoft 365 experts – Slimmer samenwerken met ShareValue","Wij helpen organisaties het maximale uit Microsoft 365 te halen. Van inrichting tot adoptie, governance en beheer.",{"url":177,"@type":178,"@context":179,"provider":180,"areaServed":184,"description":187,"serviceType":188},"https://www.sharevalue.nl/wat-we-doen/microsoft-365","Service","https://schema.org",{"url":181,"name":182,"@type":183},"https://www.sharevalue.nl","ShareValue","Organization",{"name":185,"@type":186},"Nederland","Country","ShareValue ondersteunt organisaties bij het slim inrichten en gebruiken van Microsoft 365. Van technische implementatie tot governance, adoptie en beheer: onze consultants zorgen dat je meer haalt uit je digitale werkomgeving.","Microsoft 365 consultancy",{"__component":110,"id":111,"titleLeft":112,"callToActionTextLeft":113,"callToActionLinkUrlLeft":114,"titleRight":115,"callToActionTextRight":116,"callToActionLinkUrlRight":117,"icon