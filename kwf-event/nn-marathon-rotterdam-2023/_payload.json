26,"formats":11,"hash":427,"ext":85,"mime":86,"size":428,"url":429,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":430,"updatedAt":431,"documentId":432,"publishedAt":60},8,"briefcase.svg",70,"briefcase_679abae475",4.49,"https://incredible-beef-2a6059b946.media.strapiapp.com/briefcase_679abae475.svg","2023-08-17T08:31:37.038Z","2025-01-24T15:53:51.531Z","bfdftlvwhj35dm37dzv4aujf",{"id":434,"name":435,"alternativeText":11,"caption":11,"width":436,"height":426,"formats":11,"hash":437,"ext":85,"mime":86,"size":438,"url":439,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":440,"updatedAt":441,"documentId":442,"publishedAt":60},6,"bulb.svg",71,"bulb_dd2e1d4efb",3.75,"https://incredible-beef-2a6059b946.media.strapiapp.com/bulb_dd2e1d4efb.svg","2023-08-17T08:31:37.036Z","2025-04-01T14:08:08.648Z","l2lglwkh4lf7ip36sjvs42rc",{"id":444,"title":445,"content":446,"eventStart":447,"eventEnd":448,"allDay":11,"location":271,"slug":449,"createdAt":450,"updatedAt":451,"publishedAt":452,"donateLink":11,"documentId":453,"image":454,"blocks":460,"seo":11},2,"NN Marathon Rotterdam 2023","Op zondag 16 april 2023 hebben wij deelgenomen aan de NN Marathon Rotterdam met twee business estafette teams.\n","2023-04-16T07:30:00.000Z","2023-04-16T16:00:00.000Z","nn-marathon-rotterdam-2023","2023-09-01T10:15:47.708Z","2025-03-04T15:39:46.492Z","2023-09-01T10:15:49.526Z","q0bdnwsbyb5vlot0y3nykm2o",{"id":278,"name":279,"alternativeText":11,"caption":11,"width":22,"height":23,"formats":455,"hash":301,"ext":26,"mime":29,"size":302,"url":303,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":304,"updatedAt":304,"documentId":305,"publishedAt":60},{"large":456,"small":457,"medium":458,"thumbnail":459},{"ext":26,"url":282,"hash":283,"mime":29,"name":284,"path":11,"size":285,"width":32,"height":33},{"ext":26,"url":287,"hash":288,"mime":29,"name":289,"path":11,"size":290,"width":23,"height":39},{"ext":26,"url":292,"hash":293,"mime":29,"name":294,"path":11,"size":295,"width":45,"height":46},{"ext":26,"url":297,"hash":298,"mime":29,"name":299,"path":11,"size":300,"width":52,"height":53},[461,464,468,471,474,476],{"__component":63,"id":462,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":11,"content":463,"introductionText":11},1586,"Wij hebben in 2023 deelgenomen aan de NN Marathon Rotterdam. Op zondag 16 april 2023 hadden wij twee business estafette teams. Per team liepen 4 deelnemers gezamenlijk de gehele marathon. De verdeling per team was als volgt:\n\n- loper 1: 9 km\n- loper 2: 12 km\n- loper 3: 8,5 km\n- loper 4: 12,5 km\n\nDe starttijd en startlocatie was dus per deelnemer verschillend. Nadat de lopers klaar waren en de medailles waren opgehaald, kwamen zij naar onze verzamellocatie.",{"__component":63,"id":465,"title":11,"asideText":466,"underline":65,"centered":65,"blankAside":65,"aside":11,"content":467,"introductionText":11},1588,"Geld inzamelen","## De verzamellocatie van de ShareValue teams\nDe verzamellocatie van onze teams is het prachtige Restaurant het Schielandshuis. Dit restaurant ligt om de hoek van de start- en finishlocatie. Onze deelnemers komen hier gespreid binnen tussen 11:00 en 16:00 uur, waarna ze kunnen genieten van een welverdiend hapje en een drankje. Een leuk moment om even na te praten over hun ervaringen.\n",{"__component":63,"id":469,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":11,"content":470,"introductionText":11},1589,"## Wil jij onze lopers sponsoren?\nOnze lopers hebben het allemaal gered! Ze hebben met deze prestatie een mooi bedrag bij elkaar verdiend voor KWF.  Sponsoren kan nog altijd via onze [KWF actiepagina](https://acties.kwf.nl/fundraisers/onzeKWFevents), jouw bijdrage komt dan direct bij KWF terecht. \n\nHieronder vind je een aantal foto's van deze mooie dag:",{"__component":128,"id":472,"imageList":473},34,[],{"__component":68,"id":475,"title":11,"showBlankAside":309},163,{"__component":71,"id":477,"titleLeft":73,"callToActionTextLeft":74,"callToActionLinkUrlLeft":75,"titleRight":420,"callToActionTextRight":421,"callToActionLinkUrlRight":422,"iconUrlLeft":478,"iconUrlRight":479},188,{"id":424,"name":425,"alternativeText":11,"caption":11,"width":426,"height":426,"formats":11,"hash":427,"ext":85,"mime":86,"size":428,"url":429,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":430,"updatedAt":431,"documentId":432,"publishedAt":60},{"id":434,"name":435,"alternativeText":11,"caption":11,"width":436,"height":426,"formats":11,"hash":437,"ext":85,"mime":86,"size":438,"url":439,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":440,"updatedAt":441,"documentId":442,"publishedAt":60},{"id":481,"title":482,"content":483,"eventStart":484,"eventEnd":485,"allDay":11,"location":271,"slug":486,"createdAt":487,"updatedAt":488,"publishedAt":489,"donateLink":11,"documentId":490,"image":491,"blocks":497,"seo":11},1,"The Marathon Rotterdam Walk","Op zaterdag 15 april 2023 hebben deelgenomen aan The Marathon Rotterdam Walk voor KWF.","2023-04-15T05:45:00.000Z","2023-04-15T12:00:00.000Z","the-marathon-rotterdam-walk-2023","2023-09-01T10:14:08.142Z","2025-03-04T15:40:12.646Z","2023-09-01T10:14:09.440Z","os8qh76am3mqb9pw84ntxptd",{"id":20,"name":21,"alternativeText":11,"caption":11,"width":22,"height":23,"formats":492,"hash":54,"ext":26,"mime":29,"size":55,"url":56,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":58,"updatedAt":58,"documentId":59,"publishedAt":60},{"large":493,"small":494,"medium":495,"thumbnail":496},{"ext":26,"url":27,"hash":28,"mime":29,"name":30,"path":11,"size":31,"width":32,"height":33},{"ext":26,"url":35,"hash":36,"mime":29,"name":37,"path":11,"size":38,"width":23,"height":39},{"ext":26,"url":41,"hash":42,"mime":29,"name":43,"path":11,"size":44,"width":45,"height":46},{"ext":26,"url":48,"hash":49,"mime":29,"name":50,"path":11,"size":51,"width":52,"height":53},[498,501,504],{"__component":63,"id":499,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":11,"content":500,"introductionText":11},1587,"Op zaterdag 15 april 2023 hebben wij door Rotterdam gewandeld voor KWF. Bij deze stadswandeling wandel je de dag vóór de NN Marathon Rotterdam door de stad, leer je meer over de marathon en finish je ook op de Coolsingel. De gehele route is aangegeven met pijlen. Onderweg wandel je langs meerdere muzikale acts en zijn er verzorgingsposten. Kortom, een gezellige dag waarbij je Rotterdam beter leert kennen, je gezond bezig bent en ook nog eens het goede doel steunt!\n\nWe hadden de keuze uit drie afstanden:\n\n- 15 km\n- 10 km\n- 5 km",{"__component":63,"id":502,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":11,"content":503,"introductionText":11},1590,"## De verzamellocatie van team ShareValue\n\nDe verzamellocatie van ons team was in het prachtige Restaurant het Schielandshuis. Dit restaurant ligt om de hoek van de start- en finishlocatie. Onze deelnemers kwamen allemaal gespreid tussen 11:00 en 13:00 uur terug in het restaurant waar belegde broodjes klaarstonden en wat te drinken. Het was een leuk moment om even na te praten over alles wat we onderweg gezien hebben.\n\n## Wil jij onze wandelaars sponsoren?\nOnze wandelaars hebben de wandeling allemaal afgerond. Ze hebben met deze prestatie een mooi bedrag bij elkaar verdiend voor KWF. \nSponsoren kan nog altijd via onze [KWF actiepagina](https://acties.kwf.nl/fundraisers/onzeKWFevents), jouw bijdrage komt dan direct bij KWF terecht. \n\nHieronder vind je een aantal foto's van deze mooie dag:",{"__component":128,"id":505,"imageList":506},35,[507,539,570,601,632,662,692],{"id":508,"title":11,"image":509},30,{"id":510,"name":511,"alternativeText":11,"caption":11,"width":234,"height":512,"formats":513,"hash":534,"ext":26,"mime":29,"size":535,"url":536,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":537,"updatedAt":537,"documentId":538,"publishedAt":60},389,"The_Walk_2023-1.jpg"