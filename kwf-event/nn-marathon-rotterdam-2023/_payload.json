_The_Walk_2024_groepsfoto_2_b886c62a8f","large_The Walk 2024  groepsfoto 2.jpg",171.53,{"ext":26,"url":242,"hash":243,"mime":29,"name":244,"path":11,"size":245,"width":23,"height":147},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_The_Walk_2024_groepsfoto_2_b886c62a8f.jpg","small_The_Walk_2024_groepsfoto_2_b886c62a8f","small_The Walk 2024  groepsfoto 2.jpg",50.15,{"ext":26,"url":247,"hash":248,"mime":29,"name":249,"path":11,"size":250,"width":45,"height":153},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_The_Walk_2024_groepsfoto_2_b886c62a8f.jpg","medium_The_Walk_2024_groepsfoto_2_b886c62a8f","medium_The Walk 2024  groepsfoto 2.jpg",103.7,{"ext":26,"url":252,"hash":253,"mime":29,"name":254,"path":11,"size":255,"width":159,"height":160},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_The_Walk_2024_groepsfoto_2_b886c62a8f.jpg","thumbnail_The_Walk_2024_groepsfoto_2_b886c62a8f","thumbnail_The Walk 2024  groepsfoto 2.jpg",10.99,"The_Walk_2024_groepsfoto_2_b886c62a8f",356.33,"https://incredible-beef-2a6059b946.media.strapiapp.com/The_Walk_2024_groepsfoto_2_b886c62a8f.jpg","2024-04-15T07:55:03.498Z","ht2qgqp38l5vzv6awnlaxj92",{"__component":71,"id":262,"titleLeft":73,"callToActionTextLeft":74,"callToActionLinkUrlLeft":75,"titleRight":76,"callToActionTextRight":77,"callToActionLinkUrlRight":78,"iconUrlLeft":263,"iconUrlRight":264},670,{"id":80,"name":81,"alternativeText":11,"caption":11,"width":82,"height":83,"formats":11,"hash":84,"ext":85,"mime":86,"size":87,"url":88,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":89,"updatedAt":90,"documentId":91,"publishedAt":60},{"id":93,"name":94,"alternativeText":11,"caption":11,"width":95,"height":83,"formats":11,"hash":96,"ext":85,"mime":86,"size":97,"url":98,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":99,"updatedAt":100,"documentId":101,"publishedAt":60},{"id":266,"title":267,"content":268,"eventStart":269,"eventEnd":270,"allDay":11,"location":271,"slug":272,"createdAt":273,"updatedAt":274,"publishedAt":275,"donateLink":11,"documentId":276,"image":277,"blocks":306,"seo":11},3,"NN Marathon Rotterdam 2024","Op zondag 14 april 2024 hebben we met één team meegedaan aan de Business Run van NN Marathon Rotterdam.","2024-04-14T07:30:00.000Z","2024-04-14T16:00:00.000Z","Beursplein 37, Rotterdam","nn-marathon-rotterdam-2024","2023-09-29T11:18:42.382Z","2025-03-04T15:37:35.214Z","2023-09-29T11:18:43.373Z","vtj0x12r9s7vqluj4xnd2sj0",{"id":278,"name":279,"alternativeText":11,"caption":11,"width":22,"height":23,"formats":280,"hash":301,"ext":26,"mime":29,"size":302,"url":303,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":304,"updatedAt":304,"documentId":305,"publishedAt":60},219,"Headerfoto_KWF_marathon_16-04-2023.jpg",{"large":281,"small":286,"medium":291,"thumbnail":296},{"ext":26,"url":282,"hash":283,"mime":29,"name":284,"path":11,"size":285,"width":32,"height":33},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885.jpg","large_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885","large_Headerfoto_KWF_marathon_16-04-2023.jpg",60.28,{"ext":26,"url":287,"hash":288,"mime":29,"name":289,"path":11,"size":290,"width":23,"height":39},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885.jpg","small_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885","small_Headerfoto_KWF_marathon_16-04-2023.jpg",20.32,{"ext":26,"url":292,"hash":293,"mime":29,"name":294,"path":11,"size":295,"width":45,"height":46},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885.jpg","medium_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885","medium_Headerfoto_KWF_marathon_16-04-2023.jpg",38.2,{"ext":26,"url":297,"hash":298,"mime":29,"name":299,"path":11,"size":300,"width":52,"height":53},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885.jpg","thumbnail_Headerfoto_KWF_marathon_16_04_2023_12b4fe2885","thumbnail_Headerfoto_KWF_marathon_16-04-2023.jpg",6.46,"Headerfoto_KWF_marathon_16_04_2023_12b4fe2885",85.04,"https://incredible-beef-2a6059b946.media.strapiapp.com/Headerfoto_KWF_marathon_16_04_2023_12b4fe2885.jpg","2023-09-01T10:15:44.860Z","n4yewj9rb3drapash0w9rajn",[307,311,314,317,416,418],{"__component":63,"id":308,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":309,"aside":11,"content":310,"introductionText":11},1585,true,"Wij hebben ook in 2024 weer deelgenomen aan de NN Marathon Rotterdam. Op zondag 14 april 2024 hadden wij één business estafette team. Per team loop je met 4 deelnemers gezamenlijk de gehele marathon. De verdeling was als volgt:\n\n- loper 1: 9 km\n- loper 2: 12 km\n- loper 3: 8,5 km\n- loper 4: 12,5 km\n\nDe starttijd en startlocatie was dus per deelnemer verschillend. Nadat de lopers klaar waren en de medailles waren opgehaald, kwamen zij naar onze verzamellocatie.",{"__component":63,"id":312,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":122,"content":313,"introductionText":11},1840,"## De verzamellocatie van het ShareValue team\n\nDe verzamellocatie van ons team was Café Erasmus. Dit café ligt aan de Coolsingel en dus direct aan de start- en finishlocatie. Onze deelnemers kwamen hier gespreid binnen tussen 12:30 en 16:00 uur, waarna ze konden genieten van een welverdiend hapje en een drankje. Een leuk moment om even na te praten over hun ervaringen.",{"__component":63,"id":315,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":122,"content":316,"introductionText":11},1841,"## Wil jij onze lopers sponsoren?\nOnze lopers hebben het allemaal gered! Ze hebben met deze prestatie een mooi bedrag bij elkaar verdiend voor KWF.  Sponsoren kan nog altijd via onze [KWF sponsorpagina](https://acties.kwf.nl/fundraisers/onzeKWFevents), jouw bijdrage komt dan direct bij KWF terecht. \n\nHieronder 