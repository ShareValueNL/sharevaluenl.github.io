[{"data":1,"prerenderedAt":725},["ShallowReactive",2],{"collection-KWFEvents-3938":3,"_apollo:default":724},{"data":4,"meta":721},[5,102,265,443,480],{"id":6,"title":7,"content":8,"eventStart":9,"eventEnd":10,"allDay":11,"location":12,"slug":13,"createdAt":14,"updatedAt":15,"publishedAt":16,"donateLink":17,"documentId":18,"image":19,"blocks":61,"seo":11},23,"The Marathon Rotterdam Walk 2026","Op zaterdag 11 april 2026 hebben we als groep 10 kilometer gewandeld voor KWF.","2026-04-11T06:30:00.000Z","2026-04-11T11:30:00.000Z",null,"Centrum Rotterdam","the-marathon-rotterdam-walk-2026","2026-02-03T14:01:19.885Z","2026-04-13T13:09:40.084Z","2026-04-13T13:09:40.268Z","https://acties.kwf.nl/fundraisers/onzeKWFevents/sharevalue-kwf","fknp7wltdeizbr0bgwdmhs9p",{"id":20,"name":21,"alternativeText":11,"caption":11,"width":22,"height":23,"formats":24,"hash":54,"ext":26,"mime":29,"size":55,"url":56,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":58,"updatedAt":58,"documentId":59,"publishedAt":60},218,"Headerfoto_KWF_The_Walk.jpg",1280,500,{"large":25,"small":34,"medium":40,"thumbnail":47},{"ext":26,"url":27,"hash":28,"mime":29,"name":30,"path":11,"size":31,"width":32,"height":33},".jpg","https://incredible-beef-2a6059b946.media.strapiapp.com/large_Headerfoto_KWF_The_Walk_c869c2c45b.jpg","large_Headerfoto_KWF_The_Walk_c869c2c45b","image/jpeg","large_Headerfoto_KWF_The_Walk.jpg",46.99,1000,391,{"ext":26,"url":35,"hash":36,"mime":29,"name":37,"path":11,"size":38,"width":23,"height":39},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_Headerfoto_KWF_The_Walk_c869c2c45b.jpg","small_Headerfoto_KWF_The_Walk_c869c2c45b","small_Headerfoto_KWF_The_Walk.jpg",18.16,195,{"ext":26,"url":41,"hash":42,"mime":29,"name":43,"path":11,"size":44,"width":45,"height":46},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_Headerfoto_KWF_The_Walk_c869c2c45b.jpg","medium_Headerfoto_KWF_The_Walk_c869c2c45b","medium_Headerfoto_KWF_The_Walk.jpg",31.53,750,293,{"ext":26,"url":48,"hash":49,"mime":29,"name":50,"path":11,"size":51,"width":52,"height":53},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_Headerfoto_KWF_The_Walk_c869c2c45b.jpg","thumbnail_Headerfoto_KWF_The_Walk_c869c2c45b","thumbnail_Headerfoto_KWF_The_Walk.jpg",6.36,245,96,"Headerfoto_KWF_The_Walk_c869c2c45b",62.56,"https://incredible-beef-2a6059b946.media.strapiapp.com/Headerfoto_KWF_The_Walk_c869c2c45b.jpg","strapi-provider-upload-strapi-cloud","2023-09-01T10:13:36.081Z","h1bj31z9a00amy1i90vex9us","2026-01-05T12:38:34.018Z",[62,67,70],{"__component":63,"id":64,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":11,"content":66,"introductionText":11},"global.pagesection",4817,false,"Wat was het een geslaagde dag! We genoten van een mooie wandeling door de stad, waarbij we onderweg niet alleen actief bezig waren, maar ook de omgeving op een andere manier leerden kennen. De route was duidelijk aangegeven en onderweg was er volop sfeer dankzij verschillende acts en fijne tussenstops. Een gezellige en sportieve dag dus, waarbij we samen in beweging kwamen én ons inzetten voor een goed doel.\n\n## Sponsoren kan nog steeds\nOnze wandelaars hebben de wandeling allemaal afgerond. Ze hebben met deze prestatie een mooi bedrag bij elkaar verdiend voor KWF. \nSponsoren kan nog altijd via onze [KWF actiepagina](https://acties.kwf.nl/fundraisers/onzeKWFevents), jouw bijdrage komt dan direct bij KWF terecht. \n\n![Routes The Walk 2026.png](https://incredible-beef-2a6059b946.media.strapiapp.com/Routes_The_Walk_2026_e8f8b1c7f6.png)",{"__component":68,"id":69,"title":11,"showBlankAside":65},"global.social-sharing",550,{"__component":71,"id":72,"titleLeft":73,"callToActionTextLeft":74,"callToActionLinkUrlLeft":75,"titleRight":76,"callToActionTextRight":77,"callToActionLinkUrlRight":78,"iconUrlLeft":79,"iconUrlRight":92},"call-to-action.double",673,"Wil je onze collega worden?","Bekijk onze vacatures","/word-onze-collega/vacatures","Ken je ShareValue al?","Lees hier meer over ShareValue","https://www.sharevalue.nl/",{"id":80,"name":81,"alternativeText":11,"caption":11,"width":82,"height":83,"formats":11,"hash":84,"ext":85,"mime":86,"size":87,"url":88,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":89,"updatedAt":90,"documentId":91,"publishedAt":60},7,"people.svg",83,60,"people_6bb632d0d7",".svg","image/svg+xml",1.47,"https://incredible-beef-2a6059b946.media.strapiapp.com/people_6bb632d0d7.svg","2023-08-17T08:31:37.039Z","2024-09-13T08:11:42.408Z","iyvqylwtkx5qokq2hk77ppgf",{"id":93,"name":94,"alternativeText":11,"caption":11,"width":95,"height":83,"formats":11,"hash":96,"ext":85,"mime":86,"size":97,"url":98,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":99,"updatedAt":100,"documentId":101,"publishedAt":60},372,"magnifier.svg",49,"magnifier_d084afba36",1.05,"https://incredible-beef-2a6059b946.media.strapiapp.com/magnifier_d084afba36.svg","2023-11-03T11:13:25.446Z","2026-05-12T12:19:53.518Z","e7czsfz9jg7oi93q44vomebz",{"id":103,"title":104,"content":105,"eventStart":106,"eventEnd":107,"allDay":65,"location":12,"slug":108,"createdAt":109,"updatedAt":110,"publishedAt":111,"donateLink":11,"documentId":112,"image":113,"blocks":119,"seo":11},20,"The Marathon Rotterdam Walk 2024","\nOp zaterdag 13 april 2024 hebben we weer door Rotterdam gewandeld voor KWF. Bij deze stadswandeling wandel je de dag vóór de NN Marathon Rotterdam door de stad en finish je ook op de Coolsingel. ","2024-04-13T06:15:00.000Z","2024-04-13T12:00:00.000Z","the-marathon-rotterdam-walk-2024","2024-02-12T13:42:26.569Z","2026-04-13T13:06:18.688Z","2026-04-13T13:06:18.893Z","pas2v39cwgp0vbm0fjebuhmv",{"id":20,"name":21,"alternativeText":11,"caption":11,"width":22,"height":23,"formats":114,"hash":54,"ext":26,"mime":29,"size":55,"url":56,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":58,"updatedAt":58,"documentId":59,"publishedAt":60},{"large":115,"small":116,"medium":117,"thumbnail":118},{"ext":26,"url":27,"hash":28,"mime":29,"name":30,"path":11,"size":31,"width":32,"height":33},{"ext":26,"url":35,"hash":36,"mime":29,"name":37,"path":11,"size":38,"width":23,"height":39},{"ext":26,"url":41,"hash":42,"mime":29,"name":43,"path":11,"size":44,"width":45,"height":46},{"ext":26,"url":48,"hash":49,"mime":29,"name":50,"path":11,"size":51,"width":52,"height":53},[120,124,127,261],{"__component":63,"id":121,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":122,"content":123,"introductionText":11},4813,"","Op zaterdag 13 april 2024 hebben wij door zonnig Rotterdam gewandeld voor KWF. Bij deze stadswandeling wandel je de dag vóór de NN Marathon Rotterdam door de stad, leer je meer over de marathon en finish je ook op de Coolsingel. De gehele route was aangegeven met pijlen. Onderweg wandelden we langs meerdere muzikale acts en verzorgingsposten. Kortom, een gezellige dag waarbij we Rotterdam beter leerden kennen, gezond bezig waren en ook nog eens het goede doel steunden!",{"__component":63,"id":125,"title":11,"asideText":11,"underline":65,"centered":65,"blankAside":65,"aside":11,"content":126,"introductionText":11},4814,"## De verzamellocatie van team ShareValue\n\nDe verzamellocatie van ons team was in het recent geopende café Erasmus. Dit restaurant ligt direct aan de Coolsingel en dus vlakbij start- en finishlocatie. Onze deelnemers kwamen na de wandeling terug in het restaurant voor een gezamenlijke lunch en wat te drinken. Het was een leuk moment om even na te praten over alles wat we onderweg gezien hebben.\n\n## Wil jij onze wandelaars sponsoren?\nOnze wandelaars hebben de wandeling allemaal afgerond. Ze hebben met deze prestatie een mooi bedrag bij elkaar verdiend voor KWF. \nSponsoren kan nog altijd via onze [KWF actiepagina](https://acties.kwf.nl/fundraisers/onzeKWFevents), jouw bijdrage komt dan direct bij KWF terecht. ",{"__component":128,"id":83,"imageList":129},"global.image-carousal",[130,166,197,228],{"id":131,"title":11,"image":132},87,{"id":133,"name":134,"alternativeText":11,"caption":11,"width":22,"height":135,"formats":136,"hash":161,"ext":26,"mime":29,"size":162,"url":163,"previewUrl":11,"provider":57,"provider_metadata":11,"createdAt":164,"updatedAt":164,"documentId":165,"publishedAt":60},676,"The Walk 2024 groepsfoto 1.jpg",960,{"large":137,"small":142,"medium":148,"thumbnail":154},{"ext":26,"url":138,"hash":139,"mime":29,"name":140,"path":11,"size":141,"width":32,"height":45},"https://incredible-beef-2a6059b946.media.strapiapp.com/large_The_Walk_2024_groepsfoto_1_7c6886a702.jpg","large_The_Walk_2024_groepsfoto_1_7c6886a702","large_The Walk 2024 groepsfoto 1.jpg",236.62,{"ext":26,"url":143,"hash":144,"mime":29,"name":145,"path":11,"size":146,"width":23,"height":147},"https://incredible-beef-2a6059b946.media.strapiapp.com/small_The_Walk_2024_groepsfoto_1_7c6886a702.jpg","small_The_Walk_2024_groepsfoto_1_7c6886a702","small_The Walk 2024 groepsfoto 1.jpg",61.57,375,{"ext":26,"url":149,"hash":150,"mime":29,"name":151,"path":11,"size":152,"width":45,"height":153},"https://incredible-beef-2a6059b946.media.strapiapp.com/medium_The_Walk_2024_groepsfoto_1_7c6886a702.jpg","medium_The_Walk_2024_groepsfoto_1_7c6886a702","medium_The Walk 2024 groepsfoto 1.jpg",136.14,563,{"ext":26,"url":155,"hash":156,"mime":29,"name":157,"path":11,"size":158,"width":159,"height":160},"https://incredible-beef-2a6059b946.media.strapiapp.com/thumbnail_The_Walk_2024_groepsfoto_1_7c6886a702.jpg","thumbnail_The_Walk_2024_groepsfoto_1_7c6886a702","thumbnail_The Walk 2024 groepsfoto 1.jpg",11.53,208,156,"The_Walk_2024_groepsfoto_1_7c6886a702",382.74,"https://incredible-beef-2a6059b946.media.strapiapp.com/The_Walk_2024_groepsfoto_1_7c6886a702.jpg","2024-04-15T07:55:03.198Z","gzdbqp9izxinio9m49dsob61",{"id":167,"title":11,"image":168},88,{"id":169,"name":170,"alternativeText":11,"caption":11,"width":22,"height":135,"formats":171,"hash":192,"ext":26,"mime":29,"size":193,"url":194,"previewUrl":11,"provider":57